# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=your_app_secret_here
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=8.0.32&charset=utf8mb4"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
DATABASE_URL="mysql://root:@127.0.0.1:3306/nova_db?serverVersion=8.0.32&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_jwt_passphrase_here
###< lexik/jwt-authentication-bundle ###

###> symfony/messenger ###
# Choose one of the transports below
# MESSENGER_TRANSPORT_DSN=amqp://guest:guest@localhost:5672/%2f/messages
# MESSENGER_TRANSPORT_DSN=redis://localhost:6379/messages
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

###> symfony/mailer ###
# Gmail configuration - real emails will be sent
# Format: gmail://username:app_password@default
# Get app password from: https://myaccount.google.com/apppasswords
MAILER_DSN=gmail://your_email@gmail.com:your_app_password@default
###< symfony/mailer ###

###> External API Configuration ###
# YouTube Data API v3 - Get your key from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=AIzaSyAShl3jw6VtNY-3sJINQ78fS3APnWEL-sw

# OpenWeatherMap API - Get your key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OpenAI API - Get your key from: https://platform.openai.com/api-keys
# Alternative: Use Gemini API key from: https://makersuite.google.com/app/apikey
OPENAI_API_KEY=your_openai_api_key_here
# YouTube Data API v3
# Get your key from: https://console.cloud.google.com/apis/credentials
# Required for: Video search and recommendations (Requirement 6.1)
YOUTUBE_API_KEY=your_youtube_api_key_here

# OpenWeatherMap API
# Get your key from: https://openweathermap.org/api
# Required for: Weather-based study suggestions (Requirement 8.1)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# OpenAI API
# Get your key from: https://platform.openai.com/api-keys
# Required for: AI-powered study recommendations, note summarization, quiz generation (Requirement 9.2)
# Alternative: Use Gemini API key from: https://makersuite.google.com/app/apikey
OPENAI_API_KEY=your_openai_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
###< External API Configuration ###

###> Study Session File Uploads ###
# Directory for PDF resource uploads (relative to public directory)
UPLOAD_DIRECTORY=uploads/study_sessions
###< Study Session File Uploads ###

# GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=AIzaSyCvHfdoX60adVpppS20J_GkoENOnAv2wyM


# Using 8.3 short path format (no spaces) - more reliable on Windows
# This directory will store uploaded study materials and resources
# Default: uploads/study_sessions
UPLOAD_DIRECTORY=uploads/study_sessions
###< Study Session File Uploads ###

###> knplabs/knp-snappy-bundle ###
# Path to wkhtmltopdf binary for PDF generation
# Windows: Use 8.3 short path format (no spaces) for reliability
# Linux/Mac: Use full path to binary
WKHTMLTOPDF_PATH=C:\PROGRA~1\WKHTML~1\bin\wkhtmltopdf.exe
WKHTMLTOIMAGE_PATH=C:\PROGRA~1\WKHTML~1\bin\wkhtmltoimage.exe
###< knplabs/knp-snappy-bundle ###

###> symfony/google-mailer ###
# Gmail SHOULD NOT be used on production, use it in development only.
# MAILER_DSN=gmail://USERNAME:PASSWORD@default
###< symfony/google-mailer ###

###> OAuth2 Configuration ###
# Google OAuth
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# LinkedIn OAuth
# Get credentials from: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
###< OAuth2 Configuration ###