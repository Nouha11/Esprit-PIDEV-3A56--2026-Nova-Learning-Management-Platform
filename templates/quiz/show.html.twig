{% extends 'base_content.html.twig' %}

{% block title %}{{ quiz.title }}{% endblock %}

{% block body %}
<div class="container">
    <div class="row mb-4">
        <div class="col-lg-8 mx-auto">
            <div class="card bg-primary bg-opacity-10 border-0 rounded-3 mb-4">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="badge bg-primary mb-2">Quiz #{{ quiz.id }}</span>
                            <h1 class="h3 mb-1">{{ quiz.title }}</h1>
                            <p class="mb-0 text-muted">{{ quiz.description }}</p>
                        </div>
                        <div>
                            <a href="{{ path('app_quiz_edit', {'id': quiz.id}) }}" class="btn btn-sm btn-dark">
                                <i class="bi bi-pencil-square me-1"></i> Edit Settings
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="mb-0">Questions <span class="badge bg-light text-dark">{{ quiz.questions|length }}</span></h4>
                
                <a href="{{ path('app_quiz_question_new') }}" class="btn btn-success">
                    <i class="bi bi-plus-lg me-2"></i>Add New Question
                </a>
            </div>

            {% if quiz.questions is empty %}
                <div class="text-center p-5 border border-dashed rounded-3">
                    <i class="bi bi-folder2-open display-4 text-muted"></i>
                    <p class="mt-3 mb-0">This quiz has no questions yet.</p>
                    <p class="text-muted small">Click the button above to add your first challenge!</p>
                </div>
            {% else %}
                <div class="card shadow-sm border-0">
                    <div class="list-group list-group-flush">
                        {% for question in quiz.questions %}
                            <div class="list-group-item p-4 d-flex justify-content-between align-items-center">
                                <div>
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge bg-{{ question.difficulty == 'Hard' ? 'danger' : (question.difficulty == 'Medium' ? 'warning' : 'success') }}">
                                            {{ question.difficulty }}
                                        </span>
                                        <span class="text-muted small">+{{ question.xpValue }} XP</span>
                                    </div>
                                    <h6 class="mb-0">{{ question.text }}</h6>
                                </div>
                                <div class="btn-group">
                                    <a href="{{ path('app_quiz_question_edit', {'id': question.id}) }}" class="btn btn-sm btn-light border">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <div class="mt-4">
                <a href="{{ path('app_quiz_index') }}" class="text-muted text-decoration-none">
                    <i class="bi bi-arrow-left"></i> Back to all quizzes
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}