{% extends 'base.html.twig' %}

{% block title %}Question{% endblock %}

{% block body %}
    <h1>Question</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ question.id }}</td>
            </tr>
            <tr>
                <th>Text</th>
                <td>{{ question.text }}</td>
            </tr>
            <tr>
                <th>XpValue</th>
                <td>{{ question.xpValue }}</td>
            </tr>
            <tr>
                <th>Difficulty</th>
                <td>{{ question.difficulty }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_quiz_question_index') }}">back to list</a>

    <a href="{{ path('app_quiz_question_edit', {'id': question.id}) }}">edit</a>

    {{ include('quiz/question/_delete_form.html.twig') }}
{% endblock %}
