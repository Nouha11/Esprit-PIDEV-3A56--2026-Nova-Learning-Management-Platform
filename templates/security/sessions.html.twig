{% extends 'base.html.twig' %}

{% block title %}Active Sessions - NOVA{% endblock %}

{% block body %}
<section class="pt-5 pb-5">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="mb-1">Where You're Logged In</h1>
                        <p class="text-muted mb-0">Manage your active sessions and remotely log out from devices</p>
                    </div>
                    {% if activeSessions|length > 1 %}
                        <button type="button" class="btn btn-danger" onclick="terminateAllSessions()">
                            <i class="bi bi-x-circle me-2"></i>Log Out All Other Devices
                        </button>
                    {% endif %}
                </div>

                {% if activeSessions is empty %}
                    <div class="card border">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-shield-check display-1 text-muted"></i>
                            <h3 class="mt-3">No Active Sessions</h3>
                            <p class="text-muted">You don't have any active sessions at the moment.</p>
                        </div>
                    </div>
                {% else %}
                    <div class="row g-4">
                        {% for session in activeSessions %}
                            <div class="col-12" id="session-{{ session.id }}">
                                <div class="card border {% if session.isCurrent %}border-success{% endif %} h-100">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-auto">
                                                <div class="icon-lg bg-{{ session.isCurrent ? 'success' : 'primary' }} bg-opacity-10 rounded-circle text-{{ session.isCurrent ? 'success' : 'primary' }}">
                                                    {% if session.device == 'Mobile' %}
                                                        <i class="bi bi-phone fs-2"></i>
                                                    {% elseif session.device == 'Tablet' %}
                                                        <i class="bi bi-tablet fs-2"></i>
                                                    {% else %}
                                                        <i class="bi bi-laptop fs-2"></i>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            <div class="col">
                                                <div class="d-flex justify-content-between align-items-start">
                                                    <div>
                                                        <h5 class="mb-1">
                                                            {{ session.browser ?? 'Unknown Browser' }}
                                                            {% if session.isCurrent %}
                                                                <span class="badge bg-success ms-2">Current Session</span>
                                                            {% endif %}
                                                        </h5>
                                                        <div class="text-muted small">
                                                            <div class="mb-1">
                                                                <i class="bi bi-laptop me-1"></i>
                                                                <strong>Platform:</strong> {{ session.platform ?? 'Unknown' }}
                                                            </div>
                                                            <div class="mb-1">
                                                                <i class="bi bi-geo-alt me-1"></i>
                                                                <strong>Location:</strong> {{ session.location ?? session.ipAddress ?? 'Unknown' }}
                                                            </div>
                                                            <div class="mb-1">
                                                                <i class="bi bi-clock me-1"></i>
                                                                <strong>Last Active:</strong> {{ session.lastActivity|date('M d, Y \\a\\t h:i A') }}
                                                            </div>
                                                            <div>
                                                                <i class="bi bi-calendar-plus me-1"></i>
                                                                <strong>Signed In:</strong> {{ session.createdAt|date('M d, Y \\a\\t h:i A') }}
                                                            </div>
                                                        </div>
                                                    </div>
                                                    {% if not session.isCurrent %}
                                                        <button type="button" class="btn btn-sm btn-outline-danger" onclick="terminateSession({{ session.id }})">
                                                            <i class="bi bi-x-circle me-1"></i>Log Out
                                                        </button>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}

                <div class="card border-info mt-4">
                    <div class="card-body">
                        <div class="d-flex align-items-start">
                            <i class="bi bi-info-circle text-info fs-3 me-3"></i>
                            <div>
                                <h6 class="mb-2">About Active Sessions</h6>
                                <p class="text-muted mb-0 small">
                                    These are the devices where you're currently logged in to your NOVA account. 
                                    If you see a session you don't recognize, log it out immediately and consider changing your password.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
function terminateSession(sessionId) {
    if (!confirm('Are you sure you want to log out from this device?')) {
        return;
    }

    fetch(`/sessions/terminate/${sessionId}`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            // Remove the session card with animation
            const sessionCard = document.getElementById(`session-${sessionId}`);
            if (sessionCard) {
                sessionCard.style.transition = 'opacity 0.3s ease';
                sessionCard.style.opacity = '0';
                setTimeout(() => {
                    sessionCard.remove();
                    
                    // Check if no sessions left
                    const remainingSessions = document.querySelectorAll('[id^="session-"]');
                    if (remainingSessions.length === 0) {
                        location.reload();
                    }
                }, 300);
            }
            
            // Show success message
            showAlert('success', data.message);
        } else {
            showAlert('danger', data.message);
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('danger', 'An error occurred while terminating the session');
    });
}

function terminateAllSessions() {
    if (!confirm('Are you sure you want to log out from all other devices? You will remain logged in on this device.')) {
        return;
    }

    fetch('/sessions/terminate-all', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showAlert('success', data.message);
            setTimeout(() => {
                location.reload();
            }, 1500);
        } else {
            showAlert('danger', 'Failed to terminate sessions');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showAlert('danger', 'An error occurred while terminating sessions');
    });
}

function showAlert(type, message) {
    const alertDiv = document.createElement('div');
    alertDiv.className = `alert alert-${type} alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3`;
    alertDiv.style.zIndex = '9999';
    alertDiv.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    document.body.appendChild(alertDiv);
    
    setTimeout(() => {
        alertDiv.remove();
    }, 3000);
}
</script>
{% endblock %}
