{% extends 'base.html.twig' %}

{% block title %}Sign Up - Choose Your Role{% endblock %}

{% block body %}
<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-10">
            <h1 class="text-center mb-5">Join Our Learning Platform</h1>
            
            <div class="row g-4">
                <!-- Student Card -->
                <div class="col-md-6">
                    <div class="card shadow-lg h-100 border-primary">
                        <div class="card-body text-center p-5">
                            <div class="mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-mortarboard text-primary" viewBox="0 0 16 16">
                                    <path d="M8.211 2.047a.5.5 0 0 0-.422 0l-7.5 3.5a.5.5 0 0 0 .025.917l7.5 3a.5.5 0 0 0 .372 0L14 7.14V13a1 1 0 0 0-1 1v2h3v-2a1 1 0 0 0-1-1V6.739l.686-.275a.5.5 0 0 0 .025-.917l-7.5-3.5ZM8 8.46 1.758 5.965 8 3.052l6.242 2.913L8 8.46Z"/>
                                    <path d="M4.176 9.032a.5.5 0 0 0-.656.327l-.5 1.7a.5.5 0 0 0 .294.605l4.5 1.8a.5.5 0 0 0 .372 0l4.5-1.8a.5.5 0 0 0 .294-.605l-.5-1.7a.5.5 0 0 0-.656-.327L8 10.466 4.176 9.032Zm-.068 1.873.22-.748 3.496 1.311a.5.5 0 0 0 .352 0l3.496-1.311.22.748L8 12.46l-3.892-1.556Z"/>
                                </svg>
                            </div>
                            <h2 class="card-title mb-3">I'm a Student</h2>
                            <p class="card-text text-muted mb-4">
                                Looking to learn and connect with expert tutors to enhance your academic journey.
                            </p>
                            <ul class="list-unstyled text-start mb-4">
                                <li class="mb-2">✓ Access to qualified tutors</li>
                                <li class="mb-2">✓ Schedule study sessions</li>
                                <li class="mb-2">✓ Track your progress</li>
                                <li class="mb-2">✓ Join study groups</li>
                            </ul>
                            <a href="{{ path('app_signup_student') }}" class="btn btn-primary btn-lg w-100">
                                Sign Up as Student
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Tutor Card -->
                <div class="col-md-6">
                    <div class="card shadow-lg h-100 border-success">
                        <div class="card-body text-center p-5">
                            <div class="mb-4">
                                <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" fill="currentColor" class="bi bi-person-workspace text-success" viewBox="0 0 16 16">
                                    <path d="M4 16s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1H4Zm4-5.95a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5Z"/>
                                    <path d="M2 1a2 2 0 0 0-2 2v9.5A1.5 1.5 0 0 0 1.5 14h.653a5.373 5.373 0 0 1 1.066-2H1V3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v9h-2.219c.554.654.89 1.373 1.066 2h.653a1.5 1.5 0 0 0 1.5-1.5V3a2 2 0 0 0-2-2H2Z"/>
                                </svg>
                            </div>
                            <h2 class="card-title mb-3">I'm a Tutor</h2>
                            <p class="card-text text-muted mb-4">
                                Share your expertise and help students achieve their academic goals while earning.
                            </p>
                            <ul class="list-unstyled text-start mb-4">
                                <li class="mb-2">✓ Set your own schedule</li>
                                <li class="mb-2">✓ Define your hourly rate</li>
                                <li class="mb-2">✓ Build your reputation</li>
                                <li class="mb-2">✓ Manage your students</li>
                            </ul>
                            <a href="{{ path('app_signup_tutor') }}" class="btn btn-success btn-lg w-100">
                                Sign Up as Tutor
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-5">
                <p class="text-muted">Already have an account? 
                    <a href="{{ path('app_login') }}" class="text-decoration-none">Login here</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
