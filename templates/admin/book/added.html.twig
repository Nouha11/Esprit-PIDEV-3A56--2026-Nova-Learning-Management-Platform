{% extends 'admin/base.html.twig' %}

{% block title %}Book Added Successfully - Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
{% endblock %}

{% block admin_content %}
<!-- Page main content START -->
<div class="page-content-wrapper border">

    <section class="overflow-hidden pt-5">
        <div class="container">
            <div class="row">
                <div class="col-md-8 text-center mx-auto">
                    <!-- SVG decoration START -->
                    <figure class="ms-n4">
                        <svg width="334.7px" height="224px">
                            <path class="fill-info" d="M314.2,176.9c-2.8-1.4-3.2-2.3-2.6-5.4c1.2-5.8-0.5-11.6-4.7-15.4c0,2.2,0.3,4.2,0,6.2 c-0.8,5.8-4.7,10.2-10.2,11.6c-5.4,1.3-11-0.8-14.1-5.4c-3.5-5.1-3.1-11.5,1.2-17.1c1.6-2.2,3.6-4,6-5.2c2-1,1.1-1.4,0-2.1 c-7.9-4.8-16.4-7.1-25.6-6.7c-2.6,0.1-4.2-1.1-4.3-3.2c-0.1-2.1,1.5-3.4,4.1-3.5c14-0.5,26.3,3.9,36.7,13.3c1.2,1.1,2.6,1.9,4.1,2.6 c10.3,4.5,15.9,15.7,13.4,26.6c-0.3,1.3-0.9,2.3-1.6,3.3C315.7,176.5,315,176.7,314.2,176.9z"/>
                            <path class="fill-body" d="M300.6,155.1c0.5,2.2,0.6,4.1,0.2,5.9c-0.8,4-4.6,6.3-8.4,5.3c-3.8-1.1-5.8-5.2-4.3-8.9c1-2.7,2.8-4.8,5.3-6.3 c2.9-1.7,4.7-1.2,6.2,1.8C300.1,153.6,300.5,154.5,300.6,155.1z"/>
                            <path class="fill-warning" d="M88.6,106.9c-3-1.9-5.7-3.4-8.2-5.2c-1.3-0.9-2.3-0.8-3.6-0.2c-2.8,1.3-5.6,2.4-8.8,3.8 c0.8-3.1,1.4-5.9,2.2-8.6c0.5-1.8,0.4-3.2-1-4.7c-2-2.1-3.6-4.5-5.3-6.8c2.7-0.2,5.7-0.5,8.8-0.6c1.5,0,2.4-0.5,3.1-1.8 c1.5-2.7,3.1-5.3,4.9-8.3c1.3,3.1,2.5,5.9,3.5,8.6c0.6,1.6,1.4,2.4,3.2,2.7c2.9,0.5,5.8,1.3,8.6,1.9c-2.3,2.1-4.4,4.3-6.8,6.2 c-1.4,1.1-1.6,2.3-1.4,3.9C88.1,100.6,88.3,103.5,88.6,106.9z"/>
                            <circle class="fill-success" cx="175.3" cy="116.6" r="69.5"/>
                            <path class="fill-white" d="M145.1,107.5c0.4,0.3,0.7,0.6,1,0.9c5.4,5.3,10.7,10.6,16,15.9c0.9,0.9,1.3,0.9,2.2,0 c13.3-13.4,26.7-26.7,40-40.1c1-1,1.5-0.9,2.4,0c3.4,3.5,6.9,6.9,10.4,10.2c0.7,0.7,0.7,1.1,0,1.8c-17.7,17.6-35.3,35.3-53,53 c-0.7,0.7-1,0.7-1.8,0c-9.6-9.6-19.2-19.1-28.8-28.6c-0.7-0.7-0.9-1.1-0.1-1.9c3.6-3.5,7.2-7,10.8-10.5 C144.5,108,144.8,107.8,145.1,107.5z"/>
                        </svg>
                    </figure>
                    <!-- SVG decoration END -->
                    
                    <!-- Title -->
                    <h3 class="mb-3">Your book has been added successfully!</h3>
                    
                    <!-- Subtitle -->
                    <p class="mb-4">
                        {% if book is defined %}
                            <strong>"{{ book.title }}"</strong> has been added to your library. 
                        {% endif %}
                        The book is now available for students to view, borrow, or purchase.
                    </p>

                    <!-- Action buttons -->
                    <div class="d-flex gap-2 justify-content-center flex-wrap mb-5">
                        {% if book is defined %}
                            <a href="{{ path('admin_books_show', {'id': book.id}) }}" class="btn btn-primary mb-0">
                                <i class="bi bi-eye me-2"></i>View Book
                            </a>
                            <a href="{{ path('admin_books_edit', {'id': book.id}) }}" class="btn btn-success-soft mb-0">
                                <i class="bi bi-pencil-square me-2"></i>Edit Book
                            </a>
                        {% endif %}
                        <a href="{{ path('admin_books_new') }}" class="btn btn-light mb-0">
                            <i class="bi bi-plus-circle me-2"></i>Add Another Book
                        </a>
                        <a href="{{ path('admin_books_index') }}" class="btn btn-secondary mb-0">
                            <i class="bi bi-arrow-left me-2"></i>Back to Books
                        </a>
                    </div>

                    <!-- Info card -->
                    {% if book is defined %}
                    <div class="card border rounded-3 p-4 mt-4">
                        <div class="row g-4 align-items-center">
                            <!-- Book cover -->
                            <div class="col-md-4">
                                {% if book.coverImage %}
                                    <img src="{{ asset(book.coverImage) }}" alt="{{ book.title }}" class="rounded-3 shadow" style="max-width: 200px; height: auto;">
                                {% else %}
                                    <div class="bg-light rounded-3 p-4">
                                        <i class="bi bi-book text-muted" style="font-size: 4rem;"></i>
                                    </div>
                                {% endif %}
                            </div>
                            
                            <!-- Book details -->
                            <div class="col-md-8 text-start">
                                <h5 class="mb-3">{{ book.title }}</h5>
                                <ul class="list-unstyled">
                                    <li class="mb-2">
                                        <i class="bi bi-person-circle text-primary me-2"></i>
                                        <strong>Author:</strong> {{ book.author ?? 'Unknown' }}
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-tag text-primary me-2"></i>
                                        <strong>Price:</strong> ${{ book.price ?? '0.00' }}
                                    </li>
                                    <li class="mb-2">
                                        <i class="bi bi-file-earmark text-primary me-2"></i>
                                        <strong>Format:</strong> 
                                        {% if book.isDigital %}
                                            <span class="badge bg-success bg-opacity-10 text-success">Digital</span>
                                        {% else %}
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary">Physical</span>
                                        {% endif %}
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    <!-- Next steps -->
                    <div class="alert alert-info mt-4" role="alert">
                        <h6 class="alert-heading"><i class="bi bi-info-circle me-2"></i>What's Next?</h6>
                        <p class="mb-0">
                            You can now manage your book, view statistics, or add more books to your library. 
                            Students can find this book in the library section.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

</div>
<!-- Page main content END -->
{% endblock %}

{% block javascripts %}
    {{ parent() }}
{% endblock %}
