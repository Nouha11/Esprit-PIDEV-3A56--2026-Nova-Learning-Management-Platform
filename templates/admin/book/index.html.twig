{% extends 'admin/base.html.twig' %}

{% block title %}Books Management - Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/choices/css/choices.min.css') }}">
{% endblock %}

{% block admin_content %}
<!-- Title and Action START -->
<div class="row mb-3">
    <div class="col-12">
        <div class="d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">Books Management</h1>
            <div>
                <a href="{{ path('admin_books_analytics') }}" class="btn btn-sm btn-info mb-0 me-2">
                    <i class="bi bi-graph-up me-2"></i>View Analytics
                </a>
                <a href="{{ path('admin_books_new') }}" class="btn btn-sm btn-primary mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Add New Book
                </a>
            </div>
        </div>
    </div>
</div>
<!-- Title and Action END -->

<!-- Sales Statistics START -->
<div class="row g-3 mb-4">
    <div class="col-md-6 col-lg-3">
        <div class="card border-primary">
            <div class="card-body text-center">
                <h3 class="text-primary mb-0">{{ books|length }}</h3>
                <small class="text-muted">Total Books</small>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-success">
            <div class="card-body text-center">
                <h3 class="text-success mb-0">{{ totalSales }}</h3>
                <small class="text-muted">Total Sales</small>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-info">
            <div class="card-body text-center">
                <h3 class="text-info mb-0">${{ totalRevenue|number_format(2) }}</h3>
                <small class="text-muted">Total Revenue</small>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-3">
        <div class="card border-warning">
            <div class="card-body text-center">
                <h3 class="text-warning mb-0">
                    {% if totalSales > 0 %}
                        ${{ (totalRevenue / totalSales)|number_format(2) }}
                    {% else %}
                        $0.00
                    {% endif %}
                </h3>
                <small class="text-muted">Avg. Price</small>
            </div>
        </div>
    </div>
</div>
<!-- Sales Statistics END -->

<!-- Flash messages -->
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
{% endfor %}

<!-- Card START -->
<div class="card shadow h-100">
        <!-- Card header START -->
        <div class="card-header p-4 border-bottom">
            <div class="row g-3 align-items-center justify-content-between">
                <!-- Title -->
                <div class="col-md-8">
                    <h5 class="mb-0">All Books</h5>
                </div>

                <!-- Search and filter -->
                <div class="col-md-4">
                    <form class="rounded position-relative">
                        <input class="form-control pe-5 bg-secondary bg-opacity-10 border-0" type="search" placeholder="Search books..." aria-label="Search">
                        <button class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-primary" type="submit">
                            <i class="fas fa-search fs-6"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
        <!-- Card header END -->

        <!-- Card body START -->
        <div class="card-body p-4">
            {% if books|length > 0 %}
                <!-- Books table START -->
                <div class="table-responsive border-0">
                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                        <!-- Table head -->
                        <thead>
                            <tr>
                                <th scope="col" class="border-0 rounded-start">Book</th>
                                <th scope="col" class="border-0">Author</th>
                                <th scope="col" class="border-0">Type</th>
                                <th scope="col" class="border-0">Price</th>
                                <th scope="col" class="border-0">Sales</th>
                                <th scope="col" class="border-0">Revenue</th>
                                <th scope="col" class="border-0">Published</th>
                                <th scope="col" class="border-0 rounded-end">Action</th>
                            </tr>
                        </thead>

                        <!-- Table body START -->
                        <tbody>
                            {% for book in books %}
                            <!-- Table row -->
                            <tr>
                                <!-- Book item -->
                                <td>
                                    <div class="d-flex align-items-center">
                                        <!-- Image -->
                                        <div class="w-60px">
                                            {% if book.coverImage %}
                                                <img src="{{ asset(book.coverImage) }}" class="rounded" alt="{{ book.title }}">
                                            {% else %}
                                                <img src="{{ asset('assets/images/book/01.jpg') }}" class="rounded" alt="{{ book.title }}">
                                            {% endif %}
                                        </div>
                                        <div class="mb-0 ms-2">
                                            <!-- Title -->
                                            <h6 class="mb-0">
                                                <a href="{{ path('admin_books_show', {'id': book.id}) }}">{{ book.title }}</a>
                                            </h6>
                                        </div>
                                    </div>
                                </td>

                                <!-- Author -->
                                <td>
                                    <div class="mb-0">
                                        <h6 class="mb-0">{{ book.author ?? 'Unknown' }}</h6>
                                    </div>
                                </td>

                                <!-- Type -->
                                <td>
                                    {% if book.isDigital %}
                                        <span class="badge bg-success bg-opacity-10 text-success">Digital</span>
                                    {% else %}
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary">Physical</span>
                                    {% endif %}
                                </td>

                                <!-- Price -->
                                <td>
                                    <h6 class="mb-0 fw-normal">${{ book.price ?? '0.00' }}</h6>
                                </td>

                                <!-- Sales -->
                                <td>
                                    {% set sales = salesData[book.id] %}
                                    <span class="badge bg-success">
                                        <i class="bi bi-cart-check me-1"></i>{{ sales.count }}
                                    </span>
                                </td>

                                <!-- Revenue -->
                                <td>
                                    {% set sales = salesData[book.id] %}
                                    <h6 class="mb-0 fw-bold text-success">${{ sales.revenue|number_format(2) }}</h6>
                                </td>

                                <!-- Published date -->
                                <td>{{ book.publishedAt ? book.publishedAt|date('M d, Y') : book.createdAt|date('M d, Y') }}</td>

                                <!-- Action -->
                                <td>
                                    <div class="d-flex gap-2">
                                        <a href="{{ path('admin_books_show', {'id': book.id}) }}" class="btn btn-sm btn-success-soft btn-round me-1 mb-0" title="View">
                                            <i class="far fa-fw fa-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_books_edit', {'id': book.id}) }}" class="btn btn-sm btn-info-soft btn-round me-1 mb-0" title="Edit">
                                            <i class="far fa-fw fa-edit"></i>
                                        </a>
                                        <form action="{{ path('admin_books_delete', {'id': book.id}) }}" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                                            <button type="submit" class="btn btn-sm btn-danger-soft btn-round mb-0" title="Delete">
                                                <i class="fas fa-fw fa-times"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <!-- Table body END -->
                    </table>
                </div>
                <!-- Books table END -->
            {% else %}
                <!-- Empty state -->
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-book display-1 text-muted"></i>
                    </div>
                    <h5>No books found</h5>
                    <p class="mb-3">Start building your library by adding your first book.</p>
                    <a href="{{ path('admin_books_new') }}" class="btn btn-primary mb-0">
                        <i class="bi bi-plus-circle me-2"></i>Add Your First Book
                    </a>
                </div>
            {% endif %}
        </div>
        <!-- Card body END -->

        <!-- Card footer START -->
        <div class="card-footer bg-transparent pt-0">
            <!-- Pagination (if needed) -->
            <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                <p class="mb-0 text-center text-sm-start">Showing {{ books|length }} book(s)</p>
                <!-- Pagination can be added here if needed -->
            </div>
        </div>
        <!-- Card footer END -->
    </div>
    <!-- Card END -->
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>
{% endblock %}
