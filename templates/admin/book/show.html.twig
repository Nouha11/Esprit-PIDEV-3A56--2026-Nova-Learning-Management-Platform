{% extends 'admin/base.html.twig' %}

{% block title %}{{ book.title }} - Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/choices/css/choices.min.css') }}">
{% endblock %}

{% block admin_content %}
<!-- Page main content START -->
<div class="page-content-wrapper border">

    <!-- Title START -->
    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <div class="mb-2 mb-sm-0">
                <h1 class="h3 mb-0">{{ book.title }}</h1>
                <p class="mb-0">
                    <i class="bi bi-person-circle me-1"></i>
                    <span class="text-muted">By {{ book.author ?? 'Unknown Author' }}</span>
                </p>
            </div>
            <div class="d-flex gap-2">
                <a href="{{ path('admin_books_edit', {'id': book.id}) }}" class="btn btn-sm btn-primary-soft mb-0">
                    <i class="bi bi-pencil-square me-1"></i>Edit
                </a>
                <form action="{{ path('admin_books_delete', {'id': book.id}) }}" method="POST" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this book?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ book.id) }}">
                    <button type="submit" class="btn btn-sm btn-danger-soft mb-0">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
    <!-- Title END -->

    <!-- Flash messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'success' ? 'success' : 'danger' }} alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="row g-4">
        <!-- Main content START -->
        <div class="col-xl-8">
            <!-- Book details START -->
            <div class="card border rounded-3 mb-4">
                <!-- Card header -->
                <div class="card-header border-bottom">
                    <h5 class="card-header-title">Book Information</h5>
                </div>

                <!-- Card body START -->
                <div class="card-body">
                    <!-- Information item -->
                    <div class="row g-4">
                        <!-- Title -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-success bg-opacity-10 text-success rounded-circle flex-shrink-0">
                                    <i class="bi bi-book fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">Title</span>
                                    <h6 class="mb-0">{{ book.title }}</h6>
                                </div>
                            </div>
                        </div>

                        <!-- Author -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-info bg-opacity-10 text-info rounded-circle flex-shrink-0">
                                    <i class="bi bi-person-circle fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">Author</span>
                                    <h6 class="mb-0">{{ book.author ?? 'Unknown' }}</h6>
                                </div>
                            </div>
                        </div>

                        <!-- Type -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-purple bg-opacity-10 text-purple rounded-circle flex-shrink-0">
                                    <i class="bi bi-file-earmark fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">Format</span>
                                    <h6 class="mb-0">
                                        {% if book.isDigital %}
                                            <span class="badge bg-success bg-opacity-10 text-success">Digital (PDF)</span>
                                        {% else %}
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary">Physical Book</span>
                                        {% endif %}
                                    </h6>
                                </div>
                            </div>
                        </div>

                        <!-- Price -->
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded-circle flex-shrink-0">
                                    <i class="bi bi-tag fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">Price</span>
                                    <h6 class="mb-0 text-success">${{ book.price ?? '0.00' }}</h6>
                                </div>
                            </div>
                        </div>

                        <!-- ISBN -->
                        {% if book.isbn %}
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-primary bg-opacity-10 text-primary rounded-circle flex-shrink-0">
                                    <i class="bi bi-upc-scan fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">ISBN</span>
                                    <h6 class="mb-0">{{ book.isbn }}</h6>
                                </div>
                            </div>
                        </div>
                        {% endif %}

                        <!-- Published Date -->
                        {% if book.publishedAt %}
                        <div class="col-md-6">
                            <div class="d-flex align-items-center">
                                <div class="icon-lg bg-orange bg-opacity-10 text-orange rounded-circle flex-shrink-0">
                                    <i class="bi bi-calendar-event fs-5"></i>
                                </div>
                                <div class="ms-3">
                                    <span class="text-body small">Published Date</span>
                                    <h6 class="mb-0">{{ book.publishedAt|date('M d, Y') }}</h6>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    <!-- Description -->
                    <div class="mt-4">
                        <h6 class="mb-3">Description</h6>
                        <div class="bg-light rounded p-3">
                            {% if book.description %}
                                <p class="mb-0">{{ book.description }}</p>
                            {% else %}
                                <p class="mb-0 text-muted fst-italic">No description provided</p>
                            {% endif %}
                        </div>
                    </div>
                </div>
                <!-- Card body END -->
            </div>
            <!-- Book details END -->

            <!-- Statistics START -->
            <div class="card border rounded-3">
                <div class="card-header border-bottom">
                    <h5 class="card-header-title">Book Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-sm-6 col-lg-4">
                            <div class="text-center">
                                <div class="icon-lg bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-2">
                                    <i class="bi bi-eye fs-5"></i>
                                </div>
                                <h6 class="mb-0">Views</h6>
                                <p class="mb-0 text-muted small">Coming soon</p>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="text-center">
                                <div class="icon-lg bg-info bg-opacity-10 text-info rounded-circle mx-auto mb-2">
                                    <i class="bi bi-cart-check fs-5"></i>
                                </div>
                                <h6 class="mb-0">Purchases</h6>
                                <p class="mb-0 text-muted small">Coming soon</p>
                            </div>
                        </div>
                        <div class="col-sm-6 col-lg-4">
                            <div class="text-center">
                                <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded-circle mx-auto mb-2">
                                    <i class="bi bi-book fs-5"></i>
                                </div>
                                <h6 class="mb-0">Loans</h6>
                                <p class="mb-0 text-muted small">Coming soon</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- Statistics END -->
        </div>
        <!-- Main content END -->

        <!-- Right sidebar START -->
        <div class="col-xl-4">
            <!-- Cover Image START -->
            <div class="card border rounded-3 mb-4">
                <div class="card-header border-bottom">
                    <h5 class="card-header-title">Cover Image</h5>
                </div>
                <div class="card-body text-center">
                    {% if book.coverImage %}
                        <img src="{{ asset(book.coverImage) }}" alt="{{ book.title }}" class="rounded-3 shadow" style="max-width: 100%; height: auto;">
                    {% else %}
                        <div class="bg-light rounded-3 p-5">
                            <i class="bi bi-image text-muted" style="font-size: 4rem;"></i>
                            <p class="text-muted mt-2 mb-0">No cover image</p>
                        </div>
                    {% endif %}
                </div>
            </div>
            <!-- Cover Image END -->

            <!-- Metadata START -->
            <div class="card border rounded-3 mb-4">
                <div class="card-header border-bottom">
                    <h5 class="card-header-title">Metadata</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-borderless">
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span class="h6 fw-light mb-0"><i class="bi bi-calendar-plus text-primary me-2"></i>Created</span>
                            <span>{{ book.createdAt|date('M d, Y') }}</span>
                        </li>
                        {% if book.updatedAt %}
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span class="h6 fw-light mb-0"><i class="bi bi-clock-history text-primary me-2"></i>Updated</span>
                            <span>{{ book.updatedAt|date('M d, Y') }}</span>
                        </li>
                        {% endif %}
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span class="h6 fw-light mb-0"><i class="bi bi-hash text-primary me-2"></i>Book ID</span>
                            <span>{{ book.id }}</span>
                        </li>
                        {% if book.uploaderId %}
                        <li class="list-group-item px-0 d-flex justify-content-between">
                            <span class="h6 fw-light mb-0"><i class="bi bi-person-badge text-primary me-2"></i>Uploader</span>
                            <span>{{ book.uploaderId }}</span>
                        </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
            <!-- Metadata END -->

            <!-- Quick Actions START -->
            <div class="card border rounded-3">
                <div class="card-header border-bottom">
                    <h5 class="card-header-title">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('book_show', {'id': book.id}) }}" class="btn btn-light mb-0" target="_blank">
                            <i class="bi bi-box-arrow-up-right me-2"></i>View Public Page
                        </a>
                        <a href="{{ path('admin_books_edit', {'id': book.id}) }}" class="btn btn-primary mb-0">
                            <i class="bi bi-pencil-square me-2"></i>Edit Book
                        </a>
                        <a href="{{ path('admin_books_index') }}" class="btn btn-secondary mb-0">
                            <i class="bi bi-arrow-left me-2"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
            <!-- Quick Actions END -->
        </div>
        <!-- Right sidebar END -->
    </div>

</div>
<!-- Page main content END -->
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>
{% endblock %}
