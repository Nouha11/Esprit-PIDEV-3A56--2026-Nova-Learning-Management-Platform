        <div class="input-group">
            <input type="text" class="form-control bg-light border-0 small" id="searchInput" 
                   placeholder="Search for books..." aria-label="Search" autocomplete="off">
            <button class="btn btn-primary" type="submit">
                <i class="fas fa-search fa-sm"></i>
            </button>
        </div>
        <!-- Search Results Dropdown -->
        <div id="searchResults" class="dropdown-menu shadow-lg" style="display: none; width: 400px; max-height: 400px; overflow-y: auto;">
