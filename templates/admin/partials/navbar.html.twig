<style>
    /* Topbar styling */
    .topbar {
        height: 4.375rem;
    }
    
    .topbar .navbar-search {
        width: 25rem;
    }
    
    .topbar .navbar-search input {
        font-size: 0.85rem;
        height: 2rem;
    }
    
    .topbar-divider {
        width: 0;
        border-right: 1px solid #e3e6f0;
        height: calc(4.375rem - 2rem);
        margin: auto 1rem;
    }
    
    .img-profile {
        height: 2rem;
        width: 2rem;
    }
    
    .badge-counter {
        position: absolute;
        transform: scale(0.7);
        transform-origin: top right;
        right: 0.25rem;
        margin-top: -0.25rem;
    }
    
    .icon-circle {
        height: 2.5rem;
        width: 2.5rem;
        border-radius: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .dropdown-menu {
        font-size: 0.85rem;
    }
    
    .dropdown-header {
        font-weight: 800;
        font-size: 0.65rem;
        color: #858796;
    }
    
    /* Search Results Styling */
    #searchResults {
        position: absolute;
        top: 100%;
        left: 0;
        z-index: 1000;
        margin-top: 0.5rem;
    }
    
    .search-result-item {
        padding: 0.75rem 1rem;
        border-bottom: 1px solid #e3e6f0;
        cursor: pointer;
        transition: background-color 0.2s;
    }
    
    .search-result-item:hover {
        background-color: #f8f9fc;
    }
    
    .search-result-item:last-child {
        border-bottom: none;
    }
    
    .search-result-img {
        width: 50px;
        height: 70px;
        object-fit: cover;
        border-radius: 4px;
    }
</style>

<script>
// Live Search Functionality
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const searchResults = document.getElementById('searchResults');
    const searchResultsContent = document.getElementById('searchResultsContent');
    const searchForm = document.getElementById('searchForm');
    let searchTimeout;

    // Fonction de recherche
    function performSearch(query) {
        if (query.length < 2) {
            searchResults.style.display = 'none';
            return;
        }

        // Appel AJAX pour rechercher les livres
        fetch(`{{ path('admin_books_search') }}?q=${encodeURIComponent(query)}`)
            .then(response => response.json())
            .then(books => {
                if (books.length === 0) {
                    searchResultsContent.innerHTML = `
                        <div class="p-3 text-center text-muted">
                            <i class="fas fa-search fa-2x mb-2"></i>
                            <p class="mb-0">No books found</p>
                        </div>
                    `;
                } else {
                    searchResultsContent.innerHTML = books.map(book => `
                        <a href="${book.url}" class="search-result-item text-decoration-none d-flex align-items-center">
                            <img src="${book.coverImage}" alt="${book.title}" class="search-result-img me-3">
                            <div class="flex-grow-1">
                                <h6 class="mb-1 text-dark">${book.title}</h6>
                                <p class="mb-0 small text-muted">
                                    <i class="fas fa-user me-1"></i>${book.author}
                                    <span class="mx-2">•</span>
                                    <i class="fas fa-tag me-1"></i>$${book.price}
                                    <span class="mx-2">•</span>
                                    ${book.isDigital ? '<span class="badge bg-success">Digital</span>' : '<span class="badge bg-secondary">Physical</span>'}
                                </p>
                            </div>
                        </a>
                    `).join('');
                }
                searchResults.style.display = 'block';
            })
            .catch(error => {
                console.error('Search error:', error);
                searchResultsContent.innerHTML = `
                    <div class="p-3 text-center text-danger">
                        <i class="fas fa-exclamation-triangle fa-2x mb-2"></i>
                        <p class="mb-0">Error loading results</p>
                    </div>
                `;
                searchResults.style.display = 'block';
            });
    }

    // Événement de saisie dans le champ de recherche
    searchInput.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        const query = this.value.trim();
        
        // Délai de 300ms avant de lancer la recherche
        searchTimeout = setTimeout(() => {
            performSearch(query);
        }, 300);
    });

    // Empêcher la soumission du formulaire
    searchForm.addEventListener('submit', function(e) {
        e.preventDefault();
        performSearch(searchInput.value.trim());
    });

    // Fermer les résultats quand on clique ailleurs
    document.addEventListener('click', function(e) {
        if (!searchForm.contains(e.target)) {
            searchResults.style.display = 'none';
        }
    });

    // Rouvrir les résultats quand on clique dans le champ
    searchInput.addEventListener('focus', function() {
        if (this.value.trim().length >= 2 && searchResultsContent.innerHTML) {
            searchResults.style.display = 'block';
        }
    });
});
</script>