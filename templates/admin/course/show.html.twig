{% extends 'admin/base.html.twig' %}

{% block title %}Course Details{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Course Details</h1>
        <div>
            <a href="{{ path('admin_course_edit', {id: course.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit
            </a>
            <a href="{{ path('admin_course_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Course Information</h6>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th width="200">Course Name:</th>
                            <td>{{ course.courseName }}</td>
                        </tr>
                        <tr>
                            <th>Description:</th>
                            <td>{{ course.description ?? 'N/A' }}</td>
                        </tr>
                        <tr>
                            <th>Category:</th>
                            <td><span class="badge bg-info">{{ course.category }}</span></td>
                        </tr>
                        <tr>
                            <th>Difficulty:</th>
                            <td><span class="badge bg-warning">{{ course.difficulty }}</span></td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                {% if course.status == 'COMPLETED' %}
                                    <span class="badge bg-success">Completed</span>
                                {% elseif course.status == 'IN_PROGRESS' %}
                                    <span class="badge bg-primary">In Progress</span>
                                {% else %}
                                    <span class="badge bg-secondary">Not Started</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Estimated Duration:</th>
                            <td>{{ course.estimatedDuration }} minutes</td>
                        </tr>
                        <tr>
                            <th>Progress:</th>
                            <td>
                                <div class="progress">
                                    <div class="progress-bar" role="progressbar" style="width: {{ course.progress }}%" aria-valuenow="{{ course.progress }}" aria-valuemin="0" aria-valuemax="100">
                                        {{ course.progress }}%
                                    </div>
                                </div>
                            </td>
                        </tr>
                        <tr>
                            <th>Max Students:</th>
                            <td>{{ course.maxStudents ?? 'Unlimited' }}</td>
                        </tr>
                        <tr>
                            <th>Published:</th>
                            <td>
                                {% if course.isPublished %}
                                    <span class="badge bg-success">Yes</span>
                                {% else %}
                                    <span class="badge bg-secondary">No</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Created At:</th>
                            <td>{{ course.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Related Planning Sessions</h6>
                </div>
                <div class="card-body">
                    {% if course.plannings|length > 0 %}
                        <ul class="list-group">
                            {% for planning in course.plannings %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    {{ planning.title }}
                                    <span class="badge bg-primary rounded-pill">{{ planning.status }}</span>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted">No planning sessions yet.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
