{% extends 'admin/base.html.twig' %}

{% block title %}Manage Courses{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Courses Management</h1>
        <a href="{{ path('admin_course_new') }}" class="btn btn-primary">
            <i class="fas fa-plus"></i> Create New Course
        </a>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">All Courses</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Course Name</th>
                            <th>Category</th>
                            <th>Difficulty</th>
                            <th>Duration (min)</th>
                            <th>Status</th>
                            <th>Published</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for course in courses %}
                            <tr>
                                <td>{{ course.id }}</td>
                                <td>{{ course.courseName }}</td>
                                <td><span class="badge bg-info">{{ course.category }}</span></td>
                                <td><span class="badge bg-warning">{{ course.difficulty }}</span></td>
                                <td>{{ course.estimatedDuration }}</td>
                                <td>
                                    {% if course.status == 'COMPLETED' %}
                                        <span class="badge bg-success">Completed</span>
                                    {% elseif course.status == 'IN_PROGRESS' %}
                                        <span class="badge bg-primary">In Progress</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Not Started</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if course.isPublished %}
                                        <span class="badge bg-success">Published</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Draft</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('admin_course_show', {id: course.id}) }}" class="btn btn-sm btn-info" title="View">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a href="{{ path('admin_course_edit', {id: course.id}) }}" class="btn btn-sm btn-warning" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    
                                    <form method="post" action="{{ path('admin_course_toggle_publish', {id: course.id}) }}" style="display:inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ course.id) }}">
                                        <button class="btn btn-sm btn-secondary" title="Toggle Publish">
                                            <i class="fas fa-toggle-{{ course.isPublished ? 'on' : 'off' }}"></i>
                                        </button>
                                    </form>
                                    
                                    <form method="post" action="{{ path('admin_course_delete', {id: course.id}) }}" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ course.id) }}">
                                        <button class="btn btn-sm btn-danger" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="text-center">No courses found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
