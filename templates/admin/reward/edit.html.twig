{% extends 'admin/base.html.twig' %}

{% block title %}Edit Reward{% endblock %}

{% block admin_content %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Edit Reward: {{ reward.name }}</h1>
        <a href="{{ path('admin_reward_show', {id: reward.id}) }}" class="btn btn-outline-secondary">
            <i class="bi bi-eye me-2"></i>View Reward
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                    {{ form_start(form, {
                        'attr': {
                            'novalidate': 'novalidate'
                        }
                    }) }}
                        <div class="mb-3">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name) }}
                            {{ form_errors(form.name) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description) }}
                            {{ form_widget(form.description) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.type) }}
                                {{ form_widget(form.type) }}
                                {{ form_errors(form.type) }}
                            </div>

                            <div class="col-md-6 mb-3">
                                {{ form_label(form.value) }}
                                {{ form_widget(form.value) }}
                                {{ form_errors(form.value) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.requirement) }}
                            {{ form_widget(form.requirement) }}
                            {{ form_errors(form.requirement) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.icon) }}
                            {{ form_widget(form.icon) }}
                            {{ form_errors(form.icon) }}
                            <small class="form-text text-muted">
                                Current: {{ reward.icon ? reward.icon : 'None' }}
                            </small>
                        </div>

                        <div class="mb-3 form-check">
                            {{ form_widget(form.isActive) }}
                            {{ form_label(form.isActive) }}
                            {{ form_errors(form.isActive) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Update Reward
                            </button>
                            <a href="{{ path('admin_reward_show', {id: reward.id}) }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Current Reward Preview</h5>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        {% if reward.icon %}
                            <span style="font-size: 4rem;">{{ reward.icon }}</span>
                        {% else %}
                            <i class="bi bi-award text-muted" style="font-size: 4rem;"></i>
                        {% endif %}
                    </div>
                    <h4>{{ reward.name }}</h4>
                    <p class="text-muted">{{ reward.description }}</p>
                    <div class="mt-3">
                        {% if reward.type == 'BADGE' %}
                            <span class="badge bg-primary">Badge</span>
                        {% elseif reward.type == 'ACHIEVEMENT' %}
                            <span class="badge bg-warning">Achievement</span>
                        {% elseif reward.type == 'BONUS_XP' %}
                            <span class="badge bg-info">Bonus XP: {{ reward.value }}</span>
                        {% elseif reward.type == 'BONUS_TOKENS' %}
                            <span class="badge bg-success">Bonus Tokens: {{ reward.value }}</span>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-success text-white">
                    <h6 class="mb-0">Associated Games</h6>
                </div>
                <div class="card-body">
                    {% if reward.games is not empty %}
                        <p class="mb-2">This reward is offered by <strong>{{ reward.games|length }}</strong> game(s):</p>
                        <ul class="list-unstyled mb-0">
                            {% for game in reward.games|slice(0, 5) %}
                                <li class="mb-2">
                                    <a href="{{ path('admin_game_show', {id: game.id}) }}" class="text-decoration-none">
                                        {{ game.name }}
                                        <span class="badge bg-{{ game.difficulty == 'EASY' ? 'success' : (game.difficulty == 'MEDIUM' ? 'warning' : 'danger') }}">
                                            {{ game.difficulty }}
                                        </span>
                                    </a>
                                </li>
                            {% endfor %}
                            {% if reward.games|length > 5 %}
                                <li class="text-muted">
                                    <small>+ {{ reward.games|length - 5 }} more...</small>
                                </li>
                            {% endif %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">Not associated with any games yet</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}