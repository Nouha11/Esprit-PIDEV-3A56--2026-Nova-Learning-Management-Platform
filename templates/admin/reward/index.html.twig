{% extends 'admin/base.html.twig' %}

{% block title %}Manage Rewards{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Rewards & Badges</h1>
        <a href="{{ path('admin_reward_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Create New Reward
        </a>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Icon</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Value</th>
                            <th>Requirement</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% if rewards is empty %}
                            <tr>
                                <td colspan="7" class="text-center py-4">
                                    <p class="text-muted mb-3">No rewards created yet.</p>
                                    <a href="{{ path('admin_reward_new') }}" class="btn btn-primary">
                                        Create Your First Reward
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            {% for reward in rewards %}
                                <tr>
                                    <td>
                                        {% if reward.icon %}
                                            <span style="font-size: 2rem;">{{ reward.icon }}</span>
                                        {% else %}
                                            <i class="bi bi-award text-muted" style="font-size: 2rem;"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <strong>{{ reward.name }}</strong>
                                        {% if reward.description %}
                                            <br><small class="text-muted">{{ reward.description|slice(0, 50) }}{% if reward.description|length > 50 %}...{% endif %}</small>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if reward.type == 'BADGE' %}
                                            <span class="badge bg-primary">Badge</span>
                                        {% elseif reward.type == 'ACHIEVEMENT' %}
                                            <span class="badge bg-success">Achievement</span>
                                        {% elseif reward.type == 'BONUS_XP' %}
                                            <span class="badge bg-info">Bonus XP</span>
                                        {% elseif reward.type == 'BONUS_TOKENS' %}
                                            <span class="badge bg-warning">Bonus Tokens</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if reward.type in ['BONUS_XP', 'BONUS_TOKENS'] %}
                                            <strong>{{ reward.value }}</strong>
                                        {% else %}
                                            -
                                        {% endif %}
                                    </td>
                                    <td>
                                        <small>{{ reward.requirement|slice(0, 40) }}{% if reward.requirement|length > 40 %}...{% endif %}</small>
                                    </td>
                                    <td>
                                        {% if reward.isActive %}
                                            <span class="badge bg-success">Active</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Inactive</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a href="{{ path('admin_reward_edit', {id: reward.id}) }}" class="btn btn-sm btn-outline-primary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <form method="post" action="{{ path('admin_reward_delete', {id: reward.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this reward?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reward.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Quick Add Default Badges Section -->
    <div class="card mt-4">
        <div class="card-header bg-light">
            <h5 class="mb-0">Quick Setup: Default Milestone Badges</h5>
        </div>
        <div class="card-body">
            <p class="text-muted">Create these recommended milestone badges to automatically reward students:</p>
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="border rounded p-3">
                        <h6>🏆 First Victory</h6>
                        <small class="text-muted">Awarded for winning first game</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3">
                        <h6>👑 Game Master</h6>
                        <small class="text-muted">Awarded for 10 wins on same game</small>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="border rounded p-3">
                        <h6>⭐ Perfect Score</h6>
                        <small class="text-muted">100% win rate after 10+ games</small>
                    </div>
                </div>
            </div>
            <div class="mt-3">
                <a href="{{ path('admin_reward_new') }}" class="btn btn-sm btn-primary">
                    Create These Badges
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
