<div class="table-responsive">
    <table class="table table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Icon</th>
                <th>Name</th>
                <th>Type</th>
                <th>Value</th>
                <th>Associated Games</th>
                <th>Requirement</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% if rewards is empty %}
                <tr>
                    <td colspan="9" class="text-center py-4">
                        <i class="bi bi-inbox fs-1 text-muted"></i>
                        <p class="text-muted mb-3 mt-2">No rewards found matching your filters.</p>
                        <button class="btn btn-outline-primary" onclick="clearFilters()">
                            <i class="bi bi-x-circle me-1"></i>Clear Filters
                        </button>
                    </td>
                </tr>
            {% else %}
                {% for reward in rewards %}
                    <tr>
                        <td>{{ reward.id }}</td>
                        <td>
                            {% if reward.icon %}
                                <img src="{{ asset('uploads/rewards/' ~ reward.icon) }}" alt="{{ reward.name }}" style="width: 50px; height: 50px; object-fit: contain;">
                            {% else %}
                                <i class="bi bi-award text-muted" style="font-size: 2rem;"></i>
                            {% endif %}
                        </td>
                        <td>
                            <strong>{{ reward.name }}</strong>
                            {% if reward.description %}
                                <br><small class="text-muted">{{ reward.description|slice(0, 50) }}{% if reward.description|length > 50 %}...{% endif %}</small>
                            {% endif %}
                        </td>
                        <td>
                            {% if reward.type == 'BADGE' %}
                                <span class="badge bg-primary">Badge</span>
                            {% elseif reward.type == 'ACHIEVEMENT' %}
                                <span class="badge bg-warning text-dark">Achievement</span>
                            {% elseif reward.type == 'BONUS_XP' %}
                                <span class="badge bg-info">Bonus XP</span>
                            {% elseif reward.type == 'BONUS_TOKENS' %}
                                <span class="badge bg-success">Bonus Tokens</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if reward.type in ['BONUS_XP', 'BONUS_TOKENS'] %}
                                <strong>{{ reward.value }}</strong>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            {% set fullGamesCount = reward.games|filter(g => g.category == 'FULL_GAME')|length %}
                            {% if fullGamesCount > 0 %}
                                <span class="badge bg-success" title="{{ fullGamesCount }} game(s) offer this reward">
                                    <i class="bi bi-controller me-1"></i>{{ fullGamesCount }}
                                </span>
                                <button class="btn btn-sm btn-outline-info" 
                                        type="button" 
                                        data-bs-toggle="collapse" 
                                        data-bs-target="#games-{{ reward.id }}" 
                                        aria-expanded="false">
                                    <i class="bi bi-eye"></i>
                                </button>
                            {% else %}
                                <span class="badge bg-secondary">None</span>
                            {% endif %}
                        </td>
                        <td>
                            <small>{{ reward.requirement|slice(0, 40) }}{% if reward.requirement|length > 40 %}...{% endif %}</small>
                        </td>
                        <td>
                            {% if reward.isActive %}
                                <span class="badge bg-success">Active</span>
                            {% else %}
                                <span class="badge bg-secondary">Inactive</span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="btn-group" role="group">
                                <a href="{{ path('admin_reward_show', {id: reward.id}) }}" 
                                   class="btn btn-sm btn-outline-info" 
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('admin_reward_edit', {id: reward.id}) }}" 
                                   class="btn btn-sm btn-outline-warning" 
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" 
                                      action="{{ path('admin_reward_toggle_status', {id: reward.id}) }}" 
                                      style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ reward.id) }}">
                                    <button type="submit" 
                                            class="btn btn-sm btn-outline-{{ reward.isActive ? 'secondary' : 'success' }}" 
                                            title="{{ reward.isActive ? 'Deactivate' : 'Activate' }}">
                                        <i class="bi bi-{{ reward.isActive ? 'toggle-off' : 'toggle-on' }}"></i>
                                    </button>
                                </form>
                                <form method="post" 
                                      action="{{ path('admin_reward_delete', {id: reward.id}) }}" 
                                      style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete {{ reward.name|escape('js') }}? This will remove the reward from all associated games.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ reward.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% set fullGamesForReward = reward.games|filter(g => g.category == 'FULL_GAME') %}
                    {% if fullGamesForReward|length > 0 %}
                    <tr class="collapse" id="games-{{ reward.id }}">
                        <td colspan="9" class="bg-light">
                            <div class="p-3">
                                <h6 class="mb-2"><i class="bi bi-controller me-2"></i>Games offering this reward:</h6>
                                <div class="d-flex flex-wrap gap-2">
                                    {% for game in fullGamesForReward %}
                                        <a href="{{ path('admin_game_show', {id: game.id}) }}" 
                                           class="btn btn-sm btn-outline-primary">
                                            {{ game.name }}
                                            <span class="badge bg-{{ game.difficulty == 'EASY' ? 'success' : (game.difficulty == 'MEDIUM' ? 'warning' : 'danger') }}">
                                                {{ game.difficulty }}
                                            </span>
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </td>
                    </tr>
                    {% endif %}
                {% endfor %}
            {% endif %}
        </tbody>
    </table>
</div>

<!-- Pagination -->
<div class="mt-3">
    {{ knp_pagination_render(rewards, 'pagination/custom_pagination.html.twig') }}
</div>

<!-- Update results count -->
<script>
    document.getElementById('results-count').textContent = {{ rewards.getTotalItemCount }};
</script>
