{% extends 'admin/base.html.twig' %}

{% block title %}Create New Reward{% endblock %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Create New Reward</h1>
        <a href="{{ path('admin_reward_index') }}" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-2"></i>Back to Rewards
        </a>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body">
                {{ form_start(form, {
                    'attr': {
                        'novalidate': 'novalidate',
                        'enctype': 'multipart/form-data'
                    }
                }) }}
                        <div class="mb-3">
                            {{ form_label(form.name) }}
                            {{ form_widget(form.name) }}
                            {{ form_errors(form.name) }}
                            <small class="form-text text-muted">Give your reward a clear, descriptive name</small>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.description) }}
                            {{ form_widget(form.description) }}
                            {{ form_errors(form.description) }}
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                {{ form_label(form.type) }}
                                {{ form_widget(form.type) }}
                                {{ form_errors(form.type) }}
                            </div>

                            <div class="col-md-6 mb-3">
                                {{ form_label(form.value) }}
                                {{ form_widget(form.value) }}
                                {{ form_errors(form.value) }}
                                <small class="form-text text-muted">For BONUS_XP or BONUS_TOKENS types</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.requirement) }}
                            {{ form_widget(form.requirement) }}
                            {{ form_errors(form.requirement) }}
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.iconFile) }}
                            {{ form_widget(form.iconFile) }}
                            {{ form_errors(form.iconFile) }}
                            <small class="form-text text-muted">Upload an image file (PNG, JPG, SVG, WEBP - max 2MB)</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label d-flex justify-content-between align-items-center">
                                <span>{{ form.games.vars.label }}</span>
                                <div>
                                    <button type="button" class="btn btn-sm btn-outline-primary" onclick="selectAllGames(true)">
                                        <i class="bi bi-check-square me-1"></i>Select All
                                    </button>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="selectAllGames(false)">
                                        <i class="bi bi-square me-1"></i>Deselect All
                                    </button>
                                </div>
                            </label>
                            <div class="mb-2">
                                <input type="text" id="gameSearch" class="form-control form-control-sm" placeholder="Search games...">
                            </div>
                            <div class="border rounded p-3" style="max-height: 400px; overflow-y: auto; background-color: var(--bs-body-bg);">
                                <div class="row g-2" id="gamesList">
                                    {% for game_checkbox in form.games %}
                                        <div class="col-md-6 game-item" data-game-name="{{ game_checkbox.vars.label|lower }}">
                                            <div class="form-check">
                                                {{ form_widget(game_checkbox, {'attr': {'class': 'form-check-input game-checkbox'}}) }}
                                                {{ form_label(game_checkbox, null, {'label_attr': {'class': 'form-check-label'}}) }}
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            </div>
                            {{ form_errors(form.games) }}
                            <small class="text-muted d-block mt-1">
                                <i class="bi bi-info-circle me-1"></i>
                                {{ form.games.vars.help }}
                            </small>
                        </div>

                        <script>
                            function selectAllGames(checked) {
                                document.querySelectorAll('.game-checkbox:not([style*="display: none"])').forEach(checkbox => {
                                    if (checkbox.closest('.game-item').style.display !== 'none') {
                                        checkbox.checked = checked;
                                    }
                                });
                            }
                            
                            // Search functionality
                            document.getElementById('gameSearch').addEventListener('input', function(e) {
                                const searchTerm = e.target.value.toLowerCase();
                                document.querySelectorAll('.game-item').forEach(item => {
                                    const gameName = item.getAttribute('data-game-name');
                                    if (gameName.includes(searchTerm)) {
                                        item.style.display = '';
                                    } else {
                                        item.style.display = 'none';
                                    }
                                });
                            });
                        </script>

                        <style>
                            .form-check-input:checked {
                                background-color: #667eea;
                                border-color: #667eea;
                            }
                            .form-check-label {
                                cursor: pointer;
                                user-select: none;
                            }
                            .form-check:hover {
                                background-color: rgba(102, 126, 234, 0.1);
                                border-radius: 4px;
                                padding: 2px 4px;
                                margin: -2px -4px;
                            }
                        </style>

                        <div class="mb-3 form-check">
                            {{ form_widget(form.isActive) }}
                            {{ form_label(form.isActive) }}
                            {{ form_errors(form.isActive) }}
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Create Reward
                            </button>
                            <a href="{{ path('admin_reward_index') }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Reward Types</h5>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <h6><span class="badge bg-primary">BADGE</span></h6>
                        <small>Collectible achievement badge. Automatically awarded based on milestones.</small>
                    </div>
                    <div class="mb-3">
                        <h6><span class="badge bg-warning">ACHIEVEMENT</span></h6>
                        <small>Special achievement for completing specific tasks.</small>
                    </div>
                    <div class="mb-3">
                        <h6><span class="badge bg-info">BONUS_XP</span></h6>
                        <small>Bonus experience points. Set the value field.</small>
                    </div>
                    <div class="mb-3">
                        <h6><span class="badge bg-success">BONUS_TOKENS</span></h6>
                        <small>Bonus tokens. Set the value field.</small>
                    </div>
                </div>
            </div>

            <div class="card mt-3">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Recommended Badges</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">🏆 <strong>First Victory</strong> - First game win</li>
                        <li class="mb-2">👑 <strong>Game Master</strong> - 10 wins on same game</li>
                        <li class="mb-2">⭐ <strong>Perfect Score</strong> - 100% win rate</li>
                        <li class="mb-2">🎓 <strong>Quick Learner</strong> - Reach level 5</li>
                        <li class="mb-2">📚 <strong>Scholar</strong> - Reach level 10</li>
                        <li>💰 <strong>Token Collector</strong> - Collect 1000 tokens</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}