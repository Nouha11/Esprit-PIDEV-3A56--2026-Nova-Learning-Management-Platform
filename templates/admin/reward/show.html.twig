{% extends 'admin/base.html.twig' %}

{% block title %}{{ reward.name }}{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1>{{ reward.name }}</h1>
                <div>
                    <a href="{{ path('admin_reward_edit', {id: reward.id}) }}" class="btn btn-warning">
                        <i class="bi bi-pencil"></i> Edit Reward
                    </a>
                </div>
            </div>
            
            <div class="mb-3">
                <span class="badge 
                    {% if reward.type == 'BADGE' %}bg-primary
                    {% elseif reward.type == 'ACHIEVEMENT' %}bg-warning
                    {% elseif reward.type == 'BONUS_XP' %}bg-info
                    {% elseif reward.type == 'BONUS_TOKENS' %}bg-success
                    {% endif %}">
                    {{ reward.type|replace({'_': ' '}) }}
                </span>
                {% if reward.isActive %}
                    <span class="badge bg-success">Active</span>
                {% else %}
                    <span class="badge bg-secondary">Inactive</span>
                {% endif %}
            </div>

            {# Reward Details Card #}
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Reward Details</h5>
                </div>
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <strong>Icon/Image:</strong>
                        </div>
                        <div class="col-md-9">
                            {% if reward.icon %}
                                <div class="mb-2">
                                    <img src="{{ asset('uploads/rewards/' ~ reward.icon) }}" 
                                         alt="{{ reward.name }}" 
                                         style="max-width: 150px; max-height: 150px; object-fit: contain;"
                                         class="border rounded p-2 bg-light">
                                </div>
                                <div class="text-muted">
                                    <i class="bi bi-file-image me-1"></i>
                                    <strong>Filename:</strong> {{ reward.icon }}
                                </div>
                            {% else %}
                                <div class="d-flex align-items-center">
                                    {% if reward.type == 'BADGE' %}
                                        <i class="bi bi-award-fill text-warning me-3" style="font-size: 3rem;"></i>
                                    {% elseif reward.type == 'ACHIEVEMENT' %}
                                        <i class="bi bi-trophy-fill text-success me-3" style="font-size: 3rem;"></i>
                                    {% elseif reward.type == 'BONUS_XP' %}
                                        <i class="bi bi-star-fill text-info me-3" style="font-size: 3rem;"></i>
                                    {% elseif reward.type == 'BONUS_TOKENS' %}
                                        <i class="bi bi-coin text-warning me-3" style="font-size: 3rem;"></i>
                                    {% else %}
                                        <i class="bi bi-award text-muted me-3" style="font-size: 3rem;"></i>
                                    {% endif %}
                                    <span class="text-muted">No image uploaded (using default icon)</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <strong>Description:</strong>
                        </div>
                        <div class="col-md-9">
                            {{ reward.description ?? 'No description provided' }}
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <strong>Type:</strong>
                        </div>
                        <div class="col-md-9">
                            {{ reward.type|replace({'_': ' '}) }}
                        </div>
                    </div>

                    {% if reward.type in ['BONUS_XP', 'BONUS_TOKENS'] %}
                    <div class="row mb-3">
                        <div class="col-md-3">
                            <strong>Value:</strong>
                        </div>
                        <div class="col-md-9">
                            {% if reward.type == 'BONUS_XP' %}
                                <span class="text-info fw-bold">+{{ reward.value }} XP</span>
                            {% else %}
                                <span class="text-success fw-bold">+{{ reward.value }} Tokens</span>
                            {% endif %}
                        </div>
                    </div>
                    {% endif %}

                    <div class="row mb-3">
                        <div class="col-md-3">
                            <strong>Requirement:</strong>
                        </div>
                        <div class="col-md-9">
                            {{ reward.requirement ?? 'No requirement specified' }}
                        </div>
                    </div>
                </div>
            </div>

            {# Associated Games Section - Only Full Games #}
            {% set fullGames = reward.games|filter(g => g.category == 'FULL_GAME') %}
            <div class="card mb-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-controller me-2"></i>Games Offering This Reward
                    </h5>
                    <span class="badge bg-light text-dark">{{ fullGames|length }} game(s)</span>
                </div>
                <div class="card-body">
                    {% if fullGames is not empty %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Game Name</th>
                                        <th>Type</th>
                                        <th>Difficulty</th>
                                        <th>Cost</th>
                                        <th>Base Rewards</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for game in fullGames %}
                                        <tr>
                                            <td>{{ game.id }}</td>
                                            <td><strong>{{ game.name }}</strong></td>
                                            <td><span class="badge bg-info">{{ game.type }}</span></td>
                                            <td>
                                                <span class="badge bg-{{ game.difficulty == 'EASY' ? 'success' : (game.difficulty == 'MEDIUM' ? 'warning' : 'danger') }}">
                                                    {{ game.difficulty }}
                                                </span>
                                            </td>
                                            <td>{{ game.tokenCost }} <i class="bi bi-coin text-warning"></i></td>
                                            <td>
                                                <small class="text-muted">
                                                    {{ game.rewardTokens }}T / {{ game.rewardXP }}XP
                                                </small>
                                            </td>
                                            <td>
                                                {% if game.isActive %}
                                                    <span class="badge bg-success">Active</span>
                                                {% else %}
                                                    <span class="badge bg-secondary">Inactive</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <a href="{{ path('admin_game_show', {id: game.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary" 
                                                   title="View Game">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% else %}
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            This reward is not currently offered by any full game. To associate it with games, edit the game and add this reward. Note: Mini games cannot offer rewards.
                        </div>
                    {% endif %}
                </div>
            </div>

            {# Students Who Earned This Reward #}
            <div class="card mb-4">
                <div class="card-header bg-warning d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">
                        <i class="bi bi-people-fill me-2"></i>Students Who Earned This
                    </h5>
                    <span class="badge bg-dark">{{ reward.students|length }} student(s)</span>
                </div>
                <div class="card-body">
                    {% if students.getTotalItemCount > 0 %}
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Student Name</th>
                                        <th>Email</th>
                                        <th>Level</th>
                                        <th>Total XP</th>
                                        <th>Total Tokens</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for student in students %}
                                        <tr>
                                            <td>{{ student.id }}</td>
                                            <td>
                                                <strong>{{ student.firstName }} {{ student.lastName }}</strong>
                                            </td>
                                            <td>
                                                <small class="text-muted">{{ student.email }}</small>
                                            </td>
                                            <td>
                                                <span class="badge bg-primary">Level {{ student.level }}</span>
                                            </td>
                                            <td>
                                                <i class="bi bi-star-fill text-warning"></i> {{ student.totalXP }}
                                            </td>
                                            <td>
                                                <i class="bi bi-coin text-warning"></i> {{ student.totalTokens }}
                                            </td>
                                            <td>
                                                <a href="{{ path('app_admin_students_show', {id: student.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary" 
                                                   title="View Student Profile">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        {% if students.getTotalItemCount > 10 %}
                            <div class="mt-3">
                                {{ knp_pagination_render(students, 'pagination/custom_pagination.html.twig') }}
                            </div>
                        {% endif %}
                    {% else %}
                        <div class="alert alert-info mb-0">
                            <i class="bi bi-info-circle me-2"></i>
                            No students have earned this reward yet.
                        </div>
                    {% endif %}
                </div>
            </div>

            <div class="d-flex gap-2">
                <a href="{{ path('admin_reward_index') }}" class="btn btn-lg btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Rewards
                </a>
                <a href="{{ path('admin_reward_edit', {id: reward.id}) }}" class="btn btn-lg btn-warning">
                    <i class="bi bi-pencil"></i> Edit Reward
                </a>
            </div>
        </div>

        {# Sidebar #}
        <div class="col-md-4">
            <div class="card sticky-top" style="top: 20px;">
                <div class="card-header bg-light text-center">
                    <h6 class="mb-0">Reward Preview</h6>
                </div>
                <div class="card-body text-center">
                    <div class="mb-3">
                        {% if reward.icon %}
                            <img src="{{ asset('uploads/rewards/' ~ reward.icon) }}" 
                                 alt="{{ reward.name }}" 
                                 style="max-width: 150px; max-height: 150px; object-fit: contain;"
                                 class="mb-2">
                            <div class="text-muted small">
                                <i class="bi bi-file-image me-1"></i>{{ reward.icon }}
                            </div>
                        {% else %}
                            {% if reward.type == 'BADGE' %}
                                <i class="bi bi-award-fill text-warning" style="font-size: 5rem;"></i>
                            {% elseif reward.type == 'ACHIEVEMENT' %}
                                <i class="bi bi-trophy-fill text-success" style="font-size: 5rem;"></i>
                            {% elseif reward.type == 'BONUS_XP' %}
                                <i class="bi bi-star-fill text-info" style="font-size: 5rem;"></i>
                            {% elseif reward.type == 'BONUS_TOKENS' %}
                                <i class="bi bi-coin text-warning" style="font-size: 5rem;"></i>
                            {% else %}
                                <i class="bi bi-award text-muted" style="font-size: 5rem;"></i>
                            {% endif %}
                            <div class="text-muted small mt-2">Default icon</div>
                        {% endif %}
                    </div>
                    <h4>{{ reward.name }}</h4>
                    <p class="text-muted">{{ reward.description }}</p>
                    <div class="mt-3">
                        <span class="badge 
                            {% if reward.type == 'BADGE' %}bg-primary
                            {% elseif reward.type == 'ACHIEVEMENT' %}bg-warning
                            {% elseif reward.type == 'BONUS_XP' %}bg-info
                            {% elseif reward.type == 'BONUS_TOKENS' %}bg-success
                            {% endif %}">
                            {{ reward.type|replace({'_': ' '}) }}
                        </span>
                    </div>
                    {% if reward.type in ['BONUS_XP', 'BONUS_TOKENS'] %}
                        <div class="mt-3">
                            <h5 class="mb-0">
                                {% if reward.type == 'BONUS_XP' %}
                                    <span class="text-info">+{{ reward.value }} XP</span>
                                {% else %}
                                    <span class="text-success">+{{ reward.value }} Tokens</span>
                                {% endif %}
                            </h5>
                        </div>
                    {% endif %}
                </div>
                <div class="card-footer">
                    <div class="d-grid gap-2">
                        <a href="{{ path('front_reward_browse') }}" 
                           class="btn btn-sm btn-outline-primary" 
                           target="_blank">
                            <i class="bi bi-box-arrow-up-right me-1"></i>View on Frontend
                        </a>
                    </div>
                </div>
            </div>

            {% set fullGamesForStats = reward.games|filter(g => g.category == 'FULL_GAME') %}
            <div class="card mt-3">
                <div class="card-header bg-info text-white">
                    <h6 class="mb-0">Quick Stats</h6>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <small class="text-muted d-block">Associated Games</small>
                        <h4>{{ fullGamesForStats|length }}</h4>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block">Active Games</small>
                        <h4>{{ fullGamesForStats|filter(g => g.isActive)|length }}</h4>
                    </div>
                    <div>
                        <small class="text-muted d-block">Students Earned</small>
                        <h4>{{ students.getTotalItemCount }}</h4>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}