{% extends 'admin/base.html.twig' %}

{% block title %}Edit Level Milestone{% endblock %}

{% block admin_content %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="card">
            <div class="card-header">
                <h3><i class="bi bi-pencil me-2"></i>Edit Level Milestone</h3>
            </div>
            <div class="card-body">
                {{ form_start(form, {
                    'attr': {
                        'novalidate': 'novalidate',
                        'enctype': 'multipart/form-data'
                    }
                }) }}
                    <div class="mb-3">
                        {{ form_row(form.name) }}
                    </div>
                    <div class="mb-3">
                        {{ form_row(form.description) }}
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.requiredLevel) }}
                        </div>
                        <div class="col-md-6 mb-3">
                            {{ form_row(form.value) }}
                        </div>
                    </div>
                    <div class="mb-3">
                        {{ form_label(form.icon, 'Icon/Image Upload') }}
                        
                        {% if milestone.icon %}
                            <div class="alert alert-info mb-2">
                                <i class="bi bi-image me-2"></i>
                                <strong>Current file:</strong> {{ milestone.icon }}
                            </div>
                            <div class="mb-2">
                                <img src="{{ asset('uploads/rewards/' ~ milestone.icon) }}" 
                                     alt="Current icon" 
                                     style="max-width: 120px; max-height: 120px; object-fit: contain;" 
                                     class="border rounded p-2 bg-light">
                            </div>
                        {% endif %}
                        
                        <div class="custom-file-upload">
                            {{ form_widget(form.icon, {'attr': {'class': 'form-control', 'id': 'iconFileInput'}}) }}
                            {% if not milestone.icon %}
                                <small class="form-text text-muted d-block mt-1">
                                    <i class="bi bi-info-circle me-1"></i>No icon uploaded yet. Upload an image file.
                                </small>
                            {% else %}
                                <small class="form-text text-muted d-block mt-1">
                                    <i class="bi bi-info-circle me-1"></i>Upload a new file to replace the current icon, or leave empty to keep it.
                                </small>
                            {% endif %}
                        </div>
                        {{ form_errors(form.icon) }}
                    </div>
                    
                    <script>
                        // Show selected filename when user chooses a new file
                        document.getElementById('iconFileInput').addEventListener('change', function(e) {
                            const fileName = e.target.files[0]?.name;
                            if (fileName) {
                                const fileInfo = document.createElement('div');
                                fileInfo.className = 'alert alert-success mt-2';
                                fileInfo.innerHTML = '<i class="bi bi-check-circle me-2"></i><strong>New file selected:</strong> ' + fileName;
                                
                                // Remove any existing new file alert
                                const existingAlert = e.target.parentElement.querySelector('.alert-success');
                                if (existingAlert) {
                                    existingAlert.remove();
                                }
                                
                                e.target.parentElement.appendChild(fileInfo);
                            }
                        });
                    </script>
                    <div class="mb-3">
                        <div class="form-check">
                            {{ form_widget(form.isActive) }}
                            {{ form_label(form.isActive) }}
                        </div>
                        <small class="form-text text-muted">{{ form_help(form.isActive) }}</small>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <a href="{{ path('admin_level_milestone_index') }}" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Update Milestone
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
