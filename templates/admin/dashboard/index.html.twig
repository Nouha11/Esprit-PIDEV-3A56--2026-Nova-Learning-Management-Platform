{% block stylesheets %}
{{ parent() }}
<style>
    .hover-lift {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }
    
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    
    .avatar-circle {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 1.2rem;
    }
    
    .card {
        transition: all 0.3s ease;
    }
    
    .summary-stat-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    
    .summary-stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15) !important;
    }
    
    /* Dark mode support */
    [data-bs-theme="dark"] .card {
        background-color: #1a1d20;
        border-color: #2b3035;
    }
    
    [data-bs-theme="dark"] .card-header {
        background-color: #2b3035 !important;
        border-color: #3a3f44;
    }
    
    [data-bs-theme="dark"] .text-gray-800 {
        color: #e9ecef !important;
    }
    
    [data-bs-theme="dark"] .bg-white {
        background-color: #1a1d20 !important;
    }
    
    [data-bs-theme="dark"] .list-group-item {
        background-color: transparent;
        border-color: #2b3035;
    }
    
    [data-bs-theme="dark"] .summary-stat-card {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
    }
    
    [data-bs-theme="dark"] .summary-stat-card:hover {
        box-shadow: 0 8px 20px rgba(255,255,255,0.1) !important;
    }
</style>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="text/javascript" src="https://www.gstatic.com/charts/loader.js"></script>
<script>
    // Load Google Charts
    google.charts.load('current', {'packages':['corechart', 'bar']});
    google.charts.setOnLoadCallback(loadDashboardStats);

    function isDarkMode() {
        return document.documentElement.getAttribute('data-bs-theme') === 'dark';
    }

    function getChartColors() {
        const dark = isDarkMode();
        return {
            backgroundColor: dark ? '#1a1d20' : '#ffffff',
            textColor: dark ? '#e9ecef' : '#212529',
            gridColor: dark ? '#495057' : '#e9ecef',
            primaryColor: '#667eea',
            colors: ['#667eea', '#764ba2', '#f093fb', '#4facfe', '#43e97b', '#fa709a']
        };
    }

    function loadDashboardStats() {
        // Load learning statistics
        loadLearningStats();
        
        // Load games summary statistics
        fetch('{{ path('admin_statistics_summary') }}')
            .then(response => response.json())
            .then(data => {
                document.getElementById('statsStudents').textContent = data.totalStudents.toLocaleString();
                document.getElementById('statsGames').textContent = data.totalGames.toLocaleString();
                document.getElementById('statsRewards').textContent = data.totalRewards.toLocaleString();
                document.getElementById('statsXP').textContent = data.totalXP.toLocaleString();
                document.getElementById('statsTokens').textContent = data.totalTokens.toLocaleString();
                document.getElementById('statsAvgRating').textContent = data.avgRating.toFixed(1);
            })
            .catch(error => console.error('Error loading summary:', error));

        // Load Top Users Chart
        loadTopUsersChart();
        
        // Load Game Types Chart
        loadGameTypesChart();
        
        // Load Recent Activities
        loadRecentActivities();

        // Listen for theme changes
        const observer = new MutationObserver(function(mutations) {
            mutations.forEach(function(mutation) {
                if (mutation.attributeName === 'data-bs-theme') {
                    loadTopUsersChart();
                    loadGameTypesChart();
                }
            });
        });

        observer.observe(document.documentElement, {
            attributes: true,
            attributeFilter: ['data-bs-theme']
        });
    }

    function loadLearningStats() {
        // Fetch learning statistics from API
        fetch('{{ path('admin_api_learning_stats') }}')
            .then(response => response.json())
            .then(data => {
                document.getElementById('statsCourses').textContent = data.totalCourses.toLocaleString();
                document.getElementById('statsPlanningSessions').textContent = data.totalPlanningSessions.toLocaleString();
                document.getElementById('statsStudySessions').textContent = data.totalStudySessions.toLocaleString();
                document.getElementById('statsEnrollments').textContent = data.totalEnrollments.toLocaleString();
            })
            .catch(error => {
                console.error('Error loading learning stats:', error);
                document.getElementById('statsCourses').textContent = '0';
                document.getElementById('statsPlanningSessions').textContent = '0';
                document.getElementById('statsStudySessions').textContent = '0';
                document.getElementById('statsEnrollments').textContent = '0';
            });
    }

    function loadRecentActivities() {
        // Simulate recent activities - in production, this would fetch from an API
        const activities = [
            {
                icon: 'bi-person-plus-fill',
                color: 'success',
                title: 'New User Registration',
                description: 'A new user has joined the platform',
                time: '5 minutes ago'
            },
            {
                icon: 'bi-trophy-fill',
                color: 'warning',
                title: 'Reward Claimed',
                description: 'Student earned "Quiz Master" badge',
                time: '15 minutes ago'
            },
            {
                icon: 'bi-controller',
                color: 'danger',
                title: 'Game Completed',
                description: 'Student completed "Math Challenge" game',
                time: '30 minutes ago'
            },
            {
                icon: 'bi-book-fill',
                color: 'primary',
                title: 'Course Enrollment',
                description: 'New enrollment in "Introduction to PHP"',
                time: '1 hour ago'
            },
            {
                icon: 'bi-patch-question-fill',
                color: 'info',
                title: 'Quiz Submitted',
                description: 'Student completed "JavaScript Basics" quiz',
                time: '2 hours ago'
            }
        ];

        const container = document.getElementById('recentActivitiesContainer');
        let html = '<div class="list-group list-group-flush">';
        
        activities.forEach((activity, index) => {
            html += `
                <div class="list-group-item px-0 ${index !== activities.length - 1 ? 'border-bottom' : 'border-0'}">
                    <div class="d-flex align-items-start">
                        <div class="bg-${activity.color} bg-opacity-10 rounded-3 p-3 me-3">
                            <i class="bi ${activity.icon} text-${activity.color}" style="font-size: 1.5rem;"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <h6 class="mb-1 fw-semibold">${activity.title}</h6>
                                    <p class="text-muted mb-0 small">${activity.description}</p>
                                </div>
                                <small class="text-muted">${activity.time}</small>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        });
        
        html += '</div>';
        container.innerHTML = html;
    }

    function loadTopUsersChart() {
        fetch('{{ path('admin_statistics_top_users_xp') }}')
            .then(response => response.json())
            .then(data => {
                const chartData = google.visualization.arrayToDataTable(data);
                const colors = getChartColors();

                const options = {
                    chartArea: {width: '70%', height: '80%'},
                    colors: [colors.primaryColor],
                    hAxis: {
                        title: 'Total XP',
                        minValue: 0,
                        textStyle: { color: colors.textColor },
                        titleTextStyle: { color: colors.textColor },
                        gridlines: { color: colors.gridColor }
                    },
                    vAxis: {
                        textStyle: { color: colors.textColor }
                    },
                    legend: { position: 'none' },
                    backgroundColor: colors.backgroundColor,
                    titleTextStyle: { color: colors.textColor }
                };

                const chart = new google.visualization.BarChart(document.getElementById('dashboardTopUsersChart'));
                chart.draw(chartData, options);
            })
            .catch(error => {
                console.error('Error loading top users chart:', error);
                document.getElementById('dashboardTopUsersChart').innerHTML = 
                    '<div class="alert alert-warning m-3">Error loading chart data</div>';
            });
    }

    function loadGameTypesChart() {
        fetch('{{ path('admin_statistics_game_types') }}')
            .then(response => response.json())
            .then(data => {
                const chartData = google.visualization.arrayToDataTable(data);
                const colors = getChartColors();

                const options = {
                    pieHole: 0.4,
                    colors: colors.colors,
                    legend: { 
                        position: 'bottom',
                        textStyle: { color: colors.textColor }
                    },
                    backgroundColor: colors.backgroundColor,
                    chartArea: {width: '90%', height: '75%'},
                    pieSliceTextStyle: { color: colors.textColor }
                };

                const chart = new google.visualization.PieChart(document.getElementById('dashboardGameTypesChart'));
                chart.draw(chartData, options);
            })
            .catch(error => {
                console.error('Error loading game types chart:', error);
                document.getElementById('dashboardGameTypesChart').innerHTML = 
                    '<div class="alert alert-warning m-3">Error loading chart data</div>';
            });
    }

    // Responsive charts - redraw on window resize
    window.addEventListener('resize', function() {
        if (typeof google !== 'undefined' && google.visualization) {
            loadTopUsersChart();
            loadGameTypesChart();
        }
    });
</script>
{% endblock %}
