            </div>
            <a href="{{ path('admin_statistics_dashboard') }}" class="btn btn-primary btn-lg">
                <i class="bi bi-bar-chart-line-fill me-2"></i>View Full Statistics Dashboard
            </a>
        </div>
    </div>
    
    {# Summary Stats Cards #}
    <div class="col-md-2 mb-4">
