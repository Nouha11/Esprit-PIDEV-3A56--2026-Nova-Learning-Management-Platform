        </div>
    </div>
    
    <div class="col-md-3 mb-4">
        <div class="card text-center summary-stat-card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-calendar-check-fill text-info" style="font-size: 2.5rem;"></i>
                <h3 class="mt-3 mb-1 fw-bold" id="statsPlanningSessions">-</h3>
                <p class="text-muted small mb-0">Planning Sessions</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 mb-4">
        <div class="card text-center summary-stat-card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-journal-check text-primary" style="font-size: 2.5rem;"></i>
                <h3 class="mt-3 mb-1 fw-bold" id="statsStudySessions">-</h3>
                <p class="text-muted small mb-0">Completed Sessions</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-3 mb-4">
        <div class="card text-center summary-stat-card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <i class="bi bi-people-fill text-warning" style="font-size: 2.5rem;"></i>
                <h3 class="mt-3 mb-1 fw-bold" id="statsEnrollments">-</h3>
                <p class="text-muted small mb-0">Total Enrollments</p>
            </div>
