{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard - NOVA Admin{% endblock %}

{% block admin_content %}
<div class="d-sm-flex align-items-center justify-content-between mb-5">
    <div>
        <h1 class="h3 mb-1 text-gray-800">
            <i class="bi bi-speedometer2 me-2"></i>Admin Dashboard
        </h1>
        <p class="text-muted mb-0">Welcome back! Here's what's happening with your platform.</p>
    </div>
    <div>
        <span class="badge bg-primary fs-6 px-3 py-2">
            <i class="bi bi-calendar3 me-1"></i>{{ "now"|date("F d, Y") }}
        </span>
    </div>
</div>

{# Statistics Cards #}
<div class="row g-4 mb-5">
    <div class="col-xl-3 col-md-6">
        <div class="card border-start border-primary border-4 shadow-sm h-100 hover-lift">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase text-primary fw-bold small mb-2">
                            <i class="bi bi-people-fill me-1"></i>Total Users
                        </div>
                        <div class="h2 mb-0 fw-bold">{{ totalUsers }}</div>
                    </div>
                    <div class="text-primary opacity-25">
                        <i class="bi bi-people-fill" style="font-size: 3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-start border-success border-4 shadow-sm h-100 hover-lift">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase text-success fw-bold small mb-2">
                            <i class="bi bi-mortarboard-fill me-1"></i>Students
                        </div>
                        <div class="h2 mb-0 fw-bold">{{ totalStudents }}</div>
                    </div>
                    <div class="text-success opacity-25">
                        <i class="bi bi-mortarboard-fill" style="font-size: 3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-start border-info border-4 shadow-sm h-100 hover-lift">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase text-info fw-bold small mb-2">
                            <i class="bi bi-person-video3 me-1"></i>Tutors
                        </div>
                        <div class="h2 mb-0 fw-bold">{{ totalTutors }}</div>
                    </div>
                    <div class="text-info opacity-25">
                        <i class="bi bi-person-video3" style="font-size: 3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-start border-warning border-4 shadow-sm h-100 hover-lift">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <div class="text-uppercase text-warning fw-bold small mb-2">
                            <i class="bi bi-shield-fill-check me-1"></i>Admins
                        </div>
                        <div class="h2 mb-0 fw-bold">{{ adminCount }}</div>
                    </div>
                    <div class="text-warning opacity-25">
                        <i class="bi bi-shield-fill-check" style="font-size: 3rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# User Distribution and Recent Users #}
<div class="row g-4 mb-5">
    <div class="col-xl-6 col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold text-primary">
                    <i class="bi bi-pie-chart-fill me-2"></i>User Role Distribution
                </h5>
            </div>
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold">
                            <i class="bi bi-mortarboard-fill text-success me-2"></i>Students
                        </span>
                        <span class="badge bg-success">{{ studentCount }}</span>
                    </div>
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar bg-success" role="progressbar" 
                             style="width: {{ totalUsers > 0 ? (studentCount / totalUsers * 100) : 0 }}%"
                             aria-valuenow="{{ studentCount }}" aria-valuemin="0" aria-valuemax="{{ totalUsers }}">
                            {{ totalUsers > 0 ? ((studentCount / totalUsers * 100)|round) : 0 }}%
                        </div>
                    </div>
                </div>
                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold">
                            <i class="bi bi-person-video3 text-info me-2"></i>Tutors
                        </span>
                        <span class="badge bg-info">{{ tutorCount }}</span>
                    </div>
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar bg-info" role="progressbar" 
                             style="width: {{ totalUsers > 0 ? (tutorCount / totalUsers * 100) : 0 }}%"
                             aria-valuenow="{{ tutorCount }}" aria-valuemin="0" aria-valuemax="{{ totalUsers }}">
                            {{ totalUsers > 0 ? ((tutorCount / totalUsers * 100)|round) : 0 }}%
                        </div>
                    </div>
                </div>
                <div>
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-semibold">
                            <i class="bi bi-shield-fill-check text-warning me-2"></i>Admins
                        </span>
                        <span class="badge bg-warning">{{ adminCount }}</span>
                    </div>
                    <div class="progress" style="height: 12px;">
                        <div class="progress-bar bg-warning" role="progressbar" 
                             style="width: {{ totalUsers > 0 ? (adminCount / totalUsers * 100) : 0 }}%"
                             aria-valuenow="{{ adminCount }}" aria-valuemin="0" aria-valuemax="{{ totalUsers }}">
                            {{ totalUsers > 0 ? ((adminCount / totalUsers * 100)|round) : 0 }}%
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-6 col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold text-primary">
                    <i class="bi bi-clock-history me-2"></i>Recent Users
                </h5>
            </div>
            <div class="card-body p-4">
                {% if recentUsers is empty %}
                    <div class="text-center py-4">
                        <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                        <p class="text-muted mt-2 mb-0">No users yet</p>
                    </div>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for user in recentUsers %}
                            <div class="list-group-item px-0 border-0 {% if not loop.last %}border-bottom{% endif %}">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <div class="avatar-circle bg-primary bg-opacity-10 text-primary me-3">
                                            <i class="bi bi-person-fill"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0 fw-semibold">{{ user.getUsername() }}</h6>
                                            <small class="text-muted">
                                                <i class="bi bi-envelope me-1"></i>{{ user.getEmail() }}
                                            </small>
                                        </div>
                                    </div>
                                    <div>
                                        {% if user.getRole() == 'ROLE_ADMIN' %}
                                            <span class="badge bg-warning">
                                                <i class="bi bi-shield-fill-check me-1"></i>Admin
                                            </span>
                                        {% elseif user.getRole() == 'ROLE_STUDENT' %}
                                            <span class="badge bg-success">
                                                <i class="bi bi-mortarboard-fill me-1"></i>Student
                                            </span>
                                        {% elseif user.getRole() == 'ROLE_TUTOR' %}
                                            <span class="badge bg-info">
                                                <i class="bi bi-person-video3 me-1"></i>Tutor
                                            </span>
                                        {% else %}
                                            <span class="badge bg-secondary">User</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{# Recent Activities Section #}
<div class="row mb-5">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white py-3 border-bottom">
                <h5 class="mb-0 fw-bold text-primary">
                    <i class="bi bi-activity me-2"></i>Recent Activities
                </h5>
            </div>
            <div class="card-body p-4">
                <div id="recentActivitiesContainer">
                    <div class="text-center py-4">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Security Alert #}
<div class="row mb-5">
    <div class="col-12">
        <div class="card shadow-sm border-start border-{{ app.user.totpEnabled ? 'success' : 'warning' }} border-4">
            <div class="card-body p-4">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        {% if app.user.totpEnabled %}
                            <div class="d-flex align-items-center">
                                <div class="text-success me-3" style="font-size: 2.5rem;">
                                    <i class="bi bi-shield-fill-check"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold">
                                        <i class="bi bi-check-circle-fill text-success me-2"></i>
                                        Two-Factor Authentication is Enabled
                                    </h5>
                                    <p class="text-muted mb-0">Your admin account is protected with an additional layer of security.</p>
                                </div>
                            </div>
                        {% else %}
                            <div class="d-flex align-items-center">
                                <div class="text-warning me-3" style="font-size: 2.5rem;">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                </div>
                                <div>
                                    <h5 class="mb-1 fw-bold">
                                        <i class="bi bi-exclamation-circle-fill text-warning me-2"></i>
                                        Two-Factor Authentication is Not Enabled
                                    </h5>
                                    <p class="text-muted mb-0">Protect your admin account by enabling 2FA. This adds an extra layer of security to prevent unauthorized access.</p>
                                </div>
                            </div>
                        {% endif %}
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <a href="{{ path('app_2fa_manage') }}" class="btn btn-{{ app.user.totpEnabled ? 'outline-success' : 'warning' }} btn-lg px-4">
                            <i class="bi bi-shield-{{ app.user.totpEnabled ? 'check' : 'plus' }} me-2"></i>
                            {{ app.user.totpEnabled ? 'Manage 2FA' : 'Enable 2FA Now' }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Course & Study Session Statistics Section #}
<div class="row mb-5">
    <div class="col-12 mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h4 class="fw-bold mb-1">
                    <i class="bi bi-book-fill text-success me-2"></i>Learning Statistics
                </h4>
                <p class="text-muted mb-0">Course and session metrics</p>
            </div>
            <a href="{{ path('admin_study_session_analytics') }}" class="btn btn-success btn-lg">
                <i class="bi bi-graph-up-arrow me-2"></i>View Session Analytics
