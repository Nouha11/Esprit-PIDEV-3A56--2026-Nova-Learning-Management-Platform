{% extends 'admin/base.html.twig' %}

{% block title %}Planning Details{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Planning Session Details</h1>
        <div>
            <a href="{{ path('admin_planning_edit_status', {id: planning.id}) }}" class="btn btn-warning">
                <i class="fas fa-edit"></i> Edit Status
            </a>
            <a href="{{ path('admin_planning_index') }}" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to List
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Planning Information</h6>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th width="200">Title:</th>
                            <td>{{ planning.title }}</td>
                        </tr>
                        <tr>
                            <th>Course:</th>
                            <td>{{ planning.course.courseName }}</td>
                        </tr>
                        <tr>
                            <th>Scheduled Date:</th>
                            <td>{{ planning.scheduledDate|date('Y-m-d') }}</td>
                        </tr>
                        <tr>
                            <th>Scheduled Time:</th>
                            <td>{{ planning.scheduledTime|date('H:i') }}</td>
                        </tr>
                        <tr>
                            <th>Planned Duration:</th>
                            <td>{{ planning.plannedDuration }} minutes</td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                {% if planning.status == 'COMPLETED' %}
                                    <span class="badge bg-success">Completed</span>
                                {% elseif planning.status == 'SCHEDULED' %}
                                    <span class="badge bg-primary">Scheduled</span>
                                {% elseif planning.status == 'MISSED' %}
                                    <span class="badge bg-danger">Missed</span>
                                {% else %}
                                    <span class="badge bg-secondary">Cancelled</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Reminder:</th>
                            <td>
                                {% if planning.isReminder %}
                                    <span class="badge bg-success">Enabled</span>
                                {% else %}
                                    <span class="badge bg-secondary">Disabled</span>
                                {% endif %}
                            </td>
                        </tr>
                        <tr>
                            <th>Created At:</th>
                            <td>{{ planning.createdAt|date('Y-m-d H:i:s') }}</td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Study Sessions</h6>
                </div>
                <div class="card-body">
                    {% if planning.studySessions|length > 0 %}
                        <ul class="list-group">
                            {% for session in planning.studySessions %}
                                <li class="list-group-item">
                                    <div><strong>Duration:</strong> {{ session.duration }} min</div>
                                    <div><strong>XP Earned:</strong> {{ session.xpEarned }}</div>
                                    <div><strong>Burnout Risk:</strong> 
                                        <span class="badge bg-{{ session.burnoutRisk == 'HIGH' ? 'danger' : (session.burnoutRisk == 'MODERATE' ? 'warning' : 'success') }}">
                                            {{ session.burnoutRisk }}
                                        </span>
                                    </div>
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted">No study sessions yet.</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
