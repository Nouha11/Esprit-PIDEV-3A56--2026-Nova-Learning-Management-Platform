{% extends 'admin/base.html.twig' %}

{% block title %}Edit Planning Status{% endblock %}

{% block admin_content %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Edit Planning Status: {{ planning.title }}</h1>
    </div>

    <div class="card shadow mb-4">
        <div class="card-body">
            {{ form_start(form, 
                        {'attr': {'novalidate': 'novalidate'}}) }}
                <div class="row">
                    <div class="col-md-12">
                        {{ form_row(form.status) }}
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Update Status
                    </button>
                    <a href="{{ path('admin_planning_show', {id: planning.id}) }}" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Current Planning Information</h6>
        </div>
        <div class="card-body">
            <table class="table table-borderless">
                <tr>
                    <th width="200">Title:</th>
                    <td>{{ planning.title }}</td>
                </tr>
                <tr>
                    <th>Course:</th>
                    <td>{{ planning.course.courseName }}</td>
                </tr>
                <tr>
                    <th>Scheduled Date:</th>
                    <td>{{ planning.scheduledDate|date('Y-m-d') }}</td>
                </tr>
                <tr>
                    <th>Current Status:</th>
                    <td>
                        {% if planning.status == 'COMPLETED' %}
                            <span class="badge bg-success">Completed</span>
                        {% elseif planning.status == 'SCHEDULED' %}
                            <span class="badge bg-primary">Scheduled</span>
                        {% elseif planning.status == 'MISSED' %}
                            <span class="badge bg-danger">Missed</span>
                        {% else %}
                            <span class="badge bg-secondary">Cancelled</span>
                        {% endif %}
                    </td>
                </tr>
            </table>
        </div>
    </div>
{% endblock %}
