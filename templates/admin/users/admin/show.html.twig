{% extends 'admin/base.html.twig' %}

{% block title %}User Details - {{ user.username }} - Admin{% endblock %}

{% block admin_content %}

<!-- Title -->
<div class="row mb-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-2">User Details</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="{{ path('app_admin_dashboard') }}">Dashboard</a></li>
                        <li class="breadcrumb-item"><a href="{{ path('app_admin_users_list') }}">Users</a></li>
                        <li class="breadcrumb-item active">{{ user.username }}</li>
                    </ol>
                </nav>
            </div>
            <div>
                <a href="{{ path('app_admin_users_list') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-2"></i>Back to List
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Left Column -->
    <div class="col-lg-4">
        <!-- User Profile Card -->
        <div class="card border">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0">Profile Information</h5>
            </div>
            <div class="card-body text-center">
                <div class="avatar avatar-xxl mb-3">
                    {% if user.role == 'ROLE_STUDENT' and user.studentProfile and user.studentProfile.profilePicture %}
                        <img class="avatar-img rounded-circle border border-3" src="{{ vich_uploader_asset(user.studentProfile, 'avatarFile') }}" alt="{{ user.username }}">
                    {% elseif user.role == 'ROLE_TUTOR' and user.tutorProfile and user.tutorProfile.profilePicture %}
                        <img class="avatar-img rounded-circle border border-3" src="{{ vich_uploader_asset(user.tutorProfile, 'avatarFile') }}" alt="{{ user.username }}">
                    {% else %}
                        <img class="avatar-img rounded-circle border border-3" src="{{ asset('assets/images/avatar/01.jpg') }}" alt="{{ user.username }}">
                    {% endif %}
                </div>
                <h4 class="mb-1">{{ user.username }}</h4>
                <p class="text-muted mb-3">{{ user.email }}</p>
                
                <!-- Status Badges -->
                <div class="mb-3">
                    {% if user.isActive %}
                        <span class="badge bg-success-soft text-success">
                            <i class="bi bi-check-circle me-1"></i>Active
                        </span>
                    {% else %}
                        <span class="badge bg-danger-soft text-danger">
                            <i class="bi bi-x-circle me-1"></i>Inactive
                        </span>
                    {% endif %}
                    
                    {% if user.isVerified %}
                        <span class="badge bg-info-soft text-info">
                            <i class="bi bi-patch-check me-1"></i>Verified
                        </span>
                    {% else %}
                        <span class="badge bg-warning-soft text-warning">
                            <i class="bi bi-exclamation-triangle me-1"></i>Unverified
                        </span>
                    {% endif %}
                    
                    {% if user.isBanned %}
                        <span class="badge bg-danger">
                            <i class="bi bi-ban me-1"></i>Banned
                        </span>
                    {% endif %}
                    
                    {% if user.totpEnabled %}
                        <span class="badge bg-success-soft text-success">
                            <i class="bi bi-shield-check me-1"></i>2FA Enabled
                        </span>
                    {% endif %}
                </div>
                
                <!-- Role Badge -->
                <div class="mb-3">
                    {% if user.role == 'ROLE_ADMIN' %}
                        <span class="badge bg-danger fs-6">
                            <i class="bi bi-shield-fill me-1"></i>Administrator
                        </span>
                    {% elseif user.role == 'ROLE_TUTOR' %}
                        <span class="badge bg-success fs-6">
                            <i class="bi bi-person-workspace me-1"></i>Tutor
                        </span>
                    {% elseif user.role == 'ROLE_STUDENT' %}
                        <span class="badge bg-primary fs-6">
                            <i class="bi bi-mortarboard me-1"></i>Student
                        </span>
                    {% else %}
                        <span class="badge bg-secondary fs-6">
                            <i class="bi bi-person me-1"></i>{{ user.role }}
                        </span>
                    {% endif %}
                </div>
                
                <!-- Action Buttons -->
                <div class="d-grid gap-2">
                    <a href="{{ path('app_admin_users_edit', {'id': user.id}) }}" class="btn btn-primary">
                        <i class="bi bi-pencil me-2"></i>Edit User
                    </a>
                    
                    {% if user.isBanned %}
                        <form method="post" action="{{ path('app_admin_users_unban', {'id': user.id}) }}" class="d-inline">
                            <button type="submit" class="btn btn-success w-100" onclick="return confirm('Are you sure you want to unban this user?')">
                                <i class="bi bi-check-circle me-2"></i>Unban User
                            </button>
                        </form>
                    {% else %}
                        <button type="button" class="btn btn-warning" data-bs-toggle="modal" data-bs-target="#banModal">
                            <i class="bi bi-ban me-2"></i>Ban User
                        </button>
                    {% endif %}
                    
                    <form method="post" action="{{ path('app_admin_users_toggle_status', {'id': user.id}) }}" class="d-inline">
                        <button type="submit" class="btn btn-outline-{{ user.isActive ? 'danger' : 'success' }} w-100">
                            <i class="bi bi-{{ user.isActive ? 'x-circle' : 'check-circle' }} me-2"></i>
                            {{ user.isActive ? 'Deactivate' : 'Activate' }}
                        </button>
                    </form>
                    
                    <form method="post" action="{{ path('app_admin_users_delete', {'id': user.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn btn-danger w-100" onclick="return confirm('Are you sure you want to delete this user? This action cannot be undone.')">
                            <i class="bi bi-trash me-2"></i>Delete User
                        </button>
                    </form>
                </div>
            </div>
        </div>
        
        <!-- Account Details Card -->
        <div class="card border mt-4">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0">Account Details</h5>
            </div>
            <div class="card-body">
                <ul class="list-group list-group-borderless">
                    <li class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">User ID:</span>
                            <span class="fw-bold">#{{ user.id }}</span>
                        </div>
                    </li>
                    <li class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Created:</span>
                            <span>{{ user.createdAt|date('M d, Y') }}</span>
                        </div>
                    </li>
                    <li class="list-group-item px-0 py-2">
                        <div class="d-flex justify-content-between">
                            <span class="text-muted">Last Login:</span>
                            <span>
                                {% if loginHistory is not empty %}
                                    {{ loginHistory[0].createdAt|date('M d, Y H:i') }}
                                {% else %}
                                    Never
                                {% endif %}
                            </span>
                        </div>
                    </li>
                    {% if user.isBanned %}
                        <li class="list-group-item px-0 py-2">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Banned:</span>
                                <span class="text-danger">{{ user.bannedAt|date('M d, Y') }}</span>
                            </div>
                        </li>
                        {% if user.banReason %}
                            <li class="list-group-item px-0 py-2">
                                <div>
                                    <span class="text-muted d-block mb-1">Ban Reason:</span>
                                    <span class="text-danger">{{ user.banReason }}</span>
                                </div>
                            </li>
                        {% endif %}
                    {% endif %}
                </ul>
            </div>
        </div>
    </div>
    
    <!-- Right Column -->
    <div class="col-lg-8">
        <!-- Profile Information -->
        {% if user.role == 'ROLE_STUDENT' and user.studentProfile %}
            <div class="card border mb-4">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-mortarboard me-2"></i>Student Profile
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-group list-group-borderless">
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Name:</span>
                                    <span class="fw-bold ms-2">{{ user.studentProfile.firstName }} {{ user.studentProfile.lastName }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">University:</span>
                                    <span class="ms-2">{{ user.studentProfile.university ?? 'Not set' }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Major:</span>
                                    <span class="ms-2">{{ user.studentProfile.major ?? 'Not set' }}</span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group list-group-borderless">
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Academic Level:</span>
                                    <span class="ms-2">{{ user.studentProfile.academicLevel ?? 'Not set' }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Total XP:</span>
                                    <span class="badge bg-success ms-2">{{ user.studentProfile.totalXP }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Level:</span>
                                    <span class="badge bg-primary ms-2">{{ user.studentProfile.level }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Tokens:</span>
                                    <span class="badge bg-warning ms-2">{{ user.studentProfile.totalTokens }}</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                    {% if user.studentProfile.bio %}
                        <div class="mt-3">
                            <h6 class="text-muted">Bio:</h6>
                            <p class="mb-0">{{ user.studentProfile.bio }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% elseif user.role == 'ROLE_TUTOR' and user.tutorProfile %}
            <div class="card border mb-4">
                <div class="card-header bg-light border-bottom">
                    <h5 class="mb-0">
                        <i class="bi bi-person-workspace me-2"></i>Tutor Profile
                    </h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <ul class="list-group list-group-borderless">
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Name:</span>
                                    <span class="fw-bold ms-2">{{ user.tutorProfile.firstName }} {{ user.tutorProfile.lastName }}</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Experience:</span>
                                    <span class="ms-2">{{ user.tutorProfile.yearsOfExperience }} years</span>
                                </li>
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Hourly Rate:</span>
                                    <span class="ms-2">Dt{{ user.tutorProfile.hourlyRate ?? 'Not set' }}</span>
                                </li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <ul class="list-group list-group-borderless">
                                <li class="list-group-item px-0 py-2">
                                    <span class="text-muted">Status:</span>
                                    {% if user.tutorProfile.isAvailable %}
                                        <span class="badge bg-success ms-2">Available</span>
                                    {% else %}
                                        <span class="badge bg-danger ms-2">Unavailable</span>
                                    {% endif %}
                                </li>
                            </ul>
                        </div>
                    </div>
                    {% if user.tutorProfile.expertise %}
                        <div class="mt-3">
                            <h6 class="text-muted">Expertise:</h6>
                            <div>
                                {% for skill in user.tutorProfile.expertise %}
                                    <span class="badge bg-primary-soft text-primary me-1 mb-1">{{ skill }}</span>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}
                    {% if user.tutorProfile.qualifications %}
                        <div class="mt-3">
                            <h6 class="text-muted">Qualifications:</h6>
                            <p class="mb-0">{{ user.tutorProfile.qualifications }}</p>
                        </div>
                    {% endif %}
                    {% if user.tutorProfile.bio %}
                        <div class="mt-3">
                            <h6 class="text-muted">Bio:</h6>
                            <p class="mb-0">{{ user.tutorProfile.bio }}</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
        
        <!-- Recent Activities -->
        <div class="card border mb-4">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-2"></i>Recent Activities
                </h5>
            </div>
            <div class="card-body">
                {% if recentActivities is empty %}
                    <p class="text-muted text-center py-3 mb-0">No recent activities</p>
                {% else %}
                    <div class="list-group list-group-flush">
                        {% for activity in recentActivities %}
                            <div class="list-group-item px-0 py-3">
                                <div class="d-flex align-items-start">
                                    <div class="avatar avatar-sm flex-shrink-0">
                                        <div class="avatar-img rounded-circle bg-{{ activity.color }} bg-opacity-10">
                                            <i class="{{ activity.icon }} text-{{ activity.color }} position-absolute top-50 start-50 translate-middle"></i>
                                        </div>
                                    </div>
                                    <div class="ms-3 flex-grow-1">
                                        <h6 class="mb-1">{{ activity.description }}</h6>
                                        <p class="mb-0 small text-muted">
                                            <i class="bi bi-clock me-1"></i>
                                            {{ activity.createdAt|date('M d, Y \\a\\t h:i A') }}
                                        </p>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
        
        <!-- Login History -->
        <div class="card border">
            <div class="card-header bg-light border-bottom">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-2"></i>Login History
                </h5>
            </div>
            <div class="card-body">
                {% if loginHistory is empty %}
                    <p class="text-muted text-center py-3 mb-0">No login history</p>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Status</th>
                                    <th>Date & Time</th>
                                    <th>IP Address</th>
                                    <th>Browser</th>
                                    <th>Location</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for login in loginHistory %}
                                    <tr>
                                        <td>
                                            {% if login.isSuccessful %}
                                                <span class="badge bg-success-soft text-success">
                                                    <i class="bi bi-check-circle me-1"></i>Success
                                                </span>
                                            {% else %}
                                                <span class="badge bg-danger-soft text-danger">
                                                    <i class="bi bi-x-circle me-1"></i>Failed
                                                </span>
                                            {% endif %}
                                        </td>
                                        <td>{{ login.createdAt|date('M d, Y H:i') }}</td>
                                        <td><code>{{ login.ipAddress }}</code></td>
                                        <td>{{ login.browser ?? 'Unknown' }}</td>
                                        <td>{{ login.location ?? 'Unknown' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<!-- Ban Modal -->
<div class="modal fade" id="banModal" tabindex="-1" aria-labelledby="banModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('app_admin_users_ban', {'id': user.id}) }}">
                <div class="modal-header">
                    <h5 class="modal-title" id="banModalLabel">Ban User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to ban <strong>{{ user.username }}</strong>?</p>
                    <div class="mb-3">
                        <label for="ban_reason" class="form-label">Reason for ban:</label>
                        <textarea class="form-control" id="ban_reason" name="ban_reason" rows="3" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Ban User</button>
                </div>
            </form>
        </div>
    </div>
</div>

{% endblock %}
