{% extends 'admin/base.html.twig' %}

{% block title %}User Management - Admin Dashboard{% endblock %}

{% block admin_content %}
    <!-- Title -->
    <div class="row mb-3">
        <div class="col-12 d-sm-flex justify-content-between align-items-center">
            <h1 class="h3 mb-2 mb-sm-0">User Management</h1>
            <div>
                <button type="button" class="btn btn-sm btn-warning mb-0 me-2" id="bulkActionBtn" style="display: none;">
                    <i class="bi bi-lightning-fill me-2"></i>Bulk Actions
                </button>
                <a href="{{ path('app_admin_users_new') }}" class="btn btn-sm btn-primary mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Add New User
                </a>
            </div>
        </div>
    </div>

    <!-- Bulk Actions Bar (Hidden by default) -->
    <div id="bulkActionsBar" class="alert alert-info d-none mb-3">
        <form method="post" action="{{ path('app_admin_users_bulk_action') }}" id="bulkActionForm">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <span id="selectedCount">0</span> user(s) selected
                </div>
                <div class="col-md-6 text-end">
                    <select name="bulk_action" class="form-select form-select-sm d-inline-block w-auto me-2" required>
                        <option value="">Select Action</option>
                        <option value="activate">Activate</option>
                        <option value="deactivate">Deactivate</option>
                        <option value="ban">Ban</option>
                        <option value="unban">Unban</option>
                        <option value="delete">Delete</option>
                    </select>
                    <button type="submit" class="btn btn-sm btn-primary">Apply</button>
                    <button type="button" class="btn btn-sm btn-secondary" id="cancelBulk">Cancel</button>
                </div>
            </div>
        </form>
    </div>

    <!-- Card START -->
            <div class="card bg-transparent border">
                <!-- Card header START -->
                <div class="card-header bg-light border-bottom">
                    <div class="row g-3 align-items-center justify-content-between">
                        <div class="col-md-8">
                            <form class="rounded position-relative">
                                <input class="form-control bg-body" type="search" placeholder="Search by name, email, or username" aria-label="Search">
                                <button class="bg-transparent p-2 position-absolute top-50 end-0 translate-middle-y border-0 text-primary-hover text-reset" type="submit">
                                    <i class="fas fa-search fs-6"></i>
                                </button>
                            </form>
                        </div>

                        <div class="col-md-3">
                            <form>
                                <select class="form-select js-choice border-0 z-index-9" aria-label="Filter by role">
                                    <option value="">All Roles</option>
                                    <option>Students</option>
                                    <option>Tutors</option>
                                    <option>Admins</option>
                                </select>
                            </form>
                        </div>
                    </div>
                </div>
                <!-- Card header END -->

                <!-- Card body START -->
                <div class="card-body">
                    <!-- Users table START -->
                    <div class="table-responsive border-0">
                        <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                            <!-- Table head -->
                            <thead>
                                <tr>
                                    <th scope="col" class="border-0">
                                        <input type="checkbox" id="selectAll" class="form-check-input">
                                    </th>
                                    <th scope="col" class="border-0">User</th>
                                    <th scope="col" class="border-0">Role</th>
                                    <th scope="col" class="border-0">Email</th>
                                    <th scope="col" class="border-0">Status</th>
                                    <th scope="col" class="border-0">Verified</th>
                                    <th scope="col" class="border-0">Joined</th>
                                    <th scope="col" class="border-0 rounded-end">Action</th>
                                </tr>
                            </thead>

                            <!-- Table body START -->
                            <tbody>
                                {% for user in users %}
                                <tr>
                                    <!-- Checkbox -->
                                    <td>
                                        <input type="checkbox" name="user_ids[]" value="{{ user.id }}" class="form-check-input user-checkbox">
                                    </td>
                                    
                                    <!-- User info -->
                                    <td>
                                        <div class="d-flex align-items-center position-relative">
                                            <!-- Avatar -->
                                            <div class="avatar avatar-md mb-2 mb-md-0">
                                                <img src="{{ asset('assets/images/avatar/0' ~ (loop.index % 9 + 1) ~ '.jpg') }}" class="rounded-circle" alt="">
                                            </div>
                                            <div class="mb-0 ms-2">
                                                <!-- Title -->
                                                <h6 class="mb-0">
                                                    <a href="{{ path('app_admin_users_show', {'id': user.id}) }}" class="stretched-link">
                                                        {{ user.username }}
                                                    </a>
                                                </h6>
                                                {% if user.studentProfile %}
                                                    <span class="text-body small">
                                                        <i class="fas fa-fw fa-map-marker-alt me-1 mt-1"></i>
                                                        {{ user.studentProfile.university ?? 'N/A' }}
                                                    </span>
                                                {% elseif user.tutorProfile %}
                                                    <span class="text-body small">
                                                        <i class="fas fa-fw fa-briefcase me-1 mt-1"></i>
                                                        {{ user.tutorProfile.yearsOfExperience ?? 0 }} years exp.
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </td>

                                    <!-- Role -->
                                    <td>
                                        {% if user.role == 'ROLE_ADMIN' %}
                                            <span class="badge bg-danger bg-opacity-10 text-danger">Admin</span>
                                        {% elseif user.role == 'ROLE_TUTOR' %}
                                            <span class="badge bg-warning bg-opacity-10 text-warning">Tutor</span>
                                        {% elseif user.role == 'ROLE_STUDENT' %}
                                            <span class="badge bg-primary bg-opacity-10 text-primary">Student</span>
                                        {% else %}
                                            <span class="badge bg-secondary bg-opacity-10 text-secondary">User</span>
                                        {% endif %}
                                    </td>

                                    <!-- Email -->
                                    <td>{{ user.email }}</td>

                                    <!-- Status -->
                                    <td>
                                        {% if user.isBanned %}
                                            <span class="badge bg-dark bg-opacity-10 text-dark">
                                                <i class="bi bi-ban me-1"></i>Banned
                                            </span>
                                        {% elseif user.isActive %}
                                            <span class="badge bg-success bg-opacity-10 text-success">Active</span>
                                        {% else %}
                                            <span class="badge bg-danger bg-opacity-10 text-danger">Inactive</span>
                                        {% endif %}
                                    </td>

                                    <!-- Verified -->
                                    <td>
                                        {% if user.isVerified %}
                                            <i class="bi bi-check-circle-fill text-success"></i>
                                        {% else %}
                                            <i class="bi bi-x-circle-fill text-danger"></i>
                                        {% endif %}
                                    </td>

                                    <!-- Joined date -->
                                    <td>{{ user.createdAt|date('M d, Y') }}</td>

                                    <!-- Action -->
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-light rounded-circle" type="button" id="dropdownMenuButton{{ user.id }}" data-bs-toggle="dropdown" aria-expanded="false">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="dropdownMenuButton{{ user.id }}">
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_admin_users_show', {'id': user.id}) }}">
                                                        <i class="bi bi-eye fa-fw me-2"></i>View
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_admin_users_edit', {'id': user.id}) }}">
                                                        <i class="bi bi-pencil-square fa-fw me-2"></i>Edit
                                                    </a>
                                                </li>
                                                <li>
                                                    <form method="post" action="{{ path('app_admin_users_toggle_status', {'id': user.id}) }}" style="display: inline;">
                                                        <button type="submit" class="dropdown-item">
                                                            <i class="bi bi-{{ user.isActive ? 'pause' : 'play' }}-circle fa-fw me-2"></i>
                                                            {{ user.isActive ? 'Deactivate' : 'Activate' }}
                                                        </button>
                                                    </form>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                {% if user.isBanned %}
                                                    <li>
                                                        <form method="post" action="{{ path('app_admin_users_unban', {'id': user.id}) }}" style="display: inline;">
                                                            <button type="submit" class="dropdown-item text-success">
                                                                <i class="bi bi-check-circle fa-fw me-2"></i>Unban User
                                                            </button>
                                                        </form>
                                                    </li>
                                                {% else %}
                                                    <li>
                                                        <button type="button" class="dropdown-item text-warning" data-bs-toggle="modal" data-bs-target="#banModal{{ user.id }}">
                                                            <i class="bi bi-ban fa-fw me-2"></i>Ban User
                                                        </button>
                                                    </li>
                                                {% endif %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <button type="button" class="dropdown-item text-danger" data-bs-toggle="modal" data-bs-target="#deleteModal{{ user.id }}">
                                                        <i class="bi bi-trash fa-fw me-2"></i>Delete
                                                    </button>
                                                </li>
                                            </ul>
                                        </div>

                                        <!-- Delete Modal -->
                                        <div class="modal fade" id="deleteModal{{ user.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ user.id }}" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="deleteModalLabel{{ user.id }}">Confirm Delete</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <div class="modal-body">
                                                        Are you sure you want to delete user <strong>{{ user.username }}</strong>? This action cannot be undone.
                                                    </div>
                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                        <form method="post" action="{{ path('app_admin_users_delete', {'id': user.id}) }}" style="display: inline;">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                                            <button type="submit" class="btn btn-danger">Delete</button>
                                                        </form>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Ban Modal -->
                                        <div class="modal fade" id="banModal{{ user.id }}" tabindex="-1" aria-labelledby="banModalLabel{{ user.id }}" aria-hidden="true">
                                            <div class="modal-dialog">
                                                <div class="modal-content">
                                                    <div class="modal-header">
                                                        <h5 class="modal-title" id="banModalLabel{{ user.id }}">Ban User</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                    </div>
                                                    <form method="post" action="{{ path('app_admin_users_ban', {'id': user.id}) }}">
                                                        <div class="modal-body">
                                                            <p>Are you sure you want to ban <strong>{{ user.username }}</strong>?</p>
                                                            <div class="mb-3">
                                                                <label for="banReason{{ user.id }}" class="form-label">Reason for ban:</label>
                                                                <textarea class="form-control" id="banReason{{ user.id }}" name="ban_reason" rows="3" placeholder="Enter reason for banning this user..." required></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer">
                                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                            <button type="submit" class="btn btn-warning">Ban User</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                {% else %}
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <div class="text-center">
                                            <i class="bi bi-people display-1 text-muted"></i>
                                            <h5 class="mt-3">No users found</h5>
                                            <p class="text-muted">Start by adding your first user</p>
                                            <a href="{{ path('app_admin_users_new') }}" class="btn btn-primary">Add User</a>
                                        </div>
                                    </td>
                                </tr>
                                {% endfor %}
                            </tbody>
                            <!-- Table body END -->
                        </table>
                    </div>
                    <!-- Users table END -->
                </div>
                <!-- Card body END -->

                <!-- Card footer START -->
                <div class="card-footer bg-transparent pt-0">
                    <!-- Pagination START -->
                    <div class="d-sm-flex justify-content-sm-between align-items-sm-center">
                        <p class="mb-0 text-center text-sm-start">Showing {{ users|length }} users</p>
                        <!-- Pagination -->
                        <nav class="d-flex justify-content-center mb-0" aria-label="navigation">
                            <ul class="pagination pagination-sm pagination-primary-soft d-inline-block d-md-flex rounded mb-0">
                                <li class="page-item mb-0"><a class="page-link" href="#" tabindex="-1"><i class="fas fa-angle-left"></i></a></li>
                                <li class="page-item mb-0 active"><a class="page-link" href="#">1</a></li>
                                <li class="page-item mb-0"><a class="page-link" href="#">2</a></li>
                                <li class="page-item mb-0"><a class="page-link" href="#">3</a></li>
                                <li class="page-item mb-0"><a class="page-link" href="#"><i class="fas fa-angle-right"></i></a></li>
                            </ul>
                        </nav>
                    </div>
                    <!-- Pagination END -->
                </div>
                <!-- Card footer END -->
            </div>
            <!-- Card END -->
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const selectAllCheckbox = document.getElementById('selectAll');
    const userCheckboxes = document.querySelectorAll('.user-checkbox');
    const bulkActionsBar = document.getElementById('bulkActionsBar');
    const bulkActionBtn = document.getElementById('bulkActionBtn');
    const selectedCountSpan = document.getElementById('selectedCount');
    const bulkActionForm = document.getElementById('bulkActionForm');
    const cancelBulkBtn = document.getElementById('cancelBulk');

    // Select all functionality
    selectAllCheckbox.addEventListener('change', function() {
        userCheckboxes.forEach(checkbox => {
            checkbox.checked = this.checked;
        });
        updateBulkActionsBar();
    });

    // Individual checkbox change
    userCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            updateBulkActionsBar();
            
            // Update select all checkbox
            const allChecked = Array.from(userCheckboxes).every(cb => cb.checked);
            const someChecked = Array.from(userCheckboxes).some(cb => cb.checked);
            selectAllCheckbox.checked = allChecked;
            selectAllCheckbox.indeterminate = someChecked && !allChecked;
        });
    });

    // Update bulk actions bar visibility
    function updateBulkActionsBar() {
        const checkedCount = Array.from(userCheckboxes).filter(cb => cb.checked).length;
        selectedCountSpan.textContent = checkedCount;
        
        if (checkedCount > 0) {
            bulkActionsBar.classList.remove('d-none');
            bulkActionBtn.style.display = 'inline-block';
        } else {
            bulkActionsBar.classList.add('d-none');
            bulkActionBtn.style.display = 'none';
        }
    }

    // Cancel bulk action
    cancelBulkBtn.addEventListener('click', function() {
        userCheckboxes.forEach(checkbox => checkbox.checked = false);
        selectAllCheckbox.checked = false;
        updateBulkActionsBar();
    });

    // Confirm bulk action
    bulkActionForm.addEventListener('submit', function(e) {
        const action = this.querySelector('select[name="bulk_action"]').value;
        const checkedCount = Array.from(userCheckboxes).filter(cb => cb.checked).length;
        
        if (!action) {
            e.preventDefault();
            alert('Please select an action');
            return;
        }

        const actionMessages = {
            'activate': 'activate',
            'deactivate': 'deactivate',
            'ban': 'ban',
            'unban': 'unban',
            'delete': 'permanently delete'
        };

        if (!confirm(`Are you sure you want to ${actionMessages[action]} ${checkedCount} user(s)?`)) {
            e.preventDefault();
        }
    });
});
</script>
{% endblock %}
