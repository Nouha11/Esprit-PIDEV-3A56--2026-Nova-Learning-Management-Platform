{% extends 'admin/base.html.twig' %}

{% block title %}Edit User - {{ user.username }}{% endblock %}

{% block admin_content %}
    <!-- Title -->
    <div class="row mb-3">
        <div class="col-12">
            <h1 class="h3 mb-0">Edit User</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="{{ path('app_admin_users_list') }}">Users</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Edit {{ user.username }}</li>
                </ol>
            </nav>
        </div>
    </div>

    <div class="row g-4">
        <!-- Main Content -->
        <div class="col-lg-8">
            <!-- User Information Card -->
            <div class="card border">
                <div class="card-header bg-light border-bottom">
                    <h5 class="card-header-title mb-0">User Information</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <!-- Username & Email -->
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="username" class="form-label">Username <span class="text-danger">*</span></label>
                                <input type="text" class="form-control" id="username" name="username" value="{{ user.username }}" required minlength="3">
                                <small class="text-muted">Minimum 3 characters</small>
                            </div>
                            <div class="col-md-6">
                                <label for="email" class="form-label">Email Address <span class="text-danger">*</span></label>
                                <input type="email" class="form-control" id="email" name="email" value="{{ user.email }}" required>
                            </div>
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label for="password" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="password" name="password" minlength="8">
                            <small class="text-muted">Leave blank to keep current password. Minimum 8 characters if changing.</small>
                        </div>

                        <!-- Role -->
                        <div class="mb-3">
                            <label for="role" class="form-label">User Role <span class="text-danger">*</span></label>
                            <select class="form-select" id="role" name="role" required>
                                <option value="ROLE_ADMIN" {% if user.role == 'ROLE_ADMIN' %}selected{% endif %}>
                                    <i class="bi bi-shield-fill"></i> Administrator
                                </option>
                                <option value="ROLE_TUTOR" {% if user.role == 'ROLE_TUTOR' %}selected{% endif %}>
                                    <i class="bi bi-person-workspace"></i> Tutor
                                </option>
                                <option value="ROLE_STUDENT" {% if user.role == 'ROLE_STUDENT' %}selected{% endif %}>
                                    <i class="bi bi-person-check"></i> Student
                                </option>
                                <option value="ROLE_USER" {% if user.role == 'ROLE_USER' %}selected{% endif %}>
                                    <i class="bi bi-person"></i> User
                                </option>
                            </select>
                        </div>

                        <!-- Status Toggles -->
                        <div class="mb-3">
                            <label class="form-label">Account Status</label>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="1" {% if user.isActive %}checked{% endif %}>
                                <label class="form-check-label" for="isActive">
                                    <i class="bi bi-check-circle text-success"></i> Active Account
                                </label>
                            </div>
                        </div>

                        <!-- Warning Alert -->
                        <div class="alert alert-warning d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>
                                <strong>Important:</strong> Changing the role may affect the user's access to certain features. Ensure the user has the appropriate profile (Student or Tutor) when assigning those roles.
                            </div>
                        </div>

                        <!-- Action Buttons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Update User
                            </button>
                            <a href="{{ path('app_admin_users_list') }}" class="btn btn-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">
            <!-- User Stats Card -->
            <div class="card border mb-3">
                <div class="card-header bg-light border-bottom">
                    <h5 class="card-header-title mb-0">User Details</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">User ID:</span>
                                <strong>#{{ user.id }}</strong>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Status:</span>
                                {% if user.isBanned %}
                                    <span class="badge bg-dark">Banned</span>
                                {% elseif user.isActive %}
                                    <span class="badge bg-success">Active</span>
                                {% else %}
                                    <span class="badge bg-danger">Inactive</span>
                                {% endif %}
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Email Verified:</span>
                                {% if user.isVerified %}
                                    <i class="bi bi-check-circle-fill text-success"></i>
                                {% else %}
                                    <i class="bi bi-x-circle-fill text-danger"></i>
                                {% endif %}
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">XP Points:</span>
                                <strong>{{ user.xp ?? 0 }}</strong>
                            </div>
                        </li>
                        <li class="mb-3">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Joined:</span>
                                <strong>{{ user.createdAt|date('M d, Y') }}</strong>
                            </div>
                        </li>
                        <li class="mb-0">
                            <div class="d-flex justify-content-between">
                                <span class="text-muted">Last Updated:</span>
                                <strong>{{ user.updatedAt|date('M d, Y') }}</strong>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Profile Information Card -->
            {% if user.studentProfile or user.tutorProfile %}
            <div class="card border mb-3">
                <div class="card-header bg-light border-bottom">
                    <h5 class="card-header-title mb-0">Profile Information</h5>
                </div>
                <div class="card-body">
                    {% if user.studentProfile %}
                        <h6 class="mb-3">
                            <i class="bi bi-person-badge text-primary"></i> Student Profile
                        </h6>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <strong>Name:</strong> {{ user.studentProfile.firstName }} {{ user.studentProfile.lastName }}
                            </li>
                            {% if user.studentProfile.university %}
                            <li class="mb-2">
                                <strong>University:</strong> {{ user.studentProfile.university }}
                            </li>
                            {% endif %}
                            {% if user.studentProfile.major %}
                            <li class="mb-2">
                                <strong>Major:</strong> {{ user.studentProfile.major }}
                            </li>
                            {% endif %}
                            {% if user.studentProfile.academicLevel %}
                            <li class="mb-0">
                                <strong>Level:</strong> {{ user.studentProfile.academicLevel }}
                            </li>
                            {% endif %}
                        </ul>
                    {% endif %}

                    {% if user.tutorProfile %}
                        <h6 class="mb-3">
                            <i class="bi bi-person-workspace text-warning"></i> Tutor Profile
                        </h6>
                        <ul class="list-unstyled">
                            <li class="mb-2">
                                <strong>Name:</strong> {{ user.tutorProfile.firstName }} {{ user.tutorProfile.lastName }}
                            </li>
                            {% if user.tutorProfile.yearsOfExperience %}
                            <li class="mb-2">
                                <strong>Experience:</strong> {{ user.tutorProfile.yearsOfExperience }} years
                            </li>
                            {% endif %}
                            {% if user.tutorProfile.hourlyRate %}
                            <li class="mb-0">
                                <strong>Hourly Rate:</strong> ${{ user.tutorProfile.hourlyRate }}
                            </li>
                            {% endif %}
                        </ul>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            <!-- Ban Information Card -->
            {% if user.isBanned %}
            <div class="card border border-warning mb-3">
                <div class="card-header bg-warning bg-opacity-10 border-bottom border-warning">
                    <h5 class="card-header-title mb-0 text-warning">
                        <i class="bi bi-ban me-2"></i>Ban Information
                    </h5>
                </div>
                <div class="card-body">
                    <p class="mb-2"><strong>Banned on:</strong> {{ user.bannedAt|date('M d, Y H:i') }}</p>
                    <p class="mb-3"><strong>Reason:</strong></p>
                    <div class="alert alert-warning mb-3">
                        {{ user.banReason ?? 'No reason provided' }}
                    </div>
                    <form method="post" action="{{ path('app_admin_users_unban', {'id': user.id}) }}">
                        <button type="submit" class="btn btn-success w-100">
                            <i class="bi bi-check-circle me-2"></i>Unban User
                        </button>
                    </form>
                </div>
            </div>
            {% endif %}

            <!-- Quick Actions Card -->
            <div class="card border">
                <div class="card-header bg-light border-bottom">
                    <h5 class="card-header-title mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a href="{{ path('app_admin_users_show', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-eye me-2"></i>View Full Profile
                        </a>
                        
                        <form method="post" action="{{ path('app_admin_users_toggle_status', {'id': user.id}) }}">
                            <button type="submit" class="btn btn-sm btn-outline-{{ user.isActive ? 'warning' : 'success' }} w-100">
                                <i class="bi bi-{{ user.isActive ? 'pause' : 'play' }}-circle me-2"></i>
                                {{ user.isActive ? 'Deactivate' : 'Activate' }} Account
                            </button>
                        </form>

                        {% if not user.isBanned %}
                        <button type="button" class="btn btn-sm btn-outline-warning" data-bs-toggle="modal" data-bs-target="#banModal">
                            <i class="bi bi-ban me-2"></i>Ban User
                        </button>
                        {% endif %}

                        <hr class="my-2">

                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                            <i class="bi bi-trash me-2"></i>Delete User
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Ban Modal -->
    <div class="modal fade" id="banModal" tabindex="-1" aria-labelledby="banModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="banModalLabel">Ban User</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form method="post" action="{{ path('app_admin_users_ban', {'id': user.id}) }}">
                    <div class="modal-body">
                        <p>Are you sure you want to ban <strong>{{ user.username }}</strong>?</p>
                        <div class="mb-3">
                            <label for="banReason" class="form-label">Reason for ban:</label>
                            <textarea class="form-control" id="banReason" name="ban_reason" rows="3" placeholder="Enter reason for banning this user..." required></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning">Ban User</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Delete Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Confirm Delete</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete user <strong>{{ user.username }}</strong>?</p>
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Warning:</strong> This action cannot be undone. All user data will be permanently deleted.
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <form method="post" action="{{ path('app_admin_users_delete', {'id': user.id}) }}" style="display: inline;">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                        <button type="submit" class="btn btn-danger">Delete User</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
