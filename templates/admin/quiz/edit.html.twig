{% extends 'admin/base.html.twig' %}

{% block title %}Edit Quiz{% endblock %}

{% block admin_content %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0">Edit Quiz</h1>
                    <p class="text-muted mb-0">Update settings for {{ quiz.title }}</p>
                </div>
                <a href="{{ path('app_quiz_index', {'prefix': 'admin'}) }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="card shadow-sm border rounded-3 mb-5">
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        
                        <div class="mb-4">
                            <label class="form-label fw-bold">Quiz Title</label>
                            {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg'}}) }}
                            <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Description</label>
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                            <div class="form-text text-danger">{{ form_errors(form.description) }}</div>
                        </div>

                        {# Catch-all for other fields #}
                        {% for child in form %}
                            {% if child.vars.name not in ['title', 'description', '_token'] %}
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ child.vars.label|default(child.vars.name|humanize) }}</label>
                                    {{ form_widget(child, {'attr': {'class': 'form-control'}}) }}
                                </div>
                            {% endif %}
                        {% endfor %}

                        <div class="d-grid mt-4">
                            <button class="btn btn-primary btn-lg" type="submit">Update Quiz</button>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>

            {# Delete Zone #}
            <div class="card border-danger border-opacity-25 bg-danger bg-opacity-10">
                <div class="card-body d-flex justify-content-between align-items-center p-3">
                    <span class="text-danger fw-bold">Delete this Quiz?</span>
                    <form method="post" action="{{ path('app_quiz_delete', {'id': quiz.id, 'prefix': 'admin'}) }}" onsubmit="return confirm('Are you sure? This will delete all questions too!');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                        <button class="btn btn-danger btn-sm">Delete Quiz</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}