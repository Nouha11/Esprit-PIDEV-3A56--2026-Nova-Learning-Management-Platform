{% extends 'admin/base.html.twig' %}

{% block title %}Quiz Statistics{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .chart-container {
            position: relative;
            height: 300px;
        }
    </style>
{% endblock %}

{% block admin_content %}
<div class="container-fluid py-4">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold mb-1">📊 Quiz Statistics</h1>
            <p class="text-muted">Comprehensive analytics and insights</p>
        </div>
        <div>
            <a href="{{ path('app_quiz_index', {'prefix': 'admin'}) }}" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Quizzes
            </a>
        </div>
    </div>

    {# Overview Cards #}
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total Quizzes</p>
                            <h2 class="mb-0 fw-bold">{{ stats.overview.totalQuizzes }}</h2>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-collection text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total Questions</p>
                            <h2 class="mb-0 fw-bold">{{ stats.overview.totalQuestions }}</h2>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-question-circle text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Total Reports</p>
                            <h2 class="mb-0 fw-bold">{{ stats.overview.totalReports }}</h2>
                        </div>
                        <div class="bg-warning bg-opacity-10 p-3 rounded">
                            <i class="bi bi-flag text-warning fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted mb-1 small">Pending Reports</p>
                            <h2 class="mb-0 fw-bold text-danger">{{ stats.overview.pendingReports }}</h2>
                        </div>
                        <div class="bg-danger bg-opacity-10 p-3 rounded">
                            <i class="bi bi-exclamation-triangle text-danger fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        {# Difficulty Distribution Chart #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-pie-chart me-2"></i>Question Difficulty Distribution</h5>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="difficultyChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        {# Report Status Chart #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-bar-chart me-2"></i>Report Status Distribution</h5>
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="reportStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        {# Quiz Statistics #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-bar-chart me-2"></i>Quiz Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Average Questions per Quiz</span>
                            <span class="fw-bold">{{ stats.quizzes.avgQuestionsPerQuiz }}</span>
                        </div>
                        <div class="progress" style="height: 8px;">
                            <div class="progress-bar bg-primary" style="width: {{ (stats.quizzes.avgQuestionsPerQuiz / 20 * 100)|round }}%"></div>
                        </div>
                    </div>

                    {% if stats.quizzes.mostQuestions %}
                    <div class="mb-4">
                        <p class="text-muted mb-2">Quiz with Most Questions</p>
                        <div class="bg-light p-3 rounded">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>{{ stats.quizzes.mostQuestions.title }}</strong>
                                    <br>
                                    <small class="text-muted">ID: #{{ stats.quizzes.mostQuestions.id }}</small>
                                </div>
                                <span class="badge bg-primary fs-6">{{ stats.quizzes.mostQuestions.question_count }} questions</span>
                            </div>
                        </div>
                    </div>
                    {% endif %}

                    <div class="alert alert-warning mb-0">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <strong>{{ stats.quizzes.emptyQuizzes }}</strong> quiz(es) without questions
                    </div>
                </div>
            </div>
        </div>

        {# Question Statistics #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-pie-chart me-2"></i>Question Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <p class="text-muted mb-3">Questions by Difficulty</p>
                        {% for item in stats.questions.byDifficulty %}
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span>{{ item.difficulty }}</span>
                                    <span class="fw-bold">{{ item.count }}</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    {% set percentage = (item.count / stats.overview.totalQuestions * 100)|round %}
                                    {% set color = item.difficulty == 'Easy' ? 'success' : (item.difficulty == 'Medium' ? 'warning' : 'danger') %}
                                    <div class="progress-bar bg-{{ color }}" style="width: {{ percentage }}%"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    <div class="row g-3">
                        <div class="col-6">
                            <div class="bg-light p-3 rounded text-center">
                                <div class="text-muted small mb-1">Avg XP</div>
                                <div class="fs-4 fw-bold text-primary">{{ stats.questions.avgXp }}</div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="bg-light p-3 rounded text-center">
                                <div class="text-muted small mb-1">Total XP</div>
                                <div class="fs-4 fw-bold text-success">{{ stats.questions.totalXp }}</div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="bg-info bg-opacity-10 p-3 rounded text-center">
                                <i class="bi bi-image text-info me-2"></i>
                                <strong>{{ stats.questions.withImages }}</strong> questions with images
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        {# Report Statistics #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-flag me-2"></i>Report Statistics</h5>
                </div>
                <div class="card-body">
                    <div class="mb-4">
                        <p class="text-muted mb-3">Reports by Status</p>
                        {% for item in stats.reports.byStatus %}
                            <div class="mb-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="text-capitalize">{{ item.status }}</span>
                                    <span class="fw-bold">{{ item.count }}</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    {% set percentage = (item.count / stats.overview.totalReports * 100)|round %}
                                    {% set color = item.status == 'pending' ? 'warning' : (item.status == 'resolved' ? 'success' : 'secondary') %}
                                    <div class="progress-bar bg-{{ color }}" style="width: {{ percentage }}%"></div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>

                    {% if stats.reports.mostReported %}
                    <div class="alert alert-danger mb-0">
                        <strong>Most Reported Quiz:</strong><br>
                        {{ stats.reports.mostReported.title }}<br>
                        <small>{{ stats.reports.mostReported.report_count }} report(s)</small>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Top Quizzes #}
        <div class="col-lg-6">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-trophy me-2"></i>Top Quizzes</h5>
                </div>
                <div class="card-body">
                    <div class="list-group list-group-flush">
                        {% for quiz in stats.topQuizzes %}
                            <div class="list-group-item px-0">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="flex-grow-1">
                                        <div class="fw-bold">{{ loop.index }}. {{ quiz.title }}</div>
                                        <small class="text-muted">{{ quiz.description|slice(0, 60) }}...</small>
                                    </div>
                                    <span class="badge bg-primary rounded-pill ms-2">{{ quiz.question_count }} Qs</span>
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-1"></i>
                                <p class="mt-2">No quizzes available</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        </div>

        {# Recent Activity #}
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white border-bottom">
                    <h5 class="card-title mb-0"><i class="bi bi-clock-history me-2"></i>Recent Reports</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Quiz</th>
                                    <th>Reason</th>
                                    <th>Reporter</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for report in stats.recentActivity.recentReports %}
                                    <tr>
                                        <td>{{ report.quiz_title }}</td>
                                        <td>
                                            <span class="badge bg-light text-dark">{{ report.reason }}</span>
                                        </td>
                                        <td>{{ report.reporter }}</td>
                                        <td>
                                            {% set statusColor = report.status == 'pending' ? 'warning' : (report.status == 'resolved' ? 'success' : 'secondary') %}
                                            <span class="badge bg-{{ statusColor }}">{{ report.status }}</span>
                                        </td>
                                        <td>
                                            <small class="text-muted">{{ report.created_at|date('M d, Y H:i') }}</small>
                                        </td>
                                        <td>
                                            <a href="{{ path('app_quiz_reports_show', {'id': report.id, 'prefix': 'admin'}) }}" class="btn btn-sm btn-outline-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">
                                            No recent reports
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Difficulty Distribution Pie Chart
            const difficultyCtx = document.getElementById('difficultyChart');
            if (difficultyCtx) {
                new Chart(difficultyCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Easy', 'Medium', 'Hard'],
                        datasets: [{
                            label: 'Questions',
                            data: [
                                {{ difficultyDistribution.Easy }},
                                {{ difficultyDistribution.Medium }},
                                {{ difficultyDistribution.Hard }}
                            ],
                            backgroundColor: [
                                'rgba(40, 167, 69, 0.8)',   // Green for Easy
                                'rgba(255, 193, 7, 0.8)',   // Yellow for Medium
                                'rgba(220, 53, 69, 0.8)'    // Red for Hard
                            ],
                            borderColor: [
                                'rgba(40, 167, 69, 1)',
                                'rgba(255, 193, 7, 1)',
                                'rgba(220, 53, 69, 1)'
                            ],
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    padding: 20,
                                    font: {
                                        size: 14
                                    }
                                }
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        const label = context.label || '';
                                        const value = context.parsed || 0;
                                        const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                        const percentage = total > 0 ? ((value / total) * 100).toFixed(1) : 0;
                                        return label + ': ' + value + ' (' + percentage + '%)';
                                    }
                                }
                            }
                        }
                    }
                });
            }

            // Report Status Bar Chart
            const reportStatusCtx = document.getElementById('reportStatusChart');
            if (reportStatusCtx) {
                new Chart(reportStatusCtx, {
                    type: 'bar',
                    data: {
                        labels: ['Pending', 'Resolved', 'Dismissed'],
                        datasets: [{
                            label: 'Reports',
                            data: [
                                {{ reportStatusDistribution.pending }},
                                {{ reportStatusDistribution.resolved }},
                                {{ reportStatusDistribution.dismissed }}
                            ],
                            backgroundColor: [
                                'rgba(255, 193, 7, 0.8)',   // Yellow for Pending
                                'rgba(40, 167, 69, 0.8)',   // Green for Resolved
                                'rgba(108, 117, 125, 0.8)'  // Gray for Dismissed
                            ],
                            borderColor: [
                                'rgba(255, 193, 7, 1)',
                                'rgba(40, 167, 69, 1)',
                                'rgba(108, 117, 125, 1)'
                            ],
                            borderWidth: 2,
                            borderRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: {
                                beginAtZero: true,
                                ticks: {
                                    stepSize: 1,
                                    font: {
                                        size: 12
                                    }
                                },
                                grid: {
                                    color: 'rgba(0, 0, 0, 0.05)'
                                }
                            },
                            x: {
                                ticks: {
                                    font: {
                                        size: 12
                                    }
                                },
                                grid: {
                                    display: false
                                }
                            }
                        },
                        plugins: {
                            legend: {
                                display: false
                            },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.label + ': ' + context.parsed.y + ' report(s)';
                                    }
                                }
                            }
                        }
                    }
                });
            }
        });
    </script>
{% endblock %}
