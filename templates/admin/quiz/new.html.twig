{% extends 'base_content.html.twig' %}

{% block title %}New Quiz{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h3 mb-0">Create New Quiz</h1>
                    <p class="text-muted mb-0">Start a new assessment topic.</p>
                </div>
                <a href="{{ path('app_quiz_index') }}" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-arrow-left me-1"></i> Back to List
                </a>
            </div>

            <div class="card shadow-sm border rounded-3">
                <div class="card-header bg-light border-bottom px-4 py-3">
                    <h5 class="card-title mb-0"><i class="bi bi-journal-text me-2"></i>Quiz Details</h5>
                </div>
                
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        
                        {# 1. Title Field #}
                        <div class="mb-4">
                            <label class="form-label fw-bold">Quiz Title</label>
                            {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg', 'placeholder': 'e.g., PHP Basics 101'}}) }}
                            <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                        </div>

                        {# 2. Description Field #}
                        <div class="mb-4">
                            <label class="form-label fw-bold">Description</label>
                            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Describe what this quiz covers...'}}) }}
                            <div class="form-text text-danger">{{ form_errors(form.description) }}</div>
                        </div>

                        {# 3. Any other fields your QuizType has (Generic render to be safe) #}
                        {# If you have other fields like 'summary' or 'image', this loop will catch them #}
                        {% for child in form %}
                            {% if child.vars.name not in ['title', 'description', '_token'] %}
                                <div class="mb-3">
                                    <label class="form-label fw-bold">{{ child.vars.label|default(child.vars.name|humanize) }}</label>
                                    {{ form_widget(child, {'attr': {'class': 'form-control'}}) }}
                                    <div class="form-text text-danger">{{ form_errors(child) }}</div>
                                </div>
                            {% endif %}
                        {% endfor %}

                        <div class="d-grid mt-4">
                            <button class="btn btn-primary btn-lg" type="submit">
                                <i class="bi bi-check-lg me-2"></i>Create Quiz
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}