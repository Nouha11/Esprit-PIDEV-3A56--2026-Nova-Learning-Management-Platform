{% extends 'admin/base.html.twig' %}

{% block title %}Quiz Manager{% endblock %}

{% block admin_content %}
<div class="container py-5">
    
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h3 fw-bold mb-1">Quiz Manager</h1>
            <p class="text-muted">Manage your assessments and questions.</p>
        </div>
        <div class="d-flex gap-2">
            <a href="{{ path('app_quiz_reports_index', {'prefix': 'admin'}) }}" class="btn btn-outline-danger">
                <i class="bi bi-flag me-1"></i> Reports
            </a>
            <a href="{{ path('app_quiz_new', {'prefix': 'admin'}) }}" class="btn btn-primary">
                <i class="bi bi-plus-lg me-1"></i> Create New Quiz
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary bg-opacity-10 border-0">
                <div class="card-body text-center">
                    <h3 class="text-primary mb-1">{{ statistics.totalQuizzes }}</h3>
                    <small class="text-muted">Total Quizzes</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success bg-opacity-10 border-0">
                <div class="card-body text-center">
                    <h3 class="text-success mb-1">{{ statistics.avgQuestions }}</h3>
                    <small class="text-muted">Avg Questions</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info bg-opacity-10 border-0">
                <div class="card-body text-center">
                    <h3 class="text-info mb-1">{{ statistics.minQuestions }}</h3>
                    <small class="text-muted">Min Questions</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-warning bg-opacity-10 border-0">
                <div class="card-body text-center">
                    <h3 class="text-warning mb-1">{{ statistics.maxQuestions }}</h3>
                    <small class="text-muted">Max Questions</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters and Sorting -->
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-light border-bottom px-4 py-3">
            <h5 class="card-title mb-0">
                <i class="bi bi-funnel me-2"></i>Filters & Sorting
            </h5>
        </div>
        <div class="card-body p-4">
            <form method="GET" action="{{ path('app_quiz_index', {'prefix': 'admin'}) }}" class="quiz-filter-form">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Search</label>
                        <input type="text" 
                               name="search" 
                               class="form-control" 
                               placeholder="Search by title or description..."
                               value="{{ app.request.query.get('search', '') }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Min Questions</label>
                        <input type="number" 
                               name="minQuestions" 
                               class="form-control" 
                               min="0"
                               value="{{ app.request.query.get('minQuestions', '') }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Max Questions</label>
                        <input type="number" 
                               name="maxQuestions" 
                               class="form-control" 
                               min="0"
                               value="{{ app.request.query.get('maxQuestions', '') }}">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Sort By</label>
                        <select name="sortBy" class="form-select">
                            <option value="title" {{ app.request.query.get('sortBy', 'title') == 'title' ? 'selected' : '' }}>Title</option>
                            <option value="id" {{ app.request.query.get('sortBy') == 'id' ? 'selected' : '' }}>ID</option>
                            <option value="questionCount" {{ app.request.query.get('sortBy') == 'questionCount' ? 'selected' : '' }}>Question Count</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Sort Order</label>
                        <select name="sortOrder" class="form-select">
                            <option value="ASC" {{ app.request.query.get('sortOrder', 'ASC') == 'ASC' ? 'selected' : '' }}>Ascending</option>
                            <option value="DESC" {{ app.request.query.get('sortOrder') == 'DESC' ? 'selected' : '' }}>Descending</option>
                        </select>
                    </div>
                </div>
                <div class="d-flex gap-2 mt-3">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search me-1"></i> Apply Filters
                    </button>
                    <a href="{{ path('app_quiz_index', {'prefix': 'admin'}) }}" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle me-1"></i> Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <!-- Active Filters Display -->
    {% if currentFilters is not empty or currentSort.by != 'title' or currentSort.order != 'ASC' %}
        <div class="mb-3">
            <small class="text-muted">Active filters:</small>
            {% if currentFilters.search is defined and currentFilters.search %}
                <span class="badge bg-primary ms-1">Search: "{{ currentFilters.search }}"</span>
            {% endif %}
            {% if currentFilters.minQuestions is defined and currentFilters.minQuestions %}
                <span class="badge bg-info ms-1">Min: {{ currentFilters.minQuestions }} questions</span>
            {% endif %}
            {% if currentFilters.maxQuestions is defined and currentFilters.maxQuestions %}
                <span class="badge bg-info ms-1">Max: {{ currentFilters.maxQuestions }} questions</span>
            {% endif %}
            {% if currentSort.by != 'title' or currentSort.order != 'ASC' %}
                <span class="badge bg-secondary ms-1">
                    Sort: {{ currentSort.by|title }} {{ currentSort.order == 'ASC' ? '↑' : '↓' }}
                </span>
            {% endif %}
        </div>
    {% endif %}

    <div class="row g-4">
        {% for quiz in pagination %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <span class="badge bg-primary bg-opacity-10 text-primary">Quiz #{{ quiz.id }}</span>
                            <div class="dropdown">
                                <button class="btn btn-link text-muted p-0" type="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-three-dots"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_quiz_edit', {'id': quiz.id, 'prefix': 'admin'}) }}">Edit Settings</a></li>
                                    <li>
                                        <form method="post" action="{{ path('app_quiz_delete', {'id': quiz.id, 'prefix': 'admin'}) }}" onsubmit="return confirm('Delete this quiz?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ quiz.id) }}">
                                            <button class="dropdown-item text-danger">Delete</button>
                                        </form>
                                    </li>
                                </ul>
                            </div>
                        </div>
                        
                        <h5 class="card-title fw-bold mb-2">{{ quiz.title }}</h5>
                        <p class="card-text text-muted small mb-4">
                            {{ quiz.description|default('No description provided.') }}
                        </p>

                        <div class="d-flex align-items-center justify-content-between mt-auto">
                            <div class="small text-muted">
                                <i class="bi bi-question-circle me-1"></i> {{ quiz.questions|length }} Qs
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 pb-3 pt-0">
                        <div class="d-grid gap-2">
                            <a href="{{ path('app_quiz_show', {'id': quiz.id, 'prefix': 'admin'}) }}" class="btn btn-dark btn-sm">
                                Manage Questions
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="text-muted mb-3"><i class="bi bi-folder2-open display-4"></i></div>
                <h5>No Quizzes Found</h5>
                {% if currentFilters is not empty %}
                    <p class="text-muted">Try adjusting your filters or <a href="{{ path('app_quiz_index', {'prefix': 'admin'}) }}">clear all filters</a>.</p>
                {% else %}
                    <p class="text-muted">Get started by creating your first assessment.</p>
                {% endif %}
            </div>
        {% endfor %}
    </div>

    {# Pagination Controls #}
    <div class="mt-5">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>

<script>
// Auto-submit form on select changes for better UX
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.quiz-filter-form');
    const selects = form.querySelectorAll('select');
    
    selects.forEach(select => {
        select.addEventListener('change', function() {
            form.submit();
        });
    });
});
</script>
{% endblock %}