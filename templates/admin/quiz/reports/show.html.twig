{% extends 'admin/base.html.twig' %}

{% block title %}Report Details{% endblock %}

{% block admin_content %}
{% set current_prefix = app.request.attributes.get('prefix') %}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            <div class="mb-4">
                <a href="{{ path('app_quiz_reports_index', {'prefix': current_prefix}) }}" class="text-muted text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i> Back to Reports
                </a>
            </div>

            {# Report Details Card #}
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light border-bottom px-4 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-flag-fill text-danger me-2"></i>Report Details
                        </h5>
                        {% if report.status == 'pending' %}
                            <span class="badge bg-warning text-dark">Pending</span>
                        {% elseif report.status == 'resolved' %}
                            <span class="badge bg-success">Resolved</span>
                        {% else %}
                            <span class="badge bg-secondary">Dismissed</span>
                        {% endif %}
                    </div>
                </div>
                
                <div class="card-body p-4">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold">Reported Quiz</label>
                            <p class="mb-0">
                                <a href="{{ path('app_quiz_show', {'id': report.quiz.id, 'prefix': current_prefix}) }}" 
                                   class="text-decoration-none">
                                    {{ report.quiz.title }}
                                </a>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold">Reported By</label>
                            <p class="mb-0">{{ report.reportedBy.username }}</p>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold">Reason</label>
                            <p class="mb-0">
                                <span class="badge bg-danger bg-opacity-10 text-danger">
                                    {{ report.reason }}
                                </span>
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small fw-bold">Date Reported</label>
                            <p class="mb-0">{{ report.createdAt|date('F d, Y \\a\\t g:i A') }}</p>
                        </div>
                    </div>

                    {% if report.description %}
                        <div class="mb-3">
                            <label class="text-muted small fw-bold">Description</label>
                            <div class="bg-light p-3 rounded">
                                <p class="mb-0">{{ report.description }}</p>
                            </div>
                        </div>
                    {% endif %}

                    {% if report.status != 'pending' %}
                        <hr class="my-4">
                        
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold">Resolved By</label>
                                <p class="mb-0">{{ report.resolvedBy ? report.resolvedBy.username : 'N/A' }}</p>
                            </div>
                            <div class="col-md-6">
                                <label class="text-muted small fw-bold">Resolved Date</label>
                                <p class="mb-0">{{ report.resolvedAt|date('F d, Y \\a\\t g:i A') }}</p>
                            </div>
                        </div>

                        {% if report.adminNotes %}
                            <div class="mb-3">
                                <label class="text-muted small fw-bold">Admin Notes</label>
                                <div class="bg-light p-3 rounded">
                                    <p class="mb-0">{{ report.adminNotes }}</p>
                                </div>
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {# Quiz Preview Card #}
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-light border-bottom px-4 py-3">
                    <h5 class="card-title mb-0">
                        <i class="bi bi-journal-text me-2"></i>Quiz Preview
                    </h5>
                </div>
                
                <div class="card-body p-4">
                    <h6 class="fw-bold">{{ report.quiz.title }}</h6>
                    <p class="text-muted">{{ report.quiz.description|default('No description provided.') }}</p>
                    
                    <div class="d-flex gap-3 mt-3">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-question-circle me-1"></i>
                            {{ report.quiz.questions|length }} Questions
                        </span>
                        <a href="{{ path('app_quiz_show', {'id': report.quiz.id, 'prefix': current_prefix}) }}" 
                           class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil me-1"></i> Edit Quiz
                        </a>
                    </div>
                </div>
            </div>

            {# Action Buttons (Only for Pending Reports) #}
            {% if report.status == 'pending' %}
                <div class="card shadow-sm border-0">
                    <div class="card-header bg-light border-bottom px-4 py-3">
                        <h5 class="card-title mb-0">
                            <i class="bi bi-gear me-2"></i>Actions
                        </h5>
                    </div>
                    
                    <div class="card-body p-4">
                        <form method="post" action="{{ path('app_quiz_reports_resolve', {'id': report.id, 'prefix': current_prefix}) }}">
                            
                            <div class="mb-4">
                                <label class="form-label fw-bold">Admin Notes</label>
                                <textarea name="admin_notes" class="form-control" rows="3" 
                                          placeholder="Add notes about your decision..."></textarea>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" name="action" value="resolve" 
                                        class="btn btn-success btn-lg">
                                    <i class="bi bi-check-circle me-2"></i>Mark as Resolved
                                </button>
                                
                                <button type="submit" name="action" value="dismiss" 
                                        class="btn btn-secondary btn-lg">
                                    <i class="bi bi-x-circle me-2"></i>Dismiss Report
                                </button>
                            </div>
                        </form>

                        <hr class="my-4">

                        <div class="alert alert-danger mb-0">
                            <h6 class="alert-heading fw-bold">
                                <i class="bi bi-trash me-2"></i>Delete Quiz
                            </h6>
                            <p class="small mb-3">This will permanently delete the quiz and all its questions. This action cannot be undone.</p>
                            
                            <form method="post" 
                                  action="{{ path('app_quiz_delete', {'id': report.quiz.id, 'prefix': current_prefix}) }}" 
                                  onsubmit="return confirm('Are you sure you want to delete this quiz? This action cannot be undone!');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ report.quiz.id) }}">
                                <button type="submit" class="btn btn-danger">
                                    <i class="bi bi-trash me-1"></i>Delete Quiz
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}
