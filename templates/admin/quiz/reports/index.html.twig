{% extends 'admin/base.html.twig' %}

{% block title %}Quiz Reports{% endblock %}

{% block admin_content %}
<div class="container py-5">
    
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="h3 fw-bold mb-1">Quiz Reports</h1>
            <p class="text-muted">Review and manage user-reported quizzes.</p>
        </div>
        <a href="{{ path('app_quiz_index', {'prefix': 'admin'}) }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Back to Quizzes
        </a>
    </div>

    {# Pending Reports Section #}
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-warning bg-opacity-10 border-bottom px-4 py-3">
            <h5 class="card-title mb-0">
                <i class="bi bi-exclamation-triangle text-warning me-2"></i>
                Pending Reports
                <span class="badge bg-warning text-dark ms-2">{{ pendingReports|length }}</span>
            </h5>
        </div>
        
        <div class="card-body p-0">
            {% if pendingReports is empty %}
                <div class="text-center py-5 text-muted">
                    <i class="bi bi-check-circle display-4"></i>
                    <p class="mt-3">No pending reports. All clear!</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Quiz</th>
                                <th>Reason</th>
                                <th>Reported By</th>
                                <th>Date</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for report in pendingReports %}
                                <tr>
                                    <td class="ps-4">
                                        <strong>{{ report.quiz.title }}</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-danger bg-opacity-10 text-danger">
                                            {{ report.reason }}
                                        </span>
                                    </td>
                                    <td>{{ report.reportedBy.username }}</td>
                                    <td class="text-muted small">
                                        {{ report.createdAt|date('M d, Y') }}
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_quiz_reports_show', {'id': report.id, 'prefix': 'admin'}) }}" 
                                           class="btn btn-sm btn-primary">
                                            <i class="bi bi-eye"></i> Review
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    {# Resolved Reports Section #}
    <div class="card shadow-sm border-0">
        <div class="card-header bg-light border-bottom px-4 py-3">
            <h5 class="card-title mb-0">
                <i class="bi bi-check-circle text-success me-2"></i>
                Resolved Reports
            </h5>
        </div>
        
        <div class="card-body p-0">
            {% if resolvedReports is empty %}
                <div class="text-center py-5 text-muted">
                    <p class="mb-0">No resolved reports yet.</p>
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Quiz</th>
                                <th>Reason</th>
                                <th>Status</th>
                                <th>Resolved By</th>
                                <th>Date</th>
                                <th class="text-end pe-4">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for report in resolvedReports %}
                                <tr class="opacity-75">
                                    <td class="ps-4">
                                        <strong>{{ report.quiz.title }}</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary">
                                            {{ report.reason }}
                                        </span>
                                    </td>
                                    <td>
                                        {% if report.status == 'resolved' %}
                                            <span class="badge bg-success">Resolved</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Dismissed</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ report.resolvedBy ? report.resolvedBy.username : 'N/A' }}</td>
                                    <td class="text-muted small">
                                        {{ report.resolvedAt|date('M d, Y') }}
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="{{ path('app_quiz_reports_show', {'id': report.id, 'prefix': 'admin'}) }}" 
                                           class="btn btn-sm btn-outline-secondary">
                                            <i class="bi bi-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

</div>
{% endblock %}
