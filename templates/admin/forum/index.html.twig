{% extends 'admin/base.html.twig' %}

{% block title %}Forum Moderation{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-comments fa-sm text-gray-400 mr-2"></i>Forum Moderation
        </h1>
    </div>

    <div class="card shadow mb-4">
        
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
            <div class="d-flex align-items-center">
                <h6 class="m-0 font-weight-bold text-primary mr-3">All Discussions</h6>
                <span class="badge badge-primary bg-primary badge-pill px-3 text-white shadow-sm" style="font-size: 0.9em; color: #ffffff !important;">
                    {{ posts|length }}
                </span>
            </div>
            
            <form method="get" action="{{ path('app_admin_forum_index') }}" class="form-inline my-2 my-md-0 mw-100 navbar-search">
                <div class="input-group">
                    <input type="text" 
                           name="q" 
                           class="form-control bg-dark border-0 small text-light" 
                           placeholder="Search topics or users..." 
                           aria-label="Search" 
                           value="{{ searchQuery|default('') }}"
                           style="background-color: #2c2e3e !important; width: 300px; color: #ffffff !important;">
                    
                    <div class="input-group-append">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search fa-sm"></i>
                        </button>
                        {% if searchQuery is defined and searchQuery %}
                            <a href="{{ path('app_admin_forum_index') }}" class="btn btn-secondary" title="Clear">
                                <i class="fas fa-times"></i>
                            </a>
                        {% endif %}
                    </div>
                </div>
            </form>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" id="dataTable" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 5%; color: #4e73df !important;">ID</th>
                            <th style="width: 40%; color: #4e73df !important;">Topic</th>
                            <th style="width: 20%; color: #4e73df !important;">Author</th>
                            <th style="width: 10%; color: #4e73df !important;" class="text-center">Replies</th>
                            <th style="width: 15%; color: #4e73df !important;">Created</th>
                            <th style="width: 10%; color: #4e73df !important;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for post in posts %}
                        <tr>
                            <td class="align-middle" style="color: #6e707e !important;">{{ post.id }}</td>
                            <td class="align-middle">
                                {% if post.isLocked %}
                                    <span class="badge badge-danger mb-1" style="color: #ffffff !important; background-color: #e74a3b !important;"><i class="fas fa-lock"></i> Locked</span><br>
                                {% endif %}

                                <a href="{{ path('app_forum_show', {'id': post.id}) }}" target="_blank" class="font-weight-bold text-decoration-none" style="color: #4e73df !important;">
                                    {{ post.title|slice(0, 50) }}{{ post.title|length > 50 ? '...' : '' }}
                                </a>
                                <div class="small mt-1" style="color: #858796 !important;">
                                    {{ post.content|striptags|slice(0, 60) }}...
                                </div>
                            </td>
                            <td class="align-middle">
                                <div class="d-flex align-items-center">
                                    <div class="bg-gray-200 rounded-circle d-flex align-items-center justify-content-center mr-2" style="width: 30px; height: 30px;">
                                        <i class="fas fa-user text-gray-600"></i>
                                    </div>
                                    <div>
                                        <div class="font-weight-bold" style="color: #5a5c69 !important;">{{ post.author.username ?? 'Unknown' }}</div>
                                        <div class="small" style="color: #858796 !important;">{{ post.author.email }}</div>
                                    </div>
                                </div>
                            </td>
                            <td class="align-middle text-center">
                                {% set replyCount = post.comments|length %}
                                {% if replyCount == 0 %}
                                    <span class="badge badge-secondary px-2 py-1" style="color: #ffffff !important; background-color: #858796 !important;">0 Replies</span>
                                {% else %}
                                    <span class="badge badge-success px-2 py-1" style="color: #ffffff !important; background-color: #1cc88a !important;">{{ replyCount }} Replies</span>
                                {% endif %}
                            </td>
                            <td class="align-middle">
                                <span style="color: #6e707e !important;">{{ post.createdAt ? post.createdAt|date('M d, Y') : '' }}</span><br>
                                <small style="color: #858796 !important;">{{ post.createdAt ? post.createdAt|date('H:i') : '' }}</small>
                            </td>
                            <td class="align-middle text-center">
                                <div class="btn-group" role="group">
                                    <form method="post" action="{{ path('app_admin_forum_toggle_lock', {'id': post.id}) }}" style="display: inline-block; margin-right: 4px;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('lock' ~ post.id) }}">
                                        {% if post.isLocked %}
                                            <button class="btn btn-warning btn-sm" title="Unlock Topic">
                                                <i class="fas fa-lock-open" style="color: #ffffff !important;"></i>
                                            </button>
                                        {% else %}
                                            <button class="btn btn-secondary btn-sm" title="Lock Topic">
                                                <i class="fas fa-lock" style="color: #ffffff !important;"></i>
                                            </button>
                                        {% endif %}
                                    </form>

                                    <a href="{{ path('app_forum_show', {'id': post.id}) }}" target="_blank" class="btn btn-info btn-sm" title="View Topic">
                                        <i class="fas fa-eye" style="color: #ffffff !important;"></i>
                                    </a>
                                    
                                    <form method="post" action="{{ path('app_admin_forum_delete', {'id': post.id}) }}" onsubmit="return confirm('Are you sure you want to delete this topic?');" style="display: inline-block; margin-left: 4px;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                                        <button class="btn btn-danger btn-sm" title="Delete Topic">
                                            <i class="fas fa-trash" style="color: #ffffff !important;"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <div class="text-gray-500 mb-2"><i class="fas fa-folder-open fa-3x"></i></div>
                                <p class="mb-0" style="color: #858796 !important;">No discussions found matching your search.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}