{% extends 'admin/base.html.twig' %}

{% block title %}Pending Reports{% endblock %}

{% block admin_content %}
<div class="container-fluid">

    {# --- PAGE HEADER --- #}
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <h1 class="h3 mb-0 text-gray-800">
            <i class="fas fa-flag fa-sm text-danger mr-2"></i>Pending Reports
        </h1>
        <a href="{{ path('app_admin_forum_index') }}" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
            <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Back to Forum Moderation
        </a>
    </div>

    <p class="mb-4 text-gray-600">Review content flagged by the community for rule violations.</p>

    {# --- REPORTS TABLE --- #}
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Reported Discussions</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered table-hover" width="100%" cellspacing="0">
                    <thead class="thead-light">
                        <tr>
                            <th style="width: 15%; color: #4e73df !important;">Date</th>
                            <th style="width: 15%; color: #4e73df !important;">Reporter</th>
                            <th style="width: 20%; color: #4e73df !important;">Reason</th>
                            <th style="width: 35%; color: #4e73df !important;">Reported Content</th>
                            <th style="width: 15%; color: #4e73df !important;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for report in reports %}
                        <tr>
                            <td class="align-middle" style="color: #6e707e !important;">
                                {{ report.createdAt|date('M d, Y') }}<br>
                                <small style="color: #858796 !important;">{{ report.createdAt|date('H:i') }}</small>
                            </td>
                            <td class="align-middle">
                                <span class="badge badge-secondary" style="background-color: #858796;">
                                    <i class="fas fa-user mr-1"></i>{{ report.reporter.username }}
                                </span>
                            </td>
                            <td class="align-middle font-weight-bold" style="color: #e74a3b !important;">
                                <i class="fas fa-exclamation-triangle mr-1"></i>{{ report.reason }}
                            </td>
                            <td class="align-middle">
                                <a href="{{ path('app_forum_show', {id: report.post.id}) }}" target="_blank" class="font-weight-bold text-decoration-none" style="color: #4e73df !important;">
                                    {{ report.post.title|slice(0, 40) }}{% if report.post.title|length > 40 %}...{% endif %}
                                </a>
                                <br>
                                <small class="d-inline-block text-truncate" style="max-width: 300px; color: #858796 !important;">
                                    {{ report.post.content }}
                                </small>
                            </td>
                            <td class="align-middle text-center">
                                
                                {# DISMISS BUTTON #}
                                <form action="{{ path('app_admin_forum_report_dismiss', {id: report.id}) }}" method="POST" class="d-inline-block mb-1">
                                    <input type="hidden" name="_token" value="{{ csrf_token('dismiss' ~ report.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary" onclick="return confirm('Dismiss this report? The post will NOT be deleted.')" title="Dismiss Report">
                                        <i class="fas fa-times mr-1"></i> Dismiss
                                    </button>
                                </form>
                                
                                {# DELETE POST BUTTON #}
                                <form action="{{ path('app_admin_forum_delete', {id: report.post.id}) }}" method="POST" class="d-inline-block">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ report.post.id) }}">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this entire discussion permanently? This cannot be undone.')" title="Delete Post">
                                        <i class="fas fa-trash mr-1"></i> Delete Post
                                    </button>
                                </form>

                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="mb-3" style="color: #1cc88a;"><i class="fas fa-check-circle fa-3x"></i></div>
                                <h5 class="text-gray-800">The community is clean!</h5>
                                <p class="mb-0" style="color: #858796 !important;">There are no pending reports to review.</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
{% endblock %}