{% extends 'admin/base.html.twig' %}

{% block title %}Manage Games{% endblock %}

{% block admin_content %}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Games Management</h1>
            <p class="text-muted mb-0">Manage full games and mini games</p>
        </div>
    </div>

    <!-- Flash Messages Container for Ajax -->
    <div id="ajax-flash-messages"></div>

    <!-- Tabs -->
    <ul class="nav nav-tabs mb-4" id="gameTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ app.request.get('tab') == 'mini' ? '' : 'active' }}" id="full-games-tab" data-bs-toggle="tab" data-bs-target="#full-games" type="button" role="tab">
                <i class="bi bi-controller me-2"></i>Full Games
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link {{ app.request.get('tab') == 'mini' ? 'active' : '' }}" id="mini-games-tab" data-bs-toggle="tab" data-bs-target="#mini-games" type="button" role="tab">
                <i class="bi bi-lightning-charge me-2"></i>Mini Games
            </button>
        </li>
    </ul>

    <div class="tab-content" id="gameTabsContent">
        <!-- Full Games Tab -->
        <div class="tab-pane fade {{ app.request.get('tab') == 'mini' ? '' : 'show active' }}" id="full-games" role="tabpanel">
            <div class="d-flex justify-content-end mb-3 gap-2">
                <a href="{{ path('admin_game_templates') }}" class="btn btn-success">
                    <i class="bi bi-magic me-1"></i>Game Templates
                </a>
                <a href="{{ path('admin_game_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Create New Game
                </a>
            </div>

            <!-- Ajax Filters -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Search Input -->
                        <div class="col-md-4">
                            <label for="search-input-full" class="form-label">
                                <i class="bi bi-search"></i> Search Games
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="search-input-full" 
                                   placeholder="Search by name or description..."
                                   value="{{ search }}">
                        </div>

                        <!-- Type Filter -->
                        <div class="col-md-2">
                            <label for="type-filter-full" class="form-label">
                                <i class="bi bi-controller"></i> Type
                            </label>
                            <select class="form-select" id="type-filter-full">
                                <option value="">All Types</option>
                                <option value="PUZZLE" {{ type == 'PUZZLE' ? 'selected' : '' }}>Puzzle</option>
                                <option value="MEMORY" {{ type == 'MEMORY' ? 'selected' : '' }}>Memory</option>
                                <option value="TRIVIA" {{ type == 'TRIVIA' ? 'selected' : '' }}>Trivia</option>
                                <option value="ARCADE" {{ type == 'ARCADE' ? 'selected' : '' }}>Arcade</option>
                            </select>
                        </div>

                        <!-- Difficulty Filter -->
                        <div class="col-md-2">
                            <label for="difficulty-filter-full" class="form-label">
                                <i class="bi bi-speedometer"></i> Difficulty
                            </label>
                            <select class="form-select" id="difficulty-filter-full">
                                <option value="">All Levels</option>
                                <option value="EASY" {{ difficulty == 'EASY' ? 'selected' : '' }}>Easy</option>
                                <option value="MEDIUM" {{ difficulty == 'MEDIUM' ? 'selected' : '' }}>Medium</option>
                                <option value="HARD" {{ difficulty == 'HARD' ? 'selected' : '' }}>Hard</option>
                            </select>
                        </div>

                        <!-- Status Filter -->
                        <div class="col-md-2">
                            <label for="status-filter-full" class="form-label">
                                <i class="bi bi-toggle-on"></i> Status
                            </label>
                            <select class="form-select" id="status-filter-full">
                                <option value="">All Status</option>
                                <option value="active" {{ status == 'active' ? 'selected' : '' }}>Active</option>
                                <option value="inactive" {{ status == 'inactive' ? 'selected' : '' }}>Inactive</option>
                            </select>
                        </div>

                        <!-- Clear Button -->
                        <div class="col-md-2">
                            <label class="form-label d-block">&nbsp;</label>
                            <button class="btn btn-outline-secondary w-100" onclick="clearFilters('full')">
                                <i class="bi bi-x-circle"></i> Clear
                            </button>
                        </div>
                    </div>

                    <!-- Filter Status -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <span class="text-muted">
                                <i class="bi bi-funnel"></i> <span id="results-count-full">{{ fullGames.getTotalItemCount }}</span> game(s) found
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loading Indicator -->
            <div id="loading-indicator-full" class="text-center py-4 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Loading games...</p>
            </div>

            <!-- Games Table Container -->
            <div class="card">
                <div class="card-body" id="full-games-container">
                    {% include 'admin/game/_games_table.html.twig' with {'games': fullGames} %}
                </div>
            </div>
        </div>

        <!-- Mini Games Tab -->
        <div class="tab-pane fade {{ app.request.get('tab') == 'mini' ? 'show active' : '' }}" id="mini-games" role="tabpanel">
            <div class="d-flex justify-content-end mb-3 gap-2">
                <a href="{{ path('admin_game_templates') }}" class="btn btn-success">
                    <i class="bi bi-magic me-1"></i>Game Templates
                </a>
                <a href="{{ path('admin_game_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle me-1"></i>Create New Game
                </a>
            </div>

            <!-- Ajax Filters -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Search Input -->
                        <div class="col-md-6">
                            <label for="search-input-mini" class="form-label">
                                <i class="bi bi-search"></i> Search Mini Games
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="search-input-mini" 
                                   placeholder="Search by name or description..."
                                   value="{{ search }}">
                        </div>

                        <!-- Status Filter -->
                        <div class="col-md-3">
                            <label for="status-filter-mini" class="form-label">
                                <i class="bi bi-toggle-on"></i> Status
                            </label>
                            <select class="form-select" id="status-filter-mini">
                                <option value="">All Status</option>
                                <option value="active" {{ status == 'active' ? 'selected' : '' }}>Active</option>
                                <option value="inactive" {{ status == 'inactive' ? 'selected' : '' }}>Inactive</option>
                            </select>
                        </div>

                        <!-- Clear Button -->
                        <div class="col-md-3">
                            <label class="form-label d-block">&nbsp;</label>
                            <button class="btn btn-outline-secondary w-100" onclick="clearFilters('mini')">
                                <i class="bi bi-x-circle"></i> Clear
                            </button>
                        </div>
                    </div>

                    <!-- Filter Status -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <span class="text-muted">
                                <i class="bi bi-funnel"></i> <span id="results-count-mini">{{ miniGames.getTotalItemCount }}</span> mini game(s) found
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loading Indicator -->
            <div id="loading-indicator-mini" class="text-center py-4 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Loading mini games...</p>
            </div>

            <!-- Mini Games Table Container -->
            <div class="card">
                <div class="card-body" id="mini-games-container">
                    {% include 'admin/game/_games_table.html.twig' with {'games': miniGames} %}
                </div>
            </div>
        </div>
    </div>
</div>

{% block javascripts %}
    {{ parent() }}
    <script>
        let searchTimeout = null;

        // Load games with filters
        function loadGames(category) {
            const searchId = category === 'full' ? 'search-input-full' : 'search-input-mini';
            const typeId = category === 'full' ? 'type-filter-full' : null;
            const difficultyId = category === 'full' ? 'difficulty-filter-full' : null;
            const statusId = category === 'full' ? 'status-filter-full' : 'status-filter-mini';
            const containerId = category === 'full' ? 'full-games-container' : 'mini-games-container';
            const loadingId = category === 'full' ? 'loading-indicator-full' : 'loading-indicator-mini';

            const search = document.getElementById(searchId).value;
            const type = typeId ? document.getElementById(typeId).value : '';
            const difficulty = difficultyId ? document.getElementById(difficultyId).value : '';
            const status = document.getElementById(statusId).value;

            // Build query string
            const params = new URLSearchParams();
            params.append('category', category === 'full' ? 'FULL_GAME' : 'MINI_GAME');
            if (search) params.append('search', search);
            if (type) params.append('type', type);
            if (difficulty) params.append('difficulty', difficulty);
            if (status) params.append('status', status);

            // Show loading indicator
            document.getElementById(loadingId).classList.remove('d-none');
            const container = document.getElementById(containerId);
            container.style.opacity = '0.5';

            // Fetch filtered games
            fetch('{{ path('admin_game_index') }}?' + params.toString(), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                container.innerHTML = html;
                document.getElementById(loadingId).classList.add('d-none');
                container.style.opacity = '1';
                
                // Update URL without reload
                const newUrl = '{{ path('admin_game_index') }}?tab=' + (category === 'mini' ? 'mini' : 'full') + '&' + params.toString();
                window.history.pushState({}, '', newUrl);
            })
            .catch(error => {
                console.error('Error loading games:', error);
                document.getElementById(loadingId).classList.add('d-none');
                container.style.opacity = '1';
            });
        }

        // Clear all filters
        function clearFilters(category) {
            if (category === 'full') {
                document.getElementById('search-input-full').value = '';
                document.getElementById('type-filter-full').value = '';
                document.getElementById('difficulty-filter-full').value = '';
                document.getElementById('status-filter-full').value = '';
            } else {
                document.getElementById('search-input-mini').value = '';
                document.getElementById('status-filter-mini').value = '';
            }
            loadGames(category);
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Full Games filters
            document.getElementById('search-input-full').addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => loadGames('full'), 500);
            });
            document.getElementById('type-filter-full').addEventListener('change', () => loadGames('full'));
            document.getElementById('difficulty-filter-full').addEventListener('change', () => loadGames('full'));
            document.getElementById('status-filter-full').addEventListener('change', () => loadGames('full'));

            // Mini Games filters
            document.getElementById('search-input-mini').addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => loadGames('mini'), 500);
            });
            document.getElementById('status-filter-mini').addEventListener('change', () => loadGames('mini'));
            
            // Handle pagination clicks for full games
            document.getElementById('full-games-container').addEventListener('click', function(e) {
                handlePaginationClick(e, 'full');
            });
            
            // Handle pagination clicks for mini games
            document.getElementById('mini-games-container').addEventListener('click', function(e) {
                handlePaginationClick(e, 'mini');
            });
        });

        function handlePaginationClick(e, category) {
            const paginationLink = e.target.closest('.pagination a.page-link');
            if (paginationLink) {
                e.preventDefault();
                const url = new URL(paginationLink.href);
                const page = url.searchParams.get('page') || 1;
                
                const searchId = category === 'full' ? 'search-input-full' : 'search-input-mini';
                const typeId = category === 'full' ? 'type-filter-full' : null;
                const difficultyId = category === 'full' ? 'difficulty-filter-full' : null;
                const statusId = category === 'full' ? 'status-filter-full' : 'status-filter-mini';
                const containerId = category === 'full' ? 'full-games-container' : 'mini-games-container';
                const loadingId = category === 'full' ? 'loading-indicator-full' : 'loading-indicator-mini';
                
                // Get current filters
                const search = document.getElementById(searchId).value;
                const type = typeId ? document.getElementById(typeId).value : '';
                const difficulty = difficultyId ? document.getElementById(difficultyId).value : '';
                const status = document.getElementById(statusId).value;
                
                // Build query string with page
                const params = new URLSearchParams();
                params.append('page', page);
                params.append('category', category === 'full' ? 'FULL_GAME' : 'MINI_GAME');
                if (search) params.append('search', search);
                if (type) params.append('type', type);
                if (difficulty) params.append('difficulty', difficulty);
                if (status) params.append('status', status);
                
                // Show loading indicator
                document.getElementById(loadingId).classList.remove('d-none');
                const container = document.getElementById(containerId);
                container.style.opacity = '0.5';
                
                // Fetch page
                fetch('{{ path('admin_game_index') }}?' + params.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    container.innerHTML = html;
                    document.getElementById(loadingId).classList.add('d-none');
                    container.style.opacity = '1';
                    
                    // Update URL without reload
                    const newUrl = '{{ path('admin_game_index') }}?tab=' + (category === 'mini' ? 'mini' : 'full') + '&' + params.toString();
                    window.history.pushState({}, '', newUrl);
                    
                    // Scroll to top of table
                    container.scrollIntoView({ behavior: 'smooth', block: 'start' });
                })
                .catch(error => {
                    console.error('Error loading page:', error);
                    document.getElementById(loadingId).classList.add('d-none');
                    container.style.opacity = '1';
                });
            }
        }

        // Toggle game status function (from previous implementation)
        function toggleGameStatus(gameId, csrfToken) {
            const toggleBtn = document.querySelector('.btn-toggle-' + gameId);
            const statusBadge = document.querySelector('.status-badge-' + gameId);
            const gameRow = document.getElementById('game-row-' + gameId);
            
            toggleBtn.disabled = true;
            toggleBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
            
            fetch('/admin/games/' + gameId + '/toggle-active', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: '_token=' + encodeURIComponent(csrfToken)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (data.isActive) {
                        statusBadge.className = 'badge status-badge-' + gameId + ' bg-success';
                        statusBadge.textContent = 'Active';
                        toggleBtn.className = 'btn btn-sm btn-toggle-' + gameId + ' btn-secondary';
                        toggleBtn.title = 'Deactivate';
                        toggleBtn.innerHTML = '<i class="bi bi-pause-circle"></i>';
                        gameRow.style.animation = 'fadeIn 0.5s';
                    } else {
                        statusBadge.className = 'badge status-badge-' + gameId + ' bg-secondary';
                        statusBadge.textContent = 'Inactive';
                        toggleBtn.className = 'btn btn-sm btn-toggle-' + gameId + ' btn-success';
                        toggleBtn.title = 'Activate';
                        toggleBtn.innerHTML = '<i class="bi bi-play-circle"></i>';
                        gameRow.style.animation = 'fadeOut 0.5s';
                    }
                    showFlashMessage('success', data.message);
                } else {
                    showFlashMessage('danger', data.message);
                    toggleBtn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showFlashMessage('danger', 'An error occurred while toggling game status.');
                toggleBtn.disabled = false;
            })
            .finally(() => {
                toggleBtn.disabled = false;
            });
        }
        
        function showFlashMessage(type, message) {
            const container = document.getElementById('ajax-flash-messages');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} alert-dismissible fade show`;
            alert.role = 'alert';
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            container.appendChild(alert);
            setTimeout(() => {
                alert.classList.remove('show');
                setTimeout(() => alert.remove(), 150);
            }, 5000);
        }
    </script>
    
    <style>
        @keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0.5; }
        }
        
        @keyframes fadeIn {
            from { opacity: 0.5; }
            to { opacity: 1; }
        }
        
        #ajax-flash-messages {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
            max-width: 400px;
        }
        
        #ajax-flash-messages .alert {
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            animation: slideInRight 0.3s ease-out;
        }
        
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
{% endblock %}
{% endblock %}
