{% extends 'admin/base.html.twig' %}

{% block title %}Manage Games{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Games Management</h1>
            <p class="text-muted mb-0">Manage all games and their rewards</p>
        </div>
        <a href="{{ path('admin_game_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Create New Game
        </a>
    </div>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Difficulty</th>
                            <th>Token Cost</th>
                            <th>Base Rewards</th>
                            <th>Special Rewards</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for game in games %}
                            <tr>
                                <td>{{ game.id }}</td>
                                <td>
                                    <strong>{{ game.name }}</strong>
                                </td>
                                <td><span class="badge bg-info">{{ game.type }}</span></td>
                                <td><span class="badge bg-warning text-dark">{{ game.difficulty }}</span></td>
                                <td>{{ game.tokenCost }} <i class="bi bi-coin text-warning"></i></td>
                                <td>
                                    <small class="text-muted">
                                        {{ game.rewardTokens }}T / {{ game.rewardXP }}XP
                                    </small>
                                </td>
                                <td>
                                    {% if game.rewards|length > 0 %}
                                        <span class="badge bg-success" title="{{ game.rewards|length }} special reward(s)">
                                            <i class="bi bi-trophy-fill me-1"></i>{{ game.rewards|length }}
                                        </span>
                                    {% else %}
                                        <span class="badge bg-secondary">None</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if game.isActive %}
                                        <span class="badge bg-success">Active</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Inactive</span>
                                    {% endif %}
                                </td>

                                <td>
                                    <div class="btn-group btn-group-sm" role="group">
                                        <a href="{{ path('admin_game_show', {id: game.id}) }}" 
                                           class="btn btn-info" 
                                           title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        <a href="{{ path('admin_game_edit', {id: game.id}) }}" 
                                           class="btn btn-warning" 
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" 
                                              action="{{ path('admin_game_delete', {id: game.id}) }}" 
                                              style="display:inline;"
                                              onsubmit="return confirm('Are you sure you want to delete {{ game.name|escape('js') }}? This action cannot be undone.');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="9" class="text-center py-4">
                                    <i class="bi bi-inbox fs-1 text-muted"></i>
                                    <p class="text-muted mt-2">No games found</p>
                                    <a href="{{ path('admin_game_new') }}" class="btn btn-primary">
                                        Create Your First Game
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}