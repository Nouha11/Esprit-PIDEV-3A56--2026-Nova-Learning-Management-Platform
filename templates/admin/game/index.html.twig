{% extends 'admin/base.html.twig' %}

{% block title %}Manage Games{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>Games Management</h1>
            <p class="text-muted mb-0">Manage all games and their rewards</p>
        </div>
        <div class="btn-group">
            <a href="{{ path('admin_game_templates') }}" class="btn btn-success">
                <i class="bi bi-magic me-1"></i>Game Templates
            </a>
            <a href="{{ path('admin_game_new') }}" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Create New Game
            </a>
        </div>
    </div>

    <!-- Flash Messages Container for Ajax -->
    <div id="ajax-flash-messages"></div>

    <!-- Ajax Filters -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-3">
                <!-- Search Input -->
                <div class="col-md-4">
                    <label for="search-input" class="form-label">
                        <i class="bi bi-search"></i> Search Games
                    </label>
                    <input type="text" 
                           class="form-control" 
                           id="search-input" 
                           placeholder="Search by name or description..."
                           value="{{ search }}">
                </div>

                <!-- Type Filter -->
                <div class="col-md-2">
                    <label for="type-filter" class="form-label">
                        <i class="bi bi-controller"></i> Type
                    </label>
                    <select class="form-select" id="type-filter">
                        <option value="">All Types</option>
                        <option value="PUZZLE" {{ type == 'PUZZLE' ? 'selected' : '' }}>Puzzle</option>
                        <option value="MEMORY" {{ type == 'MEMORY' ? 'selected' : '' }}>Memory</option>
                        <option value="TRIVIA" {{ type == 'TRIVIA' ? 'selected' : '' }}>Trivia</option>
                        <option value="ARCADE" {{ type == 'ARCADE' ? 'selected' : '' }}>Arcade</option>
                    </select>
                </div>

                <!-- Difficulty Filter -->
                <div class="col-md-2">
                    <label for="difficulty-filter" class="form-label">
                        <i class="bi bi-speedometer"></i> Difficulty
                    </label>
                    <select class="form-select" id="difficulty-filter">
                        <option value="">All Levels</option>
                        <option value="EASY" {{ difficulty == 'EASY' ? 'selected' : '' }}>Easy</option>
                        <option value="MEDIUM" {{ difficulty == 'MEDIUM' ? 'selected' : '' }}>Medium</option>
                        <option value="HARD" {{ difficulty == 'HARD' ? 'selected' : '' }}>Hard</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div class="col-md-2">
                    <label for="status-filter" class="form-label">
                        <i class="bi bi-toggle-on"></i> Status
                    </label>
                    <select class="form-select" id="status-filter">
                        <option value="">All Status</option>
                        <option value="active" {{ status == 'active' ? 'selected' : '' }}>Active</option>
                        <option value="inactive" {{ status == 'inactive' ? 'selected' : '' }}>Inactive</option>
                    </select>
                </div>

                <!-- Clear Button -->
                <div class="col-md-2">
                    <label class="form-label d-block">&nbsp;</label>
                    <button class="btn btn-outline-secondary w-100" onclick="clearFilters()">
                        <i class="bi bi-x-circle"></i> Clear
                    </button>
                </div>
            </div>

            <!-- Filter Status -->
            <div class="row mt-3">
                <div class="col-12">
                    <span class="text-muted">
                        <i class="bi bi-funnel"></i> <span id="results-count">{{ games.getTotalItemCount }}</span> game(s) found
                    </span>
                </div>
            </div>
        </div>
    </div>

    <!-- Loading Indicator -->
    <div id="loading-indicator" class="text-center py-4 d-none">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="mt-2 text-muted">Loading games...</p>
    </div>

    <!-- Games Table Container -->
    <div class="card" id="games-container">
        <div class="card-body">
            {% include 'admin/game/_games_table.html.twig' %}
        </div>
    </div>

{% block javascripts %}
    {{ parent() }}
    <script>
        let searchTimeout = null;

        // Load games with filters
        function loadGames() {
            const search = document.getElementById('search-input').value;
            const type = document.getElementById('type-filter').value;
            const difficulty = document.getElementById('difficulty-filter').value;
            const status = document.getElementById('status-filter').value;

            // Build query string
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            if (type) params.append('type', type);
            if (difficulty) params.append('difficulty', difficulty);
            if (status) params.append('status', status);

            // Show loading indicator
            document.getElementById('loading-indicator').classList.remove('d-none');
            const container = document.getElementById('games-container');
            container.style.opacity = '0.5';

            // Fetch filtered games
            fetch('{{ path('admin_game_index') }}?' + params.toString(), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                container.querySelector('.card-body').innerHTML = html;
                document.getElementById('loading-indicator').classList.add('d-none');
                container.style.opacity = '1';
                
                // Update URL without reload
                const newUrl = '{{ path('admin_game_index') }}?' + params.toString();
                window.history.pushState({}, '', newUrl);
            })
            .catch(error => {
                console.error('Error loading games:', error);
                document.getElementById('loading-indicator').classList.add('d-none');
                container.style.opacity = '1';
            });
        }

        // Clear all filters
        function clearFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('type-filter').value = '';
            document.getElementById('difficulty-filter').value = '';
            document.getElementById('status-filter').value = '';
            loadGames();
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Search input with debounce
            document.getElementById('search-input').addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(loadGames, 500);
            });

            // Dropdown filters
            document.getElementById('type-filter').addEventListener('change', loadGames);
            document.getElementById('difficulty-filter').addEventListener('change', loadGames);
            document.getElementById('status-filter').addEventListener('change', loadGames);
        });

        // Toggle game status function (from previous implementation)
        function toggleGameStatus(gameId, csrfToken) {
            const toggleBtn = document.querySelector('.btn-toggle-' + gameId);
            const statusBadge = document.querySelector('.status-badge-' + gameId);
            const gameRow = document.getElementById('game-row-' + gameId);
            
            toggleBtn.disabled = true;
            toggleBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span>';
            
            fetch('/admin/games/' + gameId + '/toggle-active', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: '_token=' + encodeURIComponent(csrfToken)
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    if (data.isActive) {
                        statusBadge.className = 'badge status-badge-' + gameId + ' bg-success';
                        statusBadge.textContent = 'Active';
                        toggleBtn.className = 'btn btn-sm btn-toggle-' + gameId + ' btn-secondary';
                        toggleBtn.title = 'Deactivate';
                        toggleBtn.innerHTML = '<i class="bi bi-pause-circle"></i>';
                        gameRow.style.animation = 'fadeIn 0.5s';
                    } else {
                        statusBadge.className = 'badge status-badge-' + gameId + ' bg-secondary';
                        statusBadge.textContent = 'Inactive';
                        toggleBtn.className = 'btn btn-sm btn-toggle-' + gameId + ' btn-success';
                        toggleBtn.title = 'Activate';
                        toggleBtn.innerHTML = '<i class="bi bi-play-circle"></i>';
                        gameRow.style.animation = 'fadeOut 0.5s';
                    }
                    showFlashMessage('success', data.message);
                } else {
                    showFlashMessage('danger', data.message);
                    toggleBtn.disabled = false;
                }
            })
            .catch(error => {
                console.error('Error:', error);
                showFlashMessage('danger', 'An error occurred while toggling game status.');
                toggleBtn.disabled = false;
            })
            .finally(() => {
                toggleBtn.disabled = false;
            });
        }
        
        function showFlashMessage(type, message) {
            const container = document.getElementById('ajax-flash-messages');
            const alert = document.createElement('div');
            alert.className = `alert alert-${type} alert-dismissible fade show`;
            alert.role = 'alert';
            alert.innerHTML = `
                ${message}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            `;
            container.appendChild(alert);
            setTimeout(() => {
                alert.classList.remove('show');
                setTimeout(() => alert.remove(), 150);
            }, 5000);
        }
    </script>
    
    <style>
        @keyframes fadeOut {
            from { opacity: 1; }
            to { opacity: 0.5; }
        }
        
        @keyframes fadeIn {
            from { opacity: 0.5; }
            to { opacity: 1; }
        }
        
        #ajax-flash-messages {
            position: fixed;
            top: 80px;
            right: 20px;
            z-index: 9999;
            max-width: 400px;
        }
        
        #ajax-flash-messages .alert {
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            animation: slideInRight 0.3s ease-out;
        }
        
        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
{% endblock %}
{% endblock %}
