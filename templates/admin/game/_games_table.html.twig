{% if games|length > 0 %}
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Difficulty</th>
                    <th>Token Cost</th>
                    <th>Base Rewards</th>
                    <th>Special Rewards</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                {% for game in games %}
                    <tr id="game-row-{{ game.id }}">
                        <td>{{ game.id }}</td>
                        <td>
                            <strong>{{ game.name }}</strong>
                        </td>
                        <td><span class="badge bg-info">{{ game.type }}</span></td>
                        <td><span class="badge bg-warning text-dark">{{ game.difficulty }}</span></td>
                        <td>{{ game.tokenCost }} <i class="bi bi-coin text-warning"></i></td>
                        <td>
                            <small class="text-muted">
                                {{ game.rewardTokens }}T / {{ game.rewardXP }}XP
                            </small>
                        </td>
                        <td>
                            {% if game.rewards|length > 0 %}
                                <span class="badge bg-success" title="{{ game.rewards|length }} special reward(s)">
                                    <i class="bi bi-trophy-fill me-1"></i>{{ game.rewards|length }}
                                </span>
                            {% else %}
                                <span class="badge bg-secondary">None</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge status-badge-{{ game.id }} {{ game.isActive ? 'bg-success' : 'bg-secondary' }}">
                                {{ game.isActive ? 'Active' : 'Inactive' }}
                            </span>
                        </td>

                        <td>
                            <div class="btn-group btn-group-sm" role="group">
                                <!-- Toggle Active Button -->
                                <button type="button" 
                                        class="btn btn-toggle-{{ game.id }} {{ game.isActive ? 'btn-secondary' : 'btn-success' }}" 
                                        onclick="toggleGameStatus({{ game.id }}, '{{ csrf_token('toggle_active_' ~ game.id) }}')"
                                        title="{{ game.isActive ? 'Deactivate' : 'Activate' }}">
                                    <i class="bi bi-{{ game.isActive ? 'pause-circle' : 'play-circle' }}"></i>
                                </button>
                                
                                <a href="{{ path('admin_game_show', {id: game.id}) }}" 
                                   class="btn btn-info" 
                                   title="View">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a href="{{ path('admin_game_edit', {id: game.id}) }}" 
                                   class="btn btn-warning" 
                                   title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" 
                                      action="{{ path('admin_game_delete', {id: game.id}) }}" 
                                      style="display:inline;"
                                      onsubmit="return confirm('Are you sure you want to delete {{ game.name|escape('js') }}? This action cannot be undone.');">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ game.id) }}">
                                    <button type="submit" class="btn btn-danger btn-sm" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    
    <!-- Pagination -->
    <div class="mt-3">
        {{ knp_pagination_render(games, 'pagination/custom_pagination.html.twig') }}
    </div>
{% else %}
    <div class="text-center py-5">
        <i class="bi bi-inbox fs-1 text-muted"></i>
        <p class="text-muted mt-3">No games found matching your filters.</p>
        <button class="btn btn-outline-primary" onclick="clearFilters()">
            <i class="bi bi-x-circle me-1"></i>Clear Filters
        </button>
    </div>
{% endif %}
