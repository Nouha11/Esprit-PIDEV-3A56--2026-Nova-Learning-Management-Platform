{% extends 'admin/base.html.twig' %}

{% block title %}Loan Details #{{ loan.id }}{% endblock %}

{% block admin_content %}
<div class="container-fluid p-4">
    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('admin_loans_index') }}">Loans</a></li>
            <li class="breadcrumb-item active">Loan #{{ loan.id }}</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1 class="h3 mb-0">Loan Details #{{ loan.id }}</h1>
            <p class="text-muted">Complete information about this loan request</p>
        </div>
        <div class="col-md-4 text-end">
            <span class="badge {{ loan.statusBadgeClass }} fs-6">{{ loan.statusLabel }}</span>
        </div>
    </div>

    <div class="row g-4">
        <!-- User Information -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>User Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless mb-0">
                        <tr>
                            <th width="40%">Username:</th>
                            <td>{{ loan.user.username }}</td>
                        </tr>
                        <tr>
                            <th>Email:</th>
                            <td>{{ loan.user.email }}</td>
                        </tr>
                        <tr>
                            <th>Roles:</th>
                            <td>
                                {% for role in loan.user.roles %}
                                    <span class="badge bg-secondary">{{ role }}</span>
                                {% endfor %}
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </div>

        <!-- Book Information -->
        <div class="col-md-6">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="bi bi-book me-2"></i>Book Information</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex">
                        {% if loan.book.coverImage %}
                            <img src="{{ asset(loan.book.coverImage) }}" alt="{{ loan.book.title }}" class="rounded me-3" style="width: 80px; height: auto;">
                        {% else %}
                            <img src="{{ asset('assets/images/book/01.jpg') }}" alt="{{ loan.book.title }}" class="rounded me-3" style="width: 80px; height: auto;">
                        {% endif %}
                        <div>
                            <h6 class="mb-1">{{ loan.book.title }}</h6>
                            <p class="text-muted mb-1"><small>by {{ loan.book.author ?? 'Unknown Author' }}</small></p>
                            {% if loan.book.isPhysical %}
                                <span class="badge bg-info">Physical</span>
                            {% endif %}
                            {% if loan.book.isDigital %}
                                <span class="badge bg-warning">Digital</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Loan Timeline -->
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Loan Timeline</h5>
                </div>
                <div class="card-body">
                    <table class="table table-borderless">
                        <tr>
                            <th width="30%">Requested At:</th>
                            <td>{{ loan.requestedAt|date('F d, Y \\a\\t H:i') }}</td>
                        </tr>
                        <tr>
                            <th>Pickup Date:</th>
                            <td>{{ loan.startAt|date('F d, Y \\a\\t H:i') }}</td>
                        </tr>
                        <tr>
                            <th>Expected Return:</th>
                            <td>
                                {% if loan.endAt %}
                                    {{ loan.endAt|date('F d, Y \\a\\t H:i') }}
                                {% else %}
                                    <span class="text-muted">Not set</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% if loan.approvedAt %}
                        <tr>
                            <th>Approved At:</th>
                            <td>{{ loan.approvedAt|date('F d, Y \\a\\t H:i') }}</td>
                        </tr>
                        {% endif %}
                        {% if loan.library %}
                        <tr>
                            <th>Library:</th>
                            <td>
                                <i class="bi bi-building me-1"></i>{{ loan.library.name }}
                                {% if loan.library.address %}
                                    <br><small class="text-muted">{{ loan.library.address }}</small>
                                {% endif %}
                            </td>
                        </tr>
                        {% endif %}
                    </table>

                    {% if loan.rejectionReason %}
                        <div class="alert alert-danger mt-3">
                            <strong>Rejection Reason:</strong><br>
                            {{ loan.rejectionReason }}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Actions -->
        <div class="col-md-12">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-gear me-2"></i>Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-flex gap-2">
                        {% if loan.status == 'PENDING' %}
                            <form method="post" action="{{ path('admin_loans_approve', {id: loan.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ loan.id) }}">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-check-lg me-1"></i>Approve Loan
                                </button>
                            </form>
                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="bi bi-x-lg me-1"></i>Reject Loan
                            </button>
                        {% endif %}

                        {% if loan.status == 'APPROVED' %}
                            <form method="post" action="{{ path('admin_loans_mark_active', {id: loan.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('mark_active' ~ loan.id) }}">
                                <button type="submit" class="btn btn-info">
                                    <i class="bi bi-arrow-right me-1"></i>Mark as Active (Book Picked Up)
                                </button>
                            </form>
                        {% endif %}

                        {% if loan.status == 'ACTIVE' %}
                            <form method="post" action="{{ path('admin_loans_mark_returned', {id: loan.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('mark_returned' ~ loan.id) }}">
                                <button type="submit" class="btn btn-success">
                                    <i class="bi bi-arrow-return-left me-1"></i>Mark as Returned
                                </button>
                            </form>
                        {% endif %}

                        <a href="{{ path('admin_loans_index') }}" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Back to List
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" action="{{ path('admin_loans_reject', {id: loan.id}) }}">
                <div class="modal-header">
                    <h5 class="modal-title">Reject Loan Request</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="reason" class="form-label">Rejection Reason *</label>
                        <textarea class="form-control" id="reason" name="reason" rows="4" placeholder="Please provide a reason for rejection..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ loan.id) }}">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject Loan</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
