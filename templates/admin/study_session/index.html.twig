{% extends 'admin/base.html.twig' %}

{% block title %}Manage Study Sessions{% endblock %}

{% block admin_content %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0 text-gray-800">Study Sessions Management</h1>
        <div>
            <a href="{{ path('admin_study_session_analytics') }}" class="btn btn-primary me-2">
                <i class="fas fa-chart-bar"></i> View Analytics
            </a>
            <a href="{{ path('analytics_dashboard') }}" class="btn btn-success">
                <i class="fas fa-chart-line"></i> Full Analytics
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-primary shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Sessions</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">{{ study_sessions|length }}</div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-calendar fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-success shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Completed</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% set completed = 0 %}
                                {% for session in study_sessions %}
                                    {% if session.completedAt %}
                                        {% set completed = completed + 1 %}
                                    {% endif %}
                                {% endfor %}
                                {{ completed }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-check-circle fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-info shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-info text-uppercase mb-1">With Notes</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% set with_notes = 0 %}
                                {% for session in study_sessions %}
                                    {% if session.notes|length > 0 %}
                                        {% set with_notes = with_notes + 1 %}
                                    {% endif %}
                                {% endfor %}
                                {{ with_notes }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-sticky-note fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card border-left-warning shadow h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">With Resources</div>
                            <div class="h5 mb-0 font-weight-bold text-gray-800">
                                {% set with_resources = 0 %}
                                {% for session in study_sessions %}
                                    {% if session.resources|length > 0 %}
                                        {% set with_resources = with_resources + 1 %}
                                    {% endif %}
                                {% endfor %}
                                {{ with_resources }}
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="fas fa-file-pdf fa-2x text-gray-300"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Links -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Quick Access</h6>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3 mb-2">
                    <a href="{{ path('calendar_index') }}" class="btn btn-outline-primary btn-block">
                        <i class="fas fa-calendar-alt"></i> Calendar View
                    </a>
                </div>
                <div class="col-md-3 mb-2">
                    <a href="{{ path('tag_index') }}" class="btn btn-outline-info btn-block">
                        <i class="fas fa-tags"></i> Manage Tags
                    </a>
                </div>
                <div class="col-md-3 mb-2">
                    <a href="{{ path('energy_analytics') }}" class="btn btn-outline-warning btn-block">
                        <i class="fas fa-bolt"></i> Energy Patterns
                    </a>
                </div>
                <div class="col-md-3 mb-2">
                    <a href="{{ path('integration_ai_recommendations') }}" class="btn btn-outline-success btn-block">
                        <i class="fas fa-robot"></i> AI Tools
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">Filters</h6>
        </div>
        <div class="card-body">
            <form method="get" action="{{ path('admin_study_session_index') }}">
                <div class="row">
                    <div class="col-md-2">
                        <label>User ID</label>
                        <input type="number" name="userId" class="form-control" value="{{ current_user_id ?? '' }}" placeholder="Enter user ID">
                    </div>
                    <div class="col-md-2">
                        <label>Burnout Risk</label>
                        <select name="burnoutRisk" class="form-control">
                            <option value="">All Levels</option>
                            <option value="LOW" {% if current_burnout_risk == 'LOW' %}selected{% endif %}>Low</option>
                            <option value="MODERATE" {% if current_burnout_risk == 'MODERATE' %}selected{% endif %}>Moderate</option>
                            <option value="HIGH" {% if current_burnout_risk == 'HIGH' %}selected{% endif %}>High</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Mood</label>
                        <select name="mood" class="form-control">
                            <option value="">All Moods</option>
                            <option value="positive" {% if current_mood == 'positive' %}selected{% endif %}>Positive</option>
                            <option value="neutral" {% if current_mood == 'neutral' %}selected{% endif %}>Neutral</option>
                            <option value="negative" {% if current_mood == 'negative' %}selected{% endif %}>Negative</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Energy Level</label>
                        <select name="energyLevel" class="form-control">
                            <option value="">All Levels</option>
                            <option value="high" {% if current_energy_level == 'high' %}selected{% endif %}>High</option>
                            <option value="medium" {% if current_energy_level == 'medium' %}selected{% endif %}>Medium</option>
                            <option value="low" {% if current_energy_level == 'low' %}selected{% endif %}>Low</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label>Date From</label>
                        <input type="date" name="dateFrom" class="form-control" value="{{ date_from ? date_from|date('Y-m-d') : '' }}">
                    </div>
                    <div class="col-md-2">
                        <label>Date To</label>
                        <input type="date" name="dateTo" class="form-control" value="{{ date_to ? date_to|date('Y-m-d') : '' }}">
                    </div>
                </div>
                <div class="row mt-3">
                    <div class="col-md-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-filter"></i> Apply Filters
                        </button>
                        <a href="{{ path('admin_study_session_index') }}" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Clear Filters
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Study Sessions Table -->
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">All Study Sessions</h6>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-bordered" width="100%" cellspacing="0">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>User</th>
                            <th>Planning</th>
                            <th>Started At</th>
                            <th>Duration (min)</th>
                            <th>XP Earned</th>
                            <th>Notes</th>
                            <th>Tags</th>
                            <th>Mood</th>
                            <th>Energy</th>
                            <th>Burnout Risk</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for session in study_sessions %}
                            <tr>
                                <td>{{ session.id }}</td>
                                <td>{{ session.user.email }}</td>
                                <td>{{ session.planning.title }}</td>
                                <td>{{ session.startedAt|date('Y-m-d H:i') }}</td>
                                <td>{{ session.duration }}</td>
                                <td>{{ session.xpEarned ?? 0 }}</td>
                                <td>
                                    {% if session.notes|length > 0 %}
                                        <button class="btn btn-sm btn-outline-primary" 
                                                data-bs-toggle="modal" 
                                                data-bs-target="#notesModal{{ session.id }}"
                                                title="View {{ session.notes|length }} note(s)">
                                            <i class="fas fa-sticky-note"></i> {{ session.notes|length }}
                                        </button>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if session.tags|length > 0 %}
                                        <div class="d-flex flex-wrap gap-1">
                                            {% for tag in session.tags %}
                                                <span class="badge bg-info" title="{{ tag.name }}">
                                                    <i class="fas fa-tag"></i> {{ tag.name }}
                                                </span>
                                            {% endfor %}
                                        </div>
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if session.mood %}
                                        {% if session.mood == 'positive' %}
                                            <span class="badge bg-success">😊 Positive</span>
                                        {% elseif session.mood == 'neutral' %}
                                            <span class="badge bg-secondary">😐 Neutral</span>
                                        {% else %}
                                            <span class="badge bg-danger">😞 Negative</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if session.energyLevel %}
                                        {% if session.energyLevel == 'high' %}
                                            <span class="badge bg-success">⚡ High</span>
                                        {% elseif session.energyLevel == 'medium' %}
                                            <span class="badge bg-warning">⚡ Medium</span>
                                        {% else %}
                                            <span class="badge bg-danger">⚡ Low</span>
                                        {% endif %}
                                    {% else %}
                                        <span class="text-muted">-</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if session.burnoutRisk == 'HIGH' %}
                                        <span class="badge bg-danger">High</span>
                                    {% elseif session.burnoutRisk == 'MODERATE' %}
                                        <span class="badge bg-warning">Moderate</span>
                                    {% else %}
                                        <span class="badge bg-success">Low</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if session.completedAt %}
                                        <span class="badge bg-success">✓ Completed</span>
                                    {% else %}
                                        <span class="badge bg-secondary">Planned</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <a href="{{ path('admin_study_session_show', {id: session.id}) }}" class="btn btn-sm btn-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="13" class="text-center">No study sessions found</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Notes Modals -->
    {% for session in study_sessions %}
        {% if session.notes|length > 0 %}
            <div class="modal fade" id="notesModal{{ session.id }}" tabindex="-1" aria-labelledby="notesModalLabel{{ session.id }}" aria-hidden="true">
                <div class="modal-dialog modal-lg">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title" id="notesModalLabel{{ session.id }}">
                                <i class="fas fa-sticky-note"></i> Notes for Session #{{ session.id }}
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <strong>Session:</strong> {{ session.planning.title }}<br>
                                <strong>User:</strong> {{ session.user.email }}<br>
                                <strong>Date:</strong> {{ session.startedAt|date('Y-m-d H:i') }}
                            </div>
                            <hr>
                            {% for note in session.notes %}
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <h6 class="card-title">
                                            <i class="fas fa-file-alt text-primary"></i> Note #{{ note.id }}
                                        </h6>
                                        <p class="card-text">{{ note.content }}</p>
                                        <small class="text-muted">
                                            <i class="fas fa-clock"></i> Created: {{ note.createdAt|date('Y-m-d H:i:s') }}
                                        </small>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    {% endfor %}
{% endblock %}
