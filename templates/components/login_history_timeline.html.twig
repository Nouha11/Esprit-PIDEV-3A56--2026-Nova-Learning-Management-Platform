{# Login History Timeline Component #}
{% set loginHistory = loginHistory|default([]) %}
{% set showUser = showUser|default(false) %}
{% set limit = limit|default(10) %}

<div class="login-history-timeline">
    {% if loginHistory is empty %}
        <div class="text-center py-5">
            <i class="bi bi-clock-history fs-1 text-muted"></i>
            <p class="text-muted mt-3">No login history available</p>
        </div>
    {% else %}
        <div class="timeline">
            {% for login in loginHistory|slice(0, limit) %}
                <div class="timeline-item {% if login.status == 'success' %}timeline-success{% elseif login.status == 'failed' %}timeline-danger{% else %}timeline-warning{% endif %}">
                    <div class="timeline-marker">
                        {% if login.status == 'success' %}
                            <i class="bi bi-check-circle-fill text-success"></i>
                        {% elseif login.status == 'failed' %}
                            <i class="bi bi-x-circle-fill text-danger"></i>
                        {% else %}
                            <i class="bi bi-shield-fill-exclamation text-warning"></i>
                        {% endif %}
                    </div>
                    
                    <div class="timeline-content card border-0 shadow-sm">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="mb-1">
                                        {% if login.status == 'success' %}
                                            <span class="badge bg-success-soft text-success">Successful Login</span>
                                        {% elseif login.status == 'failed' %}
                                            <span class="badge bg-danger-soft text-danger">Failed Login</span>
                                        {% else %}
                                            <span class="badge bg-warning-soft text-warning">Blocked Login</span>
                                        {% endif %}
                                        
                                        {% if login.is2faUsed %}
                                            <span class="badge bg-primary-soft text-primary ms-1">
                                                <i class="bi bi-shield-check"></i> 2FA
                                            </span>
                                        {% endif %}
                                    </h6>
                                    
                                    {% if showUser and login.user %}
                                        <p class="mb-1 small">
                                            <i class="bi bi-person"></i>
                                            <strong>{{ login.user.username }}</strong>
                                            ({{ login.user.email }})
                                        </p>
                                    {% endif %}
                                </div>
                                
                                <small class="text-muted">
                                    <i class="bi bi-clock"></i>
                                    {{ login.createdAt|date('M d, Y H:i') }}
                                </small>
                            </div>
                            
                            <div class="row g-2 small text-muted">
                                {% if login.ipAddress %}
                                    <div class="col-md-6">
                                        <i class="bi bi-geo-alt"></i>
                                        <strong>IP:</strong> {{ login.ipAddress }}
                                        {% if login.location %}
                                            <span class="badge bg-light text-dark ms-1">{{ login.location }}</span>
                                        {% endif %}
                                    </div>
                                {% endif %}
                                
                                {% if login.browser %}
                                    <div class="col-md-6">
                                        <i class="bi bi-browser-chrome"></i>
                                        <strong>Browser:</strong> {{ login.browser }}
                                    </div>
                                {% endif %}
                                
                                {% if login.platform %}
                                    <div class="col-md-6">
                                        <i class="bi bi-laptop"></i>
                                        <strong>Platform:</strong> {{ login.platform }}
                                    </div>
                                {% endif %}
                                
                                {% if login.device %}
                                    <div class="col-md-6">
                                        <i class="bi bi-phone"></i>
                                        <strong>Device:</strong> {{ login.device }}
                                    </div>
                                {% endif %}
                            </div>
                            
                            {% if login.failureReason %}
                                <div class="alert alert-danger alert-sm mt-2 mb-0">
                                    <i class="bi bi-exclamation-triangle"></i>
                                    <strong>Reason:</strong> {{ login.failureReason }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<style>
.login-history-timeline {
    position: relative;
}

.timeline {
    position: relative;
    padding-left: 30px;
}

.timeline::before {
    content: '';
    position: absolute;
    left: 10px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, #e9ecef 0%, #e9ecef 100%);
}

.timeline-item {
    position: relative;
    margin-bottom: 20px;
}

.timeline-marker {
    position: absolute;
    left: -24px;
    top: 8px;
    width: 24px;
    height: 24px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
}

.timeline-marker i {
    font-size: 20px;
}

.timeline-content {
    margin-left: 20px;
}

.timeline-item:last-child {
    margin-bottom: 0;
}

/* Badge soft colors */
.bg-success-soft {
    background-color: rgba(25, 135, 84, 0.1);
}

.bg-danger-soft {
    background-color: rgba(220, 53, 69, 0.1);
}

.bg-warning-soft {
    background-color: rgba(255, 193, 7, 0.1);
}

.bg-primary-soft {
    background-color: rgba(13, 110, 253, 0.1);
}

.alert-sm {
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
}

/* Dark mode support */
[data-bs-theme="dark"] .timeline::before {
    background: linear-gradient(to bottom, #495057 0%, #495057 100%);
}

[data-bs-theme="dark"] .timeline-marker {
    background: var(--bs-dark);
}

[data-bs-theme="dark"] .timeline-content {
    background: var(--bs-dark);
}
</style>
