{# Password Strength Meter Component #}
{% set inputId = inputId|default('password') %}
{% set showRequirements = showRequirements|default(true) %}
{% set showGenerator = showGenerator|default(false) %}

<div class="password-strength-container">
    {# Password Input with Toggle #}
    <div class="mb-3">
        <label for="{{ inputId }}" class="form-label text-body">
            Password <span class="text-danger">*</span>
        </label>
        <div class="input-group">
            <input type="password" 
                   class="form-control" 
                   id="{{ inputId }}" 
                   name="{{ inputId }}" 
                   required
                   minlength="8"
                   maxlength="128"
                   autocomplete="new-password"
                   onkeyup="checkPasswordStrength('{{ inputId }}')">
            <button class="btn btn-outline-secondary" 
                    type="button" 
                    onclick="togglePasswordVisibility('{{ inputId }}')">
                <i class="bi bi-eye" id="{{ inputId }}-toggle-icon"></i>
            </button>
        </div>
    </div>

    {# Strength Meter #}
    <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <small class="text-muted">Password Strength:</small>
            <span id="{{ inputId }}-strength-label" class="badge bg-secondary">Not entered</span>
        </div>
        <div class="progress" style="height: 8px;">
            <div id="{{ inputId }}-strength-bar" 
                 class="progress-bar" 
                 role="progressbar" 
                 style="width: 0%"
                 aria-valuenow="0" 
                 aria-valuemin="0" 
                 aria-valuemax="100">
            </div>
        </div>
        <div id="{{ inputId }}-feedback" class="mt-2"></div>
    </div>

    {% if showRequirements %}
    {# Password Requirements #}
    <div class="card border bg-body mb-3">
        <div class="card-body py-2 px-3">
            <small class="text-muted d-block mb-2"><strong>Password must contain:</strong></small>
            <div class="row g-2">
                <div class="col-md-6">
                    <small id="{{ inputId }}-check-length" class="d-block text-muted">
                        <i class="bi bi-circle"></i> 8-128 characters
                    </small>
                    <small id="{{ inputId }}-check-uppercase" class="d-block text-muted">
                        <i class="bi bi-circle"></i> Uppercase letter (A-Z)
                    </small>
                    <small id="{{ inputId }}-check-lowercase" class="d-block text-muted">
                        <i class="bi bi-circle"></i> Lowercase letter (a-z)
                    </small>
                </div>
                <div class="col-md-6">
                    <small id="{{ inputId }}-check-numbers" class="d-block text-muted">
                        <i class="bi bi-circle"></i> Number (0-9)
                    </small>
                    <small id="{{ inputId }}-check-special" class="d-block text-muted">
                        <i class="bi bi-circle"></i> Special character (!@#$...)
                    </small>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {% if showGenerator %}
    {# Password Generator #}
    <div class="mb-3">
        <button type="button" 
                class="btn btn-sm btn-outline-primary" 
                onclick="generatePassword('{{ inputId }}')">
            <i class="bi bi-key"></i> Generate Strong Password
        </button>
    </div>
    {% endif %}
</div>

<script>
// Password strength checker
function checkPasswordStrength(inputId) {
    const password = document.getElementById(inputId).value;
    const strengthBar = document.getElementById(inputId + '-strength-bar');
    const strengthLabel = document.getElementById(inputId + '-strength-label');
    const feedbackDiv = document.getElementById(inputId + '-feedback');
    
    if (!password) {
        strengthBar.style.width = '0%';
        strengthBar.className = 'progress-bar';
        strengthLabel.textContent = 'Not entered';
        strengthLabel.className = 'badge bg-secondary';
        feedbackDiv.innerHTML = '';
        resetRequirementChecks(inputId);
        return;
    }
    
    // Calculate strength
    const result = calculatePasswordStrength(password);
    
    // Update progress bar
    strengthBar.style.width = result.percentage + '%';
    strengthBar.className = 'progress-bar bg-' + result.color;
    strengthLabel.textContent = result.label;
    strengthLabel.className = 'badge bg-' + result.color;
    
    // Update feedback
    if (result.feedback.length > 0) {
        feedbackDiv.innerHTML = '<small class="text-muted"><i class="bi bi-info-circle"></i> ' + 
            result.feedback.join(', ') + '</small>';
    } else {
        feedbackDiv.innerHTML = '<small class="text-success"><i class="bi bi-check-circle"></i> Strong password!</small>';
    }
    
    // Update requirement checks
    updateRequirementChecks(inputId, result.checks);
}

function calculatePasswordStrength(password) {
    let score = 0;
    const feedback = [];
    const checks = {
        length: password.length >= 8 && password.length <= 128,
        uppercase: /[A-Z]/.test(password),
        lowercase: /[a-z]/.test(password),
        numbers: /[0-9]/.test(password),
        special: /[!@#$%^&*()_+\-=\[\]{}|;:,.<>?]/.test(password)
    };
    
    // Length scoring
    if (password.length >= 8) score++;
    if (password.length >= 12) score++;
    if (password.length >= 16) score++;
    
    // Character variety
    if (checks.lowercase) score++; else feedback.push('Add lowercase');
    if (checks.uppercase) score++; else feedback.push('Add uppercase');
    if (checks.numbers) score++; else feedback.push('Add numbers');
    if (checks.special) score++; else feedback.push('Add symbols');
    
    // Penalize patterns
    if (/(.)\1{2,}/.test(password)) {
        score = Math.max(0, score - 1);
        feedback.push('Avoid repeated characters');
    }
    
    // Normalize score
    score = Math.min(5, Math.max(0, score));
    
    const labels = ['Very Weak', 'Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'];
    const colors = ['danger', 'danger', 'warning', 'info', 'primary', 'success'];
    
    return {
        score: score,
        percentage: (score / 5) * 100,
        label: labels[score],
        color: colors[score],
        feedback: feedback,
        checks: checks
    };
}

function updateRequirementChecks(inputId, checks) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            if (checks[req]) {
                element.className = 'd-block text-success';
                element.innerHTML = '<i class="bi bi-check-circle-fill"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            } else {
                element.className = 'd-block text-muted';
                element.innerHTML = '<i class="bi bi-circle"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            }
        }
    });
}

function resetRequirementChecks(inputId) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            element.className = 'd-block text-muted';
            const text = element.textContent.replace(/^[^\s]+\s/, '');
            element.innerHTML = '<i class="bi bi-circle"></i> ' + text;
        }
    });
}

function togglePasswordVisibility(inputId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(inputId + '-toggle-icon');
    
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

function generatePassword(inputId) {
    const length = 16;
    const uppercase = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    const lowercase = 'abcdefghijklmnopqrstuvwxyz';
    const numbers = '0123456789';
    const special = '!@#$%^&*()_+-=[]{}|;:,.<>?';
    const all = uppercase + lowercase + numbers + special;
    
    let password = '';
    password += uppercase[Math.floor(Math.random() * uppercase.length)];
    password += lowercase[Math.floor(Math.random() * lowercase.length)];
    password += numbers[Math.floor(Math.random() * numbers.length)];
    password += special[Math.floor(Math.random() * special.length)];
    
    for (let i = 4; i < length; i++) {
        password += all[Math.floor(Math.random() * all.length)];
    }
    
    // Shuffle
    password = password.split('').sort(() => Math.random() - 0.5).join('');
    
    const input = document.getElementById(inputId);
    input.value = password;
    input.type = 'text'; // Show generated password
    
    // Update strength meter
    checkPasswordStrength(inputId);
    
    // Copy to clipboard
    navigator.clipboard.writeText(password).then(() => {
        alert('Strong password generated and copied to clipboard!');
    });
}
</script>

<style>
.password-strength-container .progress {
    background-color: #e9ecef;
    border-radius: 4px;
}

.password-strength-container .progress-bar {
    transition: width 0.3s ease, background-color 0.3s ease;
}

.password-strength-container .input-group .btn {
    border-left: 0;
}

.password-strength-container .card {
    font-size: 0.875rem;
}
</style>
