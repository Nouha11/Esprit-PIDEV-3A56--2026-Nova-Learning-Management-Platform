    {# MAGIC FLOATING TOASTS SCRIPT #}
    <div class="nova-toast-container" id="toastContainer"></div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toastContainer = document.getElementById('toastContainer');
            
            function createToast(message, type) {
                const toast = document.createElement('div');
                toast.className = `nova-toast ${type}`;
                
                const iconClass = type === 'success' ? 'bi-check-circle-fill' : (type === 'error' ? 'bi-exclamation-octagon-fill' : 'bi-info-circle-fill');
                
                toast.innerHTML = `<i class="bi ${iconClass}"></i> <span class="fw-bold" style="font-size: 14px;">${message}</span>`;
                toastContainer.appendChild(toast);
                
                setTimeout(() => toast.classList.add('show'), 50);
                
                setTimeout(() => {
                    toast.classList.remove('show');
                    setTimeout(() => toast.remove(), 400);
                }, 4000);
            }

            const alertContainer = document.querySelector('.container.mt-3');
            if(alertContainer && alertContainer.innerHTML.includes('alert-dismissible')) {
                alertContainer.innerHTML = ''; 
            }

            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    createToast("{{ message|escape('js') }}", "{{ label == 'danger' ? 'error' : label }}");
                {% endfor %}
            {% endfor %}
            
            // DEMO TRICK: Intercept search for the video
            const globalSearchForm = document.getElementById('globalSearchForm');
            if (globalSearchForm) {
                globalSearchForm.addEventListener('submit', function(e) {
                    e.preventDefault(); 
                    const query = document.getElementById('globalSearchInput').value;
                    if(query.trim() === '') return;

                    const toast = document.createElement('div');
                    toast.className = `nova-toast`; 
                    toast.innerHTML = `<i class="bi bi-cpu text-primary spinner-border spinner-border-sm me-2" style="width: 1rem; height: 1rem;"></i> <span class="fw-bold" style="font-size: 14px;">Searching Ecosystem for "${query}"...</span>`;
                    toastContainer.appendChild(toast);
                    
                    setTimeout(() => toast.classList.add('show'), 50);
                    
                    setTimeout(() => {
                        toast.classList.remove('show');
                        setTimeout(() => toast.remove(), 400);
                    }, 3000);
                });
            }
        });
    </script>
