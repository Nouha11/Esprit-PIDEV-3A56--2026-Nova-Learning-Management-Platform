{% import 'macros/translation.html.twig' as t %}
<!DOCTYPE html>
<html lang="{{ current_locale() }}">
<head>
    <title>{% block title %}{{ t.t('NOVA - Intelligent Study Coaching Platform') }}{% endblock %}</title>

    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="author" content="NOVA Team">
    <meta name="description" content="NOVA - Intelligent Study Coaching Platform">

    <script>
        const storedTheme = localStorage.getItem('theme')
        const getPreferredTheme = () => {
            if (storedTheme) {
                return storedTheme
            }
            return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'light'
        }
        const setTheme = function (theme) {
            if (theme === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) {
                document.documentElement.setAttribute('data-bs-theme', 'dark')
            } else {
                document.documentElement.setAttribute('data-bs-theme', theme)
            }
        }
        setTheme(getPreferredTheme())
        window.addEventListener('DOMContentLoaded', () => {
            const showActiveTheme = theme => {
                const btnToActive = document.querySelector(`[data-bs-theme-value="${theme}"]`);
                if (!btnToActive) return;
                
                document.querySelectorAll('[data-bs-theme-value]').forEach(element => {
                    element.classList.remove('active');
                });
                btnToActive.classList.add('active');
            }
            
            window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', () => {
                if (storedTheme !== 'light' || storedTheme !== 'dark') {
                    setTheme(getPreferredTheme())
                }
            })
            showActiveTheme(getPreferredTheme())
            document.querySelectorAll('[data-bs-theme-value]')
                .forEach(toggle => {
                    toggle.addEventListener('click', () => {
                        const theme = toggle.getAttribute('data-bs-theme-value')
                        localStorage.setItem('theme', theme)
                        setTheme(theme)
                        showActiveTheme(theme)
                    })
                })
        })
    </script>

    {% block stylesheets %}
    <link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com/">
    <link rel="preconnect" href="https://fonts.gstatic.com/" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Press+Start+2P&display=swap">

    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/glightbox/css/glightbox.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/vendor/choices/css/choices.min.css') }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/style.css') }}?v={{ random() }}">
    <link rel="stylesheet" type="text/css" href="{{ asset('assets/css/pagination.css') }}?v={{ random() }}">
    
    <style>
        /* GLOBAL DESIGN VARIABLES */
        :root {
            --nova-bg: #f8f9fa;
            --nova-card-bg: #ffffff;
            --nova-text-main: #1a1a1b;
            --nova-text-muted: #6c757d;
            --nova-border: #e0e3e7; 
            --nova-nav-hover: #f1f3f5;
            --nova-accent-shadow: rgba(13, 110, 253, 0.15);
        }
        [data-bs-theme="dark"], body.dark-mode, .dark-mode {
            --nova-bg: #050505; 
            --nova-card-bg: #1a1a1b;
            --nova-text-main: #d7dadc;
            --nova-text-muted: #818384;
            --nova-border: #2d2d2f;
            --nova-nav-hover: #272729;
            --nova-accent-shadow: rgba(13, 110, 253, 0.25);
        }

        body { font-family: 'Inter', sans-serif; background-color: var(--nova-bg); color: var(--nova-text-main); }
        
        /* --- PREMIUM GLASS NAVBAR --- */
        .navbar-glass { background: rgba(255, 255, 255, 0.85) !important; backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 2px solid var(--nova-border); transition: all 0.3s ease; }
        [data-bs-theme="dark"] .navbar-glass, .dark-mode .navbar-glass { background: rgba(26, 26, 27, 0.85) !important; }

        /* NAVBAR SEARCH BAR */
        .search-glass { background-color: var(--nova-bg); border: 2px solid var(--nova-border); border-radius: 8px; transition: all 0.2s ease; }
        .search-glass:focus-within { background-color: var(--nova-card-bg); border-color: #0d6efd; box-shadow: 4px 4px 0 var(--nova-accent-shadow); }
        .search-glass input { font-size: 14px; font-weight: 600; color: var(--nova-text-main); }
        .search-glass input:focus { outline: none; box-shadow: none; }
        .search-glass input::placeholder { color: var(--nova-text-muted); opacity: 0.8; font-weight: 500; }

        /* THEME SWITCHER BUTTONS */
        .mode-switch-wrapper { background: var(--nova-bg); border: 2px solid var(--nova-border); border-radius: 50rem; padding: 2px; display: flex; align-items: center; }
        .theme-btn { border-radius: 50rem; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; color: var(--nova-text-muted); transition: all 0.2s; border: none; background: transparent; }
        .theme-btn:hover { color: var(--nova-text-main); }
        .theme-btn.active[data-bs-theme-value="light"] { background-color: #ffffff; color: #f59e0b; box-shadow: 0 2px 5px rgba(0,0,0,0.1); }
        [data-bs-theme="dark"] .theme-btn.active[data-bs-theme-value="dark"] { background-color: #343536; color: #60a5fa; box-shadow: 0 2px 5px rgba(0,0,0,0.4); }

        /* NAVBAR LINKS */
        .navbar-nav.me-auto { margin-right: auto !important; flex: 1 !important; }
        .navbar .nav.flex-row { margin-left: auto !important; flex-shrink: 0 !important; }
        .nav-item.me-2 { margin-right: 0.75rem !important; }
        .navbar-nav .nav-item { margin-right: 0.25rem !important; }
        .navbar-nav .nav-link { padding: 0.6rem 0.85rem !important; white-space: nowrap !important; transition: all 0.1s ease; border-radius: 6px; color: var(--nova-text-muted) !important; font-weight: 600; border: 2px solid transparent; }
        .navbar-collapse { justify-content: space-between !important; }
        @media (max-width: 991.98px) { .navbar-collapse .navbar-nav { margin-bottom: 1rem !important; } .navbar-collapse .nav.flex-row { margin-left: 0 !important; justify-content: center !important; } }
        
        .navbar-nav .dropdown-menu { margin-top: 0; border: 2px solid var(--nova-border); border-radius: 12px; box-shadow: 4px 4px 0 rgba(0,0,0,0.1); overflow: hidden;}
        @media (min-width: 992px) { .navbar-nav .nav-item.dropdown:hover > .dropdown-menu { display: block; margin-top: 0; } }
        
        .navbar-nav .nav-link:hover:not(.active) { background-color: var(--nova-bg); color: var(--nova-text-main) !important; border-color: var(--nova-border); transform: translateY(-2px); }
        .navbar-nav .nav-link.active { color: var(--nova-text-main) !important; background-color: rgba(13, 110, 253, 0.08); border-color: rgba(13, 110, 253, 0.3); }

        /* FLOATING TOASTS */
        .nova-toast-container { position: fixed; bottom: 20px; right: 20px; z-index: 9999; display: flex; flex-direction: column; gap: 10px; }
        .nova-toast { min-width: 250px; background: var(--nova-card-bg); color: var(--nova-text-main); border: 2px solid var(--nova-border); border-radius: 4px; box-shadow: 4px 4px 0 rgba(0,0,0,0.1); padding: 16px 20px; display: flex; align-items: center; transform: translateX(120%); opacity: 0; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); border-left: 6px solid #0d6efd; }
        .nova-toast.show { transform: translateX(0); opacity: 1; }
        .nova-toast.success { border-left-color: #198754; }
        .nova-toast.error { border-left-color: #dc3545; }
        
        /* ======================================= */
        /* --- HERO & GAME AESTHETICS --- */
        /* ======================================= */
        .home-hero-bg { position: relative; background-color: var(--nova-bg); padding: 120px 0 100px 0; overflow: hidden; }
        .home-hero-bg::before { content: ''; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background-image: linear-gradient(to right, var(--nova-border) 1px, transparent 1px), linear-gradient(to bottom, var(--nova-border) 1px, transparent 1px); background-size: 24px 24px; opacity: 0.5; z-index: 0; mask-image: radial-gradient(circle at center, black 60%, transparent 100%); }
        .glow-orb { position: absolute; border-radius: 50%; filter: blur(80px); z-index: 0; opacity: 0.4; animation: floatOrb 15s infinite ease-in-out alternate; }
        .orb-1 { width: 600px; height: 600px; background: #0d6efd; top: -200px; left: -150px; }
        .orb-2 { width: 500px; height: 500px; background: #6f42c1; bottom: -150px; right: 5%; animation-delay: -7s; }
        @keyframes floatOrb { 0% { transform: translateY(0px); } 100% { transform: translateY(50px); } }

        @keyframes heroFadeUp { 0% { opacity: 0; transform: translateY(40px) scale(0.98); } 100% { opacity: 1; transform: translateY(0) scale(1); } }
        .hero-anim-1 { animation: heroFadeUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.1s; } 
        .hero-anim-2 { animation: heroFadeUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.2s; }
        .hero-anim-3 { animation: heroFadeUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.3s; }
        .hero-anim-4 { animation: heroFadeUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both; animation-delay: 0.4s; }

        .leaderboard-card { background: rgba(255, 255, 255, 0.8); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border: 3px solid var(--nova-border); border-radius: 16px; box-shadow: 8px 8px 0px var(--nova-accent-shadow), 0 20px 40px rgba(0,0,0,0.05); transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1); }
        [data-bs-theme="dark"] .leaderboard-card, .dark-mode .leaderboard-card { background: rgba(26, 26, 27, 0.8); border-color: #2d2d2f; }
        .leaderboard-card:hover { transform: translate(-4px, -4px); box-shadow: 12px 12px 0px var(--nova-accent-shadow), 0 30px 60px rgba(0,0,0,0.1); }

        .leaderboard-item { background-color: rgba(255, 255, 255, 0.5); border: 2px solid transparent; box-shadow: 0 4px 0 rgba(0,0,0,0.02); transition: all 0.2s; }
        [data-bs-theme="dark"] .leaderboard-item, .dark-mode .leaderboard-item { background-color: rgba(0, 0, 0, 0.3); border-color: transparent; box-shadow: 0 4px 0 rgba(0,0,0,0.2); }
        .leaderboard-item:hover { border-color: #0d6efd; transform: translateY(-2px); box-shadow: 0 6px 0 var(--nova-accent-shadow); }

        /* UI Mockups */
        .mockup-card { background: var(--nova-card-bg); border: 2px solid var(--nova-border); border-radius: 12px; padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); transition: all 0.3s; }
        .mockup-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.1); border-color: #0d6efd; }

        .ecosystem-card { background: var(--nova-card-bg); border: 2px solid var(--nova-border); border-radius: 12px; padding: 32px 24px; transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1); text-align: center; height: 100%; display: flex; flex-direction: column; align-items: center; text-decoration: none; color: inherit; box-shadow: 0 4px 0 var(--nova-border); }
        .ecosystem-card:hover { transform: translateY(-6px); border-color: #0d6efd; box-shadow: 0 8px 0 var(--nova-accent-shadow); }
        .ecosystem-icon { width: 72px; height: 72px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 32px; margin-bottom: 20px; transition: transform 0.3s; border: 2px solid transparent; }
        .ecosystem-card:hover .ecosystem-icon { transform: scale(1.1) rotate(-3deg); border-color: currentColor; }
        
        .game-level-card { background: var(--nova-card-bg); border: 2px solid var(--nova-border); border-radius: 12px; padding: 24px; transition: all 0.2s ease; position: relative; overflow: hidden; box-shadow: 4px 4px 0 var(--nova-border); }
        .game-level-card:hover { transform: translate(-4px, -4px); box-shadow: 8px 8px 0 var(--nova-accent-shadow); }
        .game-level-card::before { content: ''; position: absolute; top: 0; left: 0; width: 6px; height: 100%; }
        .gl-easy::before { background-color: #198754; }
        .gl-medium::before { background-color: #fd7e14; }
        .gl-hard::before { background-color: #dc3545; }
        .gl-expert::before { background-color: #6f42c1; }
        
        .text-gradient { background: linear-gradient(135deg, #0d6efd 0%, #6f42c1 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; filter: drop-shadow(2px 2px 0px rgba(13, 110, 253, 0.2)); }
        .btn-custom-outline { background-color: var(--nova-card-bg); color: var(--nova-text-main); border: 2px solid var(--nova-border); transition: all 0.2s; font-weight: 700; box-shadow: 2px 2px 0 var(--nova-border); }
        .btn-custom-outline:hover { background-color: var(--nova-bg); color: var(--nova-text-main); border-color: #0d6efd; transform: translate(-2px, -2px); box-shadow: 4px 4px 0 var(--nova-accent-shadow); }
        .btn-primary { box-shadow: 2px 2px 0 rgba(0,0,0,0.2); transition: all 0.2s; border: none;}
        .btn-primary:hover { transform: translate(-2px, -2px); box-shadow: 5px 5px 0 rgba(0,0,0,0.2); }
    </style>
    {% endblock %}
</head>

<body>
<header class="navbar-light navbar-sticky navbar-glass sticky-top p-0 p-lg-2">
    <nav class="navbar navbar-expand-xl z-index-9">
        <div class="container-fluid px-lg-5">
            <a class="navbar-brand me-4" href="{{ path('app_home') }}">
                <img class="light-mode-item navbar-brand-item h-50px h-lg-60px" src="{{ asset('assets/images/Logo.png') }}" alt="NOVA">
                <img class="dark-mode-item navbar-brand-item h-50px h-lg-60px" src="{{ asset('assets/images/Logo.png') }}" alt="NOVA">
            </a>

            <button class="navbar-toggler ms-auto" type="button" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
                <span class="navbar-toggler-animation"><span></span><span></span><span></span></span>
            </button>

            <div class="navbar-collapse collapse align-items-center" id="navbarCollapse">
                
                <form id="globalSearchForm" class="d-flex align-items-center mb-3 mb-xl-0 me-xl-5 ms-xl-3" style="max-width: 350px; width: 100%;" action="#" method="GET">
                    <div class="input-group search-glass p-1">
                        <span class="input-group-text border-0 bg-transparent ps-3 pe-2"><i class="bi bi-search text-muted"></i></span>
                        <input id="globalSearchInput" class="form-control border-0 bg-transparent ps-1 shadow-none" type="search" name="q" placeholder="Search platform..." aria-label="Search">
                    </div>
                </form>

                {% set current_route = app.request.attributes.get('_route') %}
                <ul class="navbar-nav me-auto mb-2 mb-xl-0 gap-2">
                    <li class="nav-item">
                        <a class="nav-link {{ current_route == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">
                            <i class="bi bi-house-door-fill me-1 text-secondary"></i> Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ current_route starts with 'course_' ? 'active' : '' }}" href="{{ path('course_index') }}">
                            <i class="bi bi-map-fill me-1 text-success"></i> Courses
                        </a>
                    </li>                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle {{ current_route in ['book_list', 'my_library', 'my_payments'] ? 'active' : '' }}" href="#" id="libraryDropdown" data-bs-toggle="dropdown">
                            <i class="bi bi-collection-fill me-1 text-info"></i> Library
                        </a>
                        <ul class="dropdown-menu border-0 p-2" aria-labelledby="libraryDropdown" style="background: var(--nova-card-bg);">
                            <li><a class="dropdown-item rounded-2 py-2 fw-medium {{ current_route == 'book_list' ? 'active text-primary' : '' }}" href="{{ path('book_list') }}"><i class="bi bi-compass-fill me-2 text-primary"></i>Browse Library</a></li>
                            {% if app.user %}
                                <li><hr class="dropdown-divider my-2" style="border-color: var(--nova-border);"></li>
                                <li><a class="dropdown-item rounded-2 py-2 fw-medium {{ current_route == 'my_library' ? 'active text-success' : '' }}" href="{{ path('my_library') }}"><i class="bi bi-bookmark-check-fill me-2 text-success"></i>My Books</a></li>
                                <li><a class="dropdown-item rounded-2 py-2 fw-medium {{ current_route == 'my_payments' ? 'active text-info' : '' }}" href="{{ path('my_payments') }}"><i class="bi bi-credit-card-fill me-2 text-info"></i>Payments</a></li>
                            {% endif %}
                        </ul>
                    </li>

                    {% if is_granted('ROLE_STUDENT') %}
                        <li class="nav-item">
                            <a class="nav-link {{ current_route starts with 'front_game' ? 'active' : '' }}" href="{{ path('front_game_index') }}">
                                <i class="bi bi-dpad-fill me-1 text-warning"></i> Games
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ current_route starts with 'front_reward' ? 'active' : '' }}" href="{{ path('front_reward_browse') }}">
                                <i class="bi bi-award-fill me-1 text-danger"></i> Rewards
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {{ current_route starts with 'app_front_quiz' ? 'active' : '' }}" href="{{ path('app_front_quiz_index') }}">
                                <i class="bi bi-patch-question-fill me-1" style="color: #6f42c1;"></i> Quizzes
                            </a>
                        </li>
                    {% elseif is_granted('ROLE_TUTOR') %}
                        <li class="nav-item">
                            <a class="nav-link {{ current_route starts with 'app_quiz' ? 'active' : '' }}" href="{{ path('app_quiz_index', {'prefix': 'tutor'}) }}">
                                <i class="bi bi-patch-question-fill me-1" style="color: #6f42c1;"></i> Manage Quizzes
                            </a>
                        </li>
                    {% endif %}
                    
                    <li class="nav-item">
                        <a class="nav-link {{ current_route starts with 'app_forum' ? 'active' : '' }}" href="{{ path('app_forum') }}">
                            <i class="bi bi-people-fill me-1 text-primary"></i> Forum
                        </a>
                    </li>
                </ul>
            </div>

            <ul class="nav flex-row align-items-center list-unstyled ms-auto mb-0 gap-3">
                
                <li class="nav-item dropdown">
                    <a class="nav-link btn-custom-outline px-3 py-1 rounded-pill d-flex align-items-center text-decoration-none" href="#" id="languageDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="border-width: 2px;">
                        <i class="bi bi-globe-americas me-2 text-primary"></i> <span class="fw-bold small">{{ app.request.locale|default('en')|upper }}</span>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end border-0 p-2 shadow-lg" aria-labelledby="languageDropdown" style="background: var(--nova-card-bg); min-width: 140px; border: 2px solid var(--nova-border) !important; box-shadow: 6px 6px 0 rgba(0,0,0,0.1) !important;">
                        <li><a class="dropdown-item py-2 rounded-2 fw-bold {{ app.request.locale == 'en' ? 'bg-primary bg-opacity-10 text-primary' : 'nova-text-main' }}" href="{{ path(app.request.attributes.get('_route', 'app_home'), app.request.attributes.get('_route_params', {})|merge({'_locale': 'en'})) }}"><span class="me-2 fs-5">🇺🇸</span> English</a></li>
                        <li><a class="dropdown-item py-2 rounded-2 fw-bold {{ app.request.locale == 'fr' ? 'bg-primary bg-opacity-10 text-primary' : 'nova-text-main' }}" href="{{ path(app.request.attributes.get('_route', 'app_home'), app.request.attributes.get('_route_params', {})|merge({'_locale': 'fr'})) }}"><span class="me-2 fs-5">🇫🇷</span> Français</a></li>
                    </ul>
                </li>

                <li class="nav-item d-none d-sm-block">
                    <div class="mode-switch-wrapper theme-icon-active">
                        <button type="button" class="theme-btn" data-bs-theme-value="light" title="Light Mode"><i class="bi bi-sun-fill fs-6"></i></button>
                        <button type="button" class="theme-btn" data-bs-theme-value="dark" title="Dark Mode"><i class="bi bi-moon-stars-fill fs-6"></i></button>
                    </div>
                </li>

                {% if not app.user %}
                    <li class="nav-item ms-1"><a href="{{ path('app_login') }}" class="btn btn-sm btn-custom-outline mb-0 rounded-pill px-4 py-2">Sign In</a></li>
                    <li class="nav-item ms-1"><a href="{{ path('app_signup') }}" class="btn btn-sm btn-primary mb-0 fw-bold rounded-pill px-4 py-2">Get Started</a></li>
                {% else %}
                    {% include 'components/notification_bell.html.twig' %}
                    <li class="nav-item dropdown">
                        <a class="avatar avatar-sm p-0 d-block transition-base" href="#" id="profileDropdown" data-bs-toggle="dropdown" style="transform: scale(1); transition: transform 0.2s;">
                            {% if 'ROLE_STUDENT' in app.user.roles and app.user.studentProfile and app.user.studentProfile.profilePicture %}
                                <img class="avatar-img rounded-circle border border-2 border-primary" src="{{ vich_uploader_asset(app.user.studentProfile, 'avatarFile') }}" alt="avatar" onmouseover="this.parentElement.style.transform='scale(1.1)'" onmouseout="this.parentElement.style.transform='scale(1)'">
                            {% elseif 'ROLE_TUTOR' in app.user.roles and app.user.tutorProfile and app.user.tutorProfile.profilePicture %}
                                <img class="avatar-img rounded-circle border border-2 border-primary" src="{{ vich_uploader_asset(app.user.tutorProfile, 'avatarFile') }}" alt="avatar" onmouseover="this.parentElement.style.transform='scale(1.1)'" onmouseout="this.parentElement.style.transform='scale(1)'">
                            {% else %}
                                <div class="avatar-img rounded-circle bg-primary text-white d-flex align-items-center justify-content-center border border-2 border-primary shadow-sm" style="width: 42px; height: 42px;" onmouseover="this.parentElement.style.transform='scale(1.1)'" onmouseout="this.parentElement.style.transform='scale(1)'"><span class="fw-bold">{{ app.user.username|first|upper }}</span></div>
                            {% endif %}
                        </a>

                        <ul class="dropdown-menu dropdown-animation dropdown-menu-end shadow-lg border-0 pt-3" aria-labelledby="profileDropdown" style="background: var(--nova-card-bg); border: 2px solid var(--nova-border) !important; min-width: 260px; box-shadow: 8px 8px 0 var(--nova-accent-shadow) !important;">
                            <li class="px-4 mb-3">
                                <div class="d-flex align-items-center">
                                    <div class="avatar me-3">
                                        {% if 'ROLE_STUDENT' in app.user.roles and app.user.studentProfile and app.user.studentProfile.profilePicture %}
                                            <img class="avatar-img rounded-circle" src="{{ vich_uploader_asset(app.user.studentProfile, 'avatarFile') }}">
