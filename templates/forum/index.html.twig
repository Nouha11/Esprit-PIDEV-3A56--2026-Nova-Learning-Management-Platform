{% extends 'base.html.twig' %}

{% block title %}Community Forum{% endblock %}

{% block body %}
<main>
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="bg-blue h-100px h-md-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
            </div>
        </div>
        <div class="container mt-n4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body p-0">
                        <div class="row d-flex justify-content-between">
                            <div class="col-12">
                                <div class="bg-body p-4 rounded-3 shadow-sm d-md-flex justify-content-between align-items-center">
                                    <div class="me-3">
                                        <h1 class="h3 mb-0">Community Forum</h1>
                                        {# Use text-body to ensure it is visible in Light Mode #}
                                        <p class="mb-0 text-body">Join the conversation! Ask questions, share ideas, and help others.</p>
                                    </div>

                                    <div class="d-flex align-items-center mt-3 mt-md-0 gap-3">
                                        
                                        <form method="get" action="{{ path('app_forum') }}" class="position-relative">
                                            <div class="d-flex align-items-center shadow-sm rounded-pill" style="background-color: #fff; border: 1px solid #ddd; padding: 5px 15px; min-width: 280px;">
                                                <i class="bi bi-search text-secondary me-2"></i>
                                                <input type="search" 
                                                       name="q" 
                                                       value="{{ searchQuery|default('') }}" 
                                                       placeholder="Search discussions..." 
                                                       aria-label="Search"
                                                       class="border-0 bg-transparent shadow-none w-100 text-dark" 
                                                       style="outline: none;">
                                                
                                                {% if searchQuery is defined and searchQuery %}
                                                    <a href="{{ path('app_forum') }}" class="text-secondary ms-2" title="Clear Search" style="text-decoration: none;">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </form>

                                        <button class="btn btn-primary mb-0 rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm" aria-expanded="false">
                                            <i class="bi bi-plus-lg me-1"></i> Start Discussion
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0">
        <div class="container">
            <div class="row">
                
                <div class="col-xl-3">
                    <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                        <div class="offcanvas-header bg-light">
                            <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Forum Menu</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
                        </div>
                        <div class="offcanvas-body p-3 p-xl-0">
                            <div class="bg-dark border rounded-3 pb-0 p-3 w-100">
                                <div class="list-group list-group-dark list-group-borderless">
                                    <a class="list-group-item active" href="{{ path('app_forum') }}"><i class="bi bi-ui-checks-grid fa-fw me-2"></i>All Discussions</a>
                                    <a class="list-group-item" href="#"><i class="bi bi-fire fa-fw me-2"></i>Popular</a>
                                    <a class="list-group-item" href="#"><i class="bi bi-question-circle fa-fw me-2"></i>Unanswered</a>
                                </div>
                            </div>
                        </div>
                        
                        <br>
                        
                        <div class="card border bg-transparent rounded-3 mt-4">
                            <div class="card-header bg-transparent border-bottom">
                                <h3 class="mb-0 h5">Forum Rules</h3>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled text-secondary mb-0 small">
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Be respectful to others</li>
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>No spamming</li>
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Search before posting</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-9">
                    
                    <div class="collapse mb-4 {{ form.vars.submitted ? 'show' : '' }}" id="addPostForm">
                        <div class="card border bg-transparent rounded-3 shadow-sm">
                            <div class="card-header bg-light border-bottom">
                                <h5 class="card-title mb-0">Create New Discussion</h5>
                            </div>
                            <div class="card-body">
                                {{ form_start(form) }}
                                    <div class="mb-3">
                                        <label class="form-label">Subject</label>
                                        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': 'What is this regarding?'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Description</label>
                                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Describe your question in detail...'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                    </div>
                                    <div class="text-end">
                                        <button type="submit" class="btn btn-success">Post Now</button>
                                    </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>

                    <div class="card border bg-transparent rounded-3">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0 h5">Recent Discussions</h3>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive border-0">
                                <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                                    <thead>
                                        <tr>
                                            <th scope="col" class="border-0 rounded-start">Topic</th>
                                            <th scope="col" class="border-0">Author</th>
                                            <th scope="col" class="border-0">Replies</th>
                                            <th scope="col" class="border-0 rounded-end">Action</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for post in posts %}
                                        <tr>
                                            <td class="position-relative">
                                                <h6 class="mb-0">
                                                    {% if post.isLocked %}
                                                        <i class="bi bi-lock-fill text-danger me-1" title="Locked"></i>
                                                    {% endif %}
                                                    
                                                    <a href="{{ path('app_forum_show', {'id': post.id}) }}" class="text-reset stretched-link" style="text-decoration: none;">
                                                        {{ post.title }}
                                                    </a>
                                                </h6>
                                                {# Use text-secondary for better contrast than text-muted #}
                                                <small class="text-secondary">{{ post.content|slice(0, 60) }}...</small>
                                            </td>

                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar avatar-xs me-2">
                                                        <div class="rounded-circle bg-{{ ['primary', 'success', 'info', 'warning', 'danger'][post.author.id % 5] }} text-white d-flex align-items-center justify-content-center" style="width: 35px; height: 35px; font-size: 12px;">
                                                            <span class="fw-bold">{{ post.author.username|slice(0, 2)|upper }}</span>
                                                        </div>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-0 fw-light text-sm">{{ post.author.username }}</h6>
                                                        <small class="text-secondary" style="font-size: 10px;">{{ post.createdAt|date('M d') }}</small>
                                                    </div>
                                                </div>
                                            </td>

                                            <td>
                                                <span class="badge bg-primary bg-opacity-10 text-primary">{{ post.comments|length }} replies</span>
                                            </td>

                                            <td>
                                                <a href="{{ path('app_forum_show', {'id': post.id}) }}" 
                                                   class="btn btn-success-soft btn-round mb-0 position-relative" 
                                                   style="z-index: 10;"
                                                   data-bs-toggle="tooltip" 
                                                   title="View Discussion">
                                                    <i class="far fa-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                        {% else %}
                                            <tr>
                                                <td colspan="4" class="text-center py-5">
                                                    {% if searchQuery is defined and searchQuery %}
                                                        <div class="mb-3">
                                                            <i class="bi bi-search display-1 text-secondary opacity-50"></i>
                                                        </div>
                                                        <h5 class="text-body">No results found</h5>
                                                        <p class="text-body">We couldn't find any discussions matching "<strong>{{ searchQuery }}</strong>".</p>
                                                        <a href="{{ path('app_forum') }}" class="btn btn-sm btn-outline-secondary">Clear Search</a>
                                                    {% else %}
                                                        <i class="bi bi-chat-square-text display-1 text-secondary opacity-50"></i>
                                                        <p class="mt-3 text-body">No discussions yet. Be the first to start one!</p>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}