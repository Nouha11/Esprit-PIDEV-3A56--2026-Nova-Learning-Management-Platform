{% extends 'base.html.twig' %}

{% block title %}Playing Quiz{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            
            {# 1. Game Header (XP, Timer, and Progress) #}
            <div class="d-flex justify-content-between align-items-center mb-4">
                <span class="badge bg-warning text-dark fs-6 px-3 py-2 rounded-pill" id="xp-badge">
                    <i class="bi bi-lightning-fill"></i> +{{ question.xpValue }} XP
                </span>
                
                {# Countdown Timer #}
                <div class="timer-container">
                    <div class="timer-display" id="timer-display">
                        <i class="bi bi-clock-fill me-1"></i>
                        <span id="timer-seconds">20</span>s
                    </div>
                    <div class="timer-progress">
                        <div class="timer-progress-bar" id="timer-progress-bar"></div>
                    </div>
                </div>
                
                <span class="text-muted small fw-bold text-uppercase">
                    Difficulty: {{ question.difficulty }}
                </span>
            </div>

            {# Hint Button #}
            {% if not hintUsed %}
                <div class="text-center mb-3">
                    <button type="button" class="btn btn-outline-info btn-sm" id="hint-btn" data-question-id="{{ question.id }}">
                        <i class="bi bi-lightbulb"></i> Get AI Hint (-50% XP)
                    </button>
                </div>
            {% endif %}

            {# Hint Display Area #}
            <div id="hint-container" class="alert alert-info mb-4" style="display: {% if hintUsed %}block{% else %}none{% endif %};">
                <div class="d-flex align-items-start">
                    <i class="bi bi-lightbulb-fill me-2 fs-5"></i>
                    <div>
                        <strong>AI Hint:</strong>
                        <p class="mb-0 mt-1" id="hint-text">{{ currentHint }}</p>
                        <small class="text-muted d-block mt-2">
                            <i class="bi bi-info-circle"></i> XP reduced by 50% for using hint
                        </small>
                    </div>
                </div>
            </div>

            {# 2. The Question Card #}
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
                <div class="card-body p-5 text-center bg-light">
                    {# Display question image if available #}
                    {% if question.imageName %}
                        <div class="mb-4">
                            <img src="{{ asset('uploads/questions/' ~ question.imageName) }}" 
                                 alt="Question image" 
                                 class="img-fluid rounded-3 shadow-sm"
                                 style="max-height: 300px; object-fit: contain;">
                        </div>
                    {% endif %}
                    <h2 class="display-6 fw-bold mb-4">{{ question.text }}</h2>
                </div>
            </div>

            {# 3. The Answer Form #}
            <form method="POST" class="mt-4" id="quiz-form">
                <input type="hidden" name="timeout" id="timeout-input" value="0">
                <div class="row g-3">
                    {% for choice in question.choices %}
                        <div class="col-md-6">
                            <input type="radio" class="btn-check" name="answer" id="choice_{{ choice.id }}" value="{{ choice.id }}" >
                            <label class="btn btn-outline-primary w-100 p-4 h-100 d-flex align-items-center justify-content-center rounded-3 shadow-sm choice-card" for="choice_{{ choice.id }}">
                                <span class="fs-5">{{ choice.content }}</span>
                            </label>
                        </div>
                    {% endfor %}
                </div>

                <div class="d-grid mt-5">
                    <button type="submit" class="btn btn-primary btn-lg rounded-pill py-3 fw-bold shadow-sm" id="submit-btn">
                        Submit Answer <i class="bi bi-arrow-right-circle ms-2"></i>
                    </button>
                </div>
            </form>

            {# quit button #}
            <div class="text-center mt-4">
                <a href="{{ path('app_quiz_restart') }}" class="text-muted text-decoration-none small" onclick="return confirm('Quit game? Progress will be lost.')">
                    <i class="bi bi-x-circle"></i> Quit Game
                </a>
            </div>

        </div>
    </div>
</div>

<style>
    /* Make the radio buttons look like cool cards */
    .choice-card {
        transition: all 0.2s ease;
        border-width: 2px;
    }
    .btn-check:checked + .choice-card {
        background-color: #0d6efd;
        color: white;
        border-color: #0d6efd;
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .choice-card:hover {
        transform: translateY(-2px);
    }
    
    #hint-btn.loading {
        pointer-events: none;
        opacity: 0.6;
    }
    
    /* Timer Styles */
    .timer-container {
        position: relative;
        text-align: center;
    }
    
    .timer-display {
        font-size: 1.5rem;
        font-weight: bold;
        color: #28a745;
        padding: 0.5rem 1.5rem;
        background: rgba(40, 167, 69, 0.1);
        border-radius: 50px;
        display: inline-block;
        transition: all 0.3s ease;
    }
    
    .timer-display.warning {
        color: #ffc107;
        background: rgba(255, 193, 7, 0.1);
        animation: pulse-warning 1s infinite;
    }
    
    .timer-display.danger {
        color: #dc3545;
        background: rgba(220, 53, 69, 0.1);
        animation: pulse-danger 0.5s infinite;
    }
    
    .timer-progress {
        width: 200px;
        height: 4px;
        background: rgba(0, 0, 0, 0.1);
        border-radius: 2px;
        margin: 0.5rem auto 0;
        overflow: hidden;
    }
    
    .timer-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #28a745, #20c997);
        width: 100%;
        transition: width 1s linear, background 0.3s ease;
    }
    
    .timer-progress-bar.warning {
        background: linear-gradient(90deg, #ffc107, #fd7e14);
    }
    
    .timer-progress-bar.danger {
        background: linear-gradient(90deg, #dc3545, #c82333);
    }
    
    @keyframes pulse-warning {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.05); }
    }
    
    @keyframes pulse-danger {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }
    
    .form-disabled {
        pointer-events: none;
        opacity: 0.6;
    }
    
    /* Shake animation for validation error */
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-10px); }
        20%, 40%, 60%, 80% { transform: translateX(10px); }
    }
    
    .shake {
        animation: shake 0.5s;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ===== COUNTDOWN TIMER =====
    const TIMER_DURATION = 20; // seconds
    let timeRemaining = TIMER_DURATION;
    let timerInterval = null;
    let timerPaused = false;
    
    const timerDisplay = document.getElementById('timer-display');
    const timerSeconds = document.getElementById('timer-seconds');
    const timerProgressBar = document.getElementById('timer-progress-bar');
    const quizForm = document.getElementById('quiz-form');
    const submitBtn = document.getElementById('submit-btn');
    
    function updateTimerDisplay() {
        timerSeconds.textContent = timeRemaining;
        
        // Update progress bar
        const percentage = (timeRemaining / TIMER_DURATION) * 100;
        timerProgressBar.style.width = percentage + '%';
        
        // Update colors based on time remaining
        if (timeRemaining <= 5) {
            timerDisplay.classList.remove('warning');
            timerDisplay.classList.add('danger');
            timerProgressBar.classList.remove('warning');
            timerProgressBar.classList.add('danger');
        } else if (timeRemaining <= 10) {
            timerDisplay.classList.add('warning');
            timerProgressBar.classList.add('warning');
        }
    }
    
    function startTimer() {
        timerInterval = setInterval(function() {
            if (!timerPaused) {
                timeRemaining--;
                updateTimerDisplay();
                
                if (timeRemaining <= 0) {
                    clearInterval(timerInterval);
                    handleTimeOut();
                }
            }
        }, 1000);
    }
    
    function handleTimeOut() {
        // Set timeout flag (no XP will be awarded)
        document.getElementById('timeout-input').value = '1';
        
        // Update XP badge to show 0 XP
        const xpBadge = document.getElementById('xp-badge');
        const originalXp = xpBadge.textContent;
        xpBadge.innerHTML = `<i class="bi bi-lightning-fill"></i> +0 XP <small class="text-decoration-line-through ms-1">${originalXp.replace(/[^\d]/g, '')}</small>`;
        xpBadge.classList.remove('bg-warning');
        xpBadge.classList.add('bg-secondary');
        
        // Show timeout message (but don't disable form)
        const alertDiv = document.createElement('div');
        alertDiv.className = 'alert alert-warning alert-dismissible fade show';
        alertDiv.innerHTML = `
            <i class="bi bi-clock-history me-2"></i>
            <strong>Time's up!</strong> You can still answer, but no XP will be awarded.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        document.querySelector('.container').insertBefore(alertDiv, document.querySelector('.row'));
    }
    
    // Start the timer
    startTimer();
    
    // Remove error message when an answer is selected
    const answerInputs = document.querySelectorAll('input[name="answer"]');
    answerInputs.forEach(input => {
        input.addEventListener('change', function() {
            const errorDiv = document.getElementById('answer-required-error');
            if (errorDiv) {
                errorDiv.remove();
            }
        });
    });
    
    // Pause timer when hint is being requested
    const hintBtn = document.getElementById('hint-btn');
    if (hintBtn) {
        hintBtn.addEventListener('click', async function() {
            const questionId = this.dataset.questionId;
            const xpBadge = document.getElementById('xp-badge');
            
            // Pause timer while getting hint
            timerPaused = true;
            
            // Show loading state
            this.classList.add('loading');
            this.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Generating hint...';
            
            try {
                const response = await fetch(`/game/quiz/hint/${questionId}`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                    }
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Update XP badge
                    xpBadge.innerHTML = `<i class="bi bi-lightning-fill"></i> +${data.reducedXp} XP <small class="text-decoration-line-through ms-1">${data.originalXp}</small>`;
                    
                    // Show hint
                    document.getElementById('hint-text').textContent = data.hint;
                    document.getElementById('hint-container').style.display = 'block';
                    
                    // Hide hint button
                    this.style.display = 'none';
                    
                    // Show success message
                    const alertDiv = document.createElement('div');
                    alertDiv.className = 'alert alert-warning alert-dismissible fade show';
                    alertDiv.innerHTML = `
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>
                        <strong>Hint activated!</strong> Your XP for this question has been reduced from ${data.originalXp} to ${data.reducedXp}.
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    `;
                    document.querySelector('.container').insertBefore(alertDiv, document.querySelector('.row'));
                    
                    // Auto-dismiss after 5 seconds
                    setTimeout(() => {
                        alertDiv.remove();
                    }, 5000);
                } else {
                    // Silently fail - just reset button
                    this.classList.remove('loading');
                    this.innerHTML = '<i class="bi bi-lightbulb"></i> Get AI Hint (-50% XP)';
                }
            } catch (error) {
                // Silently fail - just reset button
                console.error('Hint generation failed:', error);
                this.classList.remove('loading');
                this.innerHTML = '<i class="bi bi-lightbulb"></i> Get AI Hint (-50% XP)';
            } finally {
                // Resume timer
                timerPaused = false;
            }
        });
    }
    
    // Stop timer when form is submitted
    quizForm.addEventListener('submit', function(e) {
        // Check if an answer is selected
        const selectedAnswer = document.querySelector('input[name="answer"]:checked');
        
        if (!selectedAnswer) {
            e.preventDefault(); // Prevent form submission
            
            // Show error message
            const existingError = document.getElementById('answer-required-error');
            if (!existingError) {
                const errorDiv = document.createElement('div');
                errorDiv.id = 'answer-required-error';
                errorDiv.className = 'alert alert-danger alert-dismissible fade show mt-3';
                errorDiv.innerHTML = `
                    <i class="bi bi-exclamation-circle me-2"></i>
                    <strong>Please select an answer!</strong> You must choose an option before submitting.
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                submitBtn.parentElement.appendChild(errorDiv);
                
                // Shake animation for submit button
                submitBtn.classList.add('shake');
                setTimeout(() => {
                    submitBtn.classList.remove('shake');
                }, 500);
            }
            
            return false;
        }
        
        // If answer is selected, proceed with submission
        clearInterval(timerInterval);
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span> Submitting...';
    });
});
</script>
{% endblock %}