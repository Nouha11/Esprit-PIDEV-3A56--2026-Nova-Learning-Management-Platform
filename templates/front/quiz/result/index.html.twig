{% extends 'base_content.html.twig' %}

{% block title %}Game Over{% endblock %}

{% block body %}
<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            
            <div class="card shadow border-0 rounded-4 p-5">
                <div class="mb-4">
                    <i class="bi bi-trophy-fill text-warning display-1"></i>
                </div>
                
                <h1 class="fw-bold mb-2">Quiz Complete!</h1>
                <p class="text-muted mb-4">Great job! Here is how you did:</p>

                <div class="bg-light p-4 rounded-3 mb-4">
                    <div class="display-4 fw-bold text-primary">{{ score }} XP</div>
                    <div class="small text-uppercase text-muted fw-bold">Total Earned</div>
                </div>

                <div class="d-grid gap-2">
                    <a href="{{ path('app_front_quiz_index') }}" class="btn btn-primary btn-lg rounded-pill">
                        <i class="bi bi-controller me-2"></i> Play Another Quiz
                    </a>
                    <a href="{{ path('app_home') }}" class="btn btn-link text-muted">
                        Back to Home
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>
{% endblock %}