{% extends 'base_game.html.twig' %}

{% block title %}Playing Quiz{% endblock %}

{% block body %}
<section class="pt-0">
    <div class="container-fluid px-0">
        <div class="card bg-blue h-100px h-md-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
        </div>
    </div>
    <div class="container mt-n4">
        <div class="row">
            <div class="col-12">
                <div class="card bg-transparent card-body pb-0 px-0 mt-2 mt-sm-0">
                    <div class="row d-sm-flex justify-sm-content-between mt-2 mt-md-0">
                        <div class="col-auto">
                            <div class="avatar avatar-xxl position-relative mt-n3">
                                <img class="avatar-img rounded-circle border border-white border-3 shadow" src="{{ asset('assets/images/avatar/09.jpg') }}" alt="">
                            </div>
                        </div>
                        <div class="col d-sm-flex justify-content-between align-items-center">
                            <div>
                                <h1 class="my-1 fs-4">Student Name</h1>
                                <span class="badge bg-warning text-dark shadow-sm">
                                    <i class="fas fa-trophy me-1"></i> 250 XP
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<section class="pt-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                
                <div class="card border shadow-lg">
                    
                    <div class="card-header bg-light border-bottom d-flex justify-content-between align-items-center py-3">
                        <h5 class="card-title mb-0 text-primary">General Knowledge Quiz</h5>
                        
                        <div>
                            <span class="badge bg-info bg-opacity-10 text-info me-2">{{ question.difficulty }}</span>
                            <span class="badge bg-success bg-opacity-10 text-success">+{{ question.xpValue }} XP</span>                        </div>
                    </div>

                    <div class="card-body p-4">
                        <div class="bs-stepper-content">
                            
                            <form method="POST" action="{{ path('app_quiz_play') }}">
                                
                                <h3 class="mb-4 text-center text-dark fw-bold">{{ question.text }}</h3>
                                
                                <hr class="mb-4"> 

                                <div class="vstack gap-3">
                                    {% for choice in question.choices %}
                                        <div class="position-relative">
                                            <input type="radio" class="btn-check" name="answer" id="option_{{ choice.id }}" value="{{ choice.id }}">
                                            
                                            <label class="btn btn-outline-primary w-100 text-start p-3 border-2 fw-bold" for="option_{{ choice.id }}">
                                                <span class="badge bg-primary me-2">{{ loop.index }}</span> {{ choice.content }}
                                            </label>
                                        </div>
                                    {% endfor %}
                                </div>

                                <div class="d-flex justify-content-end mt-5">
                                    <button type="submit" class="btn btn-primary btn-lg shadow">
                                        Submit Answer <i class="fas fa-arrow-right ms-2"></i>
                                    </button>
                                </div>

                            </form>

                        </div>
                    </div>
                </div>      
            </div>
        </div> 
    </div>  
</section>
{% endblock %}