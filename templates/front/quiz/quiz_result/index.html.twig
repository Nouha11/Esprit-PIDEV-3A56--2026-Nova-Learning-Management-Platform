{% extends 'base_game.html.twig' %}

{% block title %}Quiz Result{% endblock %}

{% block body %}
<section class="pt-5 pb-0">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 col-md-8">
                <div class="card shadow-lg border-0">
                    <div class="card-body text-center p-5">
                        
                        <div class="mb-4">
                            <i class="fas fa-trophy text-warning display-1"></i>
                        </div>

                        <h2 class="mb-3">Quiz Completed!</h2>
                        <p class="lead mb-4">Great job! Here is your final score:</p>

                        <div class="bg-light p-4 rounded-3 mb-4">
                            <h1 class="display-4 fw-bold text-primary mb-0">{{ score }} XP</h1>
                            <small class="text-muted">Total Experience Earned</small>
                        </div>

                        <div class="d-grid gap-2">
                            <a href="{{ path('app_quiz_restart') }}" class="btn btn-success btn-lg">
                                <i class="fas fa-redo me-2"></i> Play Again
                            </a>
                            <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                                <i class="fas fa-home me-2"></i> Back to Home
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
{% endblock %}