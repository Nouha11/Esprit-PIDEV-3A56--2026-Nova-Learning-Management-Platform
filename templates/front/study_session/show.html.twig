{% extends 'front/base.html.twig' %}

{% block title %}Study Session Details{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Study Session Details</h1>
            <div>
                <a href="{{ path('study_session_index') }}" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to List
                </a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <div class="row">
            <!-- Main Session Information -->
            <div class="col-lg-8">
                <!-- Session Overview Card -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Session Overview</h4>
                        <div>
                            {% if study_session.completedAt %}
                                <span class="badge bg-success">Completed</span>
                            {% else %}
                                <span class="badge bg-warning">Planned</span>
                            {% endif %}
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted mb-1">Course</h6>
                                <p class="mb-0">
                                    {% if study_session.planning and study_session.planning.course %}
                                        <strong>{{ study_session.planning.course.courseName }}</strong>
                                    {% else %}
                                        <span class="text-muted">N/A</span>
                                    {% endif %}
                                </p>
                            </div>
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted mb-1">Started At</h6>
                                <p class="mb-0">
                                    <i class="bi bi-calendar-event"></i> 
                                    {{ study_session.startedAt ? study_session.startedAt|date('F d, Y') : 'N/A' }}
                                    <br>
                                    <i class="bi bi-clock"></i> 
                                    {{ study_session.startedAt ? study_session.startedAt|date('H:i') : 'N/A' }}
                                </p>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">Planned Duration</h6>
                                <p class="mb-0"><strong>{{ study_session.duration ?? 0 }}</strong> minutes</p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">Actual Duration</h6>
                                <p class="mb-0"><strong>{{ study_session.actualDuration ?? 'N/A' }}</strong> 
                                    {% if study_session.actualDuration %}minutes{% endif %}
                                </p>
                            </div>
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">XP Earned</h6>
                                <p class="mb-0"><strong>{{ study_session.xpEarned ?? 0 }}</strong> XP</p>
                            </div>
                        </div>

                        {% if study_session.completedAt %}
                        <div class="row">
                            <div class="col-12 mb-3">
                                <h6 class="text-muted mb-1">Completed At</h6>
                                <p class="mb-0">
                                    <i class="bi bi-check-circle-fill text-success"></i> 
                                    {{ study_session.completedAt|date('F d, Y H:i') }}
                                </p>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Mood & Energy Card -->
                {% if study_session.mood or study_session.energyLevel %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Mood & Energy</h4>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            {% if study_session.mood %}
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted mb-2">Mood</h6>
                                {% if study_session.mood == 'positive' %}
                                    <span class="badge bg-success fs-6">
                                        <i class="bi bi-emoji-smile"></i> Positive
                                    </span>
                                {% elseif study_session.mood == 'neutral' %}
                                    <span class="badge bg-secondary fs-6">
                                        <i class="bi bi-emoji-neutral"></i> Neutral
                                    </span>
                                {% elseif study_session.mood == 'negative' %}
                                    <span class="badge bg-danger fs-6">
                                        <i class="bi bi-emoji-frown"></i> Negative
                                    </span>
                                {% endif %}
                            </div>
                            {% endif %}

                            {% if study_session.energyLevel %}
                            <div class="col-md-6 mb-3">
                                <h6 class="text-muted mb-2">Energy Level</h6>
                                {% if study_session.energyLevel == 'high' %}
                                    <span class="badge bg-success fs-6">
                                        <i class="bi bi-lightning-charge-fill"></i> High
                                    </span>
                                {% elseif study_session.energyLevel == 'medium' %}
                                    <span class="badge bg-warning fs-6">
                                        <i class="bi bi-lightning-charge"></i> Medium
                                    </span>
                                {% elseif study_session.energyLevel == 'low' %}
                                    <span class="badge bg-danger fs-6">
                                        <i class="bi bi-battery-half"></i> Low
                                    </span>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Break Information Card -->
                {% if study_session.breakDuration or study_session.breakCount or study_session.pomodoroCount %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0">Break & Pomodoro Information</h4>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            {% if study_session.breakDuration %}
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">Break Duration</h6>
                                <p class="mb-0"><strong>{{ study_session.breakDuration }}</strong> minutes</p>
                            </div>
                            {% endif %}

                            {% if study_session.breakCount %}
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">Number of Breaks</h6>
                                <p class="mb-0"><strong>{{ study_session.breakCount }}</strong></p>
                            </div>
                            {% endif %}

                            {% if study_session.pomodoroCount %}
                            <div class="col-md-4 mb-3">
                                <h6 class="text-muted mb-1">Pomodoro Count</h6>
                                <p class="mb-0">
                                    <i class="bi bi-stopwatch"></i> <strong>{{ study_session.pomodoroCount }}</strong>
                                </p>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Notes Section -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">Notes</h4>
                        <a href="{{ path('note_create', {sessionId: study_session.id}) }}" class="btn btn-sm btn-primary">
                            <i class="bi bi-plus-circle"></i> Add Note
                        </a>
                    </div>
                    <div class="card-body">
                        {% if study_session.notes is not empty %}
                            {% for note in study_session.notes|sort((a, b) => b.createdAt <=> a.createdAt) %}
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar"></i> {{ note.createdAt|date('M d, Y H:i') }}
                                                {% if note.updatedAt and note.updatedAt != note.createdAt %}
                                                    <span class="badge bg-info">Edited</span>
                                                {% endif %}
                                            </small>
                                            <div>
                                                <a href="{{ path('note_edit', {id: note.id}) }}" 
                                                   class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form method="post" 
                                                      action="{{ path('note_delete', {id: note.id}) }}" 
                                                      style="display: inline;"
                                                      onsubmit="return confirm('Are you sure you want to delete this note?');">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_note_' ~ note.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                        <p class="mb-0">{{ note.content|nl2br }}</p>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="alert alert-info mb-0">
                                <i class="bi bi-info-circle"></i> No notes yet. Add your first note to capture important information!
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Resources Section -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">PDF Resources</h4>
                        <a href="{{ path('resource_upload', {sessionId: study_session.id}) }}" class="btn btn-sm btn-primary">
                            <i class="bi bi-upload"></i> Upload PDF
                        </a>
                    </div>
                    <div class="card-body">
                        {% if study_session.resources is not empty %}
                            <div class="list-group">
                                {% for resource in study_session.resources %}
                                    <div class="list-group-item d-flex justify-content-between align-items-center">
                                        <div>
                                            <i class="bi bi-file-pdf text-danger"></i>
                                            <strong>{{ resource.filename }}</strong>
                                            <br>
                                            <small class="text-muted">
                                                {{ (resource.fileSize / 1024 / 1024)|number_format(2) }} MB
                                                • Uploaded {{ resource.uploadedAt|date('M d, Y H:i') }}
                                            </small>
                                        </div>
                                        <div>
                                            <a href="{{ path('resource_download', {id: resource.id}) }}" 
                                               class="btn btn-sm btn-outline-primary"
                                               target="_blank">
                                                <i class="bi bi-download"></i> Download
                                            </a>
                                            <form method="post" 
                                                  action="{{ path('resource_delete', {id: resource.id}) }}" 
                                                  style="display: inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this resource?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_resource_' ~ resource.id) }}">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="alert alert-info mb-0">
                                <i class="bi bi-info-circle"></i> No PDF resources attached. Upload study materials to keep them organized!
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Tags Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Tags</h5>
                    </div>
                    <div class="card-body">
                        {% if study_session.tags is not empty %}
                            {% for tag in study_session.tags %}
                                <a href="{{ path('tag_filter', {id: tag.id}) }}" 
                                   class="badge bg-primary text-decoration-none me-1 mb-1"
                                   style="font-size: 0.9rem; padding: 0.5rem 0.75rem;">
                                    {{ tag.name }}
                                </a>
                            {% endfor %}
                        {% else %}
                            <p class="text-muted mb-0">No tags assigned</p>
                        {% endif %}
                    </div>
                </div>

                <!-- Actions Card -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="{{ path('pomodoro_timer', {id: study_session.id}) }}" 
                               class="btn btn-info">
                                <i class="bi bi-stopwatch"></i> Pomodoro Timer
                            </a>

                            <a href="{{ path('study_session_edit', {id: study_session.id}) }}" 
                               class="btn btn-primary">
                                <i class="bi bi-pencil"></i> Edit Session
                            </a>

                            {% if study_session.completedAt %}
                                <form method="post" 
                                      action="{{ path('study_session_mark_incomplete', {id: study_session.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_incomplete_' ~ study_session.id) }}">
                                    <button type="submit" class="btn btn-warning w-100">
                                        <i class="bi bi-x-circle"></i> Mark as Incomplete
                                    </button>
                                </form>
                            {% else %}
                                <form method="post" 
                                      action="{{ path('study_session_mark_complete', {id: study_session.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_complete_' ~ study_session.id) }}">
                                    <button type="submit" class="btn btn-success w-100">
                                        <i class="bi bi-check-circle"></i> Mark as Complete
                                    </button>
                                </form>
                            {% endif %}

                            <form method="post" 
                                  action="{{ path('study_session_delete', {id: study_session.id}) }}"
                                  onsubmit="return confirm('Are you sure you want to delete this study session? This will also delete all associated notes and resources.');">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_study_session_' ~ study_session.id) }}">
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-trash"></i> Delete Session
                                </button>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Quick Stats Card -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Quick Stats</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Notes</h6>
                            <p class="mb-0"><strong>{{ study_session.notes|length }}</strong> note(s)</p>
                        </div>
                        <div class="mb-3">
                            <h6 class="text-muted mb-1">Resources</h6>
                            <p class="mb-0"><strong>{{ study_session.resources|length }}</strong> PDF(s)</p>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Tags</h6>
                            <p class="mb-0"><strong>{{ study_session.tags|length }}</strong> tag(s)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
