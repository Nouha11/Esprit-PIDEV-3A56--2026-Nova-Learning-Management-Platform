{% extends 'front/base.html.twig' %}

{% block title %}Notes - Study Session{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Notes</h1>
            <div>
                <a href="{{ path('study_session_show', {id: study_session.id}) }}" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Session
                </a>
                <a href="{{ path('note_create', {studySessionId: study_session.id}) }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Add Note
                </a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <!-- Session Info Card -->
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">
                    {% if study_session.planning and study_session.planning.course %}
                        {{ study_session.planning.course.courseName }}
                    {% else %}
                        Study Session
                    {% endif %}
                </h5>
                <p class="card-text text-muted mb-0">
                    <i class="bi bi-calendar-event"></i> 
                    {{ study_session.startedAt ? study_session.startedAt|date('F d, Y H:i') : 'N/A' }}
                </p>
            </div>
        </div>

        <!-- Search Form -->
        <div class="card mb-4">
            <div class="card-body">
                <form method="get" action="{{ path('note_search', {studySessionId: study_session.id}) }}" class="row g-3">
                    <div class="col-md-10">
                        <label for="keyword" class="form-label">Search Notes</label>
                        <input type="text" 
                               class="form-control" 
                               id="keyword" 
                               name="keyword" 
                               placeholder="Enter keyword to search..." 
                               value="{{ keyword ?? '' }}">
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </form>
                {% if keyword is defined and keyword is not empty %}
                    <div class="mt-2">
                        <a href="{{ path('note_search', {studySessionId: study_session.id}) }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-x-circle"></i> Clear Search
                        </a>
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Notes List -->
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h4 class="mb-0">
                    {% if keyword is defined and keyword is not empty %}
                        Search Results for "{{ keyword }}"
                    {% else %}
                        All Notes
                    {% endif %}
                </h4>
                <span class="badge bg-primary">{{ notes|length }} note(s)</span>
            </div>
            <div class="card-body">
                {% if notes is empty %}
                    <div class="alert alert-info mb-0">
                        <i class="bi bi-info-circle"></i> 
                        {% if keyword is defined and keyword is not empty %}
                            No notes found matching "{{ keyword }}". Try a different search term.
                        {% else %}
                            No notes yet. Add your first note to capture important information!
                        {% endif %}
                    </div>
                {% else %}
                    {% for note in notes %}
                        <div class="card mb-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <small class="text-muted">
                                            <i class="bi bi-calendar"></i> 
                                            <strong>Created:</strong> {{ note.createdAt|date('M d, Y H:i') }}
                                        </small>
                                        {% if note.updatedAt and note.updatedAt != note.createdAt %}
                                            <br>
                                            <small class="text-muted">
                                                <i class="bi bi-pencil"></i> 
                                                <strong>Updated:</strong> {{ note.updatedAt|date('M d, Y H:i') }}
                                                <span class="badge bg-info">Edited</span>
                                            </small>
                                        {% endif %}
                                    </div>
                                    <div>
                                        <a href="{{ path('note_edit', {studySessionId: study_session.id, id: note.id}) }}" 
                                           class="btn btn-sm btn-outline-primary"
                                           title="Edit note">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>
                                        <form method="post" 
                                              action="{{ path('note_delete', {studySessionId: study_session.id, id: note.id}) }}" 
                                              style="display: inline;"
                                              onsubmit="return confirm('Are you sure you want to delete this note?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_note_' ~ note.id) }}">
                                            <button type="submit" 
                                                    class="btn btn-sm btn-outline-danger"
                                                    title="Delete note">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                                <div class="note-content">
                                    <p class="mb-0">{{ note.content|nl2br }}</p>
                                </div>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
