{% extends 'front/base.html.twig' %}

{% block title %}Study Sessions{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Study Sessions</h1>
            <div>
                <a href="{{ path('tag_index') }}" class="btn btn-outline-primary me-2">
                    <i class="bi bi-tags"></i> Manage Tags
                </a>
                <a href="{{ path('study_session_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> New Session
                </a>
            </div>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <!-- Filters Section -->
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title mb-3">Filters</h5>
                <div class="row g-3">
                    <!-- Status Filter -->
                    <div class="col-md-4">
                        <label class="form-label">Status</label>
                        <div class="btn-group w-100" role="group">
                            <a href="{{ path('study_session_index') }}" 
                               class="btn btn-sm btn-{{ status_filter is not defined or status_filter == 'all' ? 'primary' : 'outline-primary' }}">
                                All
                            </a>
                            <a href="{{ path('study_session_index', {status: 'completed'}) }}" 
                               class="btn btn-sm btn-{{ status_filter is defined and status_filter == 'completed' ? 'primary' : 'outline-primary' }}">
                                Completed
                            </a>
                            <a href="{{ path('study_session_index', {status: 'planned'}) }}" 
                               class="btn btn-sm btn-{{ status_filter is defined and status_filter == 'planned' ? 'primary' : 'outline-primary' }}">
                                Planned
                            </a>
                        </div>
                    </div>

                    <!-- Tag Filter -->
                    <div class="col-md-4">
                        <label class="form-label">Filter by Tag</label>
                        {% if available_tags is defined and available_tags is not empty %}
                            <select class="form-select form-select-sm" onchange="if(this.value) window.location.href=this.value;">
                                <option value="{{ path('study_session_index') }}">All Tags</option>
                                {% for tag in available_tags %}
                                    <option value="{{ path('tag_filter', {id: tag.id}) }}" 
                                            {{ filtered_by_tag is defined and filtered_by_tag.id == tag.id ? 'selected' : '' }}>
                                        {{ tag.name }} ({{ tag.studySessions|length }})
                                    </option>
                                {% endfor %}
                            </select>
                        {% else %}
                            <p class="text-muted mb-0"><small>No tags available</small></p>
                        {% endif %}
                    </div>

                    <!-- Clear Filters -->
                    <div class="col-md-4 d-flex align-items-end">
                        {% if (status_filter is defined and status_filter != 'all') or filtered_by_tag is defined %}
                            <a href="{{ path('study_session_index') }}" class="btn btn-sm btn-outline-secondary w-100">
                                <i class="bi bi-x-circle"></i> Clear All Filters
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% if filtered_by_tag is defined %}
            <div class="alert alert-info alert-dismissible fade show" role="alert">
                <i class="bi bi-filter"></i> Showing sessions filtered by tag: <strong>{{ filtered_by_tag.name }}</strong>
                <a href="{{ path('study_session_index') }}" class="btn btn-sm btn-outline-secondary ms-2">
                    Clear Filter
                </a>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endif %}

        <div class="card">
            <div class="card-body">
                {% if study_sessions is empty %}
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> No study sessions found. Create your first session to get started!
                    </div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Course</th>
                                    <th>Started At</th>
                                    <th>Duration</th>
                                    <th>XP Earned</th>
                                    <th>Mood</th>
                                    <th>Energy</th>
                                    <th>Status</th>
                                    <th>Tags</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for session in study_sessions %}
                                    <tr>
                                        <td>
                                            {% if session.planning and session.planning.course %}
                                                {{ session.planning.course.courseName }}
                                            {% else %}
                                                <span class="text-muted">N/A</span>
                                            {% endif %}
                                        </td>
                                        <td>{{ session.startedAt ? session.startedAt|date('M d, Y H:i') : 'N/A' }}</td>
                                        <td>{{ session.actualDuration ?? session.duration ?? 0 }} min</td>
                                        <td>{{ session.xpEarned ?? 0 }} XP</td>
                                        <td>
                                            {% if session.mood %}
                                                {% if session.mood == 'positive' %}
                                                    <span class="badge bg-success"><i class="bi bi-emoji-smile"></i> Positive</span>
                                                {% elseif session.mood == 'neutral' %}
                                                    <span class="badge bg-secondary"><i class="bi bi-emoji-neutral"></i> Neutral</span>
                                                {% elseif session.mood == 'negative' %}
                                                    <span class="badge bg-danger"><i class="bi bi-emoji-frown"></i> Negative</span>
                                                {% endif %}
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if session.energyLevel %}
                                                {% if session.energyLevel == 'high' %}
                                                    <span class="badge bg-success"><i class="bi bi-lightning-charge-fill"></i> High</span>
                                                {% elseif session.energyLevel == 'medium' %}
                                                    <span class="badge bg-warning"><i class="bi bi-lightning-charge"></i> Medium</span>
                                                {% elseif session.energyLevel == 'low' %}
                                                    <span class="badge bg-danger"><i class="bi bi-battery-half"></i> Low</span>
                                                {% endif %}
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if session.completedAt %}
                                                <span class="badge bg-success">Completed</span>
                                            {% else %}
                                                <span class="badge bg-warning">Planned</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if session.tags is not empty %}
                                                {% for tag in session.tags %}
                                                    <a href="{{ path('tag_filter', {id: tag.id}) }}" 
                                                       class="badge bg-primary text-decoration-none"
                                                       title="Filter by this tag">
                                                        {{ tag.name }}
                                                    </a>
                                                {% endfor %}
                                            {% else %}
                                                <span class="text-muted">-</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('pomodoro_timer', {id: session.id}) }}" 
                                               class="btn btn-sm btn-outline-secondary"
                                               title="Pomodoro Timer">
                                                <i class="bi bi-stopwatch"></i>
                                            </a>
                                            <a href="{{ path('study_session_show', {id: session.id}) }}" 
                                               class="btn btn-sm btn-outline-info"
                                               title="View details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a href="{{ path('study_session_edit', {id: session.id}) }}" 
                                               class="btn btn-sm btn-outline-primary"
                                               title="Edit session">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            
                                            {% if session.completedAt %}
                                                <form method="post" 
                                                      action="{{ path('study_session_mark_incomplete', {id: session.id}) }}" 
                                                      style="display: inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_incomplete_' ~ session.id) }}">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-warning" 
                                                            title="Mark as incomplete">
                                                        <i class="bi bi-x-circle"></i>
                                                    </button>
                                                </form>
                                            {% else %}
                                                <form method="post" 
                                                      action="{{ path('study_session_mark_complete', {id: session.id}) }}" 
                                                      style="display: inline;">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('mark_complete_' ~ session.id) }}">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-success" 
                                                            title="Mark as complete">
                                                        <i class="bi bi-check-circle"></i>
                                                    </button>
                                                </form>
                                            {% endif %}
                                            
                                            <form method="post" 
                                                  action="{{ path('study_session_delete', {id: session.id}) }}" 
                                                  style="display: inline;"
                                                  onsubmit="return confirm('Are you sure you want to delete this study session?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete_study_session_' ~ session.id) }}">
                                                <button type="submit" 
                                                        class="btn btn-sm btn-outline-danger" 
                                                        title="Delete session">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="mt-3">
            <a href="{{ path('analytics_dashboard') }}" class="btn btn-info">
                <i class="bi bi-graph-up"></i> View Analytics
            </a>
        </div>
    </div>
</div>

{# Include Study Buddy AI Widget - Students Only #}
{% if is_granted('ROLE_STUDENT') %}
    {% include 'components/study_buddy_widget.html.twig' %}
{% endif %}
{% endblock %}
