{% extends 'front/base.html.twig' %}

{% block title %}YouTube Video Search{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>YouTube Video Search</h1>
            <a href="{{ path('study_session_index') }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Study Sessions
            </a>
        </div>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="alert alert-warning alert-dismissible fade show" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}

        <!-- Search Form -->
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Search for Educational Videos</h5>
                <p class="text-muted">Find relevant YouTube videos to supplement your study sessions</p>
                <form method="get" action="{{ path('integration_youtube_search') }}" class="row g-3">
                    <div class="col-md-10">
                        <label for="query" class="form-label">Search Term</label>
                        <input type="text" 
                               class="form-control" 
                               id="query" 
                               name="q" 
                               placeholder="Enter topic or keyword (e.g., 'calculus tutorial', 'python programming')..." 
                               value="{{ query ?? '' }}"
                               required>
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-search"></i> Search
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <!-- Error Message -->
        {% if error %}
            <div class="alert alert-danger" role="alert">
                <i class="bi bi-exclamation-triangle"></i> {{ error }}
            </div>
        {% endif %}

        <!-- Video Results -->
        {% if videos is not empty %}
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">Search Results for "{{ query }}"</h4>
                    <span class="badge bg-primary">{{ videos|length }} video(s)</span>
                </div>
                <div class="card-body">
                    <div class="row">
                        {% for video in videos %}
                            <div class="col-md-6 col-lg-4 mb-4">
                                <div class="card h-100">
                                    <!-- Video Thumbnail -->
                                    <a href="https://www.youtube.com/watch?v={{ video.videoId }}" 
                                       target="_blank" 
                                       rel="noopener noreferrer"
                                       title="Watch {{ video.title }}">
                                        <img src="{{ video.thumbnailUrl }}" 
                                             class="card-img-top" 
                                             alt="{{ video.title }}"
                                             style="height: 180px; object-fit: cover;">
                                    </a>
                                    
                                    <div class="card-body d-flex flex-column">
                                        <!-- Video Title -->
                                        <h6 class="card-title">
                                            <a href="https://www.youtube.com/watch?v={{ video.videoId }}" 
                                               target="_blank" 
                                               rel="noopener noreferrer"
                                               class="text-decoration-none text-dark">
                                                {{ video.title }}
                                            </a>
                                        </h6>
                                        
                                        <!-- Channel Name -->
                                        <p class="card-text text-muted mb-2">
                                            <small>
                                                <i class="bi bi-person-circle"></i> {{ video.channelName }}
                                            </small>
                                        </p>
                                        
                                        <!-- View Count -->
                                        <p class="card-text text-muted mb-2">
                                            <small>
                                                <i class="bi bi-eye"></i> {{ video.viewCount|number_format }} views
                                            </small>
                                        </p>
                                        
                                        <!-- Published Date -->
                                        <p class="card-text text-muted mb-3">
                                            <small>
                                                <i class="bi bi-calendar"></i> {{ video.publishedAt }}
                                            </small>
                                        </p>
                                        
                                        <!-- Watch Button -->
                                        <div class="mt-auto">
                                            <a href="https://www.youtube.com/watch?v={{ video.videoId }}" 
                                               target="_blank" 
                                               rel="noopener noreferrer"
                                               class="btn btn-sm btn-primary w-100">
                                                <i class="bi bi-play-circle"></i> Watch on YouTube
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
        {% elseif query is not empty and error is null %}
            <div class="alert alert-info" role="alert">
                <i class="bi bi-info-circle"></i> No videos found for "{{ query }}". Try a different search term.
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
