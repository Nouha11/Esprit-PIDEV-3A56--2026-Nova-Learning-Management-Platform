{% extends 'front/base.html.twig' %}

{% block title %}Study Session Calendar{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        #calendar {
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
        }
        
        .fc {
            /* FullCalendar custom styling */
        }
        
        .fc-event {
            cursor: pointer;
        }
        
        .calendar-legend {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .legend-item {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .legend-color {
            width: 20px;
            height: 20px;
            border-radius: 4px;
        }
        
        .legend-color.completed {
            background-color: #28a745;
        }
        
        .legend-color.planned {
            background-color: #007bff;
        }
        
        .legend-color.scheduled {
            background-color: #6c757d;
        }
        
        /* Modal styling */
        .modal-body .detail-row {
            margin-bottom: 10px;
        }
        
        .modal-body .detail-label {
            font-weight: bold;
            color: #666;
        }
    </style>
{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h3 class="mb-0">
                    <i class="bi bi-calendar3"></i> Study Session Calendar
                </h3>
                <a href="{{ path('study_session_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> New Session
                </a>
            </div>
            <div class="card-body">
                <!-- Calendar Legend -->
                <div class="calendar-legend">
                    <div class="legend-item">
                        <div class="legend-color completed"></div>
                        <span>Completed</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-color planned"></div>
                        <span>Planned</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-color scheduled"></div>
                        <span>Scheduled</span>
                    </div>
                </div>
                
                <!-- Calendar Container -->
                <div id="calendar"></div>
            </div>
        </div>
    </div>
</div>

<!-- Event Detail Modal -->
<div class="modal fade" id="eventDetailModal" tabindex="-1" aria-labelledby="eventDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="eventDetailModalLabel">Session Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="eventDetailContent">
                <!-- Content will be populated by JavaScript -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a href="#" id="viewSessionBtn" class="btn btn-primary" style="display: none;">
                    <i class="bi bi-eye"></i> View Details
                </a>
                <a href="#" id="editSessionBtn" class="btn btn-warning" style="display: none;">
                    <i class="bi bi-pencil"></i> Edit
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Create Session Modal -->
<div class="modal fade" id="createSessionModal" tabindex="-1" aria-labelledby="createSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createSessionModalLabel">Create Study Session</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>You clicked on: <strong id="selectedDate"></strong></p>
                <p>Would you like to create a new study session for this date?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <a href="#" id="createSessionBtn" class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> Create Session
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script type="module">
        import { initializeCalendar } from '/js/calendar.js';

        document.addEventListener('DOMContentLoaded', function() {
            // Initialize calendar with configuration
            const calendar = initializeCalendar({
                eventsUrl: '{{ path('calendar_events') }}',
                updateUrl: '{{ path('calendar_update_datetime') }}',
                createUrl: '{{ path('study_session_new') }}',
                showUrl: '{{ path('study_session_show', {'id': '__ID__'}) }}',
                editUrl: '{{ path('study_session_edit', {'id': '__ID__'}) }}'
            });
        });
    </script>
{% endblock %}
