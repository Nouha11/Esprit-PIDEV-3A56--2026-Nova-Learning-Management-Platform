{% extends 'front/base.html.twig' %}

{% block title %}Upload PDF Resource{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">Upload PDF Resource</h3>
            </div>
            <div class="card-body">
                <!-- Display flash messages -->
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                <!-- Study Session Info -->
                <div class="alert alert-info mb-4">
                    <i class="bi bi-info-circle"></i>
                    <strong>Study Session:</strong> {{ study_session.planning.course.name }}
                    <br>
                    <strong>Date:</strong> {{ study_session.startedAt|date('F j, Y g:i A') }}
                </div>

                <!-- File Upload Form -->
                {{ form_start(form, {'attr': {'enctype': 'multipart/form-data'}}) }}
                    
                    <div class="mb-4">
                        {{ form_row(form.file, {
                            'label': 'Select PDF File',
                            'attr': {'class': 'form-control'}
                        }) }}
                        
                        <!-- File Requirements Info -->
                        <div class="mt-3 p-3 bg-light border rounded">
                            <h6 class="mb-2"><i class="bi bi-file-earmark-pdf"></i> File Requirements:</h6>
                            <ul class="mb-0">
                                <li><strong>Format:</strong> PDF files only (.pdf)</li>
                                <li><strong>Maximum Size:</strong> 10 MB</li>
                                <li>Ensure the file is a valid PDF document</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Display form errors -->
                    {% if form.file.vars.errors|length > 0 %}
                        <div class="alert alert-danger">
                            <strong>Validation Errors:</strong>
                            <ul class="mb-0">
                                {% for error in form.file.vars.errors %}
                                    <li>{{ error.message }}</li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% endif %}

                    {{ form_rest(form) }}

                    <div class="d-flex justify-content-between mt-4">
                        <a href="{{ path('study_session_index') }}" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-upload"></i> Upload PDF
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
