{% extends 'base.html.twig' %}

{% block title %}Edit Course - NOVA{% endblock %}

{% block body %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- Page Header -->
		<section class="bg-warning bg-opacity-10 text-white p-5 mt-4">
			<div class="d-flex justify-content-between align-items-center">
                <div class="col-12">
                    <h1 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Course
                    </h1>
                    <p class="mb-0 mt-2">Update the course information below</p>
                </div>
			</div>
		</section>

        <!-- Form Section -->
        <section class="py-5">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="card shadow">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Course Information</h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(form, 
                                        {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
                                
                                <div class="mb-3">
                                    {{ form_label(form.courseName, 'Course Name', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.courseName, {'attr': {'class': 'form-control', 'placeholder': 'Enter course name'}}) }}
                                    {{ form_errors(form.courseName) }}
                                </div>

                                <div class="mb-3">
                                    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Describe your course...'}}) }}
                                    {{ form_errors(form.description) }}
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.category, 'Category', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.category, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Programming'}}) }}
                                        {{ form_errors(form.category) }}
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.difficulty, 'Difficulty Level', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.difficulty, {'attr': {'class': 'form-select'}}) }}
                                        {{ form_errors(form.difficulty) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.estimatedDuration, 'Estimated Duration (minutes)', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.estimatedDuration, {'attr': {'class': 'form-control', 'placeholder': '60'}}) }}
                                        {{ form_errors(form.estimatedDuration) }}
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.maxStudents, 'Maximum Students', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.maxStudents, {'attr': {'class': 'form-control', 'placeholder': 'Leave empty for unlimited'}}) }}
                                        {{ form_errors(form.maxStudents) }}
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.isPublished, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.isPublished, 'Publish this course', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="card bg-light">
                                        <div class="card-body">
                                            <h6 class="card-title">
                                                <i class="bi bi-file-earmark-pdf me-2"></i>Add PDF Resources (Optional)
                                            </h6>
                                            <p class="small text-muted mb-3">
                                                Upload additional PDF files for this course. 
                                                You can upload multiple files at once (max 10MB per file).
                                            </p>
                                            {{ form_widget(form.pdfResources, {'attr': {'class': 'form-control'}}) }}
                                            {{ form_errors(form.pdfResources) }}
                                            {{ form_help(form.pdfResources) }}
                                            
                                            {% if course.resources|length > 0 %}
                                                <div class="mt-3">
                                                    <h6 class="small">Existing Resources:</h6>
                                                    <ul class="list-group list-group-flush">
                                                        {% for resource in course.resources %}
                                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                                <span>
                                                                    <i class="bi bi-file-pdf text-danger me-2"></i>
                                                                    {{ resource.filename }}
                                                                </span>
                                                                <span class="badge bg-secondary">
                                                                    {{ (resource.fileSize / 1024)|round(2) }} KB
                                                                </span>
                                                            </li>
                                                        {% endfor %}
                                                    </ul>
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-4">
                                    <a href="{{ path('course_index') }}" class="btn btn-secondary">
                                        <i class="bi bi-arrow-left me-2"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-warning">
                                        <i class="bi bi-check-circle me-2"></i>Update Course
                                    </button>
                                </div>

                            {{ form_end(form) }}
                        </div>
                    </div>

                    <!-- Danger Zone -->
                    <div class="card shadow border-danger mt-4">
                        <div class="card-header bg-danger text-white">
                            <h5 class="mb-0">
                                <i class="bi bi-exclamation-triangle me-2"></i>Danger Zone
                            </h5>
                        </div>
                        <div class="card-body">
                            <p class="text-muted mb-3">
                                Once you delete a course, there is no going back. Please be certain.
                            </p>
                            <a href="{{ path('course_delete', {id: form.vars.data.id}) }}" 
                               class="btn btn-danger"
                               onclick="return confirm('Are you sure you want to delete this course? This action cannot be undone.')">
                                <i class="bi bi-trash me-2"></i>Delete This Course
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->


<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>
{% endblock %}