{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Course List') }} - NOVA{% endblock %}

{% block body %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- Page content -->
		<section class="bg-body-secondary p-5 mt-4">
			<div class="d-flex justify-content-between align-items-center">
				<h1 class="mb-0 text-body-emphasis">{{ t.t('Course List') }}</h1>
				
				<div class="d-flex gap-2">
					{# Study Session Tools for Students #}
					{% if is_granted('ROLE_STUDENT') %}
						<a href="{{ path('study_session_index') }}" class="btn btn-outline-primary">
							<i class="bi bi-list-ul me-2"></i>{{ t.t('Study Session Tools') }}
						</a>
						<a href="{{ path('calendar_index') }}" class="btn btn-outline-info">
							<i class="bi bi-calendar3 me-2"></i>{{ t.t('Calendar View') }}
						</a>
					{% endif %}
					
					{# Show Create New Course button only for TUTOR users #}
					{% if is_granted('ROLE_TUTOR') %}
						<a href="{{ path('course_new') }}" class="btn btn-success">
							<i class="bi bi-plus-circle me-2"></i>{{ t.t('Create New Course') }}
						</a>
					{% endif %}
				</div>
			</div>
		</section>

        <section class="py-5">
            <!-- Filters Section -->
            <div class="card shadow mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">
                        <i class="bi bi-funnel"></i> {{ t.t('Filter Courses') }}
                    </h5>
                </div>
                <div class="card-body">
                    <form method="get" action="{{ path('course_index') }}">
                        <div class="row g-3">
                            <div class="col-md-4">
                                <label class="form-label">{{ t.t('Difficulty Level') }}</label>
                                <select name="difficulty" class="form-select">
                                    <option value="">{{ t.t('All Levels') }}</option>
                                    <option value="BEGINNER" {% if current_difficulty == 'BEGINNER' %}selected{% endif %}>{{ t.t('Beginner') }}</option>
                                    <option value="INTERMEDIATE" {% if current_difficulty == 'INTERMEDIATE' %}selected{% endif %}>{{ t.t('Intermediate') }}</option>
                                    <option value="ADVANCED" {% if current_difficulty == 'ADVANCED' %}selected{% endif %}>{{ t.t('Advanced') }}</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">{{ t.t('Category') }}</label>
                                <select name="category" class="form-select">
                                    <option value="">{{ t.t('All Categories') }}</option>
                                    {% for cat in categories %}
                                        <option value="{{ cat }}" {% if current_category == cat %}selected{% endif %}>{{ cat }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label">&nbsp;</label>
                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-search"></i> {{ t.t('Apply Filters') }}
                                    </button>
                                </div>
                            </div>
                        </div>
                        {% if current_difficulty or current_category %}
                            <div class="mt-3">
                                <a href="{{ path('course_index') }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-x-circle"></i> {{ t.t('Clear Filters') }}
                                </a>
                            </div>
                        {% endif %}
                    </form>
                </div>
            </div>

            <div class="row g-4">
                {% for course in courses %}
                    <div class="col-12">
                        <div class="card shadow p-3">
                            <div class="card-body">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="badge bg-primary">{{ course.category }}</span>

                                    {% if is_granted('ROLE_TUTOR') %}
                                        <div>
                                            <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-primary-soft">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="{{ path('course_delete', {id: course.id}) }}"
                                               class="btn btn-sm btn-danger-soft"
                                               onclick="return confirm('Are you sure?')">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>

                                <h5>{{ course.courseName }}</h5>

                                <p class="text-muted">
                                    {{ course.description ?? t.t('No description available') }}
                                </p>

                                <ul class="list-inline">
                                    <li class="list-inline-item">
                                        <i class="fas fa-signal text-success"></i>
                                        {{ course.difficulty }}
                                    </li>
                                    <li class="list-inline-item">
                                        <i class="bi bi-calendar text-warning"></i>
                                        {{ course.createdAt|date('M d, Y') }}
                                    </li>
                                </ul>

                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <span class="text-muted">
                                        {% if course.createdBy %}
                                            {% if course.createdBy.roles[0] == 'ROLE_TUTOR' %}
                                                <i class="bi bi-person-badge"></i> {{ t.t('By') }} {{ course.createdBy.username }}
                                            {% else %}
                                                <i class="bi bi-building"></i> {{ t.t('Provided by NOVA') }}
                                            {% endif %}
                                        {% else %}
                                            <i class="bi bi-building"></i> {{ t.t('Provided by NOVA') }}
                                        {% endif %}
                                    </span>
                                    <div>
                                        <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-primary me-2">
                                            <i class="bi bi-eye"></i> {{ t.t('View Details') }}
                                        </a>
                                        {% if is_granted('ROLE_STUDENT') %}
                                            {# Show Start Course button if enrolled #}
                                            {% if enrolled_courses[course.id] is defined and enrolled_courses[course.id] %}
                                                <a href="{{ path('course_session_view', {courseId: course.id}) }}" class="btn btn-sm btn-info me-2">
                                                    <i class="bi bi-play-circle"></i> {{ t.t('Start Course') }}
                                                </a>
                                                <a href="{{ path('planning_new', {course: course.id}) }}" class="btn btn-sm btn-success">
                                                    <i class="bi bi-calendar-plus"></i> {{ t.t('Plan Session') }}
                                                </a>
                                            {# Show Pending status if request is pending #}
                                            {% elseif pending_requests[course.id] is defined and pending_requests[course.id] %}
                                                <button class="btn btn-sm btn-warning" disabled>
                                                    <i class="bi bi-clock-history"></i> {{ t.t('Request Pending') }}
                                                </button>
                                            {# Show Request Enrollment button if not enrolled and no pending request #}
                                            {% else %}
                                                <form method="post" action="{{ path('enrollment_request', {id: course.id}) }}" class="d-inline">
                                                    <button type="submit" class="btn btn-sm btn-outline-primary">
                                                        <i class="bi bi-person-plus"></i> {{ t.t('Request Enrollment') }}
                                                    </button>
                                                </form>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="alert alert-info">
                            {{ t.t('No courses found.') }}
                            {% if is_granted('ROLE_TUTOR') %}
                                <a href="{{ path('course_new') }}">{{ t.t('Create your first course') }}</a>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->

<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>

{# Include Study Buddy AI Widget #}
{% include 'components/study_buddy_widget.html.twig' %}
{% endblock %}
