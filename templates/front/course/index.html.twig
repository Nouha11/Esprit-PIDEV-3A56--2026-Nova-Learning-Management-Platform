<!DOCTYPE html>
<html lang="en">
<head>
	<title>Course List - Eduport LMS</title>

	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">

	<link rel="shortcut icon" href="{{ asset('assets/images/favicon.ico') }}">
	<link rel="stylesheet" href="{{ asset('assets/vendor/font-awesome/css/all.min.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/vendor/bootstrap-icons/bootstrap-icons.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/vendor/choices/css/choices.min.css') }}">
	<link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">
</head>

<body>

<header class="navbar-light navbar-sticky">
	<nav class="navbar navbar-expand-xl">
		<div class="container">
			<a class="navbar-brand" href="{{ path('app_home') }}">
				<img src="{{ asset('assets/images/logo.svg') }}" alt="logo">
			</a>

			<div class="navbar-collapse collapse">
				<ul class="navbar-nav mx-auto">
					<li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Home</a></li>
					<li class="nav-item"><a class="nav-link active" href="{{ path('course_index') }}">Courses</a></li>
					{% if is_granted('ROLE_STUDENT') %}
						<li class="nav-item"><a class="nav-link" href="{{ path('planning_index') }}">My Sessions</a></li>
					{% endif %}
					{% if is_granted('ROLE_TUTOR') %}
						<li class="nav-item"><a class="nav-link" href="{{ path('course_new') }}">Create Course</a></li>
					{% endif %}
				</ul>
			</div>

			{% if app.user %}
				<a href="{{ path('app_logout') }}" class="btn btn-sm btn-outline-danger">Logout</a>
			{% else %}
				<a href="{{ path('app_login') }}" class="btn btn-sm btn-primary">Login</a>
			{% endif %}
		</div>
	</nav>
</header>

<main>

<section class="bg-dark text-white p-5">
	<div class="container">
		<h1>Course List</h1>
	</div>
</section>

<section class="py-5">
	<div class="container">

		<!-- Filters Section -->
		<div class="card shadow mb-4">
			<div class="card-header bg-light">
				<h5 class="mb-0">
					<i class="bi bi-funnel"></i> Filter Courses
				</h5>
			</div>
			<div class="card-body">
				<form method="get" action="{{ path('course_index') }}">
					<div class="row g-3">
						<div class="col-md-4">
							<label class="form-label">Difficulty Level</label>
							<select name="difficulty" class="form-select">
								<option value="">All Levels</option>
								<option value="BEGINNER" {% if current_difficulty == 'BEGINNER' %}selected{% endif %}>Beginner</option>
								<option value="INTERMEDIATE" {% if current_difficulty == 'INTERMEDIATE' %}selected{% endif %}>Intermediate</option>
								<option value="ADVANCED" {% if current_difficulty == 'ADVANCED' %}selected{% endif %}>Advanced</option>
							</select>
						</div>
						<div class="col-md-4">
							<label class="form-label">Category</label>
							<select name="category" class="form-select">
								<option value="">All Categories</option>
								{% for cat in categories %}
									<option value="{{ cat }}" {% if current_category == cat %}selected{% endif %}>{{ cat }}</option>
								{% endfor %}
							</select>
						</div>
						<div class="col-md-4">
							<label class="form-label">&nbsp;</label>
							<div class="d-grid">
								<button type="submit" class="btn btn-primary">
									<i class="bi bi-search"></i> Apply Filters
								</button>
							</div>
						</div>
					</div>
					{% if current_difficulty or current_category %}
						<div class="mt-3">
							<a href="{{ path('course_index') }}" class="btn btn-sm btn-outline-secondary">
								<i class="bi bi-x-circle"></i> Clear Filters
							</a>
						</div>
					{% endif %}
				</form>
			</div>
		</div>

		<div class="row g-4">
			{% for course in courses %}
				<div class="col-12">
					<div class="card shadow p-3">
						<div class="card-body">

							<div class="d-flex justify-content-between mb-2">
								<span class="badge bg-primary">{{ course.category }}</span>

								{% if is_granted('ROLE_TUTOR') %}
									<div>
										<a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-primary-soft">
											<i class="bi bi-pencil"></i>
										</a>
										<a href="{{ path('course_delete', {id: course.id}) }}"
										   class="btn btn-sm btn-danger-soft"
										   onclick="return confirm('Are you sure?')">
											<i class="bi bi-trash"></i>
										</a>
									</div>
								{% endif %}
							</div>

							<h5>{{ course.courseName }}</h5>

							<p class="text-muted">
								{{ course.description ?? 'No description available' }}
							</p>

							<ul class="list-inline">
								<li class="list-inline-item">
									<i class="fas fa-signal text-success"></i>
									{{ course.difficulty }}
								</li>
								<li class="list-inline-item">
									<i class="bi bi-calendar text-warning"></i>
									{{ course.createdAt|date('M d, Y') }}
								</li>
							</ul>

							<div class="d-flex justify-content-between align-items-center mt-3">
								<span class="text-muted">
									{% if course.createdBy %}
										{% if course.createdBy.roles[0] == 'ROLE_TUTOR' %}
											<i class="bi bi-person-badge"></i> By {{ course.createdBy.username }}
										{% else %}
											<i class="bi bi-building"></i> Provided by NOVA
										{% endif %}
									{% else %}
										<i class="bi bi-building"></i> Provided by NOVA
									{% endif %}
								</span>
								<div>
									<a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-primary me-2">
										<i class="bi bi-eye"></i> View Details
									</a>
									{% if is_granted('ROLE_STUDENT') %}
										<a href="{{ path('planning_new', {course: course.id}) }}" class="btn btn-sm btn-success">
											<i class="bi bi-calendar-plus"></i> Plan Session
										</a>
									{% endif %}
								</div>
							</div>

						</div>
					</div>
				</div>
			{% else %}
				<div class="col-12">
					<div class="alert alert-info">
						No courses found.
						{% if is_granted('ROLE_TUTOR') %}
							<a href="{{ path('course_new') }}">Create your first course</a>
						{% endif %}
					</div>
				</div>
			{% endfor %}
		</div>

	</div>
</section>

</main>

<footer class="bg-light p-4 text-center">
	<p class="mb-0">© 2024 Eduport</p>
</footer>

<script src="{{ asset('assets/vendor/bootstrap/dist/js/bootstrap.bundle.min.js') }}"></script>
<script src="{{ asset('assets/vendor/choices/js/choices.min.js') }}"></script>
<script src="{{ asset('assets/js/functions.js') }}"></script>

</body>
</html>
