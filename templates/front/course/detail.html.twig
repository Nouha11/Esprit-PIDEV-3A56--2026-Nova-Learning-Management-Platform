{% extends 'base.html.twig' %}

{% block title %}{{ course.courseName }} - NOVA{% endblock %}

{% block body %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- Course Header -->
		<section class="bg-primary bg-opacity-10 py-5 mt-4">
			<div class="container">
				<div class="row">
					<div class="col-lg-8">
						<span class="badge bg-primary mb-2">{{ course.category }}</span>
						<h1 class="mb-3">{{ course.courseName }}</h1>
						<p class="lead">{{ course.description ?? 'No description available' }}</p>
						
						<div class="d-flex align-items-center mt-4">
							<div class="me-4">
								<i class="bi bi-person-circle fs-5 me-2"></i>
								<span>
									{% if course.createdBy %}
										{% if course.createdBy.roles[0] == 'ROLE_TUTOR' %}
											By {{ course.createdBy.username }}
										{% else %}
											Provided by NOVA
										{% endif %}
									{% else %}
										Provided by NOVA
									{% endif %}
								</span>
							</div>
							<div class="me-4">
								<i class="bi bi-calendar3 fs-5 me-2"></i>
								<span>{{ course.createdAt|date('M d, Y') }}</span>
							</div>
						</div>
					</div>
					
					<div class="col-lg-4">
						<div class="card shadow mt-4 mt-lg-0">
							<div class="card-body text-center">
								<h4 class="mb-3">Course Status</h4>
								{% if course.status == 'COMPLETED' %}
									<span class="badge bg-success fs-6 mb-3">Completed</span>
								{% elseif course.status == 'IN_PROGRESS' %}
									<span class="badge bg-primary fs-6 mb-3">In Progress</span>
								{% else %}
									<span class="badge bg-secondary fs-6 mb-3">Not Started</span>
								{% endif %}
								
								{% if course.isPublished %}
									<p class="text-success mb-3">
										<i class="bi bi-check-circle"></i> Published
									</p>
								{% else %}
									<p class="text-muted mb-3">
										<i class="bi bi-x-circle"></i> Draft
									</p>
								{% endif %}
								
								{% if is_granted('ROLE_STUDENT') %}
									<a href="{{ path('planning_new', {course: course.id}) }}" class="btn btn-primary w-100">
										<i class="bi bi-calendar-plus"></i> Plan Study Session
									</a>
								{% endif %}
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

        <!-- Course Details -->
        <section class="py-5">
            <div class="row g-4">
                
                <!-- Main Content -->
                <div class="col-lg-8">
                    
                    <!-- Course Information -->
                    <div class="card shadow mb-4">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="bi bi-info-circle me-2"></i>Course Information
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-primary bg-opacity-10 text-primary rounded-circle me-3">
                                            <i class="bi bi-signal fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">Difficulty Level</h6>
                                            <p class="mb-0 text-muted">{{ course.difficulty }}</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-success bg-opacity-10 text-success rounded-circle me-3">
                                            <i class="bi bi-clock fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">Estimated Duration</h6>
                                            <p class="mb-0 text-muted">{{ course.estimatedDuration }} minutes</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-info bg-opacity-10 text-info rounded-circle me-3">
                                            <i class="bi bi-people fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">Maximum Students</h6>
                                            <p class="mb-0 text-muted">{{ course.maxStudents ?? 'Unlimited' }}</p>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="d-flex align-items-center">
                                        <div class="icon-lg bg-warning bg-opacity-10 text-warning rounded-circle me-3">
                                            <i class="bi bi-graph-up fs-5"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">Progress</h6>
                                            <p class="mb-0 text-muted">{{ course.progress }}%</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Progress Bar -->
                            <div class="mt-4">
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Course Progress</span>
                                    <span class="fw-bold">{{ course.progress }}%</span>
                                </div>
                                <div class="progress" style="height: 10px;">
                                    <div class="progress-bar" role="progressbar" style="width: {{ course.progress }}%" 
                                         aria-valuenow="{{ course.progress }}" aria-valuemin="0" aria-valuemax="100"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Planning Sessions -->
                    <div class="card shadow mb-4">
                        <div class="card-header bg-light d-flex justify-content-between align-items-center">
                            <h5 class="mb-0">
                                <i class="bi bi-calendar-check me-2"></i>Planning Sessions
                            </h5>
                            <button class="btn btn-sm btn-outline-primary" type="button" data-bs-toggle="collapse" data-bs-target="#planningFilters">
                                <i class="bi bi-funnel"></i> Filters
                            </button>
                        </div>
                        
                        <!-- Planning Filters -->
                        <div class="collapse" id="planningFilters">
                            <div class="card-body border-bottom bg-light">
                                <form method="get" action="{{ path('course_show', {id: course.id}) }}">
                                    <div class="row g-3">
                                        <div class="col-md-4">
                                            <label class="form-label">Status</label>
                                            <select name="status" class="form-select form-select-sm">
                                                <option value="">All Statuses</option>
                                                <option value="SCHEDULED" {% if current_status == 'SCHEDULED' %}selected{% endif %}>Scheduled</option>
                                                <option value="COMPLETED" {% if current_status == 'COMPLETED' %}selected{% endif %}>Completed</option>
                                                <option value="MISSED" {% if current_status == 'MISSED' %}selected{% endif %}>Missed</option>
                                                <option value="CANCELLED" {% if current_status == 'CANCELLED' %}selected{% endif %}>Cancelled</option>
                                            </select>
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Date From</label>
                                            <input type="date" name="dateFrom" class="form-control form-control-sm" value="{{ date_from ? date_from|date('Y-m-d') : '' }}">
                                        </div>
                                        <div class="col-md-3">
                                            <label class="form-label">Date To</label>
                                            <input type="date" name="dateTo" class="form-control form-control-sm" value="{{ date_to ? date_to|date('Y-m-d') : '' }}">
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label">&nbsp;</label>
                                            <button type="submit" class="btn btn-sm btn-primary w-100">Apply</button>
                                        </div>
                                    </div>
                                    {% if current_status or date_from or date_to %}
                                        <div class="mt-2">
                                            <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-x-circle"></i> Clear
                                            </a>
                                        </div>
                                    {% endif %}
                                </form>
                            </div>
                        </div>
                        
                        <div class="card-body">
                            {% if plannings|length > 0 %}
                                <div class="list-group list-group-flush">
                                    {% for planning in plannings %}
                                        <div class="list-group-item px-0">
                                            <div class="d-flex justify-content-between align-items-center">
                                                <div>
                                                    <h6 class="mb-1">{{ planning.title }}</h6>
                                                    <small class="text-muted">
                                                        <i class="bi bi-calendar3"></i> {{ planning.scheduledDate|date('M d, Y') }} 
                                                        at {{ planning.scheduledTime|date('H:i') }}
                                                        <span class="ms-2">
                                                            <i class="bi bi-clock"></i> {{ planning.plannedDuration }} min
                                                        </span>
                                                    </small>
                                                </div>
                                                <div>
                                                    {% if planning.status == 'COMPLETED' %}
                                                        <span class="badge bg-success">Completed</span>
                                                    {% elseif planning.status == 'SCHEDULED' %}
                                                        <span class="badge bg-primary">Scheduled</span>
                                                    {% elseif planning.status == 'MISSED' %}
                                                        <span class="badge bg-danger">Missed</span>
                                                    {% else %}
                                                        <span class="badge bg-secondary">Cancelled</span>
                                                    {% endif %}
                                                </div>
                                            </div>
                                        </div>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <p class="text-muted text-center mb-0">
                                    <i class="bi bi-calendar-x fs-1 d-block mb-2"></i>
                                    {% if current_status or date_from or date_to %}
                                        No planning sessions match your filters.
                                    {% else %}
                                        No planning sessions yet for this course.
                                    {% endif %}
                                </p>
                            {% endif %}
                        </div>
                    </div>
                    
                    <!-- Study Session Statistics -->
                    {% if total_sessions > 0 %}
                    <div class="card shadow">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="bi bi-graph-up me-2"></i>Study Session Statistics
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="row g-4 text-center">
                                <div class="col-md-4">
                                    <div class="p-3 bg-primary bg-opacity-10 rounded">
                                        <i class="bi bi-calendar-check fs-1 text-primary d-block mb-2"></i>
                                        <h3 class="mb-0">{{ total_sessions }}</h3>
                                        <p class="text-muted mb-0">Total Sessions</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 bg-success bg-opacity-10 rounded">
                                        <i class="bi bi-star fs-1 text-success d-block mb-2"></i>
                                        <h3 class="mb-0">{{ total_xp }}</h3>
                                        <p class="text-muted mb-0">Total XP Earned</p>
                                    </div>
                                </div>
                                <div class="col-md-4">
                                    <div class="p-3 bg-info bg-opacity-10 rounded">
                                        <i class="bi bi-clock fs-1 text-info d-block mb-2"></i>
                                        <h3 class="mb-0">{{ avg_duration }}</h3>
                                        <p class="text-muted mb-0">Avg Duration (min)</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    
                </div>
                
                <!-- Sidebar -->
                <div class="col-lg-4">
                    
                    <!-- Quick Actions -->
                    {% if is_granted('ROLE_TUTOR') and course.createdBy and course.createdBy.id == app.user.id %}
                        <div class="card shadow mb-4">
                            <div class="card-header bg-light">
                                <h6 class="mb-0">Quick Actions</h6>
                            </div>
                            <div class="card-body">
                                <div class="d-grid gap-2">
                                    <a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-warning">
                                        <i class="bi bi-pencil me-2"></i>Edit Course
                                    </a>
                                    <a href="{{ path('course_delete', {id: course.id}) }}" 
                                       class="btn btn-danger"
                                       onclick="return confirm('Are you sure you want to delete this course?')">
                                        <i class="bi bi-trash me-2"></i>Delete Course
                                    </a>
                                </div>
                            </div>
                        </div>
                    {% endif %}
                    
                    <!-- Course Stats -->
                    <div class="card shadow">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">Course Statistics</h6>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-calendar-plus text-primary me-2"></i>Created</span>
                                        <span class="fw-bold">{{ course.createdAt|date('M d, Y') }}</span>
                                    </div>
                                </li>
                                <li class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-calendar-check text-success me-2"></i>Planning Sessions</span>
                                        <span class="fw-bold">{{ course.plannings|length }}</span>
                                    </div>
                                </li>
                                <li class="mb-3">
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-tag text-info me-2"></i>Category</span>
                                        <span class="badge bg-primary">{{ course.category }}</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="d-flex justify-content-between">
                                        <span><i class="bi bi-eye text-warning me-2"></i>Status</span>
                                        {% if course.isPublished %}
                                            <span class="badge bg-success">Published</span>
                                        {% else %}
                                            <span class="badge bg-secondary">Draft</span>
                                        {% endif %}
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                    
                </div>
                
            </div>
            
            <!-- Back Button -->
            <div class="row mt-4">
                <div class="col-12">
                    <a href="{{ path('course_index') }}" class="btn btn-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Courses
                    </a>
                </div>
            </div>
            
        </section>
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->



<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>
{% endblock %}