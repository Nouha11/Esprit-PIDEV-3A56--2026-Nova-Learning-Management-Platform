{% extends 'base.html.twig' %}

{% block title %}Create Course - NOVA{% endblock %}

{% block body %}


<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- Page Header -->
		<section class="bg-primary bg-opacity-10 py-5 mt-4">
			<div class="row justify-content-center">
				<div class="col-lg-10 col-xl-8">
					<div class="row">
						<div class="col-12">
							<h1 class="mb-0">
								<i class="bi bi-plus-circle me-2"></i>Create New Course
							</h1>
							<p class="mb-0 mt-2">Fill in the details below to create a new course</p>
						</div>
					</div>
				</div>
			</div>
		</section>

        <!-- Form Section -->
        <section class="py-5">
            <div class="row">
                <div class="col-lg-8 mx-auto">
                    <div class="card shadow">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">Course Information</h5>
                        </div>
                        <div class="card-body">
                            {{ form_start(form) }}
                                
                                <div class="mb-3">
                                    {{ form_label(form.courseName, 'Course Name', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.courseName, {'attr': {'class': 'form-control', 'placeholder': 'Enter course name'}}) }}
                                    {{ form_errors(form.courseName) }}
                                </div>

                                <div class="mb-3">
                                    {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                                    {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 4, 'placeholder': 'Describe your course...'}}) }}
                                    {{ form_errors(form.description) }}
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.category, 'Category', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.category, {'attr': {'class': 'form-control', 'placeholder': 'e.g., Programming'}}) }}
                                        {{ form_errors(form.category) }}
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.difficulty, 'Difficulty Level', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.difficulty, {'attr': {'class': 'form-select'}}) }}
                                        {{ form_errors(form.difficulty) }}
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.estimatedDuration, 'Estimated Duration (minutes)', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.estimatedDuration, {'attr': {'class': 'form-control', 'placeholder': '60'}}) }}
                                        {{ form_errors(form.estimatedDuration) }}
                                    </div>

                                    <div class="col-md-6 mb-3">
                                        {{ form_label(form.maxStudents, 'Maximum Students', {'label_attr': {'class': 'form-label'}}) }}
                                        {{ form_widget(form.maxStudents, {'attr': {'class': 'form-control', 'placeholder': 'Leave empty for unlimited'}}) }}
                                        {{ form_errors(form.maxStudents) }}
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check">
                                        {{ form_widget(form.isPublished, {'attr': {'class': 'form-check-input'}}) }}
                                        {{ form_label(form.isPublished, 'Publish this course immediately', {'label_attr': {'class': 'form-check-label'}}) }}
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between mt-4">
                                    <a href="{{ path('course_index') }}" class="btn btn-secondary">
                                        <i class="bi bi-arrow-left me-2"></i>Cancel
                                    </a>
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-check-circle me-2"></i>Create Course
                                    </button>
                                </div>

                            {{ form_end(form) }}
                        </div>
                    </div>
                </div>
            </div>
        </section>
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->


<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>
{% endblock %}