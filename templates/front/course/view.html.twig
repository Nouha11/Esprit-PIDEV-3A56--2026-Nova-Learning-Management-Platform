    checkUrl: '{{ path('course_session_energy_check', {courseId: course.id}) }}'
};
</script>

<script src="{{ asset('js/pomodoro-timer.js') }}"></script>
<script>
// Initialize energy monitoring - the widget already has updateEnergyBar function
