{% extends 'front/base.html.twig' %}

{% block title %}{{ course.courseName }} - Course Session{% endblock %}

{% block front_content %}
<div class="row mt-4">
    <div class="col-lg-10 offset-lg-1">
        <!-- Page Header -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>{{ course.courseName }}</h1>
            <a href="{{ path('course_show', {id: course.id}) }}" class="btn btn-secondary">
                <i class="bi bi-arrow-left"></i> Back to Course Details
            </a>
        </div>

        <!-- Main Content Area -->
        <div class="row">
            <div class="col-12">
                <!-- Pomodoro Timer Component -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="bi bi-stopwatch"></i> Pomodoro Timer</h4>
                    </div>
                    <div class="card-body text-center">
                        <!-- Timer Display -->
                        <div class="timer-display mb-4">
                            <div id="timer-circle" class="timer-circle">
                                <div class="timer-text">
                                    <span id="timer-minutes">25</span>:<span id="timer-seconds">00</span>
                                </div>
                                <div class="timer-label">
                                    <small id="timer-status" class="text-muted">Ready to start</small>
                                </div>
                            </div>
                        </div>

                        <!-- Timer Controls -->
                        <div class="timer-controls mb-4">
                            <button id="start-btn" class="btn btn-success btn-lg me-2">
                                <i class="bi bi-play-fill"></i> Start
                            </button>
                            <button id="pause-btn" class="btn btn-warning btn-lg me-2" style="display: none;">
                                <i class="bi bi-pause-fill"></i> Pause
                            </button>
                            <button id="resume-btn" class="btn btn-info btn-lg me-2" style="display: none;">
                                <i class="bi bi-play-fill"></i> Resume
                            </button>
                            <button id="reset-btn" class="btn btn-secondary btn-lg">
                                <i class="bi bi-arrow-clockwise"></i> Reset
                            </button>
                        </div>
                        
                        <!-- Pomodoro Progress Indicators -->
                        <div class="mb-3">
                            <div class="d-flex justify-content-center align-items-center gap-2 mb-2">
                                <span class="pomodoro-indicator"></span>
                                <span class="pomodoro-indicator"></span>
                                <span class="pomodoro-indicator"></span>
                                <span class="pomodoro-indicator"></span>
                            </div>
                            <small class="text-muted" id="progress-text">0 / 4 Pomodoros</small>
                        </div>
                        
                        <!-- Pomodoro Count Display -->
                        <div class="mb-3">
                            <p class="mb-1 text-muted">Total Pomodoros Completed</p>
                            <h3 id="pomodoro-count-display"><strong>0</strong></h3>
                        </div>
                        
                        <!-- Pomodoro Progress Bar -->
                        <div class="progress mb-3" style="height: 20px;">
                            <div id="pomodoro-progress-bar" class="progress-bar bg-info" role="progressbar" 
                                 style="width: 0%" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                                0%
                            </div>
                        </div>

                        <!-- Break Suggestion -->
                        <div id="break-suggestion" class="alert alert-info" style="display: none;">
                            <i class="bi bi-cup-hot"></i>
                            <strong>Time for a break!</strong>
                            <p class="mb-0" id="break-message">Take a 5-minute break to recharge.</p>
                        </div>
                    </div>
                </div>

                <!-- Course Progress Bar -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="bi bi-graph-up"></i> Course Progress</h4>
                    </div>
                    <div class="card-body">
                        <div class="progress mb-2" style="height: 30px;">
                            <div id="course-progress-bar" class="progress-bar progress-bar-striped bg-success" 
                                 role="progressbar" 
                                 style="width: {{ course.progress ?? 0 }}%"
                                 aria-valuenow="{{ course.progress ?? 0 }}" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                <strong>{{ course.progress ?? 0 }}%</strong>
                            </div>
                        </div>
                        <p class="text-muted mb-0 text-center">
                            <small>You've completed {{ course.progress ?? 0 }}% of this course</small>
                        </p>
                    </div>
                </div>

                <!-- Energy Bar Display -->
                {% if is_granted('ROLE_STUDENT') %}
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="bi bi-lightning-charge-fill text-warning"></i> Energy Monitor</h4>
                    </div>
                    <div class="card-body">
                        {% include 'components/energy_bar_widget.html.twig' with {
                            'currentEnergy': currentEnergy,
                            'showLabel': true,
                            'size': 'normal',
                            'timeUntilRefill': timeUntilRefill
                        } %}
                        
                        <div class="mt-3 text-center">
                            <p class="text-muted small mb-2">
                                <i class="bi bi-info-circle me-1"></i>
                                Your energy decreases 1 point per minute as you study. Restores 10 points every 5 minutes or play mini games!
                            </p>
                            <a href="{{ path('front_game_index', {'category': 'MINI_GAME'}) }}" class="btn btn-sm btn-outline-warning">
                                <i class="bi bi-controller me-1"></i> Play Mini Games
                            </a>
                        </div>
                    </div>
                </div>
                {% endif %}

                <!-- Course Content Placeholder -->
                <div class="card mb-4" style="position: relative;">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="bi bi-book"></i> Course Content</h4>
                    </div>
                    <div class="card-body">
                        <div class="text-center py-5">
                            <i class="bi bi-file-earmark-text" style="font-size: 4rem; color: #ccc;"></i>
                            <h5 class="text-muted mt-3">Course content here</h5>
                            <p class="text-muted">This area is reserved for future course content implementation</p>
                        </div>
                    </div>
                    
                    <!-- Course Interaction Blocking Overlay -->
                    <div id="course-content-overlay" style="display: {% if currentEnergy <= 0 %}block{% else %}none{% endif %}; position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0, 0, 0, 0.7); z-index: 10; border-radius: 0.25rem;">
                        <div style="position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); text-align: center; color: white;">
                            <i class="bi bi-lock-fill" style="font-size: 3rem;"></i>
                            <h5 class="mt-3">Content Locked</h5>
                            <p>Restore your energy to continue learning</p>
                        </div>
                    </div>
                </div>

                <!-- PDF Resources Section -->
                <div class="card mb-4">
                    <div class="card-header">
                        <h4 class="mb-0"><i class="bi bi-file-pdf"></i> Course Resources</h4>
                    </div>
                    <div class="card-body">
                        {% if resources is not empty %}
                            <div class="list-group">
                                {% for resource in resources %}
                                    <a href="{{ path('course_resource_download', {courseId: course.id, resourceId: resource.id}) }}" 
                                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                       download>
                                        <div>
                                            <i class="bi bi-file-pdf-fill text-danger me-2"></i>
                                            <strong>{{ resource.filename }}</strong>
                                        </div>
                                        <span class="badge bg-primary rounded-pill">
                                            <i class="bi bi-download"></i> Download
                                        </span>
                                    </a>
                                {% endfor %}
                            </div>
                        {% else %}
                            <div class="text-center py-4">
                                <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
                                <p class="text-muted mt-3 mb-0">No resources available for this course</p>
                            </div>
                        {% endif %}
                    </div>
                </div>

                <!-- Course Notes Section -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="bi bi-journal-text"></i> Course Notes</h4>
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addNoteModal">
                            <i class="bi bi-plus-circle"></i> Add Note
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="notes-container">
                            <div class="text-center py-4">
                                <i class="bi bi-journal" style="font-size: 3rem; color: #ccc;"></i>
                                <p class="text-muted mt-3 mb-0">No notes yet. Add your first note to keep track of important information!</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Course Tags Section -->
                <div class="card mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0"><i class="bi bi-tags"></i> Course Tags</h4>
                        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addTagModal">
                            <i class="bi bi-plus-circle"></i> Add Tag
                        </button>
                    </div>
                    <div class="card-body">
                        <div id="tags-container">
                            <div class="text-center py-4">
                                <i class="bi bi-tag" style="font-size: 3rem; color: #ccc;"></i>
                                <p class="text-muted mt-3 mb-0">No tags yet. Add tags to organize your learning!</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addNoteModalLabel">
                    <i class="bi bi-journal-plus"></i> Add New Note
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addNoteForm">
                    <div class="mb-3">
                        <label for="noteTitle" class="form-label">Title</label>
                        <input type="text" class="form-control" id="noteTitle" placeholder="Enter note title" required>
                    </div>
                    <div class="mb-3">
                        <label for="noteContent" class="form-label">Content</label>
                        <textarea class="form-control" id="noteContent" rows="5" placeholder="Enter your note content" required></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveNote()">
                    <i class="bi bi-save"></i> Save Note
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Add Tag Modal -->
<div class="modal fade" id="addTagModal" tabindex="-1" aria-labelledby="addTagModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addTagModalLabel">
                    <i class="bi bi-tag-fill"></i> Add New Tag
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="addTagForm">
                    <div class="mb-3">
                        <label for="tagName" class="form-label">Tag Name</label>
                        <input type="text" class="form-control" id="tagName" placeholder="Enter tag name (e.g., Important, Review, Difficult)" required>
                    </div>
                    <div class="mb-3">
                        <label for="tagColor" class="form-label">Tag Color</label>
                        <select class="form-select" id="tagColor">
                            <option value="primary">Blue</option>
                            <option value="success">Green</option>
                            <option value="danger">Red</option>
                            <option value="warning">Yellow</option>
                            <option value="info">Cyan</option>
                            <option value="secondary">Gray</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="saveTag()">
                    <i class="bi bi-save"></i> Save Tag
                </button>
            </div>
        </div>
    </div>

<!-- Energy Depletion Modal -->
<div class="modal fade" id="energy-depletion-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="energyDepletionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center py-5">
                <div class="mb-4">
                    <i class="bi bi-battery-charging" style="font-size: 5rem; color: #dc3545;"></i>
                </div>
                <h4 class="mb-3">Energy Depleted!</h4>
                <p class="lead mb-4">Your energy is depleted and you need to play a mini game to restore it</p>
                <a href="/games" class="btn btn-primary btn-lg">
                    <i class="bi bi-controller"></i> Go to Games
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Audio element for notification sound -->
<audio id="notification-sound" preload="auto">
    <source src="data:audio/wav;base64," type="audio/wav">
</audio>

<style>
.timer-circle {
    width: 300px;
    height: 300px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    transition: all 0.3s ease;
}

.timer-circle.running {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
    animation: pulse 2s infinite;
}

.timer-circle.paused {
    background: linear-gradient(135deg, #ffecd2 0%, #fcb69f 100%);
}

@keyframes pulse {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.05); }
}

.timer-text {
    font-size: 4rem;
    font-weight: bold;
    color: white;
    font-family: 'Courier New', monospace;
}

.timer-label {
    color: rgba(255, 255, 255, 0.9);
    margin-top: 10px;
}

.pomodoro-indicator {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background-color: #e0e0e0;
    display: inline-block;
    transition: all 0.3s ease;
}

.pomodoro-indicator.completed {
    background-color: #17a2b8;
    box-shadow: 0 0 10px rgba(23, 162, 184, 0.5);
}

/* Energy depletion animation */
@keyframes energy-deplete {
    0% { transform: scale(1); }
    50% { transform: scale(0.98); }
    100% { transform: scale(1); }
}

.energy-depleting {
    animation: energy-deplete 0.5s ease-out;
}

/* Progress growth animation */
@keyframes progress-grow {
    0% { opacity: 0.7; }
    50% { opacity: 1; box-shadow: 0 0 15px rgba(40, 167, 69, 0.6); }
    100% { opacity: 1; }
}

.progress-growing {
    animation: progress-grow 0.5s ease-out;
}
</style>

