});

// Notes Management
let notes = [];

function loadNotes() {
    // Load notes from localStorage for this course
    const courseId = {{ course.id }};
    const storedNotes = localStorage.getItem(`course_${courseId}_notes`);
    if (storedNotes) {
        notes = JSON.parse(storedNotes);
        displayNotes();
    }
}

function saveNote() {
    const title = document.getElementById('noteTitle').value.trim();
    const content = document.getElementById('noteContent').value.trim();
    
    if (!title || !content) {
        alert('Please fill in both title and content');
        return;
    }
    
    const note = {
        id: Date.now(),
        title: title,
        content: content,
        createdAt: new Date().toISOString()
    };
    
    notes.push(note);
    saveNotesToStorage();
    displayNotes();
    
    // Clear form and close modal
    document.getElementById('noteTitle').value = '';
    document.getElementById('noteContent').value = '';
    bootstrap.Modal.getInstance(document.getElementById('addNoteModal')).hide();
}

function deleteNote(noteId) {
    if (confirm('Are you sure you want to delete this note?')) {
        notes = notes.filter(note => note.id !== noteId);
        saveNotesToStorage();
        displayNotes();
    }
}

function saveNotesToStorage() {
    const courseId = {{ course.id }};
    localStorage.setItem(`course_${courseId}_notes`, JSON.stringify(notes));
}

function displayNotes() {
    const container = document.getElementById('notes-container');
    
    if (notes.length === 0) {
        container.innerHTML = `
            <div class="text-center py-4">
                <i class="bi bi-journal" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3 mb-0">No notes yet. Add your first note to keep track of important information!</p>
            </div>
        `;
        return;
    }
    
    container.innerHTML = notes.map(note => `
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <h5 class="card-title mb-2">
                        <i class="bi bi-journal-text text-primary me-2"></i>${escapeHtml(note.title)}
                    </h5>
                    <button class="btn btn-sm btn-outline-danger" onclick="deleteNote(${note.id})">
                        <i class="bi bi-trash"></i>
                    </button>
                </div>
                <p class="card-text">${escapeHtml(note.content)}</p>
                <small class="text-muted">
                    <i class="bi bi-clock"></i> ${new Date(note.createdAt).toLocaleString()}
                </small>
            </div>
        </div>
    `).join('');
}

// Tags Management
let tags = [];

function loadTags() {
    // Load tags from localStorage for this course
    const courseId = {{ course.id }};
    const storedTags = localStorage.getItem(`course_${courseId}_tags`);
    if (storedTags) {
        tags = JSON.parse(storedTags);
        displayTags();
    }
}

function saveTag() {
    const name = document.getElementById('tagName').value.trim();
    const color = document.getElementById('tagColor').value;
    
    if (!name) {
        alert('Please enter a tag name');
        return;
    }
    
    // Check if tag already exists
    if (tags.some(tag => tag.name.toLowerCase() === name.toLowerCase())) {
        alert('This tag already exists');
        return;
    }
    
    const tag = {
        id: Date.now(),
        name: name,
        color: color,
        createdAt: new Date().toISOString()
    };
    
    tags.push(tag);
    saveTagsToStorage();
    displayTags();
    
    // Clear form and close modal
    document.getElementById('tagName').value = '';
    document.getElementById('tagColor').value = 'primary';
    bootstrap.Modal.getInstance(document.getElementById('addTagModal')).hide();
}

function deleteTag(tagId) {
    if (confirm('Are you sure you want to delete this tag?')) {
        tags = tags.filter(tag => tag.id !== tagId);
        saveTagsToStorage();
        displayTags();
    }
}

function saveTagsToStorage() {
    const courseId = {{ course.id }};
    localStorage.setItem(`course_${courseId}_tags`, JSON.stringify(tags));
}

function displayTags() {
    const container = document.getElementById('tags-container');
    
    if (tags.length === 0) {
        container.innerHTML = `
            <div class="text-center py-4">
                <i class="bi bi-tag" style="font-size: 3rem; color: #ccc;"></i>
                <p class="text-muted mt-3 mb-0">No tags yet. Add tags to organize your learning!</p>
            </div>
        `;
        return;
    }
    
    container.innerHTML = `
        <div class="d-flex flex-wrap gap-2">
            ${tags.map(tag => `
                <span class="badge bg-${tag.color} fs-6 d-inline-flex align-items-center">
                    <i class="bi bi-tag-fill me-1"></i>
                    ${escapeHtml(tag.name)}
                    <button class="btn btn-sm btn-link text-white p-0 ms-2" onclick="deleteTag(${tag.id})" style="text-decoration: none;">
                        <i class="bi bi-x-circle"></i>
                    </button>
                </span>
            `).join('')}
        </div>
    `;
}

// Helper function to escape HTML
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}
</script>

