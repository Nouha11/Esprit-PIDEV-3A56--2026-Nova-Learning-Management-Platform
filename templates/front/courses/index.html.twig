				<div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
					<div class="offcanvas-header bg-light">
						<h5 class="offcanvas-title" id="offcanvasNavbarLabel">Advance Filter</h5>
						<button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
					</div>
					<div class="offcanvas-body p-3 p-xl-0">
						<form method="get">
							<!-- Category START -->
							<div class="card card-body shadow p-4 mb-4">
								<!-- Title -->
								<h4 class="mb-4">Category</h4>
								<div class="row">
									<div class="col-12">
										<!-- Checkbox -->
										<div class="form-check">
											<input class="form-check-input" type="checkbox" name="category[]" value="Development" id="cat1">
											<label class="form-check-label" for="cat1">Development</label>
										</div>
										<!-- Checkbox -->
										<div class="form-check">
											<input class="form-check-input" type="checkbox" name="category[]" value="Design" id="cat2">
											<label class="form-check-label" for="cat2">Design</label>
										</div>
										<!-- Checkbox -->
										<div class="form-check">
											<input class="form-check-input" type="checkbox" name="category[]" value="Marketing" id="cat3">
											<label class="form-check-label" for="cat3">Marketing</label>
										</div>
										<!-- Checkbox -->
										<div class="form-check">
											<input class="form-check-input" type="checkbox" name="category[]" value="Business" id="cat4">
											<label class="form-check-label" for="cat4">Business</label>
										</div>
									</div>
								</div>
							</div>
							<!-- Category END -->
	
							<!-- Price START -->
							<div class="card card-body shadow p-4 mb-4">
								<!-- Title -->
								<h4 class="mb-3">Price Level</h4>
								<ul class="list-inline mb-0">
									<!-- Price item -->
									<li class="list-inline-item">
										<input type="radio" class="btn-check" name="price" id="priceAll" value="">
										<label class="btn btn-light btn-primary-soft-check" for="priceAll">All</label>
									</li>
									<!-- Price item -->
									<li class="list-inline-item">
										<input type="radio" class="btn-check" name="price" id="priceFree" value="free">
										<label class="btn btn-light btn-primary-soft-check" for="priceFree">Free</label>
									</li>
									<!-- Price item -->
									<li class="list-inline-item">
										<input type="radio" class="btn-check" name="price" id="pricePaid" value="paid">
										<label class="btn btn-light btn-primary-soft-check" for="pricePaid">Paid</label>
									</li>
								</ul>
							</div>
							<!-- Price END -->
	
							<!-- Skill level START -->
							<div class="card card-body shadow p-4 mb-4">
								<!-- Title -->
								<h4 class="mb-3">Skill level</h4>
								<ul class="list-inline mb-0">
									<!-- Item -->
									<li class="list-inline-item mb-2">
										<input type="checkbox" class="btn-check" name="difficulty[]" value="Beginner" id="lvl1">
										<label class="btn btn-light btn-primary-soft-check" for="lvl1">Beginner</label>
									</li>
									<!-- Item -->
									<li class="list-inline-item mb-2">
										<input type="checkbox" class="btn-check" name="difficulty[]" value="Intermediate" id="lvl2">
										<label class="btn btn-light btn-primary-soft-check" for="lvl2">Intermediate</label>
									</li>
									<!-- Item -->
									<li class="list-inline-item mb-2">
										<input type="checkbox" class="btn-check" name="difficulty[]" value="Advanced" id="lvl3">
										<label class="btn btn-light btn-primary-soft-check" for="lvl3">Advanced</label>
									</li>
								</ul>
							</div>
							<!-- Skill level END -->

							<!-- Button -->
							<div class="d-grid p-2 p-xl-0 bg-body text-center">
								<button type="submit" class="btn btn-primary mb-0">Filter Results</button>
							</div>
						</form>
					</div>
				</div>
				<!-- Responsive offcanvas body END -->
			</div>
			<!-- Right sidebar END -->

		</div><!-- Row END -->
	</div>
</section>
<!-- =======================
Page content END -->

</main>
