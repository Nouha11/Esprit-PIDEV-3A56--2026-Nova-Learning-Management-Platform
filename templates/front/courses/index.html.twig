Page Banner END -->

<!-- =======================
Page content START -->
<section class="pb-0 py-sm-5">
	<div class="container">
		<!-- Flash Messages -->
		{% for message in app.flashes('success') %}
			<div class="alert alert-success alert-dismissible fade show" role="alert">
				{{ message }}
				<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
			</div>
		{% endfor %}

		<!-- Title and select START -->
		<div class="row g-3 align-items-center mb-4">
			<!-- Content -->
			<div class="col-md-4">
				<h4 class="mb-0">Showing {{ courses|length }} result(s)</h4>
			</div>

			<!-- Select option -->
			<div class="col-md-8">
				<div class="row g-3 align-items-center justify-content-md-end me-auto">
					
					<!-- Short by filter -->
					<form class="col-md-4 border rounded p-1 input-borderless" method="get">
						<select class="form-select js-choice z-index-9" name="sort" aria-label=".form-select-sm" onchange="this.form.submit()">
							<option value="">Sort by</option>
							<option value="newest">Newest</option>
							<option value="popular">Most popular</option>
							<option value="title">Title</option>
						</select>
					</form>

					<!-- Advanced filter responsive toggler START -->
					<div class="col-4 text-md-end">
						<button class="btn btn-primary mb-0 d-xl-none" type="button" data-bs-toggle="offcanvas" data-bs-target="#offcanvasSidebar" aria-controls="offcanvasSidebar">
							<i class="fas fa-sliders-h me-1"></i> Show filter
						</button>
					</div>
					<!-- Advanced filter responsive toggler END -->

				</div>
			</div>
		</div>
		<!-- Title and select END -->

		<div class="row">
			<!-- Main content START -->
			<div class="col-xl-9 col-xxl-8">

				<!-- Course list START -->
				<div class="row g-4">
					{% for course in courses %}
					<!-- Card list START -->
					<div class="col-12">
						<div class="card shadow overflow-hidden p-2">
							<div class="row g-0">
								<div class="col-md-5 overflow-hidden">
									{% if course.imageUrl %}
										<img src="{{ course.imageUrl }}" class="rounded-2" alt="{{ course.title }}">
									{% else %}
										<img src="{{ asset('assets/images/courses/4by3/06.jpg') }}" class="rounded-2" alt="Course image">
									{% endif %}
									<!-- Ribbon -->
									{% if course.price == 0 %}
									<div class="card-img-overlay">
										<div class="ribbon"><span>Free</span></div>
									</div>
									{% endif %}
								</div>
								<div class="col-md-7">
									<div class="card-body">
										<!-- Badge and rating -->
										<div class="d-flex justify-content-between align-items-center mb-2">
											<!-- Badge -->
											<a href="#" class="badge text-bg-primary mb-2 mb-sm-0">{{ course.category ?? 'General' }}</a>
											<!-- Actions -->
											<div>
												{% if is_granted('ROLE_TUTOR') and course.tutor == app.user %}
													<a href="{{ path('course_edit', {id: course.id}) }}" class="btn btn-sm btn-primary-soft mb-0 me-2">
														<i class="bi bi-pencil-square"></i>
													</a>
													<a href="{{ path('course_delete', {id: course.id}) }}" class="btn btn-sm btn-danger-soft mb-0" onclick="return confirm('Are you sure?')">
														<i class="bi bi-trash"></i>
													</a>
												{% endif %}
											</div>
										</div>
			
										<!-- Title -->
										<h5 class="card-title"><a href="#">{{ course.title }}</a></h5>
										<p class="text-truncate-2 d-none d-lg-block">{{ course.description }}</p>
			
										<!-- Info -->
										<ul class="list-inline">
											<li class="list-inline-item h6 fw-light mb-1 mb-sm-0">
												<i class="fas fa-signal text-success me-2"></i>{{ course.difficulty ?? 'All levels' }}
											</li>
											<li class="list-inline-item h6 fw-light mb-1 mb-sm-0">
												<i class="bi bi-calendar text-orange me-2"></i>{{ course.createdAt|date('M d, Y') }}
											</li>
										</ul>
			
										<!-- Price and avatar -->
										<div class="d-sm-flex justify-content-sm-between align-items-center">
											<!-- Avatar -->
											<div class="d-flex align-items-center">
												<div class="avatar">
													<img class="avatar-img rounded-circle" src="{{ asset('assets/images/avatar/06.jpg') }}" alt="avatar">
												</div>
												<p class="mb-0 ms-2">
													<a href="#" class="h6 fw-light">
														{% if course.tutor %}
															{{ course.tutor.firstName }} {{ course.tutor.lastName }}
														{% else %}
															Instructor
														{% endif %}
													</a>
												</p>
											</div>
											<!-- Price -->
											<div class="mt-3 mt-sm-0">
												{% if course.price > 0 %}
													<h5 class="text-success mb-0">${{ course.price }}</h5>
												{% else %}
													<span class="badge bg-success">Free</span>
												{% endif %}
											</div>                  
										</div>
									</div>
								</div>
							</div>
						</div>
					</div>
					<!-- Card list END -->
					{% else %}
					<div class="col-12">
						<div class="alert alert-info">
							No courses found. 
							{% if is_granted('ROLE_TUTOR') %}
								<a href="{{ path('course_new') }}">Create your first course</a>
							{% endif %}
						</div>
					</div>
					{% endfor %}
