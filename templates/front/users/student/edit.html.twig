{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Edit Profile') }}{% endblock %}

{% block body %}
<div class="container-fluid py-5 bg-light">
    <div class="container">
        <!-- Page Header -->
        <section class="bg-primary bg-opacity-10 py-4 mb-4 rounded">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="flex-grow-1">
                            <h1 class="h3 mb-2">{{ t.t('Edit Profile') }}</h1>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb breadcrumb-dots mb-0">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">{{ t.t('Home') }}</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('app_student_profile') }}">{{ t.t('Profile') }}</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">{{ t.t('Edit Profile') }}</li>
                                </ol>
                            </nav>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar avatar-lg">
                                {% if student.profilePicture %}
                                    <img src="{{ vich_uploader_asset(student, 'avatarFile') }}" 
                                         class="avatar-img rounded-circle" 
                                         alt="Profile Picture">
                                {% else %}
                                    <div class="avatar-img rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center">
                                        <span class="text-primary fs-4">{{ student.firstName|first|upper }}{{ student.lastName|first|upper }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div>
                                <h6 class="mb-0">{{ student.firstName }} {{ student.lastName }}</h6>
                                <small class="text-muted">Level {{ student.level }}</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <!-- Edit Form -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 text-dark"><i class="fas fa-user-edit"></i> {{ t.t('Profile Information') }}</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('app_student_profile_edit') }}" enctype="multipart/form-data">
                            <!-- Avatar Upload Section -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-camera"></i> Profile Picture</h6>
                            {% include 'components/avatar_upload.html.twig' with {
                                'profile': student
                            } %}

                            <hr class="my-4">

                            <!-- Personal Information -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-user"></i> Personal Information</h6>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label">First Name <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="firstName" 
                                           name="firstName" 
                                           value="{{ student.firstName }}" 
                                           maxlength="100">
                                    <small class="text-muted">Minimum 2 characters, only letters and spaces</small>
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="lastName" 
                                           name="lastName" 
                                           value="{{ student.lastName }}" 
                                           maxlength="100">
                                    <small class="text-muted">Minimum 2 characters, only letters and spaces</small>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="bio" class="form-label">Bio</label>
                                <textarea class="form-control" 
                                        id="bio" 
                                        name="bio" 
                                        rows="4" 
                                        placeholder="Tell us about yourself, your academic interests, and goals...">{{ student.bio }}</textarea>
                                <small class="text-muted">Maximum 1000 characters</small>
                            </div>

                            <hr class="my-4">

                            <!-- Academic Information -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-graduation-cap"></i> Academic Information</h6>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="university" class="form-label">University/Institution <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="university" 
                                           name="university" 
                                           value="{{ student.university }}" 
                                           placeholder="e.g., University of Technology"
                                           maxlength="100">
                                </div>
                                <div class="col-md-6">
                                    <label for="major" class="form-label">Major/Field of Study</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="major" 
                                           name="major" 
                                           value="{{ student.major }}" 
                                           placeholder="e.g., Computer Science"
                                           maxlength="100">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="academicLevel" class="form-label">Academic Level</label>
                                <select class="form-select" id="academicLevel" name="academicLevel">
                                    <option value="">Select your academic level</option>
                                    <option value="BACHELOR" {% if student.academicLevel == 'BACHELOR' %}selected{% endif %}>Bachelor's Degree</option>
                                    <option value="MASTER" {% if student.academicLevel == 'MASTER' %}selected{% endif %}>Master's Degree</option>
                                    <option value="PHD" {% if student.academicLevel == 'PHD' %}selected{% endif %}>PhD</option>
                                    <option value="Freshman" {% if student.academicLevel == 'Freshman' %}selected{% endif %}>Freshman</option>
                                    <option value="Sophomore" {% if student.academicLevel == 'Sophomore' %}selected{% endif %}>Sophomore</option>
                                    <option value="Junior" {% if student.academicLevel == 'Junior' %}selected{% endif %}>Junior</option>
                                    <option value="Senior" {% if student.academicLevel == 'Senior' %}selected{% endif %}>Senior</option>
                                    <option value="Graduate" {% if student.academicLevel == 'Graduate' %}selected{% endif %}>Graduate</option>
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="interests" class="form-label">Academic Interests</label>
                                <textarea class="form-control" 
                                        id="interests" 
                                        name="interests" 
                                        rows="3" 
                                        placeholder="e.g., Artificial Intelligence, Data Science, Web Development...">{{ student.interests is iterable ? student.interests|join(', ') : student.interests }}</textarea>
                                <small class="text-muted">List your academic interests separated by commas</small>
                            </div>

                            <hr class="my-4">

                            <!-- Password Change Section -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-lock"></i> Change Password</h6>
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Leave these fields empty if you don't want to change your password</small>
                            </div>

                            <div class="mb-3">
                                <label for="current_password" class="form-label">Current Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="current_password" 
                                           name="current_password" 
                                           placeholder="Enter your current password"
                                           autocomplete="current-password">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('current_password')">
                                        <i class="bi bi-eye" id="current_password-icon"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="new_password" class="form-label">New Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="new_password" 
                                           name="new_password" 
                                           placeholder="Enter your new password"
                                           autocomplete="new-password"
                                           onkeyup="checkPasswordStrength('new_password')">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('new_password')">
                                        <i class="bi bi-eye" id="new_password-icon"></i>
                                    </button>
                                </div>
                                <small class="text-muted">Minimum 8 characters</small>
                            </div>

                            <!-- Password Strength Meter -->
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Password Strength:</small>
                                    <span id="new_password-strength-label" class="badge bg-secondary">Not entered</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div id="new_password-strength-bar" 
                                         class="progress-bar" 
                                         role="progressbar" 
                                         style="width: 0%"
                                         aria-valuenow="0" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                <div id="new_password-feedback" class="mt-2"></div>
                            </div>

                            <div class="card border bg-body mb-3">
                                <div class="card-body py-2 px-3">
                                    <small class="text-muted d-block mb-2"><strong>Password must contain:</strong></small>
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <small id="new_password-check-length" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> 8-128 characters
                                            </small>
                                            <small id="new_password-check-uppercase" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Uppercase letter (A-Z)
                                            </small>
                                            <small id="new_password-check-lowercase" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Lowercase letter (a-z)
                                            </small>
                                        </div>
                                        <div class="col-md-6">
                                            <small id="new_password-check-numbers" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Number (0-9)
                                            </small>
                                            <small id="new_password-check-special" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Special character (!@#$...)
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="confirm_password" class="form-label">Confirm New Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="confirm_password" 
                                           name="confirm_password" 
                                           placeholder="Confirm your new password"
                                           autocomplete="new-password"
                                           onkeyup="checkPasswordMatch()">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('confirm_password')">
                                        <i class="bi bi-eye" id="confirm_password-icon"></i>
                                    </button>
                                </div>
                                <div id="password-match-message" class="mt-2"></div>
                            </div>

                            <hr class="my-4">

                            <!-- Action Buttons -->
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> {{ t.t('Save Changes') }}
                                </button>
                                <a href="{{ path('app_student_profile') }}" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> {{ t.t('Cancel') }}
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar with Stats and Tips -->
            <div class="col-lg-4">
                <!-- Profile Completion Widget -->
                {% if completion is defined %}
                    {% include 'components/profile_completion.html.twig' with {
                        'completion': completion,
                        'editRoute': path('app_student_profile_edit')
                    } %}
                {% endif %}

                <!-- Progress Stats -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0"><i class="fas fa-chart-line"></i> Your Progress</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex justify-content-between mb-1">
                                <span class="text-muted">Level {{ student.level }}</span>
                                <span class="text-muted">{{ student.totalXP }} XP</span>
                            </div>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar bg-success" 
                                     role="progressbar" 
                                     style="width: {{ student.progressToNextLevel }}%"
                                     aria-valuenow="{{ student.progressToNextLevel }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                </div>
                            </div>
                            <small class="text-muted">{{ student.xpForNextLevel }} XP needed for next level</small>
                        </div>
                        
                        <hr>
                        
                        <div class="row text-center">
                            <div class="col-6">
                                <div class="display-6 fw-bold text-primary">{{ student.totalTokens }}</div>
                                <small class="text-muted">Tokens</small>
                            </div>
                            <div class="col-6">
                                <div class="display-6 fw-bold text-warning">{{ student.totalXP }}</div>
                                <small class="text-muted">Total XP</small>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Profile Tips -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-lightbulb"></i> Profile Tips</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>Complete your profile to get 50 bonus XP</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>Add your university for better course recommendations</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>List your interests to find relevant games and courses</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>A detailed bio helps tutors understand your needs</small>
                            </li>
                            <li class="mb-0">
                                <i class="fas fa-check text-success"></i>
                                <small>Update your academic level for appropriate content</small>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-white border-bottom">
                        <h6 class="mb-0 text-dark"><i class="fas fa-bolt"></i> Quick Actions</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-2">
                            <a href="{{ path('app_student_dashboard') }}" class="btn btn-outline-primary">
                                <i class="fas fa-tachometer-alt me-2"></i>Go to Dashboard
                            </a>
                            <a href="{{ path('front_game_index') }}" class="btn btn-outline-success">
                                <i class="fas fa-gamepad me-2"></i>Play Games
                            </a>
                            <a href="{{ path('course_index') }}" class="btn btn-outline-info">
                                <i class="fas fa-book me-2"></i>Browse Courses
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Security Settings -->
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary bg-opacity-10 border-bottom">
                        <h6 class="mb-0 text-dark">
                            <i class="bi bi-shield-lock text-primary me-2"></i>Account Security
                        </h6>
                    </div>
                    <div class="card-body">
                        {% if app.user.totpEnabled %}
                            <div class="alert alert-success mb-3">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <small><strong>2FA Enabled</strong><br>Your account is protected</small>
                            </div>
                        {% else %}
                            <div class="alert alert-warning mb-3">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <small><strong>2FA Not Enabled</strong><br>Enhance your security</small>
                            </div>
                        {% endif %}
                        
                        <div class="d-grid">
                            <a href="{{ path('app_2fa_manage') }}" class="btn btn-{{ app.user.totpEnabled ? 'outline-primary' : 'primary' }}">
                                <i class="bi bi-shield-{{ app.user.totpEnabled ? 'check' : 'plus' }} me-2"></i>
                                {{ app.user.totpEnabled ? 'Manage 2FA' : 'Enable 2FA' }}
                            </a>
                        </div>
                        
                        <hr class="my-3">
                        
                        <small class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Two-factor authentication adds an extra layer of security to your account.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.breadcrumb-dots .breadcrumb-item + .breadcrumb-item::before {
    content: "•";
}

.avatar {
    width: 60px;
    height: 60px;
}

.avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.progress {
    border-radius: 4px;
}

.progress-bar {
    border-radius: 4px;
}

.display-6 {
    font-size: 2rem;
    font-weight: 600;
}
</style>

<script>
// Password visibility toggle
function togglePasswordVisibility(inputId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(inputId + '-icon');
    
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

// Password strength checker
function checkPasswordStrength(inputId) {
    const password = document.getElementById(inputId).value;
    const strengthBar = document.getElementById(inputId + '-strength-bar');
    const strengthLabel = document.getElementById(inputId + '-strength-label');
    const feedbackDiv = document.getElementById(inputId + '-feedback');
    
    if (!password) {
        strengthBar.style.width = '0%';
        strengthBar.className = 'progress-bar';
        strengthLabel.textContent = 'Not entered';
        strengthLabel.className = 'badge bg-secondary';
        feedbackDiv.innerHTML = '';
        resetRequirementChecks(inputId);
        return;
    }
    
    // Calculate strength
    const result = calculatePasswordStrength(password);
    
    // Update progress bar
    strengthBar.style.width = result.percentage + '%';
    strengthBar.className = 'progress-bar bg-' + result.color;
    strengthLabel.textContent = result.label;
    strengthLabel.className = 'badge bg-' + result.color;
    
    // Update feedback
    if (result.feedback.length > 0) {
        feedbackDiv.innerHTML = '<small class="text-muted"><i class="bi bi-info-circle"></i> ' + 
            result.feedback.join(', ') + '</small>';
    } else {
        feedbackDiv.innerHTML = '<small class="text-success"><i class="bi bi-check-circle"></i> Strong password!</small>';
    }
    
    // Update requirement checks
    updateRequirementChecks(inputId, result.checks);
    
    // Check password match if confirm field has value
    checkPasswordMatch();
}

function calculatePasswordStrength(password) {
    let score = 0;
    const feedback = [];
    const checks = {
        length: password.length >= 8 && password.length <= 128,
        uppercase: /[A-Z]/.test(password),
        lowercase: /[a-z]/.test(password),
        numbers: /[0-9]/.test(password),
        special: /[!@#$%^&*()_+\-=\[\]{}|;:,.<>?]/.test(password)
    };
    
    // Length scoring
    if (password.length >= 8) score++;
    if (password.length >= 12) score++;
    if (password.length >= 16) score++;
    
    // Character variety
    if (checks.lowercase) score++; else feedback.push('Add lowercase');
    if (checks.uppercase) score++; else feedback.push('Add uppercase');
    if (checks.numbers) score++; else feedback.push('Add numbers');
    if (checks.special) score++; else feedback.push('Add symbols');
    
    // Penalize patterns
    if (/(.)\1{2,}/.test(password)) {
        score = Math.max(0, score - 1);
        feedback.push('Avoid repeated characters');
    }
    
    // Normalize score
    score = Math.min(5, Math.max(0, score));
    
    const labels = ['Very Weak', 'Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'];
    const colors = ['danger', 'danger', 'warning', 'info', 'primary', 'success'];
    
    return {
        score: score,
        percentage: (score / 5) * 100,
        label: labels[score],
        color: colors[score],
        feedback: feedback,
        checks: checks
    };
}

function updateRequirementChecks(inputId, checks) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            if (checks[req]) {
                element.className = 'd-block text-success';
                element.innerHTML = '<i class="bi bi-check-circle-fill"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            } else {
                element.className = 'd-block text-muted';
                element.innerHTML = '<i class="bi bi-circle"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            }
        }
    });
}

function resetRequirementChecks(inputId) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            element.className = 'd-block text-muted';
            const text = element.textContent.replace(/^[^\s]+\s/, '');
            element.innerHTML = '<i class="bi bi-circle"></i> ' + text;
        }
    });
}

// Password match checker
function checkPasswordMatch() {
    const newPassword = document.getElementById('new_password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    const messageDiv = document.getElementById('password-match-message');
    
    if (!confirmPassword) {
        messageDiv.innerHTML = '';
        return;
    }
    
    if (newPassword === confirmPassword) {
        messageDiv.innerHTML = '<small class="text-success"><i class="bi bi-check-circle-fill"></i> Passwords match</small>';
    } else {
        messageDiv.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle-fill"></i> Passwords do not match</small>';
    }
}
</script>
{% endblock %}