{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Student Profile') }}{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h1 class="mb-4">{{ t.t('Student Profile') }}</h1>
            
            {% if student %}
                <div class="card">
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-3 text-center">
                                {% if student.profilePicture %}
                                    <img src="{{ student.profilePicture }}" class="img-fluid rounded-circle mb-3" alt="Profile Picture" style="max-width: 150px;">
                                {% else %}
                                    <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 150px; height: 150px;">
                                        <h1 class="mb-0">{{ student.firstName|slice(0, 1) }}{{ student.lastName|slice(0, 1) }}</h1>
                                    </div>
                                {% endif %}
                                <h4>{{ student.firstName }} {{ student.lastName }}</h4>
                                <p class="text-muted">{{ t.t('Student') }}</p>
                            </div>
                            <div class="col-md-9">
                                <h5 class="mb-3">{{ t.t('Profile Information') }}</h5>
                                
                                <div class="mb-3">
                                    <strong>{{ t.t('Bio') }}:</strong>
                                    <p>{{ student.bio ?? t.t('No bio provided yet.') }}</p>
                                </div>

                                <div class="mb-3">
                                    <strong>{{ t.t('University') }}:</strong>
                                    <p>{{ student.university }}</p>
                                </div>

                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <strong>{{ t.t('Major') }}:</strong>
                                        <p>{{ student.major ?? t.t('Not specified') }}</p>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <strong>{{ t.t('Academic Level') }}:</strong>
                                        <p>{{ student.academicLevel ?? t.t('Not specified') }}</p>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <strong>{{ t.t('Interests') }}:</strong>
                                    <p>{{ student.interests is iterable ? student.interests|join(', ') : (student.interests ?? t.t('Not specified')) }}</p>
                                </div>

                                <div class="mt-4">
                                    <a href="{{ path('app_student_profile_edit') }}" class="btn btn-primary">{{ t.t('Edit Profile') }}</a>
                                    <a href="{{ path('app_2fa_manage') }}" class="btn btn-outline-primary">
                                        <i class="bi bi-shield-lock me-2"></i>{{ app.user.totpEnabled ? t.t('Manage 2FA') : t.t('Enable 2FA') }}
                                    </a>
                                    <a href="{{ path('app_student_dashboard') }}" class="btn btn-outline-secondary">{{ t.t('Back to Dashboard') }}</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="alert alert-warning">
                    <h4>{{ t.t('No Student Profile Found') }}</h4>
                    <p>{{ t.t('You don\'t have a student profile yet. Please create one to get started.') }}</p>
                    <a href="{{ path('app_student_profile_edit') }}" class="btn btn-primary">{{ t.t('Create Profile') }}</a>
                </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
