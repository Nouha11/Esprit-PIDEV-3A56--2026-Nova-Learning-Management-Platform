{% extends 'base.html.twig' %}

{% block title %}Student Dashboard - NOVA{% endblock %}

{% block body %}
<!-- Page Banner START -->
<section class="py-0 bg-blue h-100px align-items-center d-flex h-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white">Student Dashboard</h1>
                <p class="text-white mb-0">Welcome back, {{ student ? student.firstName : 'Student' }}!</p>
            </div>
        </div>
    </div>
</section>
<!-- Page Banner END -->

<!-- Page content START -->
<section class="pt-0">
    <div class="container">
        <div class="row">
            <!-- Left sidebar START -->
            <div class="col-xl-3">
                <!-- Responsive offcanvas body START -->
                <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                    <!-- Offcanvas header -->
                    <div class="offcanvas-header bg-light">
                        <h5 class="offcanvas-title" id="offcanvasNavbarLabel">My profile</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
                    </div>
                    <!-- Offcanvas body -->
                    <div class="offcanvas-body p-3 p-xl-0">
                        <div class="bg-dark border rounded-3 p-3 w-100">
                            <!-- Dashboard menu -->
                            <div class="list-group list-group-dark list-group-borderless collapse-list">
                                <a class="list-group-item active" href="{{ path('app_student_dashboard') }}">
                                    <i class="bi bi-ui-checks-grid fa-fw me-2"></i>Dashboard
                                </a>
                                <a class="list-group-item" href="{{ path('front_game_index') }}">
                                    <i class="bi bi-controller fa-fw me-2"></i>Games
                                </a>
                                <a class="list-group-item" href="{{ path('front_reward_my_rewards') }}">
                                    <i class="bi bi-trophy fa-fw me-2"></i>My Rewards
                                </a>
                                <a class="list-group-item" href="{{ path('front_reward_browse') }}">
                                    <i class="bi bi-gift fa-fw me-2"></i>Browse Rewards
                                </a>
                                <a class="list-group-item" href="{{ path('course_index') }}">
                                    <i class="bi bi-book fa-fw me-2"></i>My Courses
                                </a>
                                
                                {% if 'ROLE_STUDENT' in app.user.roles %}
                                <a class="list-group-item" href="{{ path('app_student_profile') }}">
                                    <i class="bi bi-pencil-square fa-fw me-2"></i>Edit Profile
                                </a>
                                {% elseif 'ROLE_TUTOR' in app.user.roles %}
                                    <li><a class="dropdown-item" href="{{ path('app_tutor_profile') }}"><i class="bi bi-person fa-fw me-2"></i>My Profile</a></li>
                                {% endif %}

                                <a class="list-group-item" href="#">
                                    <i class="bi bi-gear fa-fw me-2"></i>Settings
                                </a>
                                <a class="list-group-item text-danger bg-danger-soft-hover" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt fa-fw me-2"></i>Sign Out
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Responsive offcanvas body END -->
            </div>
            <!-- Left sidebar END -->

            <!-- Main content START -->
            <div class="col-xl-9">
                {% if student %}
                    <!-- Counter boxes START -->
                    <div class="row mb-4">
                        <!-- XP Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-warning bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-warning mb-0"><i class="fas fa-bolt fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ student.totalXP }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Total XP</p>
                                    <small class="text-muted">Level {{ student.level }}</small>
                                </div>
                            </div>
                        </div>
                        <!-- Tokens Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-success bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-success mb-0"><i class="fas fa-coins fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ student.totalTokens }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Tokens</p>
                                </div>
                            </div>
                        </div>
                        <!-- Level Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-purple bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-purple mb-0"><i class="fas fa-star fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ student.level }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Current Level</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Counter boxes END -->

                    <!-- Progress Card START -->
                    <div class="card bg-transparent border rounded-3 mb-4">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0">Level Progress</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <h6 class="mb-0">Level {{ student.level }}</h6>
                                <h6 class="mb-0">{{ student.xpForNextLevel }} XP to Level {{ student.level + 1 }}</h6>
                            </div>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-warning" role="progressbar" 
                                     style="width: {{ student.progressToNextLevel }}%" 
                                     aria-valuenow="{{ student.progressToNextLevel }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    {{ student.progressToNextLevel }}%
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Progress Card END -->

                    <!-- Quick Actions START -->
                    <div class="card bg-transparent border rounded-3 mb-4">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0">Quick Actions</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-grid gap-3">
                                <a href="{{ path('front_game_index') }}" class="btn btn-primary btn-lg">
                                    <i class="bi bi-controller me-2"></i>Play Games
                                </a>
                                <a href="{{ path('front_reward_browse') }}" class="btn btn-info btn-lg">
                                    <i class="bi bi-gift me-2"></i>Browse Rewards
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- Quick Actions END -->

                {% else %}
                    <!-- No Profile Message -->
                    <div class="card bg-transparent border rounded-3">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-person-x display-1 text-muted mb-3"></i>
                            <h4>Student Profile Not Found</h4>
                            <p class="text-muted">Please contact support to set up your student profile.</p>
                        </div>
                    </div>
                {% endif %}
            </div>
            <!-- Main content END -->
        </div>
    </div>
</section>
<!-- Page content END -->
{% endblock %}
