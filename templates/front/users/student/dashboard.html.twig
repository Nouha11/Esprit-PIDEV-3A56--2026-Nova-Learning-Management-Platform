{% extends 'layout.html.twig' %}

{% block title %}Student Dashboard - NOVA{% endblock %}

{% block body %}
<!-- Page Banner START -->
<section class="py-0 bg-blue h-100px align-items-center d-flex h-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
    <div class="container">
        <div class="row">
            <div class="col-12 text-center">
                <h1 class="text-white">Student Dashboard</h1>
                <p class="text-white mb-0">Welcome back, {{ student ? student.firstName : 'Student' }}!</p>
            </div>
        </div>
    </div>
</section>
<!-- Page Banner END -->

<!-- Page content START -->
<section class="pt-0">
    <div class="container">
        <div class="row">
            <!-- Left sidebar START -->
            <div class="col-xl-3">
                <!-- Responsive offcanvas body START -->
                <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                    <!-- Offcanvas header -->
                    <div class="offcanvas-header bg-light">
                        <h5 class="offcanvas-title" id="offcanvasNavbarLabel">My profile</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
                    </div>
                    <!-- Offcanvas body -->
                    <div class="offcanvas-body p-3 p-xl-0">
                        <div class="bg-dark border rounded-3 p-3 w-100">
                            <!-- Dashboard menu -->
                            <div class="list-group list-group-dark list-group-borderless collapse-list">
                                <a class="list-group-item active" href="{{ path('app_student_dashboard') }}">
                                    <i class="bi bi-ui-checks-grid fa-fw me-2"></i>Dashboard
                                </a>
                                <a class="list-group-item" href="{{ path('front_game_index') }}">
                                    <i class="bi bi-controller fa-fw me-2"></i>Games
                                </a>
                                <a class="list-group-item" href="{{ path('front_reward_my_rewards') }}">
                                    <i class="bi bi-trophy fa-fw me-2"></i>My Rewards
                                </a>
                                <a class="list-group-item" href="{{ path('front_reward_browse') }}">
                                    <i class="bi bi-gift fa-fw me-2"></i>Browse Rewards
                                </a>
                                <a class="list-group-item" href="#">
                                    <i class="bi bi-book fa-fw me-2"></i>My Courses
                                </a>
                                <a class="list-group-item" href="#">
                                    <i class="bi bi-pencil-square fa-fw me-2"></i>Edit Profile
                                </a>
                                <a class="list-group-item" href="#">
                                    <i class="bi bi-gear fa-fw me-2"></i>Settings
                                </a>
                                <a class="list-group-item text-danger bg-danger-soft-hover" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt fa-fw me-2"></i>Sign Out
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Responsive offcanvas body END -->
            </div>
            <!-- Left sidebar END -->

            <!-- Main content START -->
            <div class="col-xl-9">
                {% if student %}
                    <!-- Counter boxes START -->
                    <div class="row mb-4">
                        <!-- XP Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-warning bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-warning mb-0"><i class="fas fa-bolt fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ student.totalXP }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Total XP</p>
                                    <small class="text-muted">Level {{ student.level }}</small>
                                </div>
                            </div>
                        </div>
                        <!-- Tokens Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-success bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-success mb-0"><i class="fas fa-coins fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ student.totalTokens }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Tokens</p>
                                </div>
                            </div>
                        </div>
                        <!-- Games Won Counter -->
                        <div class="col-sm-6 col-lg-4 mb-3 mb-lg-0">
                            <div class="d-flex justify-content-center align-items-center p-4 bg-purple bg-opacity-15 rounded-3">
                                <span class="display-6 lh-1 text-purple mb-0"><i class="fas fa-trophy fa-fw"></i></span>
                                <div class="ms-4">
                                    <div class="d-flex">
                                        <h5 class="mb-0 fw-bold">{{ gameStats.totalGamesWon ?? 0 }}</h5>
                                    </div>
                                    <p class="mb-0 h6 fw-light">Games Won</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Counter boxes END -->

                    <!-- Progress Card START -->
                    <div class="card bg-transparent border rounded-3 mb-4">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0">Level Progress</h3>
                        </div>
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <h6 class="mb-0">Level {{ student.level }}</h6>
                                <h6 class="mb-0">{{ student.xpForNextLevel }} XP to Level {{ student.level + 1 }}</h6>
                            </div>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-warning" role="progressbar" 
                                     style="width: {{ student.progressToNextLevel }}%" 
                                     aria-valuenow="{{ student.progressToNextLevel }}" 
                                     aria-valuemin="0" 
                                     aria-valuemax="100">
                                    {{ student.progressToNextLevel }}%
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- Progress Card END -->

                    <!-- Recent Game Activity START -->
                    <div class="card bg-transparent border rounded-3 mb-4">
                        <div class="card-header bg-transparent border-bottom">
                            <div class="d-sm-flex justify-content-between align-items-center">
                                <h3 class="mb-2 mb-sm-0">Recent Game Activity</h3>
                                <a href="{{ path('front_game_index') }}" class="btn btn-sm btn-primary-soft mb-0">View All Games</a>
                            </div>
                        </div>
                        <div class="card-body">
                            {% if recentProgress is not empty %}
                                <!-- Table START -->
                                <div class="table-responsive border-0">
                                    <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                                        <thead>
                                            <tr>
                                                <th scope="col" class="border-0 rounded-start">Game</th>
                                                <th scope="col" class="border-0">Played</th>
                                                <th scope="col" class="border-0">Won</th>
                                                <th scope="col" class="border-0">Win Rate</th>
                                                <th scope="col" class="border-0 rounded-end">XP Earned</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for progress in recentProgress %}
                                                <tr>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="avatar avatar-md flex-shrink-0">
                                                                <div class="avatar-img rounded bg-primary bg-opacity-10 text-primary">
                                                                    <i class="fas fa-gamepad"></i>
                                                                </div>
                                                            </div>
                                                            <div class="ms-2">
                                                                <h6 class="mb-0">
                                                                    <a href="{{ path('front_game_show', {id: progress.game.id}) }}">
                                                                        {{ progress.game.name }}
                                                                    </a>
                                                                </h6>
                                                                <small class="text-muted">{{ progress.game.type }}</small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td>{{ progress.timesPlayed }}</td>
                                                    <td>{{ progress.timesWon }}</td>
                                                    <td>
                                                        <span class="badge bg-success bg-opacity-10 text-success">
                                                            {{ progress.winRate }}%
                                                        </span>
                                                    </td>
                                                    <td>
                                                        <span class="badge bg-warning bg-opacity-10 text-warning">
                                                            +{{ progress.totalXPEarned }} XP
                                                        </span>
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                                <!-- Table END -->
                            {% else %}
                                <div class="text-center py-5">
                                    <i class="bi bi-controller display-4 text-muted mb-3"></i>
                                    <p class="text-muted">No games played yet. Start playing to see your activity!</p>
                                    <a href="{{ path('front_game_index') }}" class="btn btn-primary">Browse Games</a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                    <!-- Recent Game Activity END -->

                    <!-- Rewards Summary START -->
                    <div class="card bg-transparent border rounded-3">
                        <div class="card-header bg-transparent border-bottom">
                            <div class="d-sm-flex justify-content-between align-items-center">
                                <h3 class="mb-2 mb-sm-0">My Rewards</h3>
                                {% if unviewedRewards > 0 %}
                                    <span class="badge bg-danger">{{ unviewedRewards }} New</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="text-center py-4">
                                <i class="bi bi-trophy-fill display-4 text-warning mb-3"></i>
                                <p class="mb-3">Check out your earned rewards and badges!</p>
                                <a href="{{ path('front_reward_my_rewards') }}" class="btn btn-warning-soft mb-0">
                                    <i class="bi bi-trophy me-2"></i>View My Rewards
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- Rewards Summary END -->

                {% else %}
                    <!-- No Profile Message -->
                    <div class="card bg-transparent border rounded-3">
                        <div class="card-body text-center py-5">
                            <i class="bi bi-person-x display-1 text-muted mb-3"></i>
                            <h4>Student Profile Not Found</h4>
                            <p class="text-muted">Please contact support to set up your student profile.</p>
                        </div>
                    </div>
                {% endif %}
            </div>
            <!-- Main content END -->
        </div>
    </div>
</section>
<!-- Page content END -->
{% endblock %}
