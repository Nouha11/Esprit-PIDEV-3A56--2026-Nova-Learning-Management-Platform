{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Edit Tutor Profile') }}{% endblock %}

{% block body %}
<div class="container-fluid py-5 bg-light">
    <div class="container">
        <!-- Page Header -->
        <section class="bg-primary bg-opacity-10 py-4 mb-4 rounded">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div class="flex-grow-1">
                            <h1 class="h3 mb-2">{{ t.t('Edit Tutor Profile') }}</h1>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb breadcrumb-dots mb-0">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">{{ t.t('Home') }}</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('app_tutor_profile') }}">{{ t.t('Profile') }}</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">{{ t.t('Edit') }}</li>
                                </ol>
                            </nav>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <div class="avatar avatar-lg">
                                {% if tutor.profilePicture %}
                                    <img src="{{ vich_uploader_asset(tutor, 'avatarFile') }}" 
                                         class="avatar-img rounded-circle" 
                                         alt="Profile Picture">
                                {% else %}
                                    <div class="avatar-img rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center">
                                        <span class="text-primary fs-4">{{ tutor.firstName|first|upper }}{{ tutor.lastName|first|upper }}</span>
                                    </div>
                                {% endif %}
                            </div>
                            <div>
                                <h6 class="mb-0">{{ tutor.firstName }} {{ tutor.lastName }}</h6>
                                <small class="text-muted">{{ tutor.yearsOfExperience }} years experience</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <!-- Edit Form -->
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-header bg-white border-bottom">
                        <h5 class="mb-0 text-dark"><i class="fas fa-user-edit"></i> Profile Information</h5>
                    </div>
                    <div class="card-body">
                        <form method="post" action="{{ path('app_tutor_profile_edit') }}" enctype="multipart/form-data">
                            <!-- Avatar Upload Section -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-camera"></i> Profile Picture</h6>
                            {% include 'components/avatar_upload.html.twig' with {
                                'profile': tutor
                            } %}

                            <hr class="my-4">

                            <!-- Personal Information -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-user"></i> Personal Information</h6>
                            
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label">First Name <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="firstName" 
                                           name="firstName" 
                                           value="{{ tutor.firstName }}" 
                                           maxlength="100">
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="lastName" 
                                           name="lastName" 
                                           value="{{ tutor.lastName }}" 
                                           maxlength="100">
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="bio" class="form-label">Bio</label>
                                <textarea class="form-control" 
                                        id="bio" 
                                        name="bio" 
                                        rows="4" 
                                        placeholder="Tell students about yourself...">{{ tutor.bio is iterable ? tutor.bio|join(' ') : tutor.bio }}</textarea>
                                <small class="text-muted">A brief introduction about yourself and your teaching style.</small>
                            </div>

                            <hr class="my-4">

                            <!-- Professional Information -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-briefcase"></i> Professional Information</h6>

                            <div class="mb-3">
                                <label for="expertise" class="form-label">Expertise <span class="text-danger">*</span></label>
                                <input type="text" 
                                    class="form-control" 
                                    id="expertise" 
                                    name="expertise" 
                                    value="{{ tutor.expertise is iterable ? tutor.expertise|join(', ') : tutor.expertise }}" 
                                    placeholder="e.g., Mathematics, Physics, Computer Science">
                                <small class="text-muted">Your main teaching subjects or areas of expertise.</small>
                            </div>
                            <div class="mb-3">
                                <label for="qualifications" class="form-label">Qualifications</label>
                                <textarea class="form-control" 
                                        id="qualifications" 
                                        name="qualifications" 
                                        rows="3" 
                                        placeholder="e.g., Master's in Education, PhD in Mathematics...">{{ tutor.qualifications is iterable ? tutor.qualifications|join(', ') : tutor.qualifications }}</textarea>
                                <small class="text-muted">Your educational background and certifications.</small>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <label for="yearsOfExperience" class="form-label">Years of Experience <span class="text-danger">*</span></label>
                                    <input type="number" 
                                           class="form-control" 
                                           id="yearsOfExperience" 
                                           name="yearsOfExperience" 
                                           value="{{ tutor.yearsOfExperience }}" 
                                           min="0" 
                                           max="50">
                                </div>
                                <div class="col-md-6">
                                    <label for="hourlyRate" class="form-label">Hourly Rate (Dt)</label>
                                    <input type="number" 
                                           class="form-control" 
                                           id="hourlyRate" 
                                           name="hourlyRate" 
                                           value="{{ tutor.hourlyRate }}" 
                                           min="0" 
                                           step="0.01" 
                                           placeholder="25.00">
                                </div>
                            </div>

                            <hr class="my-4">

                            <!-- Availability -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-calendar-check"></i> Availability</h6>

                            <div class="mb-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" 
                                           type="checkbox" 
                                           id="isAvailable" 
                                           name="isAvailable" 
                                           value="1" 
                                           {% if tutor.isAvailable %}checked{% endif %}>
                                    <label class="form-check-label" for="isAvailable">
                                        <strong>Available for tutoring sessions</strong>
                                        <br>
                                        <small class="text-muted">Toggle this to show/hide your profile from students</small>
                                    </label>
                                </div>
                            </div>

                            <hr class="my-4">

                            <!-- Password Change Section -->
                            <h6 class="mb-3 text-primary"><i class="fas fa-lock"></i> Change Password</h6>
                            <div class="alert alert-info">
                                <i class="bi bi-info-circle me-2"></i>
                                <small>Leave these fields empty if you don't want to change your password</small>
                            </div>

                            <div class="mb-3">
                                <label for="current_password" class="form-label">Current Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="current_password" 
                                           name="current_password" 
                                           placeholder="Enter your current password"
                                           autocomplete="current-password">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('current_password')">
                                        <i class="bi bi-eye" id="current_password-icon"></i>
                                    </button>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="new_password" class="form-label">New Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="new_password" 
                                           name="new_password" 
                                           placeholder="Enter your new password"
                                           autocomplete="new-password"
                                           onkeyup="checkPasswordStrength('new_password')">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('new_password')">
                                        <i class="bi bi-eye" id="new_password-icon"></i>
                                    </button>
                                </div>
                                <small class="text-muted">Minimum 8 characters</small>
                            </div>

                            <!-- Password Strength Meter -->
                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <small class="text-muted">Password Strength:</small>
                                    <span id="new_password-strength-label" class="badge bg-secondary">Not entered</span>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div id="new_password-strength-bar" 
                                         class="progress-bar" 
                                         role="progressbar" 
                                         style="width: 0%"
                                         aria-valuenow="0" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                <div id="new_password-feedback" class="mt-2"></div>
                            </div>

                            <div class="card border bg-body mb-3">
                                <div class="card-body py-2 px-3">
                                    <small class="text-muted d-block mb-2"><strong>Password must contain:</strong></small>
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <small id="new_password-check-length" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> 8-128 characters
                                            </small>
                                            <small id="new_password-check-uppercase" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Uppercase letter (A-Z)
                                            </small>
                                            <small id="new_password-check-lowercase" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Lowercase letter (a-z)
                                            </small>
                                        </div>
                                        <div class="col-md-6">
                                            <small id="new_password-check-numbers" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Number (0-9)
                                            </small>
                                            <small id="new_password-check-special" class="d-block text-muted">
                                                <i class="bi bi-circle"></i> Special character (!@#$...)
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label for="confirm_password" class="form-label">Confirm New Password</label>
                                <div class="input-group">
                                    <input type="password" 
                                           class="form-control" 
                                           id="confirm_password" 
                                           name="confirm_password" 
                                           placeholder="Confirm your new password"
                                           autocomplete="new-password"
                                           onkeyup="checkPasswordMatch()">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('confirm_password')">
                                        <i class="bi bi-eye" id="confirm_password-icon"></i>
                                    </button>
                                </div>
                                <div id="password-match-message" class="mt-2"></div>
                            </div>

                            <!-- Action Buttons -->
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> Save Changes
                                </button>
                                <a href="{{ path('app_tutor_profile') }}" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Sidebar with Tips -->
            <div class="col-lg-4">
                <!-- Profile Completion Widget -->
                {% if completion is defined %}
                    {% include 'components/profile_completion.html.twig' with {
                        'completion': completion,
                        'editRoute': path('app_tutor_profile_edit')
                    } %}
                {% endif %}

                <!-- Profile Tips -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0"><i class="fas fa-lightbulb"></i> Profile Tips</h6>
                    </div>
                    <div class="card-body">
                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>Write a compelling bio that highlights your teaching style</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>List all relevant qualifications and certifications</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>Be specific about your areas of expertise</small>
                            </li>
                            <li class="mb-2">
                                <i class="fas fa-check text-success"></i>
                                <small>Set competitive hourly rates based on your experience</small>
                            </li>
                            <li class="mb-0">
                                <i class="fas fa-check text-success"></i>
                                <small>Keep your availability status updated</small>
                            </li>
                        </ul>
                    </div>
                </div>

                <!-- Current Stats -->
<!-- Current Status -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-white border-bottom">
        <h6 class="mb-0"><i class="fas fa-info-circle"></i> Profile Status</h6>
    </div>
    <div class="card-body">
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted">Availability:</span>
            {% if tutor.isAvailable %}
                <span class="badge bg-success">Available</span>
            {% else %}
                <span class="badge bg-secondary">Unavailable</span>
            {% endif %}
        </div>
        <div class="d-flex justify-content-between mb-3">
            <span class="text-muted">Experience:</span>
            <strong>{{ tutor.yearsOfExperience ?? 0 }} years</strong>
        </div>
        <div class="d-flex justify-content-between">
            <span class="text-muted">Hourly Rate:</span>
            <strong>Dt{{ tutor.hourlyRate ?? '0.00' }}</strong>
        </div>
    </div>
</div>

                <!-- Security Settings -->
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary bg-opacity-10 border-bottom">
                        <h6 class="mb-0">
                            <i class="bi bi-shield-lock text-primary me-2"></i>Account Security
                        </h6>
                    </div>
                    <div class="card-body">
                        {% if app.user.totpEnabled %}
                            <div class="alert alert-success mb-3">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                <small><strong>2FA Enabled</strong><br>Your account is protected</small>
                            </div>
                        {% else %}
                            <div class="alert alert-warning mb-3">
                                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                                <small><strong>2FA Not Enabled</strong><br>Enhance your security</small>
                            </div>
                        {% endif %}
                        
                        <div class="d-grid">
                            <a href="{{ path('app_2fa_manage') }}" class="btn btn-{{ app.user.totpEnabled ? 'outline-primary' : 'primary' }}">
                                <i class="bi bi-shield-{{ app.user.totpEnabled ? 'check' : 'plus' }} me-2"></i>
                                {{ app.user.totpEnabled ? 'Manage 2FA' : 'Enable 2FA' }}
                            </a>
                        </div>
                        
                        <hr class="my-3">
                        
                        <small class="text-muted">
                            <i class="bi bi-info-circle me-1"></i>
                            Two-factor authentication adds an extra layer of security to your account.
                        </small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.breadcrumb-dots .breadcrumb-item + .breadcrumb-item::before {
    content: "•";
}
</style>

<script>
// Password visibility toggle
function togglePasswordVisibility(inputId) {
    const input = document.getElementById(inputId);
    const icon = document.getElementById(inputId + '-icon');
    
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}

// Password strength checker
function checkPasswordStrength(inputId) {
    const password = document.getElementById(inputId).value;
    const strengthBar = document.getElementById(inputId + '-strength-bar');
    const strengthLabel = document.getElementById(inputId + '-strength-label');
    const feedbackDiv = document.getElementById(inputId + '-feedback');
    
    if (!password) {
        strengthBar.style.width = '0%';
        strengthBar.className = 'progress-bar';
        strengthLabel.textContent = 'Not entered';
        strengthLabel.className = 'badge bg-secondary';
        feedbackDiv.innerHTML = '';
        resetRequirementChecks(inputId);
        return;
    }
    
    // Calculate strength
    const result = calculatePasswordStrength(password);
    
    // Update progress bar
    strengthBar.style.width = result.percentage + '%';
    strengthBar.className = 'progress-bar bg-' + result.color;
    strengthLabel.textContent = result.label;
    strengthLabel.className = 'badge bg-' + result.color;
    
    // Update feedback
    if (result.feedback.length > 0) {
        feedbackDiv.innerHTML = '<small class="text-muted"><i class="bi bi-info-circle"></i> ' + 
            result.feedback.join(', ') + '</small>';
    } else {
        feedbackDiv.innerHTML = '<small class="text-success"><i class="bi bi-check-circle"></i> Strong password!</small>';
    }
    
    // Update requirement checks
    updateRequirementChecks(inputId, result.checks);
    
    // Check password match if confirm field has value
    checkPasswordMatch();
}

function calculatePasswordStrength(password) {
    let score = 0;
    const feedback = [];
    const checks = {
        length: password.length >= 8 && password.length <= 128,
        uppercase: /[A-Z]/.test(password),
        lowercase: /[a-z]/.test(password),
        numbers: /[0-9]/.test(password),
        special: /[!@#$%^&*()_+\-=\[\]{}|;:,.<>?]/.test(password)
    };
    
    // Length scoring
    if (password.length >= 8) score++;
    if (password.length >= 12) score++;
    if (password.length >= 16) score++;
    
    // Character variety
    if (checks.lowercase) score++; else feedback.push('Add lowercase');
    if (checks.uppercase) score++; else feedback.push('Add uppercase');
    if (checks.numbers) score++; else feedback.push('Add numbers');
    if (checks.special) score++; else feedback.push('Add symbols');
    
    // Penalize patterns
    if (/(.)\1{2,}/.test(password)) {
        score = Math.max(0, score - 1);
        feedback.push('Avoid repeated characters');
    }
    
    // Normalize score
    score = Math.min(5, Math.max(0, score));
    
    const labels = ['Very Weak', 'Very Weak', 'Weak', 'Fair', 'Strong', 'Very Strong'];
    const colors = ['danger', 'danger', 'warning', 'info', 'primary', 'success'];
    
    return {
        score: score,
        percentage: (score / 5) * 100,
        label: labels[score],
        color: colors[score],
        feedback: feedback,
        checks: checks
    };
}

function updateRequirementChecks(inputId, checks) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            if (checks[req]) {
                element.className = 'd-block text-success';
                element.innerHTML = '<i class="bi bi-check-circle-fill"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            } else {
                element.className = 'd-block text-muted';
                element.innerHTML = '<i class="bi bi-circle"></i> ' + element.textContent.replace(/^[^\s]+\s/, '');
            }
        }
    });
}

function resetRequirementChecks(inputId) {
    const requirements = ['length', 'uppercase', 'lowercase', 'numbers', 'special'];
    
    requirements.forEach(req => {
        const element = document.getElementById(inputId + '-check-' + req);
        if (element) {
            element.className = 'd-block text-muted';
            const text = element.textContent.replace(/^[^\s]+\s/, '');
            element.innerHTML = '<i class="bi bi-circle"></i> ' + text;
        }
    });
}

// Password match checker
function checkPasswordMatch() {
    const newPassword = document.getElementById('new_password').value;
    const confirmPassword = document.getElementById('confirm_password').value;
    const messageDiv = document.getElementById('password-match-message');
    
    if (!confirmPassword) {
        messageDiv.innerHTML = '';
        return;
    }
    
    if (newPassword === confirmPassword) {
        messageDiv.innerHTML = '<small class="text-success"><i class="bi bi-check-circle-fill"></i> Passwords match</small>';
    } else {
        messageDiv.innerHTML = '<small class="text-danger"><i class="bi bi-x-circle-fill"></i> Passwords do not match</small>';
    }
}
</script>
{% endblock %}