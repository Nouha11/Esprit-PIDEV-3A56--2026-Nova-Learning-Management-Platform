{% extends 'base.html.twig' %}

{% block title %}Tutor Dashboard{% endblock %}

{% block body %}
<section class="pt-4">
    <div class="container">
        <div class="row">

            <div class="col-xl-3">
                <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                    <div class="offcanvas-header bg-light">
                        <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Tutor Menu</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
                    </div>
                    <div class="offcanvas-body p-3 p-xl-0">
                        <div class="bg-dark border rounded-3 p-3 w-100">
                            <div class="list-group list-group-dark list-group-borderless collapse-list">
                                <a class="list-group-item active" href="{{ path('app_tutor_dashboard') }}">
                                    <i class="bi bi-ui-checks-grid fa-fw me-2"></i>Dashboard
                                </a>
                                <a class="list-group-item" href="{{ path('app_tutor_sessions') }}">
                                    <i class="bi bi-calendar-check fa-fw me-2"></i>My Sessions
                                </a>
                                <a class="list-group-item" href="{{ path('app_tutor_availability') }}">
                                    <i class="bi bi-clock fa-fw me-2"></i>Availability
                                </a>

                                <div class="text-muted small mt-3 mb-1 text-uppercase ps-3">Teaching Tools</div>
                                
                                <a class="list-group-item" href="{{ path('app_quiz_index', {'prefix': 'tutor'}) }}">
                                    <i class="bi bi-lightning-charge fa-fw me-2"></i>Manage Quizzes
                                </a>
                                <div class="text-muted small mt-3 mb-1 text-uppercase ps-3">Account</div>
                                <a class="list-group-item" href="{{ path('app_tutor_profile_edit') }}">
                                    <i class="bi bi-pencil-square fa-fw me-2"></i>Edit Profile
                                </a>
                                <a class="list-group-item text-danger bg-danger-soft-hover" href="{{ path('app_logout') }}">
                                    <i class="fas fa-sign-out-alt fa-fw me-2"></i>Sign Out
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-xl-9">
                
                {% if tutor %}
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h1 class="mb-1 h3">Welcome back, {{ tutor.firstName }}!</h1>
                            <p class="text-muted">Here's what's happening with your tutoring today.</p>
                        </div>
                        <div>
                            {% if tutor.isAvailable %}
                                <span class="badge bg-success fs-6"><i class="bi bi-check-circle me-1"></i> Available</span>
                            {% else %}
                                <span class="badge bg-danger fs-6"><i class="bi bi-x-circle me-1"></i> Unavailable</span>
                            {% endif %}
                        </div>
                    </div>
                {% else %}
                    <h1 class="mb-4">Tutor Dashboard</h1>
                {% endif %}

                <div class="row g-4 mb-4">
                    <div class="col-sm-6 col-lg-3">
                        <div class="card border-primary h-100">
                            <div class="card-body text-center p-3">
                                <div class="icon-lg bg-primary bg-opacity-10 rounded-circle text-primary mb-3 mx-auto">
                                    <i class="bi bi-people fs-3"></i>
                                </div>
                                <h3 class="text-primary mb-0">0</h3>
                                <p class="text-muted mb-0 small">Active Students</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card border-success h-100">
                            <div class="card-body text-center p-3">
                                <div class="icon-lg bg-success bg-opacity-10 rounded-circle text-success mb-3 mx-auto">
                                    <i class="bi bi-check-circle fs-3"></i>
                                </div>
                                <h3 class="text-success mb-0">0</h3>
                                <p class="text-muted mb-0 small">Completed Sessions</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card border-info h-100">
                            <div class="card-body text-center p-3">
                                <div class="icon-lg bg-info bg-opacity-10 rounded-circle text-info mb-3 mx-auto">
                                    <i class="bi bi-calendar-event fs-3"></i>
                                </div>
                                <h3 class="text-info mb-0">0</h3>
                                <p class="text-muted mb-0 small">Upcoming Sessions</p>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-6 col-lg-3">
                        <div class="card border-warning h-100">
                            <div class="card-body text-center p-3">
                                <div class="icon-lg bg-warning bg-opacity-10 rounded-circle text-warning mb-3 mx-auto">
                                    <i class="bi bi-currency-dollar fs-3"></i>
                                </div>
                                <h3 class="text-warning mb-0">${{ tutor.hourlyRate ?? '0.00' }}</h3>
                                <p class="text-muted mb-0 small">Hourly Rate</p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card mb-4">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0">Quick Actions</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-sm-6 col-lg-4">
                                <a href="{{ path('app_quiz_new', {'prefix': 'tutor'}) }}" class="btn btn-purple w-100 h-100 d-flex align-items-center justify-content-center py-3">
                                    <i class="bi bi-plus-circle me-2"></i>Create New Quiz
                                </a>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <a href="{{ path('app_tutor_sessions') }}" class="btn btn-outline-primary w-100 h-100 d-flex align-items-center justify-content-center py-3">
                                    <i class="bi bi-calendar-check me-2"></i>View Sessions
                                </a>
                            </div>
                            <div class="col-sm-6 col-lg-4">
                                <a href="{{ path('app_tutor_availability') }}" class="btn btn-outline-success w-100 h-100 d-flex align-items-center justify-content-center py-3">
                                    <i class="bi bi-clock me-2"></i>Manage Availability
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                {% if tutor %}
                <div class="card border">
                    <div class="card-header bg-light border-bottom">
                        <h5 class="mb-0">Profile Summary</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <ul class="list-group list-group-borderless">
                                    <li class="list-group-item px-0 py-1">
                                        <span class="fw-bold me-2">Name:</span> {{ tutor.firstName }} {{ tutor.lastName }}
                                    </li>
                                    <li class="list-group-item px-0 py-1">
                                        <span class="fw-bold me-2">Experience:</span> {{ tutor.yearsOfExperience }} years
                                    </li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <ul class="list-group list-group-borderless">
                                    <li class="list-group-item px-0 py-1">
                                        <span class="fw-bold me-2">Hourly Rate:</span> ${{ tutor.hourlyRate ?? 'Not set' }}
                                    </li>
                                    <li class="list-group-item px-0 py-1">
                                        <span class="fw-bold me-2">Status:</span> 
                                        {% if tutor.isAvailable %}
                                            <span class="text-success fw-bold">Active</span>
                                        {% else %}
                                            <span class="text-danger fw-bold">Inactive</span>
                                        {% endif %}
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
                {% endif %}

            </div>
            </div>
    </div>
</section>
{% endblock %}