{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const playBtn = document.getElementById('play-game-btn');
            let currentGameId = null;
            let isChecking = false; // Flag to prevent multiple simultaneous requests
            
            // Check for milestone unlock on page load
            {% if app.session.get('milestone_unlocked') %}
                const milestones = {{ app.session.get('milestone_unlocked')|json_encode|raw }};
                if (milestones && milestones.length > 0) {
                    // Show celebration modal for first milestone (can be extended for multiple)
                    showMilestoneCelebration(milestones[0]);
                }
                // Clear the session data
                {% do app.session.remove('milestone_unlocked') %}
            {% endif %}
            
            if (playBtn) {
                playBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    // Prevent multiple simultaneous requests
                    if (isChecking) {
                        console.log('Already checking tokens, please wait...');
                        return;
                    }
                    
                    const gameId = this.dataset.gameId;
                    currentGameId = gameId;
                    const gameCost = parseInt(this.dataset.gameCost);
                    const studentTokens = parseInt(this.dataset.studentTokens);
                    
                    // Show loading state
                    const originalHtml = this.innerHTML;
                    this.disabled = true;
                    isChecking = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Checking...';
                    
                    // Check tokens via Ajax
                    checkTokens(gameId, originalHtml, playBtn);
                });
            }
            
            // Function to check tokens
            function checkTokens(gameId, originalHtml, playBtn) {
                fetch('{{ path('front_game_check_tokens', {id: '__ID__'}) }}'.replace('__ID__', gameId), {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    credentials: 'same-origin'
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Server returned ' + response.status);
                    }
                    return response.json();
                })
                .then(data => {
                    if (data.success && data.canAfford) {
                        // Sufficient tokens - show confirmation modal
                        showConfirmPlayModal(data, gameId);
                    } else if (data.success === false) {
                        // Insufficient tokens or error - show modal
                        showInsufficientTokensModal(data);
                    } else {
                        throw new Error('Unexpected response format');
                    }
                })
                .catch(error => {
                    console.error('Error checking tokens:', error);
                    alert('An error occurred while checking your tokens. Please refresh the page and try again.');
                })
                .finally(() => {
                    // Reset button state
                    playBtn.disabled = false;
                    playBtn.innerHTML = originalHtml;
                    isChecking = false;
                });
            }
            
            // Confirm play button in modal
            const confirmPlayBtn = document.getElementById('confirm-play-btn');
            if (confirmPlayBtn) {
                confirmPlayBtn.addEventListener('click', function() {
                    if (currentGameId) {
                        window.location.href = '{{ path('front_game_play', {id: '__ID__'}) }}'.replace('__ID__', currentGameId);
                    }
                });
            }
        });
        
        function showMilestoneCelebration(milestone) {
            // Update modal content
            document.getElementById('milestone-name').textContent = milestone.name;
            document.getElementById('milestone-description').textContent = milestone.description || 'You\'ve reached a new milestone!';
            document.getElementById('milestone-level').textContent = milestone.level;
            document.getElementById('milestone-tokens').textContent = milestone.tokens;
            
            // Handle icon
            const iconImg = document.getElementById('milestone-icon');
            const iconFallback = document.querySelector('.milestone-icon-fallback');
            
            if (milestone.icon) {
                iconImg.src = '{{ asset('uploads/rewards/') }}' + milestone.icon;
                iconImg.classList.remove('d-none');
                iconFallback.classList.add('d-none');
            } else {
                iconImg.classList.add('d-none');
                iconFallback.classList.remove('d-none');
            }
            
            // Show modal with delay for dramatic effect
            setTimeout(function() {
                const modal = new bootstrap.Modal(document.getElementById('milestoneCelebrationModal'));
                modal.show();
                
                // Play celebration sound if available
                try {
                    const audio = new Audio('{{ asset('sounds/celebration.mp3') }}');
                    audio.play().catch(e => console.log('Audio play failed:', e));
                } catch(e) {
                    console.log('Audio not available');
                }
            }, 500);
        }
        
        function showConfirmPlayModal(data, gameId) {
            // Update modal content
            document.getElementById('confirm-current-balance').textContent = data.currentBalance;
            document.getElementById('confirm-game-cost').textContent = data.gameCost;
            document.getElementById('confirm-remaining-balance').textContent = data.currentBalance - data.gameCost;
            
            // Get reward info from page
            const rewardTokens = {{ game.rewardTokens }};
            const rewardXP = {{ game.rewardXP }};
            document.getElementById('confirm-reward-tokens').textContent = rewardTokens;
            document.getElementById('confirm-reward-xp').textContent = rewardXP;
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('confirmPlayModal'));
            modal.show();
        }
        
        function showInsufficientTokensModal(data) {
            // Update modal content
            document.getElementById('token-message').textContent = data.message;
            document.getElementById('current-balance').textContent = data.currentBalance;
            document.getElementById('game-cost').textContent = data.gameCost;
            document.getElementById('missing-tokens').textContent = data.missing;
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('insufficientTokensModal'));
            modal.show();
        }
    </script>
{% endblock %}