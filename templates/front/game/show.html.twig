{% extends 'base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        {# Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message|raw }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <div class="col-md-8">
                <h1>{{ game.name }}</h1>
                <div class="mb-3">
                    <span class="badge bg-info">{{ game.type }}</span>
                    <span class="badge bg-warning">{{ game.difficulty }}</span>
                </div>

                <p class="lead">{{ game.description }}</p>
                
                <div class="card mb-4">
                    <div class="card-body">
                        <h5>Game Details</h5>
                        <ul>
                            <li><strong>Cost to Play:</strong> {{ game.tokenCost }} tokens</li>
                            <li><strong>Your Tokens:</strong> {{ app.user.studentProfile ? app.user.studentProfile.totalTokens : 0 }} tokens</li>
                            {% if game.category != 'MINI_GAME' %}
                                <li><strong>Base Reward:</strong> {{ game.rewardTokens }} tokens + {{ game.rewardXP }} XP</li>
                            {% else %}
                                {% if game.energyPoints > 0 %}
                                    <li><strong>Energy Regeneration:</strong> +{{ game.energyPoints }} Energy Points</li>
                                {% endif %}
                            {% endif %}
                            <li><strong>Type:</strong> {{ game.type }}</li>
                            <li><strong>Difficulty:</strong> {{ game.difficulty }}</li>
                        </ul>
                        
                        {# Show warning if not enough tokens #}
                        {% if app.user.studentProfile and app.user.studentProfile.totalTokens < game.tokenCost %}
                            <div class="alert alert-danger mt-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Insufficient Tokens!</strong> 
                                You need {{ game.tokenCost - app.user.studentProfile.totalTokens }} more tokens to play this game.
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Rating Section #}
                <div class="card mb-4">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-star-fill text-warning me-2"></i>
                            Game Rating
                        </h5>
                    </div>
                    <div class="card-body">
                        {% if is_granted('ROLE_STUDENT') or is_granted('ROLE_TUTOR') or is_granted('ROLE_ADMIN') %}
                            {% include 'front/game/_star_rating_input.html.twig' with {
                                'gameId': game.id,
                                'userRating': userRating|default(0),
                                'averageRating': averageRating|default(0),
                                'totalRatings': totalRatings|default(0)
                            } %}
                        {% else %}
                            {% include 'front/game/_star_rating.html.twig' with {
                                'rating': averageRating|default(0),
                                'count': totalRatings|default(0),
                                'size': 'lg'
                            } %}
                            <p class="text-muted mt-2">
                                <a href="{{ path('app_login') }}">Login</a> to rate this game
                            </p>
                        {% endif %}
                    </div>
                </div>

                {# Special Rewards Section #}
                {% if game.rewards is not empty %}
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-trophy-fill me-2"></i>
                            Special Rewards Available
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">Complete this game to earn these additional rewards:</p>
                        <div class="row g-3">
                            {% for reward in game.rewards %}
                                {% if reward.isActive %}
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100 reward-item">
                                        <div class="d-flex align-items-start">
                                            <div class="me-3">
                                                {% if reward.icon %}
                                                    <img src="{{ asset('images/rewards/' ~ reward.icon) }}" 
                                                         alt="{{ reward.name }}" 
                                                         class="reward-icon-small">
                                                {% else %}
                                                    {% if reward.type == 'BADGE' %}
                                                        <i class="bi bi-patch-check-fill fs-2 text-primary"></i>
                                                    {% elseif reward.type == 'ACHIEVEMENT' %}
                                                        <i class="bi bi-trophy-fill fs-2 text-warning"></i>
                                                    {% elseif reward.type == 'BONUS_XP' %}
                                                        <i class="bi bi-star-fill fs-2 text-info"></i>
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}
                                                        <i class="bi bi-coin fs-2 text-success"></i>
                                                    {% endif %}
                                                {% endif %}
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1">{{ reward.name }}</h6>
                                                <span class="badge 
                                                    {% if reward.type == 'BADGE' %}bg-primary
                                                    {% elseif reward.type == 'ACHIEVEMENT' %}bg-warning
                                                    {% elseif reward.type == 'BONUS_XP' %}bg-info
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}bg-success
                                                    {% endif %} mb-2">
                                                    {{ reward.type|replace({'_': ' '}) }}
                                                </span>
                                                {% if reward.description %}
                                                    <p class="small text-muted mb-2">{{ reward.description }}</p>
                                                {% endif %}
                                                <div class="reward-value">
                                                    {% if reward.type == 'BONUS_XP' %}
                                                        <strong class="text-info">+{{ reward.value }} XP</strong>
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}
                                                        <strong class="text-success">+{{ reward.value }} Tokens</strong>
                                                    {% endif %}
                                                </div>
                                                {% if reward.requirement %}
                                                    <small class="text-muted d-block mt-2">
                                                        <i class="bi bi-info-circle me-1"></i>{{ reward.requirement }}
                                                    </small>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endif %}

                <div class="d-flex gap-3">
                    {% if is_granted('ROLE_STUDENT') %}
                        {# Ajax-enabled play button #}
                        <button id="play-game-btn" 
                                class="btn btn-lg btn-success" 
                                data-game-id="{{ game.id }}"
                                data-game-cost="{{ game.tokenCost }}"
                                data-student-tokens="{{ app.user.studentProfile ? app.user.studentProfile.totalTokens : 0 }}">
                            <i class="fas fa-play"></i> Play Now
                        </button>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-lg btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login to Play
                        </a>
                    {% endif %}
                    <a href="{{ path('front_game_index') }}" class="btn btn-lg btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Games
                    </a>
                </div>
            </div>

            {# Sidebar with Quick Stats #}
            <div class="col-md-4">
                {% if app.user.studentProfile %}
                <div class="card mb-3 sticky-top" style="top: 20px;">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">Your Stats</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <small class="text-muted">Level</small>
                            <h4>{{ app.user.studentProfile.level }}</h4>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">Total XP</small>
                            <h4>{{ app.user.studentProfile.totalXP }}</h4>
                        </div>
                        <div>
                            <small class="text-muted">Available Tokens</small>
                            <h4>{{ app.user.studentProfile.totalTokens }}</h4>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
    .reward-item {
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }
    
    .reward-item:hover {
        background-color: #e9ecef;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    [data-bs-theme="dark"] .reward-item {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1) !important;
    }
    
    [data-bs-theme="dark"] .reward-item:hover {
        background-color: rgba(255,255,255,0.08);
        box-shadow: 0 4px 8px rgba(255,255,255,0.1);
    }
    
    .reward-icon-small {
        width: 50px;
        height: 50px;
        object-fit: contain;
    }
    
    .reward-value {
        font-size: 1.1rem;
    }
    
    /* Dark mode adjustments for cards */
    [data-bs-theme="dark"] .card {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
    }
    
    [data-bs-theme="dark"] .card-header {
        background-color: rgba(255,255,255,0.08) !important;
        border-bottom-color: rgba(255,255,255,0.1);
    }
    
    [data-bs-theme="dark"] .card-header.bg-primary {
        background-color: rgba(102, 126, 234, 0.3) !important;
    }
    
    [data-bs-theme="dark"] .card-header.bg-info {
        background-color: rgba(23, 162, 184, 0.3) !important;
    }
    
    /* Dark mode text adjustments */
    [data-bs-theme="dark"] .text-muted {
        color: rgba(255,255,255,0.6) !important;
    }
    
    [data-bs-theme="dark"] .lead {
        color: rgba(255,255,255,0.9);
    }
    
    /* Dark mode alert adjustments */
    [data-bs-theme="dark"] .alert-danger {
        background-color: rgba(220, 53, 69, 0.2);
        border-color: rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
    }
    
    /* Dark mode badge adjustments */
    [data-bs-theme="dark"] .badge.bg-info {
        background-color: #20c9e3 !important;
        color: #000 !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-warning {
        background-color: #ff9800 !important;
        color: #000 !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-primary {
        background-color: #667eea !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-success {
        background-color: #20c997 !important;
    }
    
    /* Dark mode reward value colors */
    [data-bs-theme="dark"] .text-info {
        color: #20c9e3 !important;
    }
    
    [data-bs-theme="dark"] .text-success {
        color: #20c997 !important;
    }
    
    [data-bs-theme="dark"] .text-warning {
        color: #ffc107 !important;
    }
    
    [data-bs-theme="dark"] .text-primary {
        color: #667eea !important;
    }
    
    /* Sticky card in dark mode */
    [data-bs-theme="dark"] .sticky-top {
        background-color: transparent;
    }
</style>

<!-- Insufficient Tokens Modal -->
<div class="modal fade" id="insufficientTokensModal" tabindex="-1" aria-labelledby="insufficientTokensModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="insufficientTokensModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Insufficient Tokens
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-4">
                    <i class="bi bi-coin text-warning" style="font-size: 4rem;"></i>
                </div>
                <h4 class="mb-3">Not Enough Tokens!</h4>
                <p class="lead mb-3" id="token-message">You need more tokens to play this game.</p>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Your Balance</small>
                                <h3 class="mb-0 text-primary" id="current-balance">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Game Cost</small>
                                <h3 class="mb-0 text-danger" id="game-cost">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    You need <strong id="missing-tokens">0</strong> more token(s) to play this game.
                </div>
                <p class="text-muted mb-0">
                    <i class="bi bi-lightbulb me-1"></i>
                    Play other games or complete challenges to earn more tokens!
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a href="{{ path('front_game_index') }}" class="btn btn-primary">
                    <i class="bi bi-controller me-1"></i>
                    Browse Games
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Play Modal -->
<div class="modal fade" id="confirmPlayModal" tabindex="-1" aria-labelledby="confirmPlayModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title" id="confirmPlayModalLabel">
                    <i class="bi bi-exclamation-circle-fill me-2"></i>
                    Confirm Game Play
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-4">
                    <i class="bi bi-controller text-primary" style="font-size: 4rem;"></i>
                </div>
                <h4 class="mb-3">Ready to Play?</h4>
                <p class="lead mb-4">This game will cost you tokens to play.</p>
                
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Current Balance</small>
                                <h3 class="mb-0 text-success" id="confirm-current-balance">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Game Cost</small>
                                <h3 class="mb-0 text-warning" id="confirm-game-cost">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-info mb-4">
                    <i class="bi bi-arrow-right-circle me-2"></i>
                    After playing, you'll have <strong id="confirm-remaining-balance">0</strong> tokens remaining.
                </div>
                
                <div class="card bg-success bg-opacity-10 border-success mb-3">
                    <div class="card-body">
                        <h6 class="text-success mb-2">
                            <i class="bi bi-trophy-fill me-2"></i>
                            Potential Rewards
                        </h6>
                        <p class="mb-0">
                            <strong id="confirm-reward-tokens">0</strong> tokens + 
                            <strong id="confirm-reward-xp">0</strong> XP
                        </p>
                    </div>
                </div>
                
                <p class="text-muted small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    Complete the game to earn rewards!
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle me-1"></i>
                    Cancel
                </button>
                <button type="button" class="btn btn-success" id="confirm-play-btn">
                    <i class="bi bi-play-fill me-1"></i>
                    Yes, Play Now!
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Level Milestone Celebration Modal -->
<div class="modal fade" id="milestoneCelebrationModal" tabindex="-1" aria-labelledby="milestoneCelebrationModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-gradient-celebration text-white border-0">
                <h5 class="modal-title w-100 text-center" id="milestoneCelebrationModalLabel">
                    <i class="bi bi-award-fill me-2 celebration-icon"></i>
                    <span class="celebration-title">Level Milestone Unlocked!</span>
                </h5>
            </div>
            <div class="modal-body text-center py-5 celebration-body">
                <div class="celebration-animation mb-4">
                    <div class="milestone-icon-container">
                        <img id="milestone-icon" src="" alt="Milestone" class="milestone-icon d-none">
                        <i class="bi bi-award-fill milestone-icon-fallback" style="font-size: 6rem; color: #ffd700;"></i>
                    </div>
                    <div class="confetti-container">
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                        <div class="confetti"></div>
                    </div>
                </div>
                
                <h2 class="mb-3 celebration-name" id="milestone-name">Achievement Unlocked!</h2>
                <p class="lead mb-4 text-muted" id="milestone-description">You've reached a new milestone!</p>
                
                <div class="row g-3 mb-4 justify-content-center">
                    <div class="col-6 col-md-4">
                        <div class="card bg-danger bg-opacity-10 border-danger">
                            <div class="card-body py-3">
                                <small class="text-muted d-block">Level Reached</small>
                                <h2 class="mb-0 text-danger" id="milestone-level">0</h2>
                            </div>
                        </div>
                    </div>
                    <div class="col-6 col-md-4">
                        <div class="card bg-success bg-opacity-10 border-success">
                            <div class="card-body py-3">
                                <small class="text-muted d-block">Bonus Tokens</small>
                                <h2 class="mb-0 text-success">
                                    <i class="bi bi-coin me-1"></i>
                                    <span id="milestone-tokens">0</span>
                                </h2>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="alert alert-success mb-0">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <strong>Congratulations!</strong> Keep playing to unlock more milestones!
                </div>
            </div>
            <div class="modal-footer border-0 justify-content-center">
                <button type="button" class="btn btn-lg btn-primary px-5" data-bs-dismiss="modal">
                    <i class="bi bi-check-circle me-2"></i>
                    Awesome!
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    /* Celebration Modal Styles */
    .bg-gradient-celebration {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
        background-size: 200% 200%;
        animation: gradientShift 3s ease infinite;
    }
    
    /* Ensure navbar stays on top */
    header.navbar-light.navbar-sticky,
    .navbar,
    .navbar-collapse,
    .dropdown-menu {
        z-index: 9999 !important;
    }
    
    /* Ensure modals don't interfere with navbar */
    .modal-backdrop {
        z-index: 1040 !important;
    }
    
    .modal {
        z-index: 1050 !important;
    }
    
    @keyframes gradientShift {
        0%, 100% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
    }
    
    .celebration-icon {
        animation: bounce 1s ease infinite;
        display: inline-block;
    }
    
    @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    
    .celebration-title {
        font-size: 1.5rem;
        font-weight: bold;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    
    .celebration-body {
        background: linear-gradient(180deg, rgba(102, 126, 234, 0.05) 0%, rgba(255, 255, 255, 0) 100%);
    }
    
    [data-bs-theme="dark"] .celebration-body {
        background: linear-gradient(180deg, rgba(102, 126, 234, 0.15) 0%, rgba(0, 0, 0, 0) 100%);
    }
    
    .milestone-icon-container {
        position: relative;
        display: inline-block;
        animation: scaleIn 0.5s ease-out;
    }
    
    @keyframes scaleIn {
        0% { transform: scale(0); opacity: 0; }
        50% { transform: scale(1.2); }
        100% { transform: scale(1); opacity: 1; }
    }
    
    .milestone-icon {
        width: 120px;
        height: 120px;
        object-fit: contain;
        filter: drop-shadow(0 10px 20px rgba(0,0,0,0.2));
    }
    
    [data-bs-theme="dark"] .milestone-icon {
        filter: drop-shadow(0 10px 20px rgba(255,255,255,0.2));
    }
    
    .milestone-icon-fallback {
        filter: drop-shadow(0 10px 20px rgba(255, 215, 0, 0.5));
        animation: pulse 2s ease infinite;
    }
    
    [data-bs-theme="dark"] .milestone-icon-fallback {
        filter: drop-shadow(0 10px 30px rgba(255, 215, 0, 0.7));
    }
    
    @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }
    
    .celebration-name {
        font-weight: bold;
        color: #667eea;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.1);
        animation: fadeInUp 0.6s ease-out 0.3s both;
    }
    
    [data-bs-theme="dark"] .celebration-name {
        color: #a8b5ff;
        text-shadow: 1px 1px 3px rgba(0,0,0,0.5);
    }
    
    @keyframes fadeInUp {
        0% { opacity: 0; transform: translateY(20px); }
        100% { opacity: 1; transform: translateY(0); }
    }
    
    .confetti-container {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }
    
    .confetti {
        position: absolute;
        width: 10px;
        height: 10px;
        background: #ffd700;
        top: -10px;
        animation: confettiFall 3s linear infinite;
        border-radius: 2px;
    }
    
    .confetti:nth-child(1) { left: 10%; animation-delay: 0s; background: #ff6b6b; }
    .confetti:nth-child(2) { left: 20%; animation-delay: 0.2s; background: #4ecdc4; }
    .confetti:nth-child(3) { left: 30%; animation-delay: 0.4s; background: #ffd700; }
    .confetti:nth-child(4) { left: 40%; animation-delay: 0.6s; background: #95e1d3; }
    .confetti:nth-child(5) { left: 50%; animation-delay: 0.8s; background: #f38181; }
    .confetti:nth-child(6) { left: 60%; animation-delay: 1s; background: #aa96da; }
    .confetti:nth-child(7) { left: 70%; animation-delay: 1.2s; background: #fcbad3; }
    .confetti:nth-child(8) { left: 80%; animation-delay: 1.4s; background: #ffffd2; }
    .confetti:nth-child(9) { left: 90%; animation-delay: 1.6s; background: #a8e6cf; }
