{% extends 'base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        {# Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <div class="col-md-8">
                <h1>{{ game.name }}</h1>
                <div class="mb-3">
                    <span class="badge bg-info">{{ game.type }}</span>
                    <span class="badge bg-warning">{{ game.difficulty }}</span>
                </div>

                <p class="lead">{{ game.description }}</p>
                
                <div class="card mb-4">
                    <div class="card-body">
                        <h5>Game Details</h5>
                        <ul>
                            <li><strong>Cost to Play:</strong> {{ game.tokenCost }} tokens</li>
                            <li><strong>Your Tokens:</strong> {{ app.user.studentProfile.totalTokens }} tokens</li>
                            <li><strong>Reward:</strong> {{ game.rewardTokens }} tokens + {{ game.rewardXP }} XP</li>
                            <li><strong>Type:</strong> {{ game.type }}</li>
                            <li><strong>Difficulty:</strong> {{ game.difficulty }}</li>
                        </ul>
                        
                        {# Show warning if not enough tokens #}
                        {% if app.user.studentProfile.totalTokens < game.tokenCost %}
                            <div class="alert alert-danger mt-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Insufficient Tokens!</strong> 
                                You need {{ game.tokenCost - app.user.studentProfile.totalTokens }} more tokens to play this game.
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="d-flex gap-3">
                    {# Disable button if not enough tokens #}
                    {% if app.user.studentProfile.totalTokens >= game.tokenCost %}
                        <a href="{{ path('front_game_play', {id: game.id}) }}" class="btn btn-lg btn-success">
                            <i class="fas fa-play"></i> Play Now
                        </a>
                    {% else %}
                        <button class="btn btn-lg btn-secondary" disabled title="Not enough tokens">
                            <i class="fas fa-lock"></i> Not Enough Tokens
                        </button>
                    {% endif %}
                    <a href="{{ path('front_game_index') }}" class="btn btn-lg btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Games
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}