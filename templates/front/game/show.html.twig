{% extends 'base.html.twig' %}

{% block title %}{{ game.name }}{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        {# Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="row">
            <div class="col-md-8">
                <h1>{{ game.name }}</h1>
                <div class="mb-3">
                    <span class="badge bg-info">{{ game.type }}</span>
                    <span class="badge bg-warning">{{ game.difficulty }}</span>
                </div>

                <p class="lead">{{ game.description }}</p>
                
                <div class="card mb-4">
                    <div class="card-body">
                        <h5>Game Details</h5>
                        <ul>
                            <li><strong>Cost to Play:</strong> {{ game.tokenCost }} tokens</li>
                            <li><strong>Your Tokens:</strong> {{ app.user.studentProfile ? app.user.studentProfile.totalTokens : 0 }} tokens</li>
                            <li><strong>Base Reward:</strong> {{ game.rewardTokens }} tokens + {{ game.rewardXP }} XP</li>
                            <li><strong>Type:</strong> {{ game.type }}</li>
                            <li><strong>Difficulty:</strong> {{ game.difficulty }}</li>
                        </ul>
                        
                        {# Show warning if not enough tokens #}
                        {% if app.user.studentProfile and app.user.studentProfile.totalTokens < game.tokenCost %}
                            <div class="alert alert-danger mt-3">
                                <i class="fas fa-exclamation-triangle"></i>
                                <strong>Insufficient Tokens!</strong> 
                                You need {{ game.tokenCost - app.user.studentProfile.totalTokens }} more tokens to play this game.
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# Special Rewards Section #}
                {% if game.rewards is not empty %}
                <div class="card mb-4">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">
                            <i class="bi bi-trophy-fill me-2"></i>
                            Special Rewards Available
                        </h5>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">Complete this game to earn these additional rewards:</p>
                        <div class="row g-3">
                            {% for reward in game.rewards %}
                                {% if reward.isActive %}
                                <div class="col-md-6">
                                    <div class="border rounded p-3 h-100 reward-item">
                                        <div class="d-flex align-items-start">
                                            <div class="me-3">
                                                {% if reward.icon %}
                                                    <img src="{{ asset('images/rewards/' ~ reward.icon) }}" 
                                                         alt="{{ reward.name }}" 
                                                         class="reward-icon-small">
                                                {% else %}
                                                    {% if reward.type == 'BADGE' %}
                                                        <i class="bi bi-patch-check-fill fs-2 text-primary"></i>
                                                    {% elseif reward.type == 'ACHIEVEMENT' %}
                                                        <i class="bi bi-trophy-fill fs-2 text-warning"></i>
                                                    {% elseif reward.type == 'BONUS_XP' %}
                                                        <i class="bi bi-star-fill fs-2 text-info"></i>
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}
                                                        <i class="bi bi-coin fs-2 text-success"></i>
                                                    {% endif %}
                                                {% endif %}
                                            </div>
                                            <div class="flex-grow-1">
                                                <h6 class="mb-1">{{ reward.name }}</h6>
                                                <span class="badge 
                                                    {% if reward.type == 'BADGE' %}bg-primary
                                                    {% elseif reward.type == 'ACHIEVEMENT' %}bg-warning
                                                    {% elseif reward.type == 'BONUS_XP' %}bg-info
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}bg-success
                                                    {% endif %} mb-2">
                                                    {{ reward.type|replace({'_': ' '}) }}
                                                </span>
                                                {% if reward.description %}
                                                    <p class="small text-muted mb-2">{{ reward.description }}</p>
                                                {% endif %}
                                                <div class="reward-value">
                                                    {% if reward.type == 'BONUS_XP' %}
                                                        <strong class="text-info">+{{ reward.value }} XP</strong>
                                                    {% elseif reward.type == 'BONUS_TOKENS' %}
                                                        <strong class="text-success">+{{ reward.value }} Tokens</strong>
                                                    {% endif %}
                                                </div>
                                                {% if reward.requirement %}
                                                    <small class="text-muted d-block mt-2">
                                                        <i class="bi bi-info-circle me-1"></i>{{ reward.requirement }}
                                                    </small>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                </div>
                {% endif %}

                <div class="d-flex gap-3">
                    {% if is_granted('ROLE_STUDENT') %}
                        {# Ajax-enabled play button #}
                        <button id="play-game-btn" 
                                class="btn btn-lg btn-success" 
                                data-game-id="{{ game.id }}"
                                data-game-cost="{{ game.tokenCost }}"
                                data-student-tokens="{{ app.user.studentProfile ? app.user.studentProfile.totalTokens : 0 }}">
                            <i class="fas fa-play"></i> Play Now
                        </button>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-lg btn-primary">
                            <i class="fas fa-sign-in-alt"></i> Login to Play
                        </a>
                    {% endif %}
                    <a href="{{ path('front_game_index') }}" class="btn btn-lg btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to Games
                    </a>
                </div>
            </div>

            {# Sidebar with Quick Stats #}
            <div class="col-md-4">
                {% if app.user.studentProfile %}
                <div class="card mb-3 sticky-top" style="top: 20px;">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">Your Stats</h6>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <small class="text-muted">Level</small>
                            <h4>{{ app.user.studentProfile.level }}</h4>
                        </div>
                        <div class="mb-3">
                            <small class="text-muted">Total XP</small>
                            <h4>{{ app.user.studentProfile.totalXP }}</h4>
                        </div>
                        <div>
                            <small class="text-muted">Available Tokens</small>
                            <h4>{{ app.user.studentProfile.totalTokens }}</h4>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<style>
    .reward-item {
        transition: all 0.3s ease;
        background-color: #f8f9fa;
    }
    
    .reward-item:hover {
        background-color: #e9ecef;
        transform: translateY(-2px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
    }
    
    [data-bs-theme="dark"] .reward-item {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1) !important;
    }
    
    [data-bs-theme="dark"] .reward-item:hover {
        background-color: rgba(255,255,255,0.08);
        box-shadow: 0 4px 8px rgba(255,255,255,0.1);
    }
    
    .reward-icon-small {
        width: 50px;
        height: 50px;
        object-fit: contain;
    }
    
    .reward-value {
        font-size: 1.1rem;
    }
    
    /* Dark mode adjustments for cards */
    [data-bs-theme="dark"] .card {
        background-color: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.1);
    }
    
    [data-bs-theme="dark"] .card-header {
        background-color: rgba(255,255,255,0.08) !important;
        border-bottom-color: rgba(255,255,255,0.1);
    }
    
    [data-bs-theme="dark"] .card-header.bg-primary {
        background-color: rgba(102, 126, 234, 0.3) !important;
    }
    
    [data-bs-theme="dark"] .card-header.bg-info {
        background-color: rgba(23, 162, 184, 0.3) !important;
    }
    
    /* Dark mode text adjustments */
    [data-bs-theme="dark"] .text-muted {
        color: rgba(255,255,255,0.6) !important;
    }
    
    [data-bs-theme="dark"] .lead {
        color: rgba(255,255,255,0.9);
    }
    
    /* Dark mode alert adjustments */
    [data-bs-theme="dark"] .alert-danger {
        background-color: rgba(220, 53, 69, 0.2);
        border-color: rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
    }
    
    /* Dark mode badge adjustments */
    [data-bs-theme="dark"] .badge.bg-info {
        background-color: #20c9e3 !important;
        color: #000 !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-warning {
        background-color: #ff9800 !important;
        color: #000 !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-primary {
        background-color: #667eea !important;
    }
    
    [data-bs-theme="dark"] .badge.bg-success {
        background-color: #20c997 !important;
    }
    
    /* Dark mode reward value colors */
    [data-bs-theme="dark"] .text-info {
        color: #20c9e3 !important;
    }
    
    [data-bs-theme="dark"] .text-success {
        color: #20c997 !important;
    }
    
    [data-bs-theme="dark"] .text-warning {
        color: #ffc107 !important;
    }
    
    [data-bs-theme="dark"] .text-primary {
        color: #667eea !important;
    }
    
    /* Sticky card in dark mode */
    [data-bs-theme="dark"] .sticky-top {
        background-color: transparent;
    }
</style>

<!-- Insufficient Tokens Modal -->
<div class="modal fade" id="insufficientTokensModal" tabindex="-1" aria-labelledby="insufficientTokensModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="insufficientTokensModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    Insufficient Tokens
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center py-4">
                <div class="mb-4">
                    <i class="bi bi-coin text-warning" style="font-size: 4rem;"></i>
                </div>
                <h4 class="mb-3">Not Enough Tokens!</h4>
                <p class="lead mb-3" id="token-message">You need more tokens to play this game.</p>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Your Balance</small>
                                <h3 class="mb-0 text-primary" id="current-balance">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="card bg-light">
                            <div class="card-body">
                                <small class="text-muted d-block">Game Cost</small>
                                <h3 class="mb-0 text-danger" id="game-cost">0</h3>
                                <small class="text-muted">tokens</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    You need <strong id="missing-tokens">0</strong> more token(s) to play this game.
                </div>
                <p class="text-muted mb-0">
                    <i class="bi bi-lightbulb me-1"></i>
                    Play other games or complete challenges to earn more tokens!
                </p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <a href="{{ path('front_game_index') }}" class="btn btn-primary">
                    <i class="bi bi-controller me-1"></i>
                    Browse Games
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const playBtn = document.getElementById('play-game-btn');
            
            if (playBtn) {
                playBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    
                    const gameId = this.dataset.gameId;
                    const gameCost = parseInt(this.dataset.gameCost);
                    const studentTokens = parseInt(this.dataset.studentTokens);
                    
                    // Show loading state
                    const originalHtml = this.innerHTML;
                    this.disabled = true;
                    this.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Checking...';
                    
                    // Check tokens via Ajax
                    fetch('{{ path('front_game_check_tokens', {id: '__ID__'}) }}'.replace('__ID__', gameId), {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'X-Requested-With': 'XMLHttpRequest'
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success && data.canAfford) {
                            // Sufficient tokens - redirect to play
                            window.location.href = '{{ path('front_game_play', {id: '__ID__'}) }}'.replace('__ID__', gameId);
                        } else {
                            // Insufficient tokens - show modal
                            showInsufficientTokensModal(data);
                            
                            // Reset button
                            playBtn.disabled = false;
                            playBtn.innerHTML = originalHtml;
                        }
                    })
                    .catch(error => {
                        console.error('Error checking tokens:', error);
                        alert('An error occurred. Please try again.');
                        
                        // Reset button
                        playBtn.disabled = false;
                        playBtn.innerHTML = originalHtml;
                    });
                });
            }
        });
        
        function showInsufficientTokensModal(data) {
            // Update modal content
            document.getElementById('token-message').textContent = data.message;
            document.getElementById('current-balance').textContent = data.currentBalance;
            document.getElementById('game-cost').textContent = data.gameCost;
            document.getElementById('missing-tokens').textContent = data.missing;
            
            // Show modal
            const modal = new bootstrap.Modal(document.getElementById('insufficientTokensModal'));
            modal.show();
        }
    </script>
{% endblock %}