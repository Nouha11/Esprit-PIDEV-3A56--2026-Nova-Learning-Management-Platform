<div class="col-12 col-sm-6 col-lg-4 col-xl-3">
    <div class="card h-100 reward-card">
        <div class="card-header text-center py-4 reward-header">
            {% if reward.icon %}
                {#
                    Smart icon resolution for shared Java/Symfony database:
                    - Java stores full Windows paths: C:\Users\...\image.png  → show type fallback icon
                    - Symfony stores plain filenames: reward-icon.png         → /uploads/rewards/reward-icon.png
                    - Already a URL: https://... or /uploads/...              → use as-is
                #}
                {% set icon = reward.icon %}
                {% if icon starts with 'http' %}
                    <img src="{{ icon }}" alt="{{ reward.name }}" class="reward-icon" style="width: 80px; height: 80px; object-fit: contain;">
                {% elseif icon starts with '/' %}
                    <img src="{{ icon }}" alt="{{ reward.name }}" class="reward-icon" style="width: 80px; height: 80px; object-fit: contain;">
                {% elseif ':' in icon or '\\' in icon %}
                    {# Full local path from Java — not accessible on web, show type icon instead #}
                    {% if reward.type == 'BADGE' %}
                        <i class="bi bi-patch-check-fill display-3 text-primary"></i>
                    {% elseif reward.type == 'ACHIEVEMENT' %}
                        <i class="bi bi-trophy-fill display-3 text-warning"></i>
                    {% elseif reward.type == 'BONUS_XP' %}
                        <i class="bi bi-star-fill display-3 text-info"></i>
                    {% elseif reward.type == 'BONUS_TOKENS' %}
                        <i class="bi bi-coin display-3 text-success"></i>
                    {% elseif reward.type == 'LEVEL_MILESTONE' %}
                        <i class="bi bi-award-fill display-3 text-danger"></i>
                    {% else %}
                        <i class="bi bi-gift-fill display-3 text-secondary"></i>
                    {% endif %}
                {% else %}
                    {# Plain filename from Symfony #}
                    <img src="{{ asset('uploads/rewards/' ~ icon) }}" alt="{{ reward.name }}" class="reward-icon" style="width: 80px; height: 80px; object-fit: contain;">
                {% endif %}
            {% else %}
                {% if reward.type == 'BADGE' %}
                    <i class="bi bi-patch-check-fill display-3 text-primary"></i>
                {% elseif reward.type == 'ACHIEVEMENT' %}
                    <i class="bi bi-trophy-fill display-3 text-warning"></i>
                {% elseif reward.type == 'BONUS_XP' %}
                    <i class="bi bi-star-fill display-3 text-info"></i>
                {% elseif reward.type == 'BONUS_TOKENS' %}
                    <i class="bi bi-coin display-3 text-success"></i>
                {% elseif reward.type == 'LEVEL_MILESTONE' %}
                    <i class="bi bi-award-fill display-3 text-danger"></i>
                {% endif %}
            {% endif %}
        </div>
        
        <div class="card-body d-flex flex-column p-3">
            <h5 class="card-title text-center mb-2" style="min-height: 48px; display: flex; align-items: center; justify-content: center;">
                {{ reward.name }}
            </h5>
            
            <!-- Reward Type Badge -->
            <div class="text-center mb-2">
                <span class="badge 
                    {% if reward.type == 'BADGE' %}bg-primary
                    {% elseif reward.type == 'ACHIEVEMENT' %}bg-warning text-dark
                    {% elseif reward.type == 'BONUS_XP' %}bg-info
                    {% elseif reward.type == 'BONUS_TOKENS' %}bg-success
                    {% elseif reward.type == 'LEVEL_MILESTONE' %}bg-danger
                    {% endif %}">
                    {{ reward.type|replace({'_': ' '}) }}
                </span>
            </div>

            <!-- Value or Required Level -->
            <div class="text-center mb-3">
                {% if reward.type == 'LEVEL_MILESTONE' %}
                    <span class="text-danger fw-bold">
                        <i class="bi bi-arrow-up-circle me-1"></i>Level {{ reward.requiredLevel }}
                    </span>
                    <br>
                    <span class="text-success fw-bold">
                        <i class="bi bi-coin me-1"></i>{{ reward.value }} Tokens
                    </span>
                {% elseif reward.type == 'BONUS_XP' %}
                    <span class="text-info fw-bold">Value: {{ reward.value }}</span>
                {% elseif reward.type == 'BONUS_TOKENS' %}
                    <span class="text-success fw-bold">Value: {{ reward.value }}</span>
                {% else %}
                    <span class="text-primary fw-bold">Value: {{ reward.value }}</span>
                {% endif %}
            </div>

            <!-- Status Badge -->
            <div class="mt-auto text-center">
                {% if reward.isActive %}
                    <span class="badge bg-success">
                        <i class="bi bi-check-circle-fill me-1"></i>Active
                    </span>
                {% else %}
                    <span class="badge bg-secondary">
                        <i class="bi bi-x-circle-fill me-1"></i>Inactive
                    </span>
                {% endif %}
            </div>
        </div>
        
        <div class="card-footer bg-transparent border-top">
            <div class="d-grid">
                <a href="{{ path('front_reward_show', {id: reward.id}) }}" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-info-circle me-1"></i>View Details
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .reward-card {
        transition: all 0.3s ease;
        border: 1px solid rgba(0,0,0,0.125);
    }
    
    .reward-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }
    
    [data-bs-theme="dark"] .reward-card:hover {
        box-shadow: 0 8px 20px rgba(255,255,255,0.1);
    }
    
    .reward-header {
        background: rgba(0, 0, 0, 0.03);
        min-height: 140px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    [data-bs-theme="dark"] .reward-header {
        background: rgba(255, 255, 255, 0.05);
    }
    
    [data-bs-theme="dark"] .card-footer {
        border-top-color: rgba(255, 255, 255, 0.1) !important;
    }
    
    /* Ensure all cards have same height */
    .reward-card .card-body {
        min-height: 200px;
    }
</style>
