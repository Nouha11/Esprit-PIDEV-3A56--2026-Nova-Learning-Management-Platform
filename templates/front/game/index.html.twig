{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Browse Games') }} - NOVA{% endblock %}

{% block body %}
<div class="container-fluid py-5">
    <div class="container">
        <!-- Page Heading -->
        <section class="pt-5">
            <div class="row mb-4">
                <div class="col-12">
                    <h1 class="fs-1">{{ t.t('Discover Amazing Games') }}</h1>
                    <p class="mb-0">{{ t.t('Challenge yourself and earn rewards!') }}</p>
                </div>
            </div>

            <!-- Mini Games Section (Energy Regeneration) -->
            {% if miniGames|length > 0 %}
                <div class="card shadow-lg border-0 mb-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center justify-content-between mb-4">
                            <div>
                                <h2 class="text-white mb-2">
                                    <i class="bi bi-lightning-charge-fill me-2"></i>
                                    Energy Regeneration Mini Games
                                </h2>
                                <p class="text-white-50 mb-0">
                                    <i class="bi bi-info-circle me-1"></i>
                                    Quick games to boost your energy and keep playing!
                                </p>
                            </div>
                            <div class="text-white">
                                <i class="bi bi-battery-charging fs-1"></i>
                            </div>
                        </div>

                        <!-- Mini Games Grid -->
                        <div class="row g-3">
                            {% for miniGame in miniGames %}
                                <div class="col-md-6 col-lg-4">
                                    <div class="card h-100 border-0 shadow-sm mini-game-card">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h5 class="card-title mb-0 fw-bold">{{ miniGame.name }}</h5>
                                                {% if app.user %}
                                                    <button class="btn btn-sm btn-outline-danger favorite-btn" 
                                                            data-game-id="{{ miniGame.id }}"
                                                            data-favorited="{{ app.user.hasFavoriteGame(miniGame) ? 'true' : 'false' }}"
                                                            title="{{ app.user.hasFavoriteGame(miniGame) ? 'Remove from favorites' : 'Add to favorites' }}">
                                                        <i class="bi bi-heart{{ app.user.hasFavoriteGame(miniGame) ? '-fill' : '' }}"></i>
                                                    </button>
                                                {% endif %}
                                            </div>

                                            <!-- Energy Badge -->
                                            <div class="mb-3">
                                                <span class="badge bg-success fs-6 px-3 py-2">
                                                    <i class="bi bi-lightning-charge-fill me-1"></i>
                                                    +{{ miniGame.energyPoints }} Energy
                                                </span>
                                                {% if miniGame.tokenCost == 0 %}
                                                    <span class="badge bg-info ms-1">FREE</span>
                                                {% else %}
                                                    <span class="badge bg-warning text-dark ms-1">{{ miniGame.tokenCost }} 🪙</span>
                                                {% endif %}
                                            </div>

                                            <p class="card-text text-muted small mb-3">
                                                {{ miniGame.description|length > 80 ? miniGame.description|slice(0, 80) ~ '...' : miniGame.description }}
                                            </p>

                                            {# Rating Display #}
                                            <div class="mb-3">
                                                {% set gameRating = miniGameRatings[miniGame.id]|default({'average': 0, 'count': 0}) %}
                                                {% include 'front/game/_star_rating.html.twig' with {
                                                    'rating': gameRating.average,
                                                    'count': gameRating.count,
                                                    'size': 'sm'
                                                } %}
                                            </div>

                                            <div class="d-flex justify-content-between align-items-center">
                                                {% if miniGame.rewardTokens > 0 or miniGame.rewardXP > 0 %}
                                                    <div class="small text-muted">
                                                        {% if miniGame.rewardXP > 0 %}
                                                            <i class="bi bi-trophy-fill text-warning"></i> {{ miniGame.rewardXP }} XP
                                                        {% endif %}
                                                        {% if miniGame.rewardTokens > 0 %}
                                                            <i class="bi bi-coin text-warning{% if miniGame.rewardXP > 0 %} ms-2{% endif %}"></i> {{ miniGame.rewardTokens }}
                                                        {% endif %}
                                                    </div>
                                                {% else %}
                                                    <div></div>
                                                {% endif %}
                                                <a href="{{ path('front_game_show', {id: miniGame.id}) }}" class="btn btn-sm btn-success">
                                                    <i class="bi bi-play-fill me-1"></i>Play Now
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>

                        <!-- Mini Games Pagination -->
                        {% if miniGames.getTotalItemCount > 3 %}
                            <div class="mt-4">
                                <div class="d-flex justify-content-center">
                                    {{ knp_pagination_render(miniGames, 'pagination/custom_pagination.html.twig') }}
                                </div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endif %}

            <!-- Ajax Filters -->
            <div class="mb-3">
                <h3 class="fs-3">
                    <i class="bi bi-controller me-2"></i>
                    All Games
                </h3>
                <p class="text-muted">Browse and filter through our complete game collection</p>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <div class="row g-3">
                        <!-- Search Input -->
                        <div class="col-md-4">
                            <label for="search-input" class="form-label">
                                <i class="bi bi-search"></i> Search Games
                            </label>
                            <input type="text" 
                                   class="form-control" 
                                   id="search-input" 
                                   placeholder="Search by name..."
                                   value="{{ search }}">
                        </div>

                        <!-- Type Filter -->
                        <div class="col-md-3">
                            <label for="type-filter" class="form-label">
                                <i class="bi bi-controller"></i> Game Type
                            </label>
                            <select class="form-select" id="type-filter">
                                <option value="">All Types</option>
                                <option value="PUZZLE" {{ type == 'PUZZLE' ? 'selected' : '' }}>Puzzle</option>
                                <option value="MEMORY" {{ type == 'MEMORY' ? 'selected' : '' }}>Memory</option>
                                <option value="TRIVIA" {{ type == 'TRIVIA' ? 'selected' : '' }}>Trivia</option>
                                <option value="ARCADE" {{ type == 'ARCADE' ? 'selected' : '' }}>Arcade</option>
                            </select>
                        </div>

                        <!-- Difficulty Filter -->
                        <div class="col-md-3">
                            <label for="difficulty-filter" class="form-label">
                                <i class="bi bi-speedometer"></i> Difficulty
                            </label>
                            <select class="form-select" id="difficulty-filter">
                                <option value="">All Levels</option>
                                <option value="EASY" {{ difficulty == 'EASY' ? 'selected' : '' }}>Easy</option>
                                <option value="MEDIUM" {{ difficulty == 'MEDIUM' ? 'selected' : '' }}>Medium</option>
                                <option value="HARD" {{ difficulty == 'HARD' ? 'selected' : '' }}>Hard</option>
                            </select>
                        </div>

                        <!-- Free Only Checkbox -->
                        <div class="col-md-2">
                            <label class="form-label d-block">&nbsp;</label>
                            <div class="form-check">
                                <input class="form-check-input" 
                                       type="checkbox" 
                                       id="free-only-filter"
                                       {{ freeOnly ? 'checked' : '' }}>
                                <label class="form-check-label" for="free-only-filter">
                                    <i class="bi bi-coin text-success"></i> Free Only
                                </label>
                            </div>
                        </div>
                    </div>

                    <!-- Filter Actions -->
                    <div class="row mt-3">
                        <div class="col-12">
                            <button class="btn btn-outline-secondary btn-sm" onclick="clearFilters()">
                                <i class="bi bi-x-circle"></i> Clear Filters
                            </button>
                            <span class="ms-3 text-muted" id="filter-status">
                                <i class="bi bi-funnel"></i> <span id="results-count">{{ games.getTotalItemCount }}</span> game(s) found
                            </span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Loading Indicator -->
            <div id="loading-indicator" class="text-center py-4 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Loading games...</p>
            </div>

            <!-- Games Grid Container -->
            <div id="games-container">
                {% include 'front/game/_games_list.html.twig' %}
            </div>
        </section>
    </div>
</div>

<style>
    .hover-lift {
        transition: all 0.3s ease;
    }
    
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.15) !important;
    }
    
    .form-check-input:checked {
        background-color: #28a745;
        border-color: #28a745;
    }

    /* Mini Game Cards */
    .mini-game-card {
        transition: all 0.3s ease;
        border: 2px solid transparent;
    }

    .mini-game-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.2) !important;
        border-color: #28a745;
    }

    /* Dark mode adjustments */
    [data-bs-theme="dark"] .mini-game-card {
        background-color: rgba(255,255,255,0.05);
    }

    [data-bs-theme="dark"] .mini-game-card:hover {
        background-color: rgba(255,255,255,0.08);
        box-shadow: 0 10px 25px rgba(255,255,255,0.1) !important;
    }

    [data-bs-theme="dark"] .hover-lift:hover {
        box-shadow: 0 8px 20px rgba(255,255,255,0.1) !important;
    }

    /* Energy section gradient for dark mode */
    [data-bs-theme="dark"] .card[style*="linear-gradient"] {
        opacity: 0.95;
    }

    /* Pulsing animation for energy badge */
    @keyframes pulse-energy {
        0%, 100% {
            transform: scale(1);
            box-shadow: 0 0 0 0 rgba(40, 167, 69, 0.7);
        }
        50% {
            transform: scale(1.05);
            box-shadow: 0 0 0 10px rgba(40, 167, 69, 0);
        }
    }

    .badge.bg-success {
        animation: pulse-energy 2s infinite;
    }

    /* Mini games pagination styling */
    .card[style*="linear-gradient"] .pagination {
        margin-bottom: 0;
    }

    .card[style*="linear-gradient"] .pagination .page-link {
        background-color: rgba(255, 255, 255, 0.2);
        border-color: rgba(255, 255, 255, 0.3);
        color: white;
    }

    .card[style*="linear-gradient"] .pagination .page-link:hover {
        background-color: rgba(255, 255, 255, 0.3);
        border-color: rgba(255, 255, 255, 0.5);
        color: white;
    }

    .card[style*="linear-gradient"] .pagination .page-item.active .page-link {
        background-color: rgba(255, 255, 255, 0.9);
        border-color: rgba(255, 255, 255, 1);
        color: #667eea;
        font-weight: bold;
    }

    .card[style*="linear-gradient"] .pagination .page-item.disabled .page-link {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
        color: rgba(255, 255, 255, 0.5);
    }
</style>

{# Include AI Chat Widget #}
{% include 'components/ai_chat_widget.html.twig' %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        let searchTimeout = null;

        // Load games with filters
        function loadGames() {
            const search = document.getElementById('search-input').value;
            const type = document.getElementById('type-filter').value;
            const difficulty = document.getElementById('difficulty-filter').value;
            const freeOnly = document.getElementById('free-only-filter').checked;

            // Build query string
            const params = new URLSearchParams();
            if (search) params.append('search', search);
            if (type) params.append('type', type);
            if (difficulty) params.append('difficulty', difficulty);
            if (freeOnly) params.append('free_only', 'true');

            // Show loading indicator
            document.getElementById('loading-indicator').classList.remove('d-none');
            document.getElementById('games-container').style.opacity = '0.5';

            // Fetch filtered games
            fetch("{{ path('front_game_index') }}?" + params.toString(), {
                headers: {
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => response.text())
            .then(html => {
                document.getElementById('games-container').innerHTML = html;
                document.getElementById('loading-indicator').classList.add('d-none');
                document.getElementById('games-container').style.opacity = '1';
                
                // Update URL without reload
                const newUrl = "{{ path('front_game_index') }}?" + params.toString();
                window.history.pushState({}, '', newUrl);
            })
            .catch(error => {
                console.error('Error loading games:', error);
                document.getElementById('loading-indicator').classList.add('d-none');
                document.getElementById('games-container').style.opacity = '1';
            });
        }

        // Clear all filters
        function clearFilters() {
            document.getElementById('search-input').value = '';
            document.getElementById('type-filter').value = '';
            document.getElementById('difficulty-filter').value = '';
            document.getElementById('free-only-filter').checked = false;
            loadGames();
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', function() {
            // Search input with debounce
            document.getElementById('search-input').addEventListener('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(loadGames, 500);
            });

            // Dropdown filters
            document.getElementById('type-filter').addEventListener('change', loadGames);
            document.getElementById('difficulty-filter').addEventListener('change', loadGames);
            document.getElementById('free-only-filter').addEventListener('change', loadGames);

            // Favorite button click handler (delegated event)
            document.addEventListener('click', function(e) {
                if (e.target.closest('.favorite-btn')) {
                    e.preventDefault();
                    const btn = e.target.closest('.favorite-btn');
                    toggleFavorite(btn);
                }
            });
        });

        // Toggle favorite status
        function toggleFavorite(button) {
            const gameId = button.dataset.gameId;
            const isFavorited = button.dataset.favorited === 'true';
            const icon = button.querySelector('i');

            // Disable button during request
            button.disabled = true;

            fetch(`/games/${gameId}/toggle-favorite`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                }
            })
            .then(response => {
                // Log response for debugging
                console.log('Response status:', response.status);
                return response.json();
            })
            .then(data => {
                console.log('Response data:', data);
                if (data.success) {
                    // Update button state
                    button.dataset.favorited = data.isFavorited ? 'true' : 'false';
                    
                    // Update icon
                    if (data.isFavorited) {
                        icon.classList.remove('bi-heart');
                        icon.classList.add('bi-heart-fill');
                        button.title = 'Remove from favorites';
                    } else {
                        icon.classList.remove('bi-heart-fill');
                        icon.classList.add('bi-heart');
                        button.title = 'Add to favorites';
                    }

                    // Show toast notification
                    showToast(data.message, 'success');
                } else {
                    showToast(data.message || 'Failed to update favorite', 'error');
                }
            })
            .catch(error => {
                console.error('Error toggling favorite:', error);
                showToast('Error: ' + error.message, 'error');
            })
            .finally(() => {
                button.disabled = false;
            });
        }

        // Simple toast notification
        function showToast(message, type = 'success') {
            const toast = document.createElement('div');
            toast.className = `alert alert-${type === 'success' ? 'success' : 'danger'} position-fixed top-0 end-0 m-3`;
            toast.style.zIndex = '9999';
            toast.innerHTML = `
                <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>
                ${message}
            `;
            document.body.appendChild(toast);

            setTimeout(() => {
                toast.remove();
            }, 3000);
        }
    </script>
{% endblock %}