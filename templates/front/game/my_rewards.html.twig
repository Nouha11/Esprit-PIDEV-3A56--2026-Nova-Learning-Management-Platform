{% extends 'base.html.twig' %}

{% block title %}My Rewards{% endblock %}

{% block body %}
<div class="container my-5">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="display-4 mb-3">
                <i class="bi bi-trophy-fill text-warning me-2"></i>
                My Rewards
            </h1>
            <p class="lead text-muted">Track your achievements and earned rewards</p>
        </div>
    </div>

    <!-- Player Stats Card -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <i class="bi bi-star-fill text-warning fs-1"></i>
                    <h5 class="card-title mt-2">Total XP</h5>
                    <p class="card-text display-6">{{ student.totalXP }}</p>
                    <small class="text-muted">Level {{ student.level }}</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-success">
                <div class="card-body text-center">
                    <i class="bi bi-coin text-warning fs-1"></i>
                    <h5 class="card-title mt-2">Total Tokens</h5>
                    <p class="card-text display-6">{{ student.totalTokens }}</p>
                    <small class="text-muted">Available to spend</small>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card border-info">
                <div class="card-body text-center">
                    <i class="bi bi-graph-up-arrow text-primary fs-1"></i>
                    <h5 class="card-title mt-2">Progress</h5>
                    <div class="progress mt-3" style="height: 25px;">
                        <div class="progress-bar bg-success" role="progressbar" 
                             style="width: {{ student.progressToNextLevel }}%;" 
                             aria-valuenow="{{ student.progressToNextLevel }}" 
                             aria-valuemin="0" 
                             aria-valuemax="100">
                            {{ student.progressToNextLevel }}%
                        </div>
                    </div>
                    <small class="text-muted mt-2 d-block">
                        {{ student.XPForNextLevel }} XP to next level
                    </small>
                </div>
            </div>
        </div>
    </div>

    <!-- Rewards Section -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h2 class="mb-0">
                    <i class="bi bi-award-fill text-primary me-2"></i>
                    Your Achievements
                </h2>
                <a href="{{ path('front_reward_browse') }}" class="btn btn-outline-primary">
                    <i class="bi bi-shop me-1"></i>Browse All Rewards
                </a>
            </div>
        </div>
    </div>

    <!-- Placeholder for earned rewards -->
    <div class="row">
        <div class="col-12">
            <div class="alert alert-info d-flex align-items-center" role="alert">
                <i class="bi bi-info-circle-fill me-3 fs-4"></i>
                <div>
                    <h5 class="alert-heading mb-1">Reward Tracking Coming Soon!</h5>
                    <p class="mb-0">
                        Keep playing games to earn XP and tokens. Your earned rewards will be displayed here once the tracking system is implemented.
                    </p>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-lightbulb-fill text-warning me-2"></i>
                        Tips to Earn More Rewards
                    </h5>
                    <ul class="mb-0">
                        <li>Play games regularly to earn XP and level up</li>
                        <li>Complete challenging games for bonus tokens</li>
                        <li>Browse the rewards gallery to see what's available</li>
                        <li>Higher difficulty games offer better rewards</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="row mt-4">
        <div class="col-12 text-center">
            <a href="{{ path('front_game_index') }}" class="btn btn-primary btn-lg me-2">
                <i class="bi bi-controller me-2"></i>Play Games
            </a>
            <a href="{{ path('front_reward_browse') }}" class="btn btn-outline-secondary btn-lg">
                <i class="bi bi-eye me-2"></i>View Rewards Gallery
            </a>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    
    .progress {
        border-radius: 10px;
    }
    
    .progress-bar {
        border-radius: 10px;
    }
</style>
{% endblock %}
