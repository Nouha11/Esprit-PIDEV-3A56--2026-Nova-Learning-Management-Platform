{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ space.name }} - Forum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root { --nova-bg: #dae0e6; --nova-card-bg: #ffffff; --nova-border: #cccccc; --nova-border-hover: #898989; --nova-text-main: #1a1a1b; --nova-text-muted: #787c7e; --nova-vote-bg: #f8f9fa; --nova-hover-bg: rgba(0,0,0,0.05); --nova-input-bg: #f6f7f8; }
        [data-bs-theme="dark"], body.dark-mode, .dark-mode { --nova-bg: #030303; --nova-card-bg: #1a1a1b; --nova-border: #343536; --nova-border-hover: #d7dadc; --nova-text-main: #d7dadc; --nova-text-muted: #818384; --nova-vote-bg: #1a1a1b; --nova-hover-bg: rgba(255,255,255,0.1); --nova-input-bg: #272729; }
        
        body { background-color: var(--nova-bg) !important; color: var(--nova-text-main); }
        .nova-card { background-color: var(--nova-card-bg) !important; border: 1px solid var(--nova-border) !important; border-radius: 6px; }
        .nova-text-main { color: var(--nova-text-main) !important; }
        .nova-text-muted { color: var(--nova-text-muted) !important; }
        
        .sticky-sidebar { position: sticky; top: 80px; height: calc(100vh - 80px); overflow-y: auto; }
        .sticky-sidebar::-webkit-scrollbar { width: 0px; } 

        .left-nav-link { display: flex; align-items: center; padding: 10px 16px; color: var(--nova-text-main); font-size: 14px; font-weight: 500; border-radius: 8px; text-decoration: none; transition: background 0.2s; margin-bottom: 4px; }
        .left-nav-link i { font-size: 20px; margin-right: 12px; width: 24px; text-align: center; }
        .left-nav-link:hover, .left-nav-link.active { background-color: var(--nova-hover-bg); }
        .left-nav-section-title { font-size: 11px; font-weight: 700; color: var(--nova-text-muted); text-transform: uppercase; padding: 16px 16px 8px 16px; letter-spacing: 0.5px; }

        .nova-form-wrapper { border: 1px solid var(--nova-border); border-radius: 6px; overflow: hidden; background: var(--nova-card-bg); transition: border-color 0.2s; }
        .nova-form-wrapper:focus-within { border-color: #0d6efd; }
        .nova-form-control { background: transparent !important; border: none !important; color: var(--nova-text-main) !important; box-shadow: none !important; }
        .nova-form-control::placeholder { color: var(--nova-text-muted); font-weight: 400; }
        .nova-form-footer { background: var(--nova-input-bg); border-top: 1px dashed var(--nova-border); padding: 16px; }

        .create-post-bar { background: var(--nova-card-bg); border: 1px solid var(--nova-border); border-radius: 4px; padding: 8px; display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
        .create-post-input { background: var(--nova-input-bg); border: 1px solid var(--nova-border); border-radius: 4px; padding: 10px 16px; color: var(--nova-text-muted); width: 100%; cursor: text; transition: 0.2s; }
        .create-post-input:hover { border-color: #0d6efd; background: var(--nova-card-bg); }

        .reddit-card { background: var(--nova-card-bg); border: 1px solid var(--nova-border); border-radius: 4px; transition: all 0.2s ease; cursor: pointer; }
        .reddit-card:hover { border-color: var(--nova-border-hover); }
        
        .vote-sidebar { background-color: var(--nova-vote-bg); width: 45px; border-right: 1px solid var(--nova-border); display: flex; flex-direction: column; align-items: center; padding-top: 10px; border-top-left-radius: 4px; border-bottom-left-radius: 4px;}
        .vote-arrow { color: var(--nova-text-muted); font-size: 1.4rem; cursor: pointer; border-radius: 4px; padding: 0px; line-height: 1; transition: all 0.2s; text-decoration: none;}
        .vote-arrow:hover { background-color: var(--nova-hover-bg); }
        .vote-arrow.up.active, .vote-arrow.up:hover { color: #ff4500; }
        .vote-arrow.down.active, .vote-arrow.down:hover { color: #7193ff; }
        .vote-score { font-size: 13px; font-weight: 700; color: var(--nova-text-main); margin: 6px 0; }
        
        .post-meta { font-size: 12px; color: var(--nova-text-muted); margin-bottom: 8px; }
        .post-author { color: var(--nova-text-muted); text-decoration: none; font-weight: 600; }
        .post-author:hover { text-decoration: underline; color: var(--nova-text-main); }
        .post-title { font-size: 1.15rem; font-weight: 600; color: var(--nova-text-main); text-decoration: none; line-height: 1.4; }
        .post-title:hover { text-decoration: underline; }

        .action-pill { display: inline-flex; align-items: center; padding: 6px 10px; border-radius: 4px; color: var(--nova-text-muted); font-size: 13px; font-weight: 600; text-decoration: none; transition: background-color 0.2s; background: transparent; border: none; }
        .action-pill i { font-size: 18px; margin-right: 6px; }
        .action-pill:hover { background-color: var(--nova-hover-bg); color: var(--nova-text-main); }
        .action-pill.saved { color: #eab308; }

        .sort-bar { background: var(--nova-card-bg); border: 1px solid var(--nova-border); border-radius: 4px; padding: 10px 16px; margin-bottom: 16px; display: flex; align-items: center; gap: 8px; }
        .sort-btn { background: transparent; border: none; color: var(--nova-text-muted); font-weight: 600; font-size: 14px; padding: 6px 14px; border-radius: 20px; display: flex; align-items: center; gap: 6px; transition: all 0.2s; text-decoration: none; }
        .sort-btn:hover { background: var(--nova-hover-bg); color: var(--nova-text-main); }
        .sort-btn.active { background: var(--nova-input-bg); color: #0d6efd; }
        
        .widget-card { background: var(--nova-card-bg); border: 1px solid var(--nova-border); border-radius: 4px; margin-bottom: 16px; overflow: hidden; color: var(--nova-text-main); }
        .widget-rule-item { transition: background-color 0.2s; cursor: pointer; }
        .widget-rule-item:hover { background-color: var(--nova-hover-bg) !important; }
    </style>
{% endblock %}

{% block body %}
<main style="min-height: 100vh; padding-top: 20px; padding-bottom: 40px;">
    <div class="container-fluid px-xl-5">
        <div class="row justify-content-center">
            
            {# --- 1. LEFT COLUMN --- #}
            <div class="col-xl-2 col-lg-3 d-none d-lg-block">
                <div class="sticky-sidebar pe-2">
                    <div class="left-nav-section-title">Feeds</div>
                    <a href="{{ path('app_forum') }}" class="left-nav-link">
                        <i class="bi bi-house-door"></i> Home
                    </a>
                    <a href="{{ path('app_forum', {'filter': 'popular'}) }}" class="left-nav-link">
                        <i class="bi bi-fire text-danger"></i> Popular
                    </a>
                    <a href="{{ path('app_forum', {'filter': 'unanswered'}) }}" class="left-nav-link">
                        <i class="bi bi-patch-question text-warning"></i> Unanswered
                    </a>

                    <div class="left-nav-section-title mt-3 border-top pt-3" style="border-color: var(--nova-border) !important;">My NOVA</div>
                    <a href="{{ path('app_forum', {'filter': 'history'}) }}" class="left-nav-link">
                        <i class="bi bi-clock-history text-secondary"></i> History
                    </a>
                    {% if app.user %}
                        <a href="{{ path('app_forum', {'filter': 'bookmarks'}) }}" class="left-nav-link">
                            <i class="bi bi-bookmark-fill text-info"></i> Saved Posts
                        </a>
                    {% endif %}

                    <div class="left-nav-section-title mt-3 border-top pt-3" style="border-color: var(--nova-border) !important;">Study Spaces</div>
                    {% for s in spaces|default([]) %}
                        {% set colors = ['#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#dc3545', '#6610f2', '#fd7e14'] %}
                        {% set color = colors[s.id % colors|length] %}
                        <a href="{{ path('app_forum_space', {'id': s.id}) }}" class="left-nav-link d-flex align-items-center {{ s.id == space.id ? 'active' : '' }}">
                            <div class="rounded-circle me-3" style="width: 14px; height: 14px; background-color: {{ color }}; margin-left: 5px;"></div>
                            <span class="text-truncate">{{ s.name }}</span>
                        </a>
                    {% endfor %}

                    <div class="left-nav-section-title mt-3 border-top pt-3" style="border-color: var(--nova-border) !important;">Resources</div>
                    <a href="#" class="left-nav-link"><i class="bi bi-info-circle"></i> About NOVA</a>
                    <a href="{{ path('app_forum_guidelines') }}" class="left-nav-link"><i class="bi bi-shield-check"></i> Guidelines</a>
                </div>
            </div>

            {# --- 2. MIDDLE COLUMN --- #}
            <div class="col-xl-7 col-lg-6 col-md-12">
                
                <div class="card border rounded-3 mb-4 overflow-hidden shadow-sm" style="border-color: var(--nova-border) !important; background: var(--nova-card-bg);">
                    {% set spaceColor = ['#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#dc3545', '#6610f2', '#fd7e14'][space.id % 7] %}
                    <div style="background: linear-gradient(135deg, {{ spaceColor }} 0%, #343a40 100%); height: 80px;"></div>
                    <div class="card-body d-flex align-items-center position-relative" style="padding-top: 10px;">
                        <div class="rounded-circle p-1 position-absolute" style="top: -35px; left: 15px; background: var(--nova-card-bg);">
                            <div class="text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px; font-size: 30px; background-color: {{ spaceColor }};">
                                <i class="bi bi-rocket-takeoff-fill"></i>
                            </div>
                        </div>
                        <div style="margin-left: 80px;">
                            <h1 class="h4 fw-bold mb-0 nova-text-main">NOVA/{{ space.name }}</h1>
                            <small class="nova-text-muted">Study Space</small>
                        </div>
                    </div>
                </div>

                <div class="create-post-bar shadow-sm">
                    <div class="avatar avatar-sm">
                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center" style="width: 38px; height: 38px;">
                            <i class="bi bi-person-fill"></i>
                        </div>
                    </div>
                    <div class="create-post-input" data-bs-toggle="collapse" data-bs-target="#addPostForm" style="user-select: none;">
                        Create Post
                    </div>
                    <button class="btn btn-sm btn-outline-secondary border-0 p-2" id="quick-image-btn" data-bs-toggle="collapse" data-bs-target="#addPostForm"><i class="bi bi-image fs-5"></i></button>
                    <button class="btn btn-sm btn-outline-secondary border-0 p-2" id="quick-link-btn" data-bs-toggle="collapse" data-bs-target="#addPostForm"><i class="bi bi-link-45deg fs-4"></i></button>
                    <button class="btn btn-sm btn-outline-secondary border-0 p-2" id="quick-file-btn" data-bs-toggle="collapse" data-bs-target="#addPostForm"><i class="bi bi-paperclip fs-5"></i></button>
                </div>

                <div class="collapse mb-4 {{ form.vars.submitted ? 'show' : '' }}" id="addPostForm">
                    <div class="nova-form-wrapper shadow-sm">
                        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }} 
                            <div class="d-none">{{ form_widget(form.space) }}</div>
                            
                            <div class="border-bottom" style="border-color: var(--nova-border) !important;">
                                {{ form_widget(form.title, {'attr': {'class': 'form-control nova-form-control fw-bold fs-5 py-3 px-3', 'placeholder': 'Title'}}) }}
                                <div class="px-3 pb-2 text-danger small">{{ form_errors(form.title) }}</div>
                            </div>
                            
                            <div class="d-flex justify-content-end px-3 py-2" style="background: var(--nova-input-bg); border-bottom: 1px solid var(--nova-border);">
                                <button type="button" class="btn btn-sm btn-outline-primary rounded-pill py-1 px-3 fw-bold" id="ai-enhance-btn" data-url="{{ path('app_forum_ai_enhance') }}" style="font-size: 12px;">
                                    <i class="bi bi-magic me-1"></i> Enhance with AI
                                </button>
                            </div>

                            <div>
                                {{ form_widget(form.content, {'attr': {'class': 'form-control nova-form-control post-content-textarea py-3 px-3', 'rows': '6', 'placeholder': 'Type your messy thoughts here, and let AI clean it up...', 'style': 'resize: none;'}}) }}
                                <div class="px-3 pb-2 text-danger small">{{ form_errors(form.content) }}</div>
                            </div>

                            <div class="nova-form-footer">
                                <div class="row gx-2 mb-3">
                                    <div class="col-md-4 mb-3 mb-md-0">
                                        <label class="form-label fw-bold nova-text-muted mb-1" style="font-size: 11px; text-transform: uppercase;"><i class="bi bi-link-45deg"></i> Link</label>
                                        {{ form_widget(form.link, {'attr': {'class': 'form-control form-control-sm target-link-input', 'style': 'background: var(--nova-card-bg); border: 1px solid var(--nova-border); color: var(--nova-text-main);'}}) }}
                                    </div>
                                    <div class="col-md-4 mb-3 mb-md-0">
                                        <label class="form-label fw-bold nova-text-muted mb-1" style="font-size: 11px; text-transform: uppercase;"><i class="bi bi-image"></i> Image</label>
                                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control form-control-sm target-image-input', 'style': 'background: var(--nova-card-bg); border: 1px solid var(--nova-border); color: var(--nova-text-main);'}}) }}
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label fw-bold nova-text-muted mb-1" style="font-size: 11px; text-transform: uppercase;"><i class="bi bi-paperclip"></i> File</label>
                                        {{ form_widget(form.attachmentFile, {'attr': {'class': 'form-control form-control-sm target-file-input', 'style': 'background: var(--nova-card-bg); border: 1px solid var(--nova-border); color: var(--nova-text-main);'}}) }}
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end align-items-center mt-2 pt-3 border-top" style="border-color: var(--nova-border) !important;">
                                    <button type="button" class="btn btn-light rounded-pill px-4 fw-bold me-2" data-bs-toggle="collapse" data-bs-target="#addPostForm" style="border: 1px solid var(--nova-border); background: var(--nova-card-bg); color: var(--nova-text-main);">Cancel</button>
                                    <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Post</button>
                                </div>
                            </div>
                        {{ form_end(form) }}
                    </div>
                </div>

                <div class="sort-bar shadow-sm">
                    <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'hot'}) }}" class="sort-btn {{ currentSort == 'hot' ? 'active' : '' }}"><i class="bi bi-fire fs-5"></i> Hot</a>
                    <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'new'}) }}" class="sort-btn {{ currentSort == 'new' ? 'active' : '' }}"><i class="bi bi-stars fs-5"></i> New</a>
                    <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'top'}) }}" class="sort-btn {{ currentSort == 'top' ? 'active' : '' }}"><i class="bi bi-bar-chart-line-fill fs-5"></i> Top</a>
                </div>

                <div class="d-flex flex-column gap-3 mb-4">
                    {% for post in posts %}
                        <div class="reddit-card d-flex shadow-sm" onclick="window.location.href='{{ path('app_forum_show', {'id': post.id}) }}'">
                            
                            <div class="vote-sidebar vote-container">
                                {% set is_upvoted = app.user and post.isUpvotedBy(app.user) %}
                                {% set is_downvoted = app.user and post.isDownvotedBy(app.user) %}
                                <a href="#" class="vote-arrow up {{ is_upvoted ? 'active' : '' }}" data-url="{{ path('app_forum_post_vote', {'id': post.id, 'type': 'up'}) }}" onclick="event.stopPropagation();">
                                    <i class="bi bi-arrow-up-short"></i>
                                </a>
                                <span class="vote-score">{{ post.upvotes }}</span>
                                <a href="#" class="vote-arrow down {{ is_downvoted ? 'active' : '' }}" data-url="{{ path('app_forum_post_vote', {'id': post.id, 'type': 'down'}) }}" onclick="event.stopPropagation();">
                                    <i class="bi bi-arrow-down-short"></i>
                                </a>
                            </div>

                            <div class="p-3 w-100">
                                <div class="post-meta d-flex align-items-center">
                                    <span>Posted by <a href="#" class="post-author" onclick="event.stopPropagation();">u/{{ post.author.username }}</a></span>
                                    <span class="mx-1">•</span>
                                    <span>{{ post.createdAt|date('M d, Y') }}</span>
                                    {% if post.isLocked %}<i class="bi bi-lock-fill text-danger ms-2" title="{{ t.t('Locked') }}"></i>{% endif %}
                                </div>
                                <h3 class="mb-2"><a href="{{ path('app_forum_show', {'id': post.id}) }}" class="post-title">{{ post.title }}</a></h3>
                                <div class="nova-text-main mb-3" style="font-size: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 22px;">
                                    {{ post.content }}
                                </div>

                                {% if post.imageName %}
                                    <div class="mb-3 rounded overflow-hidden border" style="border-color: var(--nova-border) !important; max-height: 400px; text-align: center; background-color: var(--nova-input-bg);">
                                        <img src="{{ vich_uploader_asset(post, 'imageFile') }}" style="max-height: 400px; width: auto; max-width: 100%; object-fit: contain;">
                                    </div>
                                {% endif %}

                                {% if post.attachmentName %}
                                    <div class="mb-3 p-3 rounded border d-flex align-items-center" style="background: var(--nova-input-bg); border-color: var(--nova-border) !important;" onclick="event.stopPropagation();">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-file-earmark-text fs-4"></i>
                                        </div>
                                        <div class="flex-grow-1 overflow-hidden pe-3">
                                            <h6 class="mb-0 nova-text-main text-truncate" style="font-size: 14px;">{{ post.attachmentName }}</h6>
                                            <small class="nova-text-muted">Attached File</small>
                                        </div>
                                        <a href="{{ vich_uploader_asset(post, 'attachmentFile') }}" class="btn btn-sm btn-outline-primary rounded-pill px-3 text-nowrap" download>
                                            <i class="bi bi-download me-1"></i> Download
                                        </a>
                                    </div>
                                {% endif %}

                                {% if post.link %}
                                    {% if post.linkTitle %}
                                        <a href="{{ post.link }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none mb-3 d-block" onclick="event.stopPropagation();">
                                            <div class="card border overflow-hidden shadow-sm" style="max-width: 500px; transition: transform 0.2s; background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                                <div class="row g-0">
                                                    {% if post.linkImage %}
                                                        <div class="col-4 bg-dark text-center border-end" style="border-color: var(--nova-border) !important;">
                                                            <img src="{{ post.linkImage }}" class="img-fluid w-100 h-100" style="object-fit: cover; min-height: 110px;">
                                                        </div>
                                                    {% endif %}
                                                    <div class="{{ post.linkImage ? 'col-8' : 'col-12' }}">
                                                        <div class="card-body p-3">
                                                            <h6 class="card-title fw-bold mb-1 nova-text-main" style="font-size: 13px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ post.linkTitle }}</h6>
                                                            {% if post.linkDescription %}
                                                                <p class="card-text mb-2 nova-text-muted" style="font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 16px;">{{ post.linkDescription }}</p>
                                                            {% endif %}
                                                            <div class="text-primary text-truncate" style="font-size: 11px;"><i class="bi bi-link-45deg"></i> {{ post.link }}</div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    {% else %}
                                        <div class="mb-3 p-2 rounded border d-inline-block" style="background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                            <a href="{{ post.link }}" target="_blank" rel="noopener noreferrer" class="fw-bold nova-text-main" onclick="event.stopPropagation();" style="font-size: 13px;">
                                                <i class="bi bi-link-45deg me-1 text-primary"></i>{{ post.link|length > 50 ? post.link|slice(0, 50) ~ '...' : post.link }}
                                            </a>
                                        </div>
                                    {% endif %}
                                {% endif %}

                                <div class="d-flex align-items-center mt-2">
                                    <a href="{{ path('app_forum_show', {'id': post.id}) }}#comments" class="action-pill" onclick="event.stopPropagation();"><i class="bi bi-chat-square"></i> {{ post.comments|length }} Comments</a>
                                    <button class="action-pill share-btn ms-1" data-url="{{ url('app_forum_show', {'id': post.id}) }}" onclick="event.stopPropagation();"><i class="bi bi-share"></i> <span class="share-text">Share</span></button>
                                    {% if app.user and app.user.hasBookmarkedPost(post) %}
                                        <button class="action-pill ms-1 saved bookmark-btn" data-url="{{ path('app_forum_post_bookmark', {'id': post.id}) }}" onclick="event.stopPropagation();"><i class="bi bi-bookmark-fill"></i> Saved</button>
                                    {% else %}
                                        <button class="action-pill ms-1 bookmark-btn" data-url="{{ path('app_forum_post_bookmark', {'id': post.id}) }}" onclick="event.stopPropagation();"><i class="bi bi-bookmark"></i> Save</button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <div class="card border-0 bg-transparent text-center py-5 mt-4">
                            <div class="card-body">
                                <i class="bi bi-moon-stars display-1 text-secondary opacity-25"></i>
                                <h5 class="mt-4 fw-bold nova-text-main">Such empty...</h5>
                                <p class="nova-text-muted">Be the first to start a discussion in NOVA/{{ space.name }}!</p>
                            </div>
                        </div>
                    {% endfor %}
                </div>
                <div class="d-flex justify-content-center mb-5">
                    {{ knp_pagination_render(posts, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
                </div>
            </div>

            {# --- 3. RIGHT COLUMN --- #}
            <div class="col-lg-3 d-none d-lg-block">
                <div class="sticky-sidebar">
                    
                    <div class="widget-card shadow-sm">
                        <div class="position-relative">
                            <div style="background: linear-gradient(135deg, {{ spaceColor }} 0%, #343a40 100%); height: 44px;"></div>
                            <div class="position-absolute rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 44px; height: 44px; top: 22px; left: 16px; border: 2px solid var(--nova-card-bg); background: var(--nova-card-bg);">
                                <div class="text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; font-size: 18px; font-weight: bold; background-color: {{ spaceColor }};">
                                    <i class="bi bi-rocket-takeoff-fill"></i>
                                </div>
                            </div>
                        </div>
                        <div class="card-body nova-text-main" style="padding: 32px 16px 16px 16px; font-size: 14px;">
                            <h2 class="h6 fw-bold mb-2">NOVA/{{ space.name }}</h2>
                            <p class="mb-3 nova-text-muted" style="font-size: 13px;">{{ space.description|default('Welcome to the ' ~ space.name ~ ' space! A place for peer-to-peer tutoring and discussion.') }}</p>
                            <hr style="border-color: var(--nova-border); opacity: 1; margin: 16px 0;">
                            <div class="d-flex gap-4 mb-3">
                                <div><div class="fs-5 fw-bold nova-text-main lh-1">{{ posts.getTotalItemCount }}</div><div class="nova-text-muted mt-1" style="font-size: 12px;">Members</div></div>
                                <div><div class="fs-5 fw-bold nova-text-main lh-1 d-flex align-items-center"><span class="bg-success rounded-circle me-2" style="width: 8px; height: 8px; display: inline-block;"></span>12</div><div class="nova-text-muted mt-1" style="font-size: 12px;">Online</div></div>
                            </div>
                            <hr style="border-color: var(--nova-border); opacity: 1; margin: 16px 0;">
                            <button class="btn w-100 rounded-pill fw-bold text-white mb-2" style="background-color: {{ spaceColor }}; border-color: {{ spaceColor }}; font-size: 14px;" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm">Create Post</button>
                        </div>
                    </div>

                    <div class="widget-card shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pt-3 pb-2 px-3">
                            <h3 class="mb-0 h6 fw-bold nova-text-main">NOVA/{{ space.name }} Rules</h3>
                        </div>
                        <div class="list-group list-group-flush rounded-bottom nova-text-main pb-2" style="font-size: 13px;">
                            <div class="list-group-item py-2 px-3 border-bottom-0 bg-transparent nova-text-main widget-rule-item d-flex align-items-center"><span class="fw-bold me-2">1.</span> <span>Be respectful to tutors and students.</span></div>
                            <hr class="my-0 mx-3" style="border-color: var(--nova-border); opacity: 0.5;">
                            <div class="list-group-item py-2 px-3 border-bottom-0 bg-transparent nova-text-main widget-rule-item d-flex align-items-center"><span class="fw-bold me-2">2.</span> <span>Do not post direct answers; help guide the peer.</span></div>
                            <hr class="my-0 mx-3" style="border-color: var(--nova-border); opacity: 0.5;">
                            <div class="list-group-item py-2 px-3 border-bottom-0 bg-transparent nova-text-main widget-rule-item d-flex align-items-center"><span class="fw-bold me-2">3.</span> <span>Stay on the topic of {{ space.name }}.</span></div>
                        </div>
                    </div>

                </div>
            </div>
            
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        document.getElementById('quick-image-btn')?.addEventListener('click', () => setTimeout(() => document.querySelector('.target-image-input').focus(), 300));
        document.getElementById('quick-link-btn')?.addEventListener('click', () => setTimeout(() => document.querySelector('.target-link-input').focus(), 300));
        document.getElementById('quick-file-btn')?.addEventListener('click', () => setTimeout(() => document.querySelector('.target-file-input').focus(), 300));

        const enhanceBtn = document.getElementById('ai-enhance-btn');
        const textArea = document.querySelector('.post-content-textarea');
        if (enhanceBtn && textArea) {
            enhanceBtn.addEventListener('click', function () {
                const rawText = textArea.value;
                if (rawText.trim() === '') { alert('Please type something first!'); return; }
                const originalBtnHtml = enhanceBtn.innerHTML;
                enhanceBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Enhancing...';
                enhanceBtn.disabled = true; textArea.disabled = true;
                fetch(enhanceBtn.dataset.url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
                    body: JSON.stringify({ text: rawText })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.enhancedText) {
                        textArea.value = data.enhancedText;
                        enhanceBtn.innerHTML = '<i class="bi bi-check-lg"></i> Perfected!';
                        enhanceBtn.classList.replace('btn-outline-primary', 'btn-success'); enhanceBtn.classList.add('text-white');
                        setTimeout(() => { enhanceBtn.innerHTML = originalBtnHtml; enhanceBtn.classList.replace('btn-success', 'btn-outline-primary'); enhanceBtn.classList.remove('text-white'); enhanceBtn.disabled = false; }, 3000);
                    }
                }).catch(error => { alert('Failed to connect.'); enhanceBtn.innerHTML = originalBtnHtml; enhanceBtn.disabled = false; })
                .finally(() => { textArea.disabled = false; });
            });
        }

        document.querySelectorAll('.share-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault(); e.stopPropagation();
                const urlToShare = this.getAttribute('data-url');
                const textSpan = this.querySelector('.share-text');
                const icon = this.querySelector('i');
                navigator.clipboard.writeText(urlToShare).then(() => {
                    const originalText = textSpan.innerText; const originalIcon = icon.className;
                    textSpan.innerText = 'Copied!'; icon.className = 'bi bi-check2 text-success fw-bold';
                    setTimeout(() => { textSpan.innerText = originalText; icon.className = originalIcon; }, 2000);
                });
            });
        });

        // ROBUST VOTE LOGIC
        document.querySelectorAll('.vote-arrow').forEach(arrow => {
            arrow.addEventListener('click', function(e) {
                e.preventDefault(); e.stopPropagation();
                const url = this.dataset.url;
                if(!url) return;
                
                const container = this.closest('.vote-container');
                const scoreDisplay = container.querySelector('.vote-score');
                
                fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(async r => {
                    if (r.status === 403) { alert('You must be logged in to vote.'); throw new Error('Auth'); }
                    if (!r.ok) { alert('Database error. Did you run the migration for downvoters?'); throw new Error('Server'); }
                    return r.json();
                }).then(data => {
                    if(data.error) return alert(data.error);
                    if(scoreDisplay) scoreDisplay.textContent = data.score ?? data.upvotes;
                    
                    const upBtn = container.querySelector('.vote-arrow.up');
                    const downBtn = container.querySelector('.vote-arrow.down');
                    if(upBtn) { upBtn.classList.remove('active'); if(data.upvoted) upBtn.classList.add('active'); }
                    if(downBtn) { downBtn.classList.remove('active'); if(data.downvoted) downBtn.classList.add('active'); }
                }).catch(err => {});
            });
        });

        // ROBUST BOOKMARK LOGIC
        document.querySelectorAll('.bookmark-btn').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.preventDefault(); e.stopPropagation();
                const url = this.dataset.url;
                if(!url) return;

                fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(async r => {
                    if (r.status === 403) { alert('You must be logged in.'); throw new Error('Auth'); }
                    return r.json();
                }).then(data => {
                    if(data) {
                        if(data.isBookmarked) {
                            this.innerHTML = '<i class="bi bi-bookmark-fill"></i> Saved';
                            this.classList.add('saved');
                        } else {
                            this.innerHTML = '<i class="bi bi-bookmark"></i> Save';
                            this.classList.remove('saved');
                        }
                    }
                }).catch(err => {});
            });
        });
    });
</script>
{% endblock %}