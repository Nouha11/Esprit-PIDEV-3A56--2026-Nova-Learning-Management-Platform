{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ space.name }} - Forum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* --- PREMIUM REDDIT-STYLE CSS --- */
        
        /* Post Cards */
        .reddit-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            transition: all 0.2s ease;
            cursor: pointer;
        }
        .reddit-card:hover {
            border-color: #adb5bd;
            box-shadow: 0 .125rem .25rem rgba(0,0,0,.075);
        }

        /* Voting Sidebar inside the Card */
        .vote-sidebar {
            background-color: #f8f9fa;
            width: 45px;
            border-top-left-radius: 8px;
            border-bottom-left-radius: 8px;
            border-right: 1px solid #f1f3f5;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 10px;
        }
        .vote-arrow {
            color: #adb5bd;
            font-size: 1.3rem;
            cursor: pointer;
            border-radius: 4px;
            padding: 0px;
            line-height: 1;
            transition: all 0.2s;
        }
        .vote-arrow.up:hover { color: #ff4500; background-color: rgba(255, 69, 0, 0.1); }
        .vote-arrow.down:hover { color: #7193ff; background-color: rgba(113, 147, 255, 0.1); }
        
        .vote-score {
            font-size: 13px;
            font-weight: 700;
            color: #212529;
            margin: 6px 0;
        }

        /* Post Metadata */
        .post-meta {
            font-size: 12px;
            color: #6c757d;
            margin-bottom: 8px;
        }
        .post-author { color: #6c757d; text-decoration: none; font-weight: 600; }
        .post-author:hover { text-decoration: underline; color: #495057; }
        
        .post-title {
            font-size: 1.15rem;
            font-weight: 600;
            color: #212529;
            text-decoration: none;
            line-height: 1.4;
        }
        .post-title:hover { text-decoration: underline; }

        /* Action Buttons (Comments, Share) */
        .action-pill {
            display: inline-flex;
            align-items: center;
            padding: 6px 10px;
            border-radius: 6px;
            color: #6c757d;
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: background-color 0.2s;
        }
        .action-pill i { font-size: 15px; margin-right: 6px; }
        .action-pill:hover { background-color: #f1f3f5; color: #343a40; }
        .action-pill.saved { color: #ffc107; }

        /* Sorting Bar */
        .sort-bar {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 10px 16px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .sort-btn {
            background: transparent;
            border: none;
            color: #6c757d;
            font-weight: 600;
            font-size: 14px;
            padding: 8px 14px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: all 0.2s;
            text-decoration: none;
        }
        .sort-btn:hover { background: #f8f9fa; color: #343a40; }
        .sort-btn.active { background: #f1f3f5; color: #0d6efd; }
        
        /* Widget Styling */
        .widget-card {
            background: #ffffff;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            margin-bottom: 16px;
            overflow: hidden;
        }
        .widget-header {
            background: #0d6efd;
            color: white;
            font-size: 14px;
            font-weight: 700;
            padding: 12px 16px;
        }
    </style>
{% endblock %}

{% block body %}
<main>
    {# --- THEME-COMPATIBLE OVERLAPPING HEADER --- #}
    <section class="pt-0">
        <div class="container-fluid px-0">
            {# The Background Strip #}
            <div class="h-100px h-md-200px rounded-0" style="background: linear-gradient(135deg, #0d6efd 0%, #6610f2 100%);">
            </div>
        </div>
        
        <div class="container mt-n4 mt-md-n5">
            <div class="row">
                <div class="col-12">
                    {# The Overlapping White Box #}
                    <div class="bg-body p-4 rounded-3 shadow-sm d-md-flex justify-content-between align-items-center mb-4 border">
                        <div class="d-flex align-items-center">
                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-4" style="width: 70px; height: 70px; font-size: 30px;">
                                <i class="bi bi-rocket-takeoff-fill"></i>
                            </div>
                            <div>
                                <h1 class="h2 fw-bold mb-1" style="letter-spacing: -0.5px;">NOVA/{{ space.name }}</h1>
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb breadcrumb-dots mb-0">
                                        <li class="breadcrumb-item"><a href="{{ path('app_forum') }}"><i class="bi bi-house me-1"></i>Forum</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">{{ space.name }}</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row">
                {# --- LEFT COLUMN: THE FEED --- #}
                <div class="col-lg-8">
                    
                    {# The Sorting Bar (FIXED KnpPaginator Error using 'sortBy') #}
                    <div class="sort-bar shadow-sm">
                        <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'hot'}) }}" class="sort-btn {{ currentSort == 'hot' ? 'active' : '' }}">
                            <i class="bi bi-fire fs-5"></i> Hot
                        </a>
                        <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'new'}) }}" class="sort-btn {{ currentSort == 'new' ? 'active' : '' }}">
                            <i class="bi bi-stars fs-5"></i> New
                        </a>
                        <a href="{{ path('app_forum_space', {'id': space.id, 'sortBy': 'top'}) }}" class="sort-btn {{ currentSort == 'top' ? 'active' : '' }}">
                            <i class="bi bi-bar-chart-line-fill fs-5"></i> Top
                        </a>
                        
                        <div class="ms-auto">
                            <button class="btn btn-primary btn-sm rounded-pill fw-bold px-4" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm">
                                <i class="bi bi-plus-lg me-1"></i> Create Post
                            </button>
                        </div>
                    </div>

                    {# Add Post Form (Hidden by default) #}
                    <div class="collapse mb-4 {{ form.vars.submitted ? 'show' : '' }}" id="addPostForm">
                        <div class="card border rounded-3 shadow-sm">
                            <div class="card-body">
                                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }} 
                                    <div class="d-none">{{ form_widget(form.space) }}</div>

                                    <div class="mb-3">
                                        {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg fw-bold', 'placeholder': 'Title', 'style': 'border: none; border-bottom: 1px solid #dee2e6; border-radius: 0;'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                                    </div>
                                    <div class="mb-3">
                                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': '5', 'placeholder': 'Text (optional)', 'style': 'background: #f8f9fa; border: 1px solid #dee2e6;'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                    </div>
                                    
                                    <div class="row bg-light p-3 rounded mx-0 mb-3 border">
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <label class="form-label fw-bold text-muted small"><i class="bi bi-link-45deg"></i> Attach Link</label>
                                            {{ form_widget(form.link, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-muted small"><i class="bi bi-image"></i> Upload Image</label>
                                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold">Post</button>
                                    </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>

                    {# THE POST FEED FOR THIS SPACE #}
                    <div class="d-flex flex-column gap-3 mb-4">
                        {% for post in posts %}
                            <div class="reddit-card d-flex shadow-sm" onclick="window.location.href='{{ path('app_forum_show', {'id': post.id}) }}'">
                                
                                {# Voting Sidebar #}
                                <div class="vote-sidebar">
                                    <i class="bi bi-arrow-up-short vote-arrow up"></i>
                                    <span class="vote-score">{{ post.upvotes }}</span>
                                    <i class="bi bi-arrow-down-short vote-arrow down"></i>
                                </div>

                                {# Main Content #}
                                <div class="p-3 w-100">
                                    
                                    {# Meta #}
                                    <div class="post-meta d-flex align-items-center">
                                        <span>Posted by <a href="#" class="post-author" onclick="event.stopPropagation();">u/{{ post.author.username }}</a></span>
                                        <span class="mx-1">•</span>
                                        <span>{{ post.createdAt|date('M d, Y') }}</span>
                                        {% if post.isLocked %}
                                            <i class="bi bi-lock-fill text-danger ms-2" title="{{ t.t('Locked') }}"></i>
                                        {% endif %}
                                    </div>

                                    {# Title #}
                                    <h3 class="mb-2">
                                        <a href="{{ path('app_forum_show', {'id': post.id}) }}" class="post-title">
                                            {{ post.title }}
                                        </a>
                                    </h3>

                                    {# Snippet #}
                                    <div class="text-body mb-3" style="font-size: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 22px;">
                                        {{ post.content }}
                                    </div>

                                    {# Image #}
                                    {% if post.imageName %}
                                        <div class="mb-3 rounded overflow-hidden border" style="max-height: 400px; text-align: center; background-color: #f8f9fa;">
                                            <img src="{{ vich_uploader_asset(post, 'imageFile') }}" style="max-height: 400px; width: auto; max-width: 100%; object-fit: contain;" alt="Post image">
                                        </div>
                                    {% endif %}

                                    {# Action Footer #}
                                    <div class="d-flex align-items-center mt-2">
                                        <a href="{{ path('app_forum_show', {'id': post.id}) }}#comments" class="action-pill" onclick="event.stopPropagation();">
                                            <i class="bi bi-chat-left"></i> {{ post.comments|length }} Comments
                                        </a>
                                        
                                        <a href="#" class="action-pill ms-1" onclick="event.stopPropagation();">
                                            <i class="bi bi-share"></i> Share
                                        </a>
                                        
                                        {% if app.user and app.user.hasBookmarkedPost(post) %}
                                            <span class="action-pill ms-1 saved" onclick="event.stopPropagation();">
                                                <i class="bi bi-bookmark-fill"></i> Saved
                                            </span>
                                        {% else %}
                                            <span class="action-pill ms-1" onclick="event.stopPropagation();">
                                                <i class="bi bi-bookmark"></i> Save
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="card border-0 bg-transparent text-center py-5 mt-4">
                                <div class="card-body">
                                    <i class="bi bi-moon-stars display-1 text-secondary opacity-25"></i>
                                    <h5 class="mt-4 fw-bold text-body">Such empty...</h5>
                                    <p class="text-secondary">Be the first to start a discussion in NOVA/{{ space.name }}!</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    
                    <div class="d-flex justify-content-center mb-5">
                        {{ knp_pagination_render(posts, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
                    </div>
                </div>

                {# --- RIGHT COLUMN: REDDIT-STYLE WIDGETS --- #}
                <div class="col-lg-4 mt-4 mt-lg-0">
                    
                    {# Widget 1: About Community #}
                    <div class="widget-card shadow-sm">
                        <div class="widget-header">
                            <i class="bi bi-info-circle me-2"></i>About Community
                        </div>
                        <div class="card-body text-body" style="font-size: 14px;">
                            <p class="mb-4">{{ space.description|default('Welcome to the ' ~ space.name ~ ' space! A place for peer-to-peer tutoring and discussion.') }}</p>
                            
                            <div class="d-flex justify-content-between mb-4 pb-3 border-bottom">
                                <div class="text-center">
                                    <div class="fs-5 fw-bold text-dark">{{ posts.getTotalItemCount }}</div>
                                    <div class="text-muted" style="font-size: 12px;">Posts</div>
                                </div>
                                <div class="text-center">
                                    <div class="fs-5 fw-bold text-success"><span class="spinner-grow spinner-grow-sm text-success" style="width: 8px; height: 8px;" role="status"></span> 12</div>
                                    <div class="text-muted" style="font-size: 12px;">Online</div>
                                </div>
                                <div class="text-center">
                                    <div class="fs-5 fw-bold text-dark"><i class="bi bi-globe"></i></div>
                                    <div class="text-muted" style="font-size: 12px;">Public</div>
                                </div>
                            </div>

                            <button class="btn btn-primary w-100 rounded-pill fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm">
                                Create Post
                            </button>
                        </div>
                    </div>

                    {# Widget 2: Rules #}
                    <div class="widget-card shadow-sm">
                        <div class="widget-header" style="background: #212529;">
                            <i class="bi bi-shield-check me-2"></i>NOVA/{{ space.name }} Rules
                        </div>
                        <div class="list-group list-group-flush rounded-bottom text-body" style="font-size: 14px;">
                            <div class="list-group-item py-3"><strong>1.</strong> Be respectful to tutors and students.</div>
                            <div class="list-group-item py-3"><strong>2.</strong> Do not post direct answers; help guide the peer to the solution.</div>
                            <div class="list-group-item py-3"><strong>3.</strong> Stay on the topic of {{ space.name }}.</div>
                        </div>
                    </div>

                    {# Widget 3: Explore #}
                    <div class="widget-card shadow-sm">
                        <div class="widget-header bg-light text-dark border-bottom">
                            <i class="bi bi-compass me-2"></i>Explore More Spaces
                        </div>
                        <div class="list-group list-group-flush rounded-bottom">
                            {% for s in spaces %}
                                {% if s.id != space.id %}
                                    <a href="{{ path('app_forum_space', {'id': s.id}) }}" class="list-group-item list-group-item-action d-flex align-items-center py-2 text-body" style="font-size: 14px; font-weight: 500;">
                                        <div class="rounded-circle bg-primary me-2 shadow-sm" style="width: 24px; height: 24px; color: white; display:flex; align-items:center; justify-content:center; font-size: 10px;">
                                            <i class="bi bi-rocket"></i>
                                        </div>
                                        NOVA/{{ s.name }}
                                    </a>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}