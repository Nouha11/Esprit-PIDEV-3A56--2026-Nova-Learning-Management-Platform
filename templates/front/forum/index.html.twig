{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Community Forum') }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* --- PREMIUM REDDIT-STYLE CSS --- */
        body { background-color: #dae0e6; }
        
        .post-card {
            background: #ffffff;
            border: 1px solid #ccc;
            border-radius: 6px;
            transition: border 0.1s;
            cursor: pointer;
        }
        .post-card:hover { border: 1px solid #898989; }

        .vote-sidebar {
            background-color: #f8f9fa;
            width: 40px;
            border-top-left-radius: 6px;
            border-bottom-left-radius: 6px;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding-top: 8px;
        }
        .vote-arrow {
            color: #878a8c;
            font-size: 1.2rem;
            cursor: pointer;
            border-radius: 2px;
            padding: 2px;
            line-height: 1;
        }
        .vote-arrow:hover { background-color: #ebebeb; }
        .vote-arrow.up:hover { color: #ff4500; }
        .vote-arrow.down:hover { color: #7193ff; }
        
        .vote-score { font-size: 12px; font-weight: 700; color: #1a1a1b; margin: 4px 0; }

        .post-meta { font-size: 12px; color: #787c7e; margin-bottom: 8px; }
        .post-author { color: #787c7e; text-decoration: none; }
        .post-author:hover { text-decoration: underline; }
        
        .post-title { font-size: 18px; font-weight: 500; color: #222222; text-decoration: none; line-height: 22px; }
        .post-title:hover { text-decoration: underline; }

        .action-pill {
            display: inline-flex;
            align-items: center;
            padding: 6px 8px;
            border-radius: 4px;
            color: #878a8c;
            font-size: 12px;
            font-weight: 700;
            text-decoration: none;
            transition: background-color 0.2s;
        }
        .action-pill i { font-size: 16px; margin-right: 6px; }
        .action-pill:hover { background-color: #e2e2e2; color: #1c1c1c; }
        .action-pill.saved { color: #eab308; }

        .sort-bar {
            background: #ffffff;
            border: 1px solid #ccc;
            border-radius: 6px;
            padding: 10px 16px;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .sort-btn {
            background: transparent;
            border: none;
            color: #878a8c;
            font-weight: 700;
            font-size: 14px;
            padding: 6px 12px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.2s;
            text-decoration: none;
        }
        .sort-btn:hover { background: #f6f7f8; color: #1c1c1c; }
        .sort-btn.active { background: #f6f7f8; color: #0079d3; }
    </style>
{% endblock %}

{% block body %}
<main>
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="bg-blue h-100px h-md-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;"></div>
        </div>
        <div class="container mt-n4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body p-0">
                        <div class="row d-flex justify-content-between">
                            <div class="col-12">
                                <div class="bg-body p-4 rounded-3 shadow-sm d-md-flex justify-content-between align-items-center">
                                    <div class="me-3">
                                        <h1 class="h3 mb-0">{{ t.t('Community Forum') }}</h1>
                                        <p class="mb-0 text-body">{{ t.t('Join the conversation! Ask questions, share ideas, and help others.') }}</p>
                                    </div>

                                    <div class="d-flex align-items-center mt-3 mt-md-0 gap-3">
                                        <form method="get" action="{{ path('app_forum') }}" class="position-relative">
                                            <div class="d-flex align-items-center shadow-sm rounded-pill" style="background-color: #fff; border: 1px solid #ddd; padding: 5px 15px; min-width: 280px;">
                                                <i class="bi bi-search text-secondary me-2"></i>
                                                <input type="search" name="q" value="{{ searchQuery|default('') }}" placeholder="{{ t.t('Search discussions...') }}" class="border-0 bg-transparent shadow-none w-100 text-dark" style="outline: none;">
                                                {% if searchQuery is defined and searchQuery %}
                                                    <a href="{{ path('app_forum') }}" class="text-secondary ms-2" title="Clear Search" style="text-decoration: none;"><i class="bi bi-x-circle-fill"></i></a>
                                                {% endif %}
                                            </div>
                                        </form>

                                        <button class="btn btn-primary mb-0 rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm" aria-expanded="false">
                                            <i class="bi bi-plus-lg me-1"></i> {{ t.t('Start Discussion') }}
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0">
        <div class="container">
            <div class="row">
                
                {# --- SIDEBAR --- #}
                <div class="col-lg-3 col-md-4 mb-4">
                    <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                        <div class="offcanvas-header bg-light">
                            <h5 class="offcanvas-title">Forum Menu</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar"></button>
                        </div>
                        <div class="offcanvas-body p-3 p-xl-0">
                            <div class="bg-dark border rounded-3 pb-0 p-3 w-100">
                                <div class="list-group list-group-dark list-group-borderless">
                                    <a class="list-group-item {{ currentFilter is null and searchQuery is empty and currentSpace is null ? 'active' : '' }}" href="{{ path('app_forum') }}">
                                        <i class="bi bi-ui-checks-grid fa-fw me-2"></i>{{ t.t('All Discussions') }}
                                    </a>
                                    <a class="list-group-item {{ currentFilter == 'popular' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'popular'}) }}">
                                        <i class="bi bi-fire fa-fw me-2"></i>{{ t.t('Popular') }}
                                    </a>
                                    <a class="list-group-item {{ currentFilter == 'unanswered' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'unanswered'}) }}">
                                        <i class="bi bi-question-circle fa-fw me-2"></i>{{ t.t('Unanswered') }}
                                    </a>
                                    {% if app.user %}
                                        <a class="list-group-item {{ currentFilter == 'bookmarks' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'bookmarks'}) }}">
                                            <i class="bi bi-bookmark-star fa-fw me-2"></i>{{ t.t('My Bookmarks') }}
                                        </a>
                                    {% endif %}
                                </div>

                                <h6 class="mt-4 mb-2 text-uppercase text-muted" style="font-size: 12px; font-weight: bold; padding-left: 15px;">Study Spaces</h6>
                                <div class="list-group list-group-dark list-group-borderless mb-3">
                                    {% for space in spaces|default([]) %}
                                        <a class="list-group-item" href="{{ path('app_forum_space', {'id': space.id}) }}">
                                            {{ space.name }}
                                        </a>
                                    {% endfor %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                {# --- MAIN CONTENT LAYOUT --- #}
                <div class="col-lg-9 col-md-8">
                    
                    <div class="sort-bar shadow-sm">
                        <a href="{{ path('app_forum', {'sortBy': 'hot'}) }}" class="sort-btn {{ currentSort == 'hot' ? 'active' : '' }}"><i class="bi bi-fire fs-5"></i> Hot</a>
                        <a href="{{ path('app_forum', {'sortBy': 'new'}) }}" class="sort-btn {{ currentSort == 'new' ? 'active' : '' }}"><i class="bi bi-stars fs-5"></i> New</a>
                        <a href="{{ path('app_forum', {'sortBy': 'top'}) }}" class="sort-btn {{ currentSort == 'top' ? 'active' : '' }}"><i class="bi bi-bar-chart-line-fill fs-5"></i> Top</a>
                    </div>
                    
                    {# Add Post Form #}
                    <div class="collapse mb-4 {{ form.vars.submitted ? 'show' : '' }}" id="addPostForm">
                        <div class="card border rounded-3 shadow-sm">
                            <div class="card-body">
                                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }} 
                                    <div class="mb-3">
                                        <label class="form-label text-muted small fw-bold text-uppercase">{{ t.t('Study Space') }} <span class="text-danger">*</span></label>
                                        {{ form_widget(form.space) }}
                                        <div class="form-text text-danger">{{ form_errors(form.space) }}</div>
                                    </div>

                                    <div class="mb-3">
                                        {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg fw-bold', 'placeholder': 'Title', 'style': 'border: none; border-bottom: 1px solid #eee; border-radius: 0;'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                                    </div>
                                    
                                    {# --- ENHANCED DESCRIPTION FIELD --- #}
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between align-items-end mb-1">
                                            <label class="form-label mb-0 text-muted small fw-bold">Description</label>
                                            <button type="button" class="btn btn-sm btn-outline-primary py-1 px-2" id="ai-enhance-btn-global" data-url="{{ path('app_forum_ai_enhance') }}">
                                                <i class="bi bi-magic me-1"></i> Enhance with AI
                                            </button>
                                        </div>
                                        {{ form_widget(form.content, {'attr': {'class': 'form-control post-content-textarea', 'rows': '5', 'placeholder': 'Text (optional)', 'style': 'background: #f6f7f8; border: 1px solid #edeff1;'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                    </div>
                                    
                                    <div class="row bg-light p-3 rounded mx-0 mb-3 border">
                                        <div class="col-md-6 mb-3 mb-md-0">
                                            <label class="form-label fw-bold text-muted small"><i class="bi bi-link-45deg"></i> Attach Link</label>
                                            {{ form_widget(form.link, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-muted small"><i class="bi bi-image"></i> Upload Image</label>
                                            {{ form_widget(form.imageFile, {'attr': {'class': 'form-control form-control-sm'}}) }}
                                        </div>
                                    </div>

                                    <div class="text-end">
                                        <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold">Post</button>
                                    </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>

                    {% if currentFilter == 'popular' or currentFilter == 'unanswered' or currentFilter == 'bookmarks' or searchQuery %}
                    <div class="d-flex align-items-center mb-3">
                        <h4 class="mb-0 me-3">
                            {% if currentFilter == 'popular' %}<i class="bi bi-fire text-danger me-2"></i>Popular Posts
                            {% elseif currentFilter == 'unanswered' %}<i class="bi bi-question-circle text-warning me-2"></i>Unanswered Posts
                            {% elseif currentFilter == 'bookmarks' %}<i class="bi bi-bookmark-star text-info me-2"></i>My Bookmarks
                            {% endif %}
                        </h4>
                        {% if searchQuery %}<span class="text-muted">Results for "{{ searchQuery }}"</span>{% endif %}
                    </div>
                    {% endif %}

                    {# THE POST FEED FOR GLOBAL VIEW #}
                    <div class="d-flex flex-column gap-2 mb-4">
                        {% for post in posts %}
                            <div class="reddit-card d-flex shadow-sm" onclick="window.location.href='{{ path('app_forum_show', {'id': post.id}) }}'">
                                <div class="vote-sidebar">
                                    <i class="bi bi-arrow-up-short vote-arrow up"></i>
                                    <span class="vote-score">{{ post.upvotes }}</span>
                                    <i class="bi bi-arrow-down-short vote-arrow down"></i>
                                </div>
                                <div class="p-2 w-100">
                                    <div class="post-meta d-flex align-items-center">
                                        {% if post.space %}
                                            <a href="{{ path('app_forum_space', {'id': post.space.id}) }}" class="fw-bold text-dark text-decoration-none me-2 d-flex align-items-center" onclick="event.stopPropagation();">
                                                <div class="rounded-circle bg-primary me-1" style="width: 16px; height: 16px; display: inline-block;"></div>
                                                NOVA/{{ post.space.name }}
                                            </a>
                                            <span class="me-2">•</span>
                                        {% endif %}
                                        <span>Posted by <a href="#" class="post-author" onclick="event.stopPropagation();">u/{{ post.author.username }}</a></span>
                                        <span class="mx-1">•</span>
                                        <span>{{ post.createdAt|date('M d, Y') }}</span>
                                        {% if post.isLocked %}<i class="bi bi-lock-fill text-warning ms-2"></i>{% endif %}
                                    </div>
                                    <h3 class="mb-2"><a href="{{ path('app_forum_show', {'id': post.id}) }}" class="post-title">{{ post.title }}</a></h3>
                                    <div class="text-dark mb-2" style="font-size: 14px; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; line-height: 21px;">
                                        {{ post.content }}
                                    </div>
                                    
                                    {% if post.imageName %}
                                        <div class="mb-2 rounded overflow-hidden" style="max-height: 400px; text-align: center; background-color: #000;">
                                            <img src="{{ vich_uploader_asset(post, 'imageFile') }}" style="max-height: 400px; width: auto; max-width: 100%; object-fit: contain;">
                                        </div>
                                    {% endif %}

                                    {# --- DISCORD-STYLE LINK PREVIEW --- #}
                                    {% if post.link %}
                                        {% if post.linkTitle %}
                                            <a href="{{ post.link }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none mb-3 d-block" onclick="event.stopPropagation();">
                                                <div class="card border rounded-3 overflow-hidden shadow-sm bg-light" style="max-width: 500px; transition: transform 0.2s;">
                                                    <div class="row g-0">
                                                        {% if post.linkImage %}
                                                            <div class="col-4 bg-dark text-center border-end">
                                                                <img src="{{ post.linkImage }}" class="img-fluid w-100 h-100" style="object-fit: cover; min-height: 110px;" alt="Link Preview">
                                                            </div>
                                                        {% endif %}
                                                        <div class="{{ post.linkImage ? 'col-8' : 'col-12' }}">
                                                            <div class="card-body p-3">
                                                                <h6 class="card-title text-dark fw-bold mb-1" style="font-size: 13px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ post.linkTitle }}</h6>
                                                                {% if post.linkDescription %}
                                                                    <p class="card-text text-secondary mb-2" style="font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; line-height: 16px;">{{ post.linkDescription }}</p>
                                                                {% endif %}
                                                                <div class="text-primary text-truncate" style="font-size: 11px;"><i class="bi bi-link-45deg"></i> {{ post.link }}</div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </a>
                                        {% else %}
                                            <div class="mb-3 p-2 bg-primary bg-opacity-10 rounded border border-primary border-opacity-25 d-inline-block">
                                                <a href="{{ post.link }}" target="_blank" rel="noopener noreferrer" class="text-body fw-bold" onclick="event.stopPropagation();" style="font-size: 13px;">
                                                    <i class="bi bi-link-45deg me-1 text-primary"></i>{{ post.link|length > 50 ? post.link|slice(0, 50) ~ '...' : post.link }}
                                                </a>
                                            </div>
                                        {% endif %}
                                    {% endif %}

                                    <div class="d-flex align-items-center mt-2">
                                        <a href="{{ path('app_forum_show', {'id': post.id}) }}#comments" class="action-pill" onclick="event.stopPropagation();"><i class="bi bi-chat-left"></i> {{ post.comments|length }} Comments</a>
                                        <a href="#" class="action-pill ms-1" onclick="event.stopPropagation();"><i class="bi bi-share"></i> Share</a>
                                        {% if app.user and app.user.hasBookmarkedPost(post) %}
                                            <span class="action-pill ms-1 saved" onclick="event.stopPropagation();"><i class="bi bi-bookmark-fill"></i> Saved</span>
                                        {% else %}
                                            <span class="action-pill ms-1" onclick="event.stopPropagation();"><i class="bi bi-bookmark"></i> Save</span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% else %}
                            <div class="card border-0 bg-transparent text-center py-5 mt-4">
                                <div class="card-body">
                                    <i class="bi bi-moon-stars display-1 text-secondary opacity-25"></i>
                                    <h5 class="mt-4 fw-bold" style="color: #1c1c1c;">Such empty...</h5>
                                    <p class="text-secondary">Be the first to start a discussion!</p>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    
                    <div class="d-flex justify-content-center mb-5">
                        {{ knp_pagination_render(posts, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>

{# --- NEW: AI ENHANCER JAVASCRIPT --- #}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const enhanceBtn = document.getElementById('ai-enhance-btn-global');
        const textArea = document.querySelector('.post-content-textarea');

        if (enhanceBtn && textArea) {
            enhanceBtn.addEventListener('click', function () {
                const rawText = textArea.value;

                if (rawText.trim() === '') {
                    alert('Please type something first before enhancing!');
                    return;
                }

                const originalBtnHtml = enhanceBtn.innerHTML;
                enhanceBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Enhancing...';
                enhanceBtn.disabled = true;
                textArea.disabled = true;

                fetch(enhanceBtn.dataset.url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ text: rawText })
                })
                .then(response => response.json())
                .then(data => {
                    if (data.enhancedText) {
                        textArea.value = data.enhancedText;
                        
                        enhanceBtn.innerHTML = '<i class="bi bi-check-lg"></i> Perfected!';
                        enhanceBtn.classList.replace('btn-outline-primary', 'btn-success');
                        enhanceBtn.classList.add('text-white');
                        
                        setTimeout(() => {
                            enhanceBtn.innerHTML = originalBtnHtml;
                            enhanceBtn.classList.replace('btn-success', 'btn-outline-primary');
                            enhanceBtn.classList.remove('text-white');
                            enhanceBtn.disabled = false;
                        }, 3000);
                    } else {
                        alert(data.error || 'Something went wrong.');
                        enhanceBtn.innerHTML = originalBtnHtml;
                        enhanceBtn.disabled = false;
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Could not connect to the AI server.');
                    enhanceBtn.innerHTML = originalBtnHtml;
                    enhanceBtn.disabled = false;
                })
                .finally(() => {
                    textArea.disabled = false;
                });
            });
        }
    });
</script>
{% endblock %}