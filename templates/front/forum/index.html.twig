{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}{{ t.t('Community Forum') }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Custom Styles for the Reddit-like Feed */
        .post-card {
            transition: border-color 0.2s ease;
            cursor: pointer; /* Makes the whole card feel clickable */
        }
        .post-card:hover {
            border-color: #6c757d !important; /* Subtle highlight on hover */
        }
        .vote-column {
            background-color: rgba(0,0,0,0.02); /* Very subtle background for the voting area */
            border-right: 1px solid rgba(0,0,0,0.05);
            min-width: 50px;
        }
        .action-btn {
            color: #6c757d;
            padding: 4px 8px;
            border-radius: 4px;
            transition: background-color 0.2s;
            text-decoration: none;
            font-size: 0.85rem;
            font-weight: 600;
        }
        .action-btn:hover {
            background-color: rgba(0,0,0,0.05);
            color: #495057;
        }
        .post-title-link {
            color: inherit;
            text-decoration: none;
        }
        .post-title-link:hover {
            text-decoration: underline;
        }
    </style>
{% endblock %}

{% block body %}
<main>
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="bg-blue h-100px h-md-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
            </div>
        </div>
        <div class="container mt-n4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body p-0">
                        <div class="row d-flex justify-content-between">
                            <div class="col-12">
                                <div class="bg-body p-4 rounded-3 shadow-sm d-md-flex justify-content-between align-items-center">
                                    <div class="me-3">
                                        <h1 class="h3 mb-0">{{ t.t('Community Forum') }}</h1>
                                        <p class="mb-0 text-body">{{ t.t('Join the conversation! Ask questions, share ideas, and help others.') }}</p>
                                    </div>

                                    <div class="d-flex align-items-center mt-3 mt-md-0 gap-3">
                                        <form method="get" action="{{ path('app_forum') }}" class="position-relative">
                                            <div class="d-flex align-items-center shadow-sm rounded-pill" style="background-color: #fff; border: 1px solid #ddd; padding: 5px 15px; min-width: 280px;">
                                                <i class="bi bi-search text-secondary me-2"></i>
                                                <input type="search" 
                                                       name="q" 
                                                       value="{{ searchQuery|default('') }}" 
                                                       placeholder="{{ t.t('Search discussions...') }}" 
                                                       aria-label="{{ t.t('Search') }}"
                                                       class="border-0 bg-transparent shadow-none w-100 text-dark" 
                                                       style="outline: none;">
                                                
                                                {% if searchQuery is defined and searchQuery %}
                                                    <a href="{{ path('app_forum') }}" class="text-secondary ms-2" title="Clear Search" style="text-decoration: none;">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </a>
                                                {% endif %}
                                            </div>
                                        </form>

                                        <button class="btn btn-primary mb-0 rounded-pill px-4 shadow-sm" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm" aria-expanded="false">
                                            <i class="bi bi-plus-lg me-1"></i> {{ t.t('Start Discussion') }}
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0">
        <div class="container">
            <div class="row">
                
                {# --- SIDEBAR --- #}
                <div class="col-lg-3 col-md-4 mb-4">
                    <div class="offcanvas-xl offcanvas-end" tabindex="-1" id="offcanvasSidebar">
                        <div class="offcanvas-header bg-light">
                            <h5 class="offcanvas-title" id="offcanvasNavbarLabel">Forum Menu</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" data-bs-target="#offcanvasSidebar" aria-label="Close"></button>
                        </div>
                        <div class="offcanvas-body p-3 p-xl-0">
                            <div class="bg-dark border rounded-3 pb-0 p-3 w-100">
                                
                                {# --- GLOBAL FILTERS --- #}
                                <div class="list-group list-group-dark list-group-borderless">
                                    <a class="list-group-item {{ currentFilter is null and searchQuery is empty ? 'active' : '' }}" href="{{ path('app_forum') }}">
                                        <i class="bi bi-ui-checks-grid fa-fw me-2"></i>{{ t.t('All Discussions') }}
                                    </a>
                                    
                                    <a class="list-group-item {{ currentFilter == 'popular' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'popular'}) }}">
                                        <i class="bi bi-fire fa-fw me-2"></i>{{ t.t('Popular') }}
                                    </a>
                                    
                                    <a class="list-group-item {{ currentFilter == 'unanswered' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'unanswered'}) }}">
                                        <i class="bi bi-question-circle fa-fw me-2"></i>{{ t.t('Unanswered') }}
                                    </a>

                                    {% if app.user %}
                                        <a class="list-group-item {{ currentFilter == 'bookmarks' ? 'active' : '' }}" href="{{ path('app_forum', {'filter': 'bookmarks'}) }}">
                                            <i class="bi bi-bookmark-star fa-fw me-2"></i>{{ t.t('My Bookmarks') }}
                                        </a>
                                    {% endif %}
                                </div>

                                {# --- NEW: STUDY SPACES SIDEBAR MENU (FIXED LINKS) --- #}
                                <h6 class="mt-4 mb-2 text-uppercase text-muted" style="font-size: 12px; font-weight: bold; padding-left: 15px;">Study Spaces</h6>
                                <div class="list-group list-group-dark list-group-borderless mb-3">
                                    {% for space in spaces|default([]) %}
                                        {# Notice the 'app_forum_space' here! #}
                                        <a class="list-group-item" href="{{ path('app_forum_space', {'id': space.id}) }}">
                                            {{ space.name }}
                                        </a>
                                    {% endfor %}
                                </div>
                                {# ----------------------------- #}

                            </div>
                        </div>
                        <br>
                        <div class="card border bg-transparent rounded-3 mt-4">
                            <div class="card-header bg-transparent border-bottom">
                                <h3 class="mb-0 h5">{{ t.t('Forum Rules') }}</h3>
                            </div>
                            <div class="card-body">
                                <ul class="list-unstyled text-secondary mb-0 small">
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ t.t('Be respectful to others') }}</li>
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ t.t('No spamming') }}</li>
                                    <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>{{ t.t('Search before posting') }}</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                {# --- MAIN CONTENT LAYOUT (Reddit Style Feed) --- #}
                <div class="col-lg-9 col-md-8">
                    
                    {# Add Post Form (Unchanged) #}
                    <div class="collapse mb-4 {{ form.vars.submitted ? 'show' : '' }}" id="addPostForm">
                        <div class="card border bg-transparent rounded-3 shadow-sm">
                            <div class="card-header bg-light border-bottom">
                                <h5 class="card-title mb-0">{{ t.t('Create New Discussion') }}</h5>
                            </div>
                            <div class="card-body">
                                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }} 
                                    <div class="mb-3">
                                        <label class="form-label">{{ t.t('Study Space') }} <span class="text-danger">*</span></label>
                                        {{ form_widget(form.space) }}
                                        <div class="form-text text-danger">{{ form_errors(form.space) }}</div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">{{ t.t('Subject') }} <span class="text-danger">*</span></label>
                                        {{ form_widget(form.title, {'attr': {'class': 'form-control', 'placeholder': t.t('What is this regarding?')}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.title) }}</div>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">{{ t.t('Description') }} <span class="text-danger">*</span></label>
                                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': t.t('Describe your question in detail...')}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                    </div>
                                    
                                    <div class="mb-3">
                                        <label class="form-label">{{ t.t('Attach a Link (Optional)') }}</label>
                                        {{ form_widget(form.link, {'attr': {'class': 'form-control'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.link) }}</div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label">{{ t.t('Upload an Image (Optional)') }}</label>
                                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.imageFile) }}</div>
                                    </div>

                                    <div class="text-end">
                                        <button type="submit" class="btn btn-success">{{ t.t('Post Now') }}</button>
                                    </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    </div>

                    {# Header for the Feed #}
                    <div class="d-flex align-items-center mb-3">
                        <h4 class="mb-0 me-3">
                            {% if currentFilter == 'popular' %}
                                <i class="bi bi-fire text-danger me-2"></i>Popular Posts
                            {% elseif currentFilter == 'unanswered' %}
                                <i class="bi bi-question-circle text-warning me-2"></i>Unanswered Posts
                            {% elseif currentFilter == 'bookmarks' %}
                                <i class="bi bi-bookmark-star text-info me-2"></i>My Bookmarks
                            {% else %}
                                <i class="bi bi-ui-checks-grid text-primary me-2"></i>{{ t.t('Recent Discussions') }}
                            {% endif %}
                        </h4>
                        {% if searchQuery %}
                            <span class="text-muted">Results for "{{ searchQuery }}"</span>
                        {% endif %}
                    </div>

                    {# THE NEW POST FEED (Replaces the old Table) #}
                    <div class="d-flex flex-column gap-3">
                        {% for post in posts %}
                            <div class="card border rounded-3 post-card bg-body overflow-hidden shadow-sm" onclick="window.location.href='{{ path('app_forum_show', {'id': post.id}) }}'">
                                <div class="d-flex flex-row h-100">
                                    
                                    {# Voting Column (Left) #}
                                    <div class="vote-column d-flex flex-column align-items-center justify-content-start py-3 px-2">
                                        <div class="text-center">
                                            {# Upvote Arrow Placeholder #}
                                            <i class="bi bi-caret-up-fill fs-5 text-secondary"></i>
                                            <div class="fw-bold fs-6 my-1" style="color: #1a1a1b;">{{ post.upvotes }}</div>
                                        </div>
                                    </div>

                                    {# Main Content Area (Right) #}
                                    <div class="p-3 w-100 d-flex flex-column">
                                        
                                        {# Meta Header #}
                                        <div class="d-flex align-items-center text-muted mb-2" style="font-size: 0.75rem;">
                                            {# Render the Space Name if the post belongs to one #}
                                            {% if post.space %}
                                                <a href="{{ path('app_forum_space', {'id': post.space.id}) }}" class="fw-bold text-dark text-decoration-none me-2 d-flex align-items-center" onclick="event.stopPropagation();">
                                                    <div class="rounded-circle bg-primary me-1" style="width: 16px; height: 16px; display: inline-block;"></div>
                                                    {{ post.space.name }}
                                                </a>
                                                <span class="me-2">•</span>
                                            {% endif %}
                                            
                                            <span>Posted by </span>
                                            <a href="#" class="text-muted text-decoration-none ms-1 fw-semibold hover-underline" onclick="event.stopPropagation();">
                                                {{ post.author.username }}
                                            </a>
                                            <span class="mx-1">•</span>
                                            <span>{{ post.createdAt|date('M d, Y') }}</span>

                                            {% if post.isLocked %}
                                                <span class="ms-2"><i class="bi bi-lock-fill text-danger" title="{{ t.t('Locked') }}"></i></span>
                                            {% endif %}
                                        </div>

                                        {# Title #}
                                        <h5 class="mb-2">
                                            <a href="{{ path('app_forum_show', {'id': post.id}) }}" class="post-title-link">
                                                {{ post.title }}
                                            </a>
                                        </h5>

                                        {# Content Snippet #}
                                        <div class="text-body mb-3" style="font-size: 0.875rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                                            {{ post.content }}
                                        </div>

                                        {# Image Preview (Optional) #}
                                        {% if post.imageName %}
                                            <div class="mb-3 rounded overflow-hidden" style="max-height: 250px; background-color: #f8f9fa;">
                                                <img src="{{ vich_uploader_asset(post, 'imageFile') }}" class="img-fluid w-100 object-fit-cover" style="max-height: 250px;" alt="Post attachment">
                                            </div>
                                        {% endif %}

                                        {# Action Footer #}
                                        <div class="d-flex align-items-center mt-auto pt-1">
                                            <a href="{{ path('app_forum_show', {'id': post.id}) }}#comments" class="action-btn d-flex align-items-center me-2" onclick="event.stopPropagation();">
                                                <i class="bi bi-chat-square me-2 fs-6"></i>
                                                <span>{{ post.comments|length }} Comments</span>
                                            </a>
                                            
                                            <a href="#" class="action-btn d-flex align-items-center me-2" onclick="event.stopPropagation();">
                                                <i class="bi bi-share me-2 fs-6"></i>
                                                <span>Share</span>
                                            </a>
                                            
                                            {# Bookmark indicator (Not interactive here, just status) #}
                                            {% if app.user and app.user.hasBookmarkedPost(post) %}
                                                <span class="action-btn d-flex align-items-center text-warning" onclick="event.stopPropagation();">
                                                    <i class="bi bi-bookmark-fill me-2 fs-6"></i>
                                                    <span>Saved</span>
                                                </span>
                                            {% else %}
                                                <span class="action-btn d-flex align-items-center" onclick="event.stopPropagation();">
                                                    <i class="bi bi-bookmark me-2 fs-6"></i>
                                                    <span>Save</span>
                                                </span>
                                            {% endif %}
                                        </div>

                                    </div>
                                </div>
                            </div>
                        {% else %}
                            {# Empty State #}
                            <div class="card border-0 bg-transparent text-center py-5">
                                <div class="card-body">
                                    {% if searchQuery is defined and searchQuery %}
                                        <div class="mb-3">
                                            <i class="bi bi-search display-1 text-secondary opacity-50"></i>
                                        </div>
                                        <h5 class="text-body">{{ t.t('No results found.') }}</h5>
                                        <p class="text-body">{{ t.t('We couldn\'t find any discussions matching') }} "<strong>{{ searchQuery }}</strong>".</p>
                                        <a href="{{ path('app_forum') }}" class="btn btn-primary rounded-pill mt-2">{{ t.t('Clear Search') }}</a>
                                    {% else %}
                                        <i class="bi bi-rocket-takeoff display-1 text-secondary opacity-50"></i>
                                        <h5 class="mt-4 text-body">It's quiet in here...</h5>
                                        <p class="text-body mb-4">{{ t.t('No discussions yet. Be the first to start one!') }}</p>
                                        <button class="btn btn-primary rounded-pill" type="button" data-bs-toggle="collapse" data-bs-target="#addPostForm" aria-expanded="false">
                                            Start the first discussion
                                        </button>
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    
                    {# --- PAGINATION LINKS --- #}
                    <div class="d-flex justify-content-center mt-5 pb-3">
                        {{ knp_pagination_render(posts, '@KnpPaginator/Pagination/bootstrap_v5_pagination.html.twig') }}
                    </div>

                </div>
            </div>
        </div>
    </section>
</main>
{% endblock %}