{% extends 'base.html.twig' %}
{% form_theme form 'bootstrap_5_layout.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root { --nova-bg: #dae0e6; --nova-card-bg: #ffffff; --nova-border: #cccccc; --nova-text-main: #1a1a1b; --nova-text-muted: #787c7e; --nova-vote-bg: #f8f9fa; --nova-hover-bg: rgba(0,0,0,0.05); --nova-input-bg: #f6f7f8; }
        [data-bs-theme="dark"], body.dark-mode, .dark-mode { --nova-bg: #030303; --nova-card-bg: #1a1a1b; --nova-border: #343536; --nova-text-main: #d7dadc; --nova-text-muted: #818384; --nova-vote-bg: #1a1a1b; --nova-hover-bg: rgba(255,255,255,0.1); --nova-input-bg: #272729; }

        body { background-color: var(--nova-bg) !important; color: var(--nova-text-main); }
        .nova-card { background-color: var(--nova-card-bg) !important; border: 1px solid var(--nova-border) !important; border-radius: 6px; color: var(--nova-text-main); }
        .nova-text-main { color: var(--nova-text-main) !important; }
        .nova-text-muted { color: var(--nova-text-muted) !important; }

        .sticky-sidebar { position: sticky; top: 80px; height: calc(100vh - 80px); overflow-y: auto; }
        .sticky-sidebar::-webkit-scrollbar { width: 0px; } 

        .left-nav-link { display: flex; align-items: center; padding: 10px 16px; color: var(--nova-text-main); font-size: 14px; font-weight: 500; border-radius: 8px; text-decoration: none; transition: background 0.2s; margin-bottom: 4px; }
        .left-nav-link i { font-size: 20px; margin-right: 12px; width: 24px; text-align: center; }
        .left-nav-link:hover, .left-nav-link.active { background-color: var(--nova-hover-bg); }
        .left-nav-section-title { font-size: 11px; font-weight: 700; color: var(--nova-text-muted); text-transform: uppercase; padding: 16px 16px 8px 16px; letter-spacing: 0.5px; }

        /* POST UI HORIZONTAL PILL */
        .vote-pill { display: inline-flex; align-items: center; background: var(--nova-input-bg); border: 1px solid var(--nova-border); border-radius: 20px; overflow: hidden; }
        .vote-pill .vote-arrow { padding: 4px 8px; color: var(--nova-text-muted); text-decoration: none; font-size: 1.2rem; display: flex; align-items: center; transition: 0.2s; }
        .vote-pill .vote-arrow:hover { background: var(--nova-hover-bg); }
        .vote-pill .vote-arrow.up.active, .vote-pill .vote-arrow.up:hover { color: #ff4500; }
        .vote-pill .vote-arrow.down.active, .vote-pill .vote-arrow.down:hover { color: #7193ff; }
        .vote-pill .vote-score { padding: 0 8px; font-weight: 700; font-size: 13px; color: var(--nova-text-main); }

        /* COMMENT VERTICAL SIDEBAR */
        .vote-sidebar { background-color: transparent; width: 40px; display: flex; flex-direction: column; align-items: center; padding-top: 4px;}
        .vote-sidebar .vote-arrow { color: var(--nova-text-muted); font-size: 1.3rem; cursor: pointer; border-radius: 4px; padding: 0px; line-height: 1; transition: all 0.2s; text-decoration: none;}
        .vote-sidebar .vote-arrow:hover { background-color: var(--nova-hover-bg); }
        .vote-sidebar .vote-arrow.up.active, .vote-sidebar .vote-arrow.up:hover { color: #ff4500; }
        .vote-sidebar .vote-arrow.down.active, .vote-sidebar .vote-arrow.down:hover { color: #7193ff; }
        .vote-sidebar .vote-score { font-size: 12px; font-weight: 700; color: var(--nova-text-main); margin: 4px 0; }

        .action-pill { display: inline-flex; align-items: center; padding: 6px 10px; border-radius: 4px; color: var(--nova-text-muted); font-size: 13px; font-weight: 600; text-decoration: none; transition: background-color 0.2s; background: transparent; border: none; }
        .action-pill i { font-size: 18px; margin-right: 6px; }
        .action-pill:hover { background-color: var(--nova-hover-bg); color: var(--nova-text-main); }
        .action-pill.saved { color: #eab308; }

        .comment-box { background: var(--nova-card-bg) !important; border-color: var(--nova-border) !important; }
    </style>
{% endblock %}

{% block body %}
<main style="min-height: 100vh; padding-top: 20px; padding-bottom: 40px;">
    <div class="container-fluid px-xl-5">
        <div class="row justify-content-center">
            
             {# --- 1. LEFT COLUMN: NAVIGATION --- #}
            <div class="col-xl-2 col-lg-3 d-none d-lg-block">
                <div class="sticky-sidebar">
                    {# --- NEW ENCLOSED CARD DESIGN --- #}
                    <div class="p-3 shadow-sm rounded-4" style="background-color: var(--nova-card-bg); border: 1px solid var(--nova-border);">
                        
                        <div class="left-nav-section-title pt-0">Feeds</div>
                        <a href="{{ path('app_forum') }}" class="left-nav-link {{ currentFilter is defined and currentFilter is null and currentSpace is defined and currentSpace is null ? 'active' : '' }}">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                        <a href="{{ path('app_forum', {'filter': 'popular'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'popular' ? 'active' : '' }}">
                            <i class="bi bi-fire text-danger"></i> Popular
                        </a>
                        <a href="{{ path('app_forum', {'filter': 'unanswered'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'unanswered' ? 'active' : '' }}">
                            <i class="bi bi-patch-question text-warning"></i> Unanswered
                        </a>

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">My NOVA</div>
                        <a href="{{ path('app_forum', {'filter': 'history'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'history' ? 'active' : '' }}">
                            <i class="bi bi-clock-history text-secondary"></i> History
                        </a>
                        {% if app.user %}
                            <a href="{{ path('app_forum', {'filter': 'bookmarks'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'bookmarks' ? 'active' : '' }}">
                                <i class="bi bi-bookmark-fill text-info"></i> Saved Posts
                            </a>
                        {% endif %}

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">Study Spaces</div>
                        {% for s in spaces|default([]) %}
                            {% set colors = ['#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#dc3545', '#6610f2', '#fd7e14'] %}
                            {% set color = colors[s.id % colors|length] %}
                            <a href="{{ path('app_forum_space', {'id': s.id}) }}" class="left-nav-link d-flex align-items-center {{ currentSpace is defined and currentSpace == s.id ? 'active' : (space is defined and space.id == s.id ? 'active' : (post is defined and post.space and post.space.id == s.id ? 'active' : '')) }}">
                                <div class="rounded-circle me-3" style="width: 14px; height: 14px; background-color: {{ color }}; margin-left: 5px;"></div>
                                <span class="text-truncate">{{ s.name }}</span>
                            </a>
                        {% endfor %}

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">Resources</div>
                        <a href="{{ path('app_forum_guidelines') }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'guidelines' ? 'active' : '' }}"><i class="bi bi-shield-check"></i> Guidelines</a>
                        <a href="{{ path('app_forum_about') }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'about' ? 'active' : '' }}"><i class="bi bi-info-circle"></i> About NOVA</a>

                    </div>
                </div>
            </div>

            {# --- 2. MIDDLE COLUMN: POST DETAILS --- #}
            <div class="col-xl-7 col-lg-6 col-md-12">
                
                <div class="nova-card mb-4 shadow-sm pb-2">
                    <div class="card-header border-bottom p-3" style="background: transparent; border-color: var(--nova-border) !important;">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb breadcrumb-dots mb-2">
                                <li class="breadcrumb-item"><a href="{{ path('app_forum') }}" class="nova-text-muted">Forum</a></li>
                                {% if post.space %}
                                    <li class="breadcrumb-item"><a href="{{ path('app_forum_space', {'id': post.space.id}) }}" class="nova-text-muted">{{ post.space.name }}</a></li>
                                {% endif %}
                            </ol>
                        </nav>
                        <h1 class="h4 mb-0 nova-text-main fw-bold">
                            {{ post.title }}
                            {% if post.isLocked %}
                                <span class="badge bg-danger ms-2" style="font-size: 0.5em; vertical-align: middle;"><i class="bi bi-lock-fill me-1"></i>Locked</span>
                            {% endif %}
                        </h1>
                    </div>

                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-4">
                            <div class="avatar avatar-md me-3">
                                <div class="rounded-circle bg-{{ ['primary', 'success', 'info', 'warning', 'danger'][post.author.id % 5] }} text-white d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; font-size: 16px;">
                                    <span class="fw-bold">{{ post.author.username|slice(0, 2)|upper }}</span>
                                </div>
                            </div>
                            <div>
                                <h6 class="mb-0 nova-text-main">{{ post.author.username }}</h6>
                                <small class="nova-text-muted">{{ post.createdAt|date('F d, Y') }}</small>
                            </div>
                        </div>

                        <p class="mb-4 nova-text-main" style="white-space: pre-wrap; font-size: 15px;">{{ post.content }}</p>

                        {% if post.imageName %}
                            <div class="mb-4 text-center p-3 rounded-3 border" style="background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                <img src="{{ vich_uploader_asset(post, 'imageFile') }}" class="img-fluid rounded" style="max-height: 500px; object-fit: contain;">
                            </div>
                        {% endif %}

                        {# --- FILE ATTACHMENT CARD --- #}
                        {% if post.attachmentName %}
                            <div class="mb-4 p-3 rounded-3 border d-flex align-items-center" style="background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                <div class="bg-primary bg-opacity-10 text-primary rounded d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                    <i class="bi bi-file-earmark-text fs-3"></i>
                                </div>
                                <div class="flex-grow-1 overflow-hidden pe-3">
                                    <h6 class="mb-1 nova-text-main text-truncate" style="font-size: 15px;">{{ post.attachmentName }}</h6>
                                    <small class="nova-text-muted">Attached Document</small>
                                </div>
                                <a href="{{ vich_uploader_asset(post, 'attachmentFile') }}" class="btn btn-primary rounded-pill px-4 text-nowrap" download>
                                    <i class="bi bi-download me-2"></i> Download
                                </a>
                            </div>
                        {% endif %}

                        {% if post.link %}
                            {% if post.linkTitle %}
                                <div class="mb-4 mt-2">
                                    <a href="{{ post.link }}" target="_blank" rel="noopener noreferrer" class="text-decoration-none d-block">
                                        <div class="card border overflow-hidden shadow-sm" style="transition: transform 0.2s; background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                            <div class="row g-0">
                                                {% if post.linkImage %}
                                                    <div class="col-md-3 col-4 bg-dark text-center border-end" style="border-color: var(--nova-border) !important;">
                                                        <img src="{{ post.linkImage }}" class="img-fluid w-100 h-100" style="object-fit: cover; min-height: 120px;">
                                                    </div>
                                                {% endif %}
                                                <div class="{{ post.linkImage ? 'col-md-9 col-8' : 'col-12' }}">
                                                    <div class="card-body p-3 p-md-4">
                                                        <h5 class="card-title fw-bold mb-2 nova-text-main">{{ post.linkTitle }}</h5>
                                                        {% if post.linkDescription %}
                                                            <p class="card-text mb-2 nova-text-muted" style="font-size: 14px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ post.linkDescription }}</p>
                                                        {% endif %}
                                                        <div class="text-primary text-truncate" style="font-size: 13px;"><i class="bi bi-link-45deg"></i> {{ post.link }}</div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            {% else %}
                                <div class="mb-4 p-3 rounded-3 border" style="background: var(--nova-input-bg); border-color: var(--nova-border) !important;">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-link-45deg fs-3 text-primary me-3"></i>
                                        <a href="{{ post.link }}" target="_blank" class="fw-bold nova-text-main text-decoration-underline">{{ post.link }}</a>
                                    </div>
                                </div>
                            {% endif %}
                        {% endif %}

                        {# --- REDESIGNED AI SUMMARY INLINE WIDGET --- #}
                        <div class="d-flex justify-content-between align-items-center p-3 mb-4 rounded-3" style="background: rgba(111, 66, 193, 0.05); border: 1px solid rgba(111, 66, 193, 0.2);">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-stars fs-4 me-3" style="color: #6f42c1;"></i>
                                <div>
                                    <h6 class="mb-0 fw-bold" style="color: #6f42c1;">AI Summary</h6>
                                    <small class="text-muted" id="ai-summary-content">Get a quick TL;DR of this discussion.</small>
                                </div>
                            </div>
                            <button id="btn-summarize" class="btn btn-sm rounded-pill text-white fw-bold px-3" style="background-color: #6f42c1; box-shadow: 0 2px 4px rgba(111,66,193,0.3);" data-url="{{ path('app_forum_summary', {id: post.id}) }}">
                                Generate
                            </button>
                        </div>

                        {# --- REDESIGNED ACTION FOOTER --- #}
                        <div class="d-flex flex-wrap gap-2 align-items-center mt-2 pt-3 border-top" style="border-color: var(--nova-border) !important;">
                            
                            {# THE VOTE PILL #}
                            <div class="vote-pill vote-container me-2">
                                {% set is_upvoted = app.user and post.isUpvotedBy(app.user) %}
                                {% set is_downvoted = app.user and post.isDownvotedBy(app.user) %}
                                <a href="#" class="vote-arrow up {{ is_upvoted ? 'active' : '' }}" data-url="{{ path('app_forum_post_vote', {'id': post.id, 'type': 'up'}) }}"><i class="bi bi-arrow-up-short"></i></a>
                                <span class="vote-score">{{ post.upvotes }}</span>
                                <a href="#" class="vote-arrow down {{ is_downvoted ? 'active' : '' }}" data-url="{{ path('app_forum_post_vote', {'id': post.id, 'type': 'down'}) }}"><i class="bi bi-arrow-down-short"></i></a>
                            </div>
                            
                            <a href="#replyForm" class="action-pill"><i class="bi bi-chat-square"></i> {{ post.comments|length }} Comments</a>
                            <button class="action-pill share-btn" data-url="{{ url('app_forum_show', {'id': post.id}) }}"><i class="bi bi-share"></i> Share</button>
                            
                            {% if app.user and app.user.hasBookmarkedPost(post) %}
                                <button class="action-pill saved bookmark-btn" data-url="{{ path('app_forum_post_bookmark', {'id': post.id}) }}"><i class="bi bi-bookmark-fill"></i> Saved</button>
                            {% else %}
                                <button class="action-pill bookmark-btn" data-url="{{ path('app_forum_post_bookmark', {'id': post.id}) }}"><i class="bi bi-bookmark"></i> Save</button>
                            {% endif %}
                            
                            <div class="ms-auto d-flex align-items-center">
                                {% if app.user and app.user != post.author %}
                                    <button class="action-pill" data-bs-toggle="modal" data-bs-target="#reportModal-{{ post.id }}"><i class="bi bi-flag"></i> Report</button>
                                {% endif %}
                                {% if app.user and (app.user.id == post.author.id or is_granted('ROLE_ADMIN')) %}
                                    <div class="dropdown">
                                        <button class="action-pill" type="button" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm" style="background: var(--nova-card-bg); border-color: var(--nova-border);">
                                            <li><a class="dropdown-item nova-text-main" href="{{ path('app_forum_toggle_lock', {'id': post.id}) }}"><i class="bi bi-{{ post.isLocked ? 'unlock' : 'lock' }} me-2"></i> {{ post.isLocked ? 'Unlock' : 'Lock' }}</a></li>
                                            <li><a class="dropdown-item nova-text-main" href="{{ path('app_forum_edit', {'id': post.id}) }}"><i class="bi bi-pencil me-2"></i> Edit Post</a></li>
                                            <li><hr class="dropdown-divider" style="border-color: var(--nova-border);"></li>
                                            <li>
                                                <form method="post" action="{{ path('app_forum_delete', {'id': post.id}) }}" onsubmit="return confirm('Delete this post?')">
                                                    <button type="submit" class="dropdown-item text-danger"><i class="bi bi-trash me-2"></i> Delete Post</button>
                                                </form>
                                            </li>
                                        </ul>
                                    </div>
                                {% endif %}
                            </div>
                        </div>

                    </div>
                </div>

                <div class="nova-card shadow-sm">
                    <div class="card-header border-bottom p-3" style="background: transparent; border-color: var(--nova-border) !important;">
                        <h3 class="mb-0 h5 nova-text-main">Replies ({{ post.comments|length }})</h3>
                    </div>
                    <div class="card-body">
                        {% for comment in post.comments %}
                            <div class="d-flex mb-4 p-3 rounded-3 comment-box border {{ comment.isSolution ? 'border-success' : '' }}" id="comment-{{ comment.id }}">
                                <div class="me-3 text-center d-flex flex-column align-items-center" style="min-width: 50px;">
                                    <div class="avatar avatar-sm mb-2">
                                        <div class="rounded-circle bg-{{ ['primary', 'success', 'info', 'warning', 'danger'][comment.author.id % 5] }} text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-size: 14px;">
                                            <span class="fw-bold">{{ comment.author.username|slice(0, 2)|upper }}</span>
                                        </div>
                                    </div>
                                    <div class="vote-sidebar vote-container">
                                        <a href="#" class="vote-arrow up {{ app.user and comment.isUpvotedBy(app.user) ? 'active' : '' }}" data-url="{{ path('app_forum_comment_vote', {'id': comment.id, 'type': 'up'}) }}"><i class="bi bi-arrow-up-short"></i></a>
                                        <span class="vote-score">{{ comment.score }}</span>
                                        <a href="#" class="vote-arrow down {{ app.user and comment.isDownvotedBy(app.user) ? 'active' : '' }}" data-url="{{ path('app_forum_comment_vote', {'id': comment.id, 'type': 'down'}) }}"><i class="bi bi-arrow-down-short"></i></a>
                                    </div>
                                </div>
                                <div class="w-100">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <h6 class="mb-0 nova-text-main">{{ comment.author.username }} {% if comment.author.id == post.author.id %}<span class="badge bg-secondary ms-1" style="font-size: 0.6em;">AUTHOR</span>{% endif %}</h6>
                                            <small class="nova-text-muted">{{ comment.createdAt|date('M d, Y H:i') }}</small>
                                        </div>
                                        <div class="solution-badge {{ comment.isSolution ? '' : 'd-none' }}">
                                            <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i> Solution</span>
                                        </div>
                                    </div>
                                    <p class="mt-2 mb-2 nova-text-main" style="white-space: pre-wrap;">{{ comment.content }}</p>
                                    {% if app.user and (app.user.id == post.author.id or is_granted('ROLE_ADMIN')) %}
                                        <div class="d-flex justify-content-end mt-2 pt-2 border-top" style="border-color: var(--nova-border) !important;">
                                            <button class="btn btn-sm solution-btn {{ comment.isSolution ? 'btn-outline-success active' : 'btn-outline-secondary' }}" data-url="{{ path('app_forum_solution', {'id': comment.id}) }}" data-id="{{ comment.id }}">
                                                <i class="bi bi-check-lg"></i> <span class="btn-text">{{ comment.isSolution ? 'Unmark Solution' : 'Mark as Solution' }}</span>
                                            </button>
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        {% else %}
                            <div class="text-center py-4">
                                <i class="bi bi-chat-square-dots display-6 text-secondary mb-3"></i>
                                <p class="nova-text-muted mb-0">No replies yet. Be the first to help!</p>
                            </div>
                        {% endfor %}
                    </div>
                </div>

                {% if post.isLocked %}
                    <div class="alert alert-secondary d-flex align-items-center mt-4 p-4 rounded-3 shadow-sm" role="alert">
                        <div class="display-6 me-3"><i class="bi bi-lock-fill"></i></div>
                        <div>
                            <h6 class="mb-1">This discussion is locked</h6>
                            <p class="mb-0 small">The author or an administrator has closed this topic. New replies are no longer accepted.</p>
                        </div>
                    </div>
                {% else %}
                    <div class="nova-card mt-4 shadow-sm" id="replyForm">
                        <div class="card-header border-bottom p-3" style="background: transparent; border-color: var(--nova-border) !important;">
                            <h5 class="mb-0 nova-text-main">Leave a Reply</h5>
                        </div>
                        <div class="card-body p-4">
                            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                                <div class="mb-3">
                                    {{ form_widget(form.content, {'attr': {'class': 'form-control nova-text-main', 'rows': '4', 'placeholder': 'Type your answer here...', 'style': 'background: var(--nova-input-bg); border-color: var(--nova-border);'}}) }}
                                    <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                </div>
                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary rounded-pill px-4 fw-bold mb-0">Post Reply</button>
                                </div>
                            {{ form_end(form) }}
                        </div>
                    </div>
                {% endif %}
            </div>

            {# --- 3. RIGHT COLUMN: WIDGETS --- #}
            <div class="col-xl-3 d-none d-lg-block">
                <div class="sticky-sidebar">
                    <div class="nova-card mb-3 shadow-sm">
                        <div class="card-header border-bottom p-3" style="background: transparent; border-color: var(--nova-border) !important;">
                            <h3 class="mb-0 h6 fw-bold nova-text-main">Discussion Stats</h3>
                        </div>
                        <div class="card-body p-3">
                            <ul class="list-unstyled mb-0 font-sm nova-text-main">
                                <li class="mb-3 d-flex align-items-center"><i class="bi bi-shield-lock-fill {{ post.isLocked ? 'text-danger' : 'text-success' }} fs-5 me-3"></i> <div><small class="nova-text-muted d-block">Status</small><strong>{{ post.isLocked ? 'Closed' : 'Open' }}</strong></div></li>
                                <li class="mb-3 d-flex align-items-center"><i class="bi bi-chat-dots-fill text-primary fs-5 me-3"></i> <div><small class="nova-text-muted d-block">Replies</small><strong>{{ post.comments|length }}</strong></div></li>
                            </ul>
                        </div>
                    </div>

                    <div class="nova-card shadow-sm">
                        <div class="card-header border-bottom p-3" style="background: transparent; border-color: var(--nova-border) !important;">
                            <h3 class="mb-0 h6 fw-bold nova-text-main">Forum Rules</h3>
                        </div>
                        <div class="card-body p-3">
                            <ul class="list-unstyled nova-text-muted mb-0 small">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Be respectful to others</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>No spamming</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Stay on topic</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Provide helpful answers</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

{# --- REPORT MODAL --- #}
{% if app.user and app.user != post.author %}
<div class="modal fade" id="reportModal-{{ post.id }}" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="background-color: var(--nova-card-bg); color: var(--nova-text-main); border-color: var(--nova-border);">
            <div class="modal-header border-bottom" style="border-color: var(--nova-border) !important;">
                <h5 class="modal-title"><i class="bi bi-flag-fill text-danger me-2"></i>Report Discussion</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form action="{{ path('app_forum_report', {id: post.id}) }}" method="POST">
                <div class="modal-body">
                    <p class="mb-3 nova-text-muted">Please tell us why you are reporting <strong>"{{ post.title|slice(0, 30) }}..."</strong>.</p>
                    <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reason" value="Spam or Advertising" required><label class="form-check-label">Spam or Advertising</label></div>
                    <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reason" value="Harassment or Hate Speech"><label class="form-check-label">Harassment or Hate Speech</label></div>
                    <div class="form-check mb-2"><input class="form-check-input" type="radio" name="reason" value="Off-Topic or Inappropriate"><label class="form-check-label">Off-Topic or Inappropriate</label></div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Submit Report</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endif %}

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // ROBUST VOTE LOGIC (Handles both Vertical Sidebar and Horizontal Pill)
        document.querySelectorAll('.vote-arrow').forEach(arrow => {
            arrow.addEventListener('click', function(e) {
                e.preventDefault(); e.stopPropagation();
                const url = this.dataset.url;
                if(!url) return;
                
                const container = this.closest('.vote-container');
                const scoreDisplay = container.querySelector('.vote-score');
                
                fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(async r => {
                    if (r.status === 403) { alert('You must be logged in to vote.'); throw new Error('Auth'); }
                    if (!r.ok) { alert('Database error. Did you run the migration for downvoters?'); throw new Error('Server'); }
                    return r.json();
                }).then(data => {
                    if(data.error) return alert(data.error);
                    if(scoreDisplay) scoreDisplay.textContent = data.score ?? data.upvotes;
                    
                    const upBtn = container.querySelector('.vote-arrow.up');
                    const downBtn = container.querySelector('.vote-arrow.down');
                    if(upBtn) { upBtn.classList.remove('active'); if(data.upvoted) upBtn.classList.add('active'); }
                    if(downBtn) { downBtn.classList.remove('active'); if(data.downvoted) downBtn.classList.add('active'); }
                }).catch(err => {});
            });
        });

        // Bookmark
        document.querySelectorAll('.bookmark-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault(); const url = this.dataset.url;
                if(!url) return;
                fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(async r => {
                    if (r.status === 403) { alert('You must be logged in.'); throw new Error('Auth'); }
                    return r.json();
                }).then(data => {
                    if (data.isBookmarked) { this.innerHTML = '<i class="bi bi-bookmark-fill"></i> Saved'; this.classList.add('saved'); } 
                    else { this.innerHTML = '<i class="bi bi-bookmark"></i> Save'; this.classList.remove('saved'); }
                }).catch(err => {});
            });
        });

        // Share Button
        document.querySelectorAll('.share-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault(); e.stopPropagation();
                const urlToShare = this.getAttribute('data-url'); const textSpan = this.querySelector('.share-text'); const icon = this.querySelector('i');
                navigator.clipboard.writeText(urlToShare).then(() => {
                    const originalText = textSpan.innerText; const originalIcon = icon.className;
                    textSpan.innerText = 'Copied!'; icon.className = 'bi bi-check2 text-success fw-bold';
                    setTimeout(() => { textSpan.innerText = originalText; icon.className = originalIcon; }, 2000);
                });
            });
        });

        // Mark Solution
        document.querySelectorAll('.solution-btn').forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault(); 
                const url = this.dataset.url;
                const container = document.getElementById('comment-' + this.dataset.id);
                fetch(url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json()).then(data => {
                    document.querySelectorAll('.solution-btn').forEach(b => { b.classList.replace('btn-outline-success', 'btn-outline-secondary'); b.classList.remove('active'); b.querySelector('.btn-text').textContent = 'Mark as Solution'; });
                    document.querySelectorAll('.solution-badge').forEach(b => b.classList.add('d-none'));
                    document.querySelectorAll('[id^="comment-"]').forEach(c => c.classList.remove('border-success'));
                    if (data.isSolution) { container.classList.add('border-success'); container.querySelector('.solution-badge').classList.remove('d-none'); this.classList.replace('btn-outline-secondary', 'btn-outline-success'); this.classList.add('active'); this.querySelector('.btn-text').textContent = 'Unmark Solution'; }
                });
            });
        });

        // AI Summary
        const btnSum = document.getElementById('btn-summarize');
        const summaryContent = document.getElementById('ai-summary-content');
        if (btnSum) {
            btnSum.addEventListener('click', function() {
                const origTxt = this.innerHTML; 
                this.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; 
                this.disabled = true;
                summaryContent.classList.remove('d-none');
                summaryContent.innerHTML = 'Google Gemini is reading the discussion...';
                
                fetch(this.dataset.url, { method: 'POST', headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.json()).then(data => { 
                    summaryContent.innerHTML = `<strong>TL;DR:</strong> ${data.summary}`; 
                    this.innerHTML = '✨ Summarized'; 
                })
                .catch(() => { 
                    summaryContent.innerHTML = 'Error communicating with AI.'; 
                    this.innerHTML = origTxt; 
                    this.disabled = false; 
                });
            });
        }
    });
</script>
{% endblock %}