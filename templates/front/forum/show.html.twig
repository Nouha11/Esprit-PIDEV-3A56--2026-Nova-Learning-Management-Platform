{% extends 'base.html.twig' %}

{% block title %}{{ post.title }}{% endblock %}

{% block body %}
<main>
    <section class="pt-0">
        <div class="container-fluid px-0">
            <div class="bg-blue h-100px h-md-200px rounded-0" style="background:url({{ asset('assets/images/pattern/04.png') }}) no-repeat center center; background-size:cover;">
            </div>
        </div>
        <div class="container mt-n4">
            <div class="row">
                <div class="col-12">
                    <div class="card bg-transparent card-body p-0">
                        <div class="row d-flex justify-content-between">
                            <div class="col-12">
                                <div class="bg-body p-4 rounded-3 shadow-sm">
                                    <nav aria-label="breadcrumb">
                                        <ol class="breadcrumb breadcrumb-dots mb-1">
                                            <li class="breadcrumb-item"><a href="{{ path('app_forum') }}">Forum</a></li>
                                            <li class="breadcrumb-item active" aria-current="page">Discussion Details</li>
                                        </ol>
                                    </nav>
                                    <div class="d-flex align-items-center">
                                        <h1 class="h3 mb-0">{{ post.title }}</h1>
                                        {% if post.isLocked %}
                                            <span class="badge bg-danger ms-3">
                                                <i class="bi bi-lock-fill me-1"></i>Locked
                                            </span>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="pt-0">
        <div class="container">
            <div class="row">
                <div class="col-xl-9">
                    
                    <div class="card border bg-transparent rounded-3 mb-4">
                        <div class="card-header bg-transparent border-bottom p-3">
                            <div class="d-flex align-items-center justify-content-between">
                                <div class="d-flex align-items-center">
                                    <div class="avatar avatar-md me-2">
                                        <div class="rounded-circle bg-{{ ['primary', 'success', 'info', 'warning', 'danger'][post.author.id % 5] }} text-white d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; font-size: 16px;">
                                            <span class="fw-bold">{{ post.author.username|slice(0, 2)|upper }}</span>
                                        </div>
                                    </div>
                                    <div>
                                        <h6 class="mb-0">{{ post.author.username }}</h6>
                                        <small class="text-secondary">Posted on {{ post.createdAt|date('F d, Y') }}</small>
                                    </div>
                                </div>
                                <span class="badge bg-primary bg-opacity-10 text-primary">
                                    <span id="top-upvote-count">{{ post.upvotes }}</span> Upvotes
                                </span>
                            </div>
                        </div>

                        <div class="card-body p-4">
                            <p class="mb-4 text-body">{{ post.content }}</p>

                            <div class="d-flex gap-2 align-items-center">
                                {# UPVOTE BUTTON #}
                                {% set is_upvoted = app.user and post.isUpvotedBy(app.user) %}
                                <button class="btn btn-sm mb-0 upvote-btn {{ is_upvoted ? 'btn-primary' : 'btn-light' }}" 
                                        data-id="{{ post.id }}">
                                    <i class="bi bi-hand-thumbs-up me-1"></i> 
                                    <span class="btn-text">{{ is_upvoted ? 'Upvoted' : 'Upvote' }}</span>
                                </button>
                                
                                {# REPLY BUTTON (Hidden if locked) #}
                                {% if not post.isLocked %}
                                    <a href="#replyForm" class="btn btn-sm btn-primary-soft mb-0"><i class="bi bi-reply-fill me-1"></i> Reply</a>
                                {% endif %}
                                
                                {# AUTHOR / ADMIN ACTIONS #}
                                {% if app.user and (app.user.id == post.author.id or is_granted('ROLE_ADMIN')) %}
                                    <div class="ms-auto d-flex gap-2">
                                        {# NEW: LOCK/UNLOCK BUTTON #}
                                        <a href="{{ path('app_forum_toggle_lock', {'id': post.id}) }}" 
                                           class="btn btn-sm {{ post.isLocked ? 'btn-success-soft' : 'btn-secondary-soft' }} mb-0"
                                           title="{{ post.isLocked ? 'Unlock Discussion' : 'Lock Discussion' }}">
                                            {% if post.isLocked %}
                                                <i class="bi bi-unlock-fill"></i> Unlock
                                            {% else %}
                                                <i class="bi bi-lock-fill"></i> Lock
                                            {% endif %}
                                        </a>

                                        {# EDIT BUTTON #}
                                        <a href="{{ path('app_forum_edit', {'id': post.id}) }}" class="btn btn-sm btn-warning-soft mb-0">
                                            <i class="bi bi-pencil"></i> Edit
                                        </a>

                                        {# DELETE BUTTON #}
                                        <form method="post" action="{{ path('app_forum_delete', {'id': post.id}) }}" style="display:inline;" onsubmit="return confirm('Delete this post? This action cannot be undone.')">
                                            <button class="btn btn-sm btn-danger-soft mb-0" type="submit">
                                                <i class="bi bi-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="card border bg-transparent rounded-3">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0 h5">Replies ({{ post.comments|length }})</h3>
                        </div>
                        <div class="card-body">
                            {% for comment in post.comments %}
                                <div class="d-flex mb-4 p-3 rounded-3 {{ comment.isSolution ? 'bg-success bg-opacity-10 border border-success' : '' }}" id="comment-{{ comment.id }}">
                                    <div class="avatar avatar-sm me-3">
                                        <div class="rounded-circle bg-{{ ['primary', 'success', 'info', 'warning', 'danger'][comment.author.id % 5] }} text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; font-size: 14px;">
                                            <span class="fw-bold">{{ comment.author.username|slice(0, 2)|upper }}</span>
                                        </div>
                                    </div>
                                    <div class="w-100">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <h6 class="mb-0">
                                                    {{ comment.author.username }}
                                                    {% if comment.author.id == post.author.id %}
                                                        <span class="badge bg-secondary ms-1" style="font-size: 0.6em;">AUTHOR</span>
                                                    {% endif %}
                                                </h6>
                                                <small class="text-secondary">{{ comment.createdAt|date('M d, Y H:i') }}</small>
                                            </div>

                                            <div class="solution-badge {{ comment.isSolution ? '' : 'd-none' }}">
                                                <span class="badge bg-success"><i class="bi bi-check-circle-fill me-1"></i> Solution</span>
                                            </div>
                                        </div>

                                        <p class="mt-2 mb-2 text-body">{{ comment.content }}</p>

                                        {% if app.user and (app.user.id == post.author.id or is_granted('ROLE_ADMIN')) %}
                                            <div class="d-flex justify-content-end">
                                                <button class="btn btn-sm solution-btn {{ comment.isSolution ? 'btn-outline-success active' : 'btn-outline-secondary' }}" 
                                                        data-id="{{ comment.id }}">
                                                    <i class="bi bi-check-lg"></i> 
                                                    <span class="btn-text">{{ comment.isSolution ? 'Unmark Solution' : 'Mark as Solution' }}</span>
                                                </button>
                                            </div>
                                        {% endif %}
                                    </div>
                                </div>
                                {% if not loop.last %}<hr class="my-2">{% endif %}
                            {% else %}
                                <div class="text-center py-4">
                                    <i class="bi bi-chat-square-dots display-6 text-secondary mb-3"></i>
                                    <p class="text-secondary mb-0">No replies yet. Be the first to help!</p>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    {% if post.isLocked %}
                        <div class="alert alert-secondary d-flex align-items-center mt-4 p-4 rounded-3" role="alert">
                            <div class="display-6 me-3"><i class="bi bi-lock-fill"></i></div>
                            <div>
                                <h6 class="mb-1">This discussion is locked</h6>
                                <p class="mb-0 small">The author or an administrator has closed this topic. New replies are no longer accepted.</p>
                            </div>
                        </div>
                    {% else %}
                        <div class="card border bg-transparent rounded-3 mt-4" id="replyForm">
                            <div class="card-header bg-transparent border-bottom">
                                <h5 class="mb-0">Leave a Reply</h5>
                            </div>
                            <div class="card-body">
                                {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                                    <div class="mb-3">
                                        {{ form_widget(form.content, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Type your answer here...'}}) }}
                                        <div class="form-text text-danger">{{ form_errors(form.content) }}</div>
                                    </div>
                                    <div class="text-end">
                                        <button type="submit" class="btn btn-primary mb-0">Post Reply</button>
                                    </div>
                                {{ form_end(form) }}
                            </div>
                        </div>
                    {% endif %}

                </div>

                <div class="col-xl-3">
                    <div class="card border bg-transparent rounded-3 mb-3">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0 h5">Discussion Stats</h3>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled mb-0">
                                <li class="mb-2">
                                    <i class="bi bi-shield-lock-fill {{ post.isLocked ? 'text-danger' : 'text-secondary' }} me-2"></i>
                                    <strong>Status:</strong> {{ post.isLocked ? 'Closed' : 'Open' }}
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-eye-fill text-info me-2"></i>
                                    <strong>Views:</strong> N/A
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-chat-dots-fill text-success me-2"></i>
                                    <strong>Replies:</strong> {{ post.comments|length }}
                                </li>
                                <li class="mb-2">
                                    <i class="bi bi-hand-thumbs-up-fill text-primary me-2"></i>
                                    <strong>Upvotes:</strong> <span id="sidebar-upvote-count">{{ post.upvotes }}</span>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <div class="card border bg-transparent rounded-3">
                        <div class="card-header bg-transparent border-bottom">
                            <h3 class="mb-0 h5">Forum Rules</h3>
                        </div>
                        <div class="card-body">
                            <ul class="list-unstyled text-secondary mb-0 small">
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Be respectful to others</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>No spamming</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Stay on topic</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Provide helpful answers</li>
                                <li class="mb-2"><i class="bi bi-check-circle-fill text-success me-2"></i>Mark solutions when answered</li>
                            </ul>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </section>
</main>

{# --- JAVASCRIPT FOR UPVOTES AND SOLUTIONS --- #}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        // UPVOTE LOGIC
        const upvoteBtn = document.querySelector('.upvote-btn');
        if (upvoteBtn) {
            upvoteBtn.addEventListener('click', function (e) {
                e.preventDefault();
                const postId = this.dataset.id;
                const textSpan = this.querySelector('.btn-text');
                const topCount = document.getElementById('top-upvote-count');
                const sideCount = document.getElementById('sidebar-upvote-count');

                fetch(`/forum/post/${postId}/upvote`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => {
                    if (response.status === 403) {
                        alert('You must be logged in to upvote!');
                        throw new Error('Not logged in');
                    }
                    return response.json();
                })
                .then(data => {
                    if (data) {
                        if (data.isUpvoted) {
                            this.classList.remove('btn-light');
                            this.classList.add('btn-primary');
                            textSpan.textContent = 'Upvoted';
                        } else {
                            this.classList.remove('btn-primary');
                            this.classList.add('btn-light');
                            textSpan.textContent = 'Upvote';
                        }
                        if (topCount) topCount.textContent = data.upvotes;
                        if (sideCount) sideCount.textContent = data.upvotes;
                    }
                })
                .catch(err => console.error('Error:', err));
            });
        }

        // SOLUTION LOGIC
        const solutionBtns = document.querySelectorAll('.solution-btn');
        solutionBtns.forEach(btn => {
            btn.addEventListener('click', function (e) {
                e.preventDefault();
                const commentId = this.dataset.id;
                const container = document.getElementById('comment-' + commentId);
                const badge = container.querySelector('.solution-badge');
                const btnText = this.querySelector('.btn-text');

                fetch(`/forum/comment/${commentId}/solution`, {
                    method: 'POST',
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(response => {
                    if (response.status === 403) {
                        alert('Unauthorized action.');
                        return;
                    }
                    return response.json();
                })
                .then(data => {
                    if (data) {
                        // Reset all comments
                        document.querySelectorAll('.solution-btn').forEach(b => {
                            b.classList.remove('btn-outline-success', 'active');
                            b.classList.add('btn-outline-secondary');
                            b.querySelector('.btn-text').textContent = 'Mark as Solution';
                        });
                        document.querySelectorAll('.solution-badge').forEach(b => b.classList.add('d-none'));
                        document.querySelectorAll('[id^="comment-"]').forEach(c => c.classList.remove('bg-success', 'bg-opacity-10', 'border', 'border-success'));

                        // Activate selected comment if marked as solution
                        if (data.isSolution) {
                            container.classList.add('bg-success', 'bg-opacity-10', 'border', 'border-success');
                            badge.classList.remove('d-none');
                            this.classList.remove('btn-outline-secondary');
                            this.classList.add('btn-outline-success', 'active');
                            btnText.textContent = 'Unmark Solution';
                        }
                    }
                })
                .catch(err => console.error('Error:', err));
            });
        });
    });
</script>
{% endblock %}