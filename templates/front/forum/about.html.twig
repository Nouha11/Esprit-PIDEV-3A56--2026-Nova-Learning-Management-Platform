                        <hr style="border-color: var(--nova-border); opacity: 0.5;" class="mb-5">

                        <h4 class="fw-bold mb-4 text-center">Meet the Developers</h4>
                        <div class="row g-4 justify-content-center">
                            
                            <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T1</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Nouha Hamrouni</h6>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T2</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Oumeyma Radhouani</h6>
                                    </div>
                                </div>
                            </div>

                             <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T3</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Acil Jouini</h6>
                                    </div>
                                </div>
                            </div>


                             <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T4</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Oussema Ben Zinouba</h6>
                                    </div>
                                </div>
                            </div>

                             <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T5</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Said Hadj Abdallah</h6>
                                    </div>
                                </div>
                            </div>

                             <div class="col-md-6">
                                <div class="d-flex align-items-center p-3 rounded-3" style="background: var(--nova-input-bg); border: 1px solid var(--nova-border);">
                                    <div class="avatar avatar-xl me-3">
                                        <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center fw-bold fs-4" style="width: 60px; height: 60px;">T6</div>
                                    </div>
                                    <div>
                                        <h6 class="mb-1 fw-bold">Wassim Ouni</h6>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </div>

            {# --- 3. RIGHT COLUMN: WIDGETS --- #}
            <div class="col-xl-3 col-lg-3 d-none d-lg-block">
                <div class="sticky-sidebar">
                    <div class="widget-card shadow-sm">
                        <div class="card-header bg-transparent border-bottom-0 pt-3 pb-2 px-3">
                            <h3 class="mb-0 h6 fw-bold nova-text-main">Platform Stats</h3>
                        </div>
                        <div class="card-body p-3 pt-0 nova-text-muted" style="font-size: 13px;">
                            <ul class="list-unstyled mb-0 mt-2 font-sm nova-text-main">
                                <li class="mb-3 d-flex align-items-center"><i class="bi bi-people-fill text-primary fs-5 me-3"></i> <div><small class="nova-text-muted d-block">Total Users</small><strong>1,204</strong></div></li>
                                <li class="mb-3 d-flex align-items-center"><i class="bi bi-file-earmark-post-fill text-success fs-5 me-3"></i> <div><small class="nova-text-muted d-block">Discussions</small><strong>{{ spaces|length * 42 }}</strong></div></li>
                                <li class="mb-0 d-flex align-items-center"><i class="bi bi-building text-info fs-5 me-3"></i> <div><small class="nova-text-muted d-block">Study Spaces</small><strong>{{ spaces|length }}</strong></div></li>
                            </ul>
                            <a href="{{ path('app_forum') }}" class="btn btn-primary btn-sm w-100 mt-4 rounded-pill fw-bold">Return to Feed</a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>
{% endblock %}