{% extends 'base.html.twig' %}
{% import 'macros/translation.html.twig' as t %}

{% block title %}About NOVA - Forum{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        :root { --nova-bg: #dae0e6; --nova-card-bg: #ffffff; --nova-border: #cccccc; --nova-text-main: #1a1a1b; --nova-text-muted: #787c7e; --nova-vote-bg: #f8f9fa; --nova-hover-bg: rgba(0,0,0,0.05); --nova-input-bg: #f6f7f8; }
        [data-bs-theme="dark"], body.dark-mode, .dark-mode { --nova-bg: #030303; --nova-card-bg: #1a1a1b; --nova-border: #343536; --nova-text-main: #d7dadc; --nova-text-muted: #818384; --nova-vote-bg: #1a1a1b; --nova-hover-bg: rgba(255,255,255,0.1); --nova-input-bg: #272729; }
        
        body { background-color: var(--nova-bg) !important; color: var(--nova-text-main); }
        .nova-card { background-color: var(--nova-card-bg) !important; border: 1px solid var(--nova-border) !important; border-radius: 6px; }
        .nova-text-main { color: var(--nova-text-main) !important; }
        .nova-text-muted { color: var(--nova-text-muted) !important; }
        
        .sticky-sidebar { position: sticky; top: 80px; height: calc(100vh - 80px); overflow-y: auto; }
        .sticky-sidebar::-webkit-scrollbar { width: 0px; } 

        .left-nav-link { display: flex; align-items: center; padding: 10px 12px; color: var(--nova-text-main); font-size: 14px; font-weight: 500; border-radius: 8px; text-decoration: none; transition: background 0.2s; margin-bottom: 4px; }
        .left-nav-link i { font-size: 20px; margin-right: 12px; width: 24px; text-align: center; }
        .left-nav-link:hover, .left-nav-link.active { background-color: var(--nova-hover-bg); }
        .left-nav-section-title { font-size: 11px; font-weight: 700; color: var(--nova-text-muted); text-transform: uppercase; padding: 16px 8px 8px 8px; letter-spacing: 0.5px; }

        .widget-card { background: var(--nova-card-bg); border: 1px solid var(--nova-border); border-radius: 4px; margin-bottom: 16px; overflow: hidden; color: var(--nova-text-main); }
    
    /* ========================================== */
        /* --- 🪄 NOVA MAGIC UI ANIMATIONS PACK --- */
        /* ========================================== */

        /* 1. Smooth Cascading Page Load */
        @keyframes fadeSlideUp {
            0% { opacity: 0; transform: translateY(20px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        
        /* Apply base animation to all main blocks */
        .sticky-sidebar, .create-post-bar, .sort-bar, .post-card, .reddit-card, .nova-card {
            animation: fadeSlideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) both;
        }

        /* Stagger the delays for the "Cascade" effect */
        .col-xl-2 .sticky-sidebar { animation-delay: 0.05s; }
        .col-xl-7 > div:nth-child(1) { animation-delay: 0.1s; }
        .col-xl-7 > div:nth-child(2) { animation-delay: 0.15s; }
        .col-xl-7 > div:nth-child(3) { animation-delay: 0.2s; }
        .col-xl-7 > div:nth-child(4) { animation-delay: 0.25s; }
        .col-xl-3 .sticky-sidebar { animation-delay: 0.3s; }

        /* 2. Premium Card Hover Lift */
        .post-card, .reddit-card {
            transition: transform 0.2s ease-out, box-shadow 0.2s ease-out, border-color 0.2s ease-out !important;
        }
        .post-card:hover, .reddit-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.06) !important;
            border-color: #0d6efd !important; /* Highlights the border in brand blue */
        }

        /* 3. The "Reddit Vote Pop" Micro-interaction */
        @keyframes votePop {
            0% { transform: scale(1); }
            50% { transform: scale(1.4); }
            100% { transform: scale(1); }
        }
        .vote-arrow.active {
            animation: votePop 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        /* 4. Squishy Buttons */
        .btn, .action-pill {
            transition: transform 0.1s ease, background-color 0.2s ease, color 0.2s ease;
        }
        .btn:active, .action-pill:active {
            transform: scale(0.95); /* Squish effect when clicked */
        }

        /* 5. Smooth Tab switching for Left Nav */
        .left-nav-link {
            transition: all 0.2s ease;
        }
        .left-nav-link:hover {
            transform: translateX(4px); /* Gently nudges the link to the right on hover */
        }
    </style>
{% endblock %}

{% block body %}
<main style="min-height: 100vh; padding-top: 20px; padding-bottom: 40px;">
    <div class="container-fluid px-xl-5">
        <div class="row justify-content-center">
            
             {# --- 1. LEFT COLUMN: NAVIGATION --- #}
            <div class="col-xl-2 col-lg-3 d-none d-lg-block">
                <div class="sticky-sidebar">
                    <div class="p-3 shadow-sm rounded-4" style="background-color: var(--nova-card-bg); border: 1px solid var(--nova-border);">
                        
                        <div class="left-nav-section-title pt-0">Feeds</div>
                        <a href="{{ path('app_forum') }}" class="left-nav-link {{ currentFilter is defined and currentFilter is null and currentSpace is defined and currentSpace is null ? 'active' : '' }}">
                            <i class="bi bi-house-door"></i> Home
                        </a>
                        <a href="{{ path('app_forum', {'filter': 'popular'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'popular' ? 'active' : '' }}">
                            <i class="bi bi-fire text-danger"></i> Popular
                        </a>
                        <a href="{{ path('app_forum', {'filter': 'unanswered'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'unanswered' ? 'active' : '' }}">
                            <i class="bi bi-patch-question text-warning"></i> Unanswered
                        </a>

                        {# --- NEW NOVA AI ASSIST LINK --- #}
                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">Tutor</div>
                        <a href="{{ path('app_forum_ai_assist') }}" class="left-nav-link" style="background: rgba(111, 66, 193, 0.1); color: #6f42c1; border: 1px solid rgba(111, 66, 193, 0.2);">
                            <i class="bi bi-stars"></i> <span class="fw-bold">NOVA AI</span>
                        </a>

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">My NOVA</div>
                        <a href="{{ path('app_forum', {'filter': 'history'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'history' ? 'active' : '' }}">
                            <i class="bi bi-clock-history text-secondary"></i> History
                        </a>
                        {% if app.user %}
                            <a href="{{ path('app_forum', {'filter': 'bookmarks'}) }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'bookmarks' ? 'active' : '' }}">
                                <i class="bi bi-bookmark-fill text-info"></i> Saved Posts
                            </a>
                        {% endif %}

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">Study Spaces</div>
                        {% for s in spaces|default([]) %}
                            {% set colors = ['#0d6efd', '#198754', '#0dcaf0', '#ffc107', '#dc3545', '#6610f2', '#fd7e14'] %}
                            {% set color = colors[s.id % colors|length] %}
                            <a href="{{ path('app_forum_space', {'id': s.id}) }}" class="left-nav-link d-flex align-items-center {{ currentSpace is defined and currentSpace == s.id ? 'active' : (space is defined and space.id == s.id ? 'active' : (post is defined and post.space and post.space.id == s.id ? 'active' : '')) }}">
                                <div class="rounded-circle me-3" style="width: 14px; height: 14px; background-color: {{ color }}; margin-left: 5px;"></div>
                                <span class="text-truncate">{{ s.name }}</span>
                            </a>
                        {% endfor %}

                        <div class="left-nav-section-title mt-2 border-top pt-3" style="border-color: var(--nova-border) !important;">Resources</div>
                        <a href="{{ path('app_forum_guidelines') }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'guidelines' ? 'active' : '' }}"><i class="bi bi-shield-check"></i> Guidelines</a>
                        <a href="{{ path('app_forum_about') }}" class="left-nav-link {{ currentFilter is defined and currentFilter == 'about' ? 'active' : '' }}"><i class="bi bi-info-circle"></i> About NOVA</a>

                    </div>
                </div>
            </div>

            {# --- 2. MIDDLE COLUMN: ABOUT CONTENT --- #}
            <div class="col-xl-7 col-lg-6 col-md-12">
                <div class="nova-card shadow-sm mb-4 overflow-hidden">
                    <div class="card-header border-bottom p-5 text-center" style="background: linear-gradient(135deg, #0d6efd 0%, #6f42c1 100%); border-color: var(--nova-border) !important;">
                        <i class="bi bi-rocket-takeoff-fill text-white display-1 mb-3"></i>
                        <h1 class="text-white fw-bold display-5 mb-0">NOVA</h1>
                        <p class="text-white opacity-75 fs-5">Empowering Student Collaboration.</p>
                    </div>
                    
                    <div class="card-body p-4 p-md-5 nova-text-main">
                        <div class="mb-5 text-center">
                            <h3 class="fw-bold mb-3">Our Mission</h3>
                            <p class="fs-5 nova-text-muted" style="line-height: 1.6;">
                                NOVA was built to bridge the gap between students, allowing them to share knowledge, ask complex questions, and receive peer-to-peer tutoring in a structured, AI-enhanced environment.
                            </p>
