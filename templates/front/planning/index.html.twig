{% extends 'base.html.twig' %}

{% block title %}My Study Sessions{% endblock %}

{% block body %}
<section class="pt-0">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <div class="card bg-transparent border rounded-3">
                    <div class="card-header bg-transparent border-bottom">
                        <div class="row justify-content-between align-middle">
                            <div class="col-sm-6">
                                <h3 class="card-header-title mb-2 mb-sm-0">My Study Sessions</h3>
                            </div>
                        </div>
                    </div>

                    <div class="card-body">
                        <!-- Filter Section -->
                        <div class="bg-light rounded p-3 mb-4">
                            <form method="get" class="row g-3">
                                <div class="col-md-4">
                                    <label class="form-label">Status</label>
                                    <select name="status" class="form-select">
                                        <option value="">All Statuses</option>
                                        <option value="SCHEDULED" {% if currentStatus == 'SCHEDULED' %}selected{% endif %}>Scheduled</option>
                                        <option value="COMPLETED" {% if currentStatus == 'COMPLETED' %}selected{% endif %}>Completed</option>
                                        <option value="MISSED" {% if currentStatus == 'MISSED' %}selected{% endif %}>Missed</option>
                                        <option value="CANCELLED" {% if currentStatus == 'CANCELLED' %}selected{% endif %}>Cancelled</option>
                                    </select>
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Start Date</label>
                                    <input type="date" name="start_date" class="form-control" value="{{ startDate }}">
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">End Date</label>
                                    <input type="date" name="end_date" class="form-control" value="{{ endDate }}">
                                </div>
                                <div class="col-md-2 d-flex align-items-end">
                                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                                </div>
                            </form>
                        </div>

                        {% if plannings is empty %}
                            <div class="text-center py-5">
                                <i class="bi bi-calendar-x display-1 text-muted"></i>
                                <p class="mt-3">No study sessions planned yet.</p>
                                <a href="{{ path('course_index') }}" class="btn btn-primary">Browse Courses</a>
                            </div>
                        {% else %}
                            <div class="table-responsive border-0">
                                <table class="table table-dark-gray align-middle p-4 mb-0 table-hover">
                                    <thead>
                                        <tr>
                                            <th scope="col" class="border-0 rounded-start">Course</th>
                                            <th scope="col" class="border-0">Title</th>
                                            <th scope="col" class="border-0">Scheduled</th>
                                            <th scope="col" class="border-0">Duration</th>
                                            <th scope="col" class="border-0">Status</th>
                                            <th scope="col" class="border-0 rounded-end">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for planning in plannings %}
                                            <tr>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="w-60px">
                                                            <img src="{{ asset('assets/images/courses/4by3/08.jpg') }}" class="rounded" alt="">
                                                        </div>
                                                        <div class="ms-2">
                                                            <h6 class="mb-0 fw-light">
                                                                <a href="{{ path('course_show', {id: planning.course.id}) }}">{{ planning.course.courseName }}</a>
                                                            </h6>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td>{{ planning.title }}</td>
                                                <td>
                                                    <div>{{ planning.scheduledDate|date('M d, Y') }}</div>
                                                    <small class="text-muted">{{ planning.scheduledTime|date('H:i') }}</small>
                                                </td>
                                                <td>{{ planning.plannedDuration }} min</td>
                                                <td>
                                                    {% set statusClass = {
                                                        'SCHEDULED': 'warning',
                                                        'COMPLETED': 'success',
                                                        'MISSED': 'danger',
                                                        'CANCELLED': 'secondary'
                                                    } %}
                                                    <span class="badge bg-{{ statusClass[planning.status] ?? 'secondary' }}">
                                                        {{ planning.status }}
                                                    </span>
                                                </td>
                                                <td>
                                                    <a href="{{ path('planning_show', {id: planning.id}) }}" class="btn btn-sm btn-light me-1" title="View Details">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    {% if planning.status == 'SCHEDULED' %}
                                                        <form method="post" action="{{ path('study_complete', {planning: planning.id}) }}" class="d-inline">
                                                            <input type="hidden" name="_token" value="{{ csrf_token('complete_session_' ~ planning.id) }}">
                                                            <button type="submit" class="btn btn-sm btn-success" title="Complete Session" onclick="return confirm('Mark this session as completed?')">
                                                                <i class="bi bi-check-circle"></i>
                                                            </button>
                                                        </form>
                                                    {% endif %}
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


{# Include Study Buddy AI Widget - Students Only #}
{% if is_granted('ROLE_STUDENT') %}
    {% include 'components/study_buddy_widget.html.twig' %}
{% endif %}
{% endblock %}
