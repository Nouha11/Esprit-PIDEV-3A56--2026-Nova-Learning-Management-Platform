{% extends 'base.html.twig' %}

{% block title %}Libraries - {{ book.title }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        #map {
            height: 500px;
            width: 100%;
            border-radius: 0.5rem;
            box-shadow: 0 0.125rem 0.25rem rgba(0,0,0,0.075);
        }
        
        /* Dark theme map tiles */
        [data-bs-theme="dark"] .leaflet-tile-pane {
            filter: brightness(0.6) invert(1) contrast(3) hue-rotate(200deg) saturate(0.3) brightness(0.7);
        }
        
        [data-bs-theme="dark"] .leaflet-control-zoom a,
        [data-bs-theme="dark"] .leaflet-control-attribution {
            background-color: #212529 !important;
            color: #dee2e6 !important;
            border-color: #495057 !important;
        }
        
        [data-bs-theme="dark"] .leaflet-popup-content-wrapper,
        [data-bs-theme="dark"] .leaflet-popup-tip {
            background-color: #212529 !important;
            color: #dee2e6 !important;
        }
        
        .library-card {
            transition: all 0.3s ease;
            cursor: pointer;
            border: 2px solid transparent;
        }
        .library-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.15) !important;
        }
        .library-card.selected {
            border: 3px solid #0d6efd !important;
            box-shadow: 0 0.5rem 1.5rem rgba(13, 110, 253, 0.3) !important;
        }
        
        /* Light theme */
        [data-bs-theme="light"] .library-card.selected {
            background: linear-gradient(135deg, #cfe2ff 0%, #e7f1ff 100%);
        }
        
        /* Dark theme */
        [data-bs-theme="dark"] .library-card.selected {
            background: linear-gradient(135deg, rgba(13, 110, 253, 0.2) 0%, rgba(13, 110, 253, 0.1) 100%);
        }
        
        .library-card.selected .card-title {
            color: #0d6efd !important;
        }
        .library-card.selected .library-icon {
            background-color: #0d6efd !important;
            color: white !important;
        }
        .distance-badge {
            font-size: 0.875rem;
            font-weight: 600;
        }
        .library-icon {
            width: 60px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 0.5rem;
        }
        .card-title {
            font-size: 1.1rem;
        }
    </style>
{% endblock %}

{% block body %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- =======================
        Page Banner START -->
        <section class="bg-primary bg-opacity-10 py-5 mt-4">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h3 mb-0">Available Libraries</h1>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb breadcrumb-dots mb-0">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('book_list') }}">Books</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('book_show', {'id': book.id}) }}">{{ book.title }}</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">Libraries</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- =======================
        Page Banner END -->

        <!-- =======================
        Page content START -->
        <section class="py-5">
            <div class="row">
                <div class="col-12">
                    <!-- Book Info Card -->
                    <div class="card shadow mb-4">
                        <div class="card-body">
                            <div class="d-flex align-items-center">
                                <div class="flex-shrink-0">
                                    {% if book.coverImage %}
                                        <img src="{{ asset(book.coverImage) }}" alt="{{ book.title }}" class="rounded" style="width: 100px; height: auto;">
                                    {% else %}
                                        <img src="{{ asset('assets/images/book/01.jpg') }}" alt="{{ book.title }}" class="rounded" style="width: 100px; height: auto;">
                                    {% endif %}
                                </div>
                                <div class="ms-4">
                                    <h3 class="mb-2">{{ book.title }}</h3>
                                    <p class="mb-1 text-muted">
                                        <i class="bi bi-person-circle me-1"></i>{{ book.author ?? 'Unknown Author' }}
                                    </p>
                                    <span class="badge bg-primary">Physical Book</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Interactive Map Section -->
                    <div class="card shadow mb-4">
                        <div class="card-header bg-transparent">
                            <h5 class="mb-0">
                                <i class="bi bi-map me-2"></i>Find Libraries Near You
                            </h5>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <button class="btn btn-sm btn-primary" onclick="getUserLocation()">
                                    <i class="bi bi-geo-alt-fill me-1"></i>Use My Location
                                </button>
                                <span class="ms-2 text-muted" id="location-status"></span>
                            </div>
                            <div id="map"></div>
                        </div>
                    </div>

                    <!-- Libraries List -->
                    <h4 class="mb-4">
                        <i class="bi bi-building me-2"></i>Libraries where this book is available
                    </h4>

                    {% if book.libraries|length > 0 %}
                        <div class="row g-4" id="libraries-list">
                            {% for library in book.libraries %}
                                <div class="col-md-6 col-lg-4">
                                    <div class="card shadow-sm h-100 library-card" 
                                         data-library-id="{{ library.id }}"
                                         data-lat="{{ library.latitude }}"
                                         data-lng="{{ library.longitude }}"
                                         onclick="selectLibrary({{ library.id }}, {{ library.latitude }}, {{ library.longitude }})">
                                        <div class="card-body p-4">
                                            <div class="d-flex align-items-start mb-3">
                                                <div class="library-icon bg-primary bg-opacity-10 text-primary flex-shrink-0">
                                                    <i class="bi bi-building fs-3"></i>
                                                </div>
                                                <div class="ms-3 flex-grow-1">
                                                    <h5 class="card-title mb-2 fw-bold">{{ library.name }}</h5>
                                                    {% if library.address %}
                                                        <p class="mb-2">
                                                            <i class="bi bi-geo-alt-fill text-primary me-1"></i>
                                                            <small class="fw-normal">{{ library.address }}</small>
                                                        </p>
                                                    {% endif %}
                                                    <div class="distance-info-{{ library.id }}" style="display: none;">
                                                        <span class="badge bg-success text-white distance-badge">
                                                            <i class="bi bi-pin-map-fill me-1"></i><span class="distance-text"></span>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                            
                                            <div class="d-grid gap-2">
                                                <a href="{{ path('book_loan', {'id': book.id, 'library': library.id}) }}" 
                                                   class="btn btn-primary"
                                                   onclick="event.stopPropagation()">
                                                    <i class="bi bi-book me-2"></i>Request Loan
                                                </a>
                                                <button class="btn btn-sm btn-outline-primary" 
                                                        onclick="event.stopPropagation(); focusOnMap({{ library.id }}, {{ library.latitude }}, {{ library.longitude }})">
                                                    <i class="bi bi-map me-1"></i>View on Map
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="alert alert-info d-flex align-items-center" role="alert">
                            <i class="bi bi-info-circle fs-3 me-3"></i>
                            <div>
                                <h5 class="alert-heading mb-1">No Libraries Available</h5>
                                <p class="mb-0">This book is not currently available in any physical library. Please check back later or consider purchasing the digital version.</p>
                            </div>
                        </div>
                        
                        {% if book.isDigital %}
                            <div class="mt-4">
                                <a href="{{ path('book_purchase', {'id': book.id}) }}" class="btn btn-success">
                                    <i class="bi bi-cart-check me-2"></i>Purchase Digital Copy
                                </a>
                            </div>
                        {% endif %}
                    {% endif %}

                    <!-- Back Button -->
                    <div class="mt-4">
                        <a href="{{ path('book_show', {'id': book.id}) }}" class="btn btn-light">
                            <i class="bi bi-arrow-left me-2"></i>Back to Book Details
                        </a>
                    </div>
                </div>
            </div>
        </section>
        <!-- =======================
        Page content END -->
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->

<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>

{% block javascripts %}
    {{ parent() }}
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // Données des bibliothèques
        const libraries = [
            {% for library in book.libraries %}
                {% if library.latitude and library.longitude %}
                {
                    id: {{ library.id }},
                    name: "{{ library.name|e('js') }}",
                    address: "{{ library.address|e('js') }}",
                    lat: {{ library.latitude }},
                    lng: {{ library.longitude }},
                    bookId: {{ book.id }}
                },
                {% endif %}
            {% endfor %}
        ];

        let map;
        let markers = [];
        let userMarker = null;
        let userLocation = null;

        // Initialiser la carte
        function initMap() {
            // Centre par défaut (Tunis, Tunisie)
            const defaultCenter = [36.8065, 10.1815];
            const defaultZoom = 12;

            // Créer la carte
            map = L.map('map').setView(defaultCenter, defaultZoom);

            // Ajouter les tuiles OpenStreetMap
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '© OpenStreetMap contributors',
                maxZoom: 19
            }).addTo(map);

            // Ajouter les marqueurs pour chaque bibliothèque
            libraries.forEach(library => {
                const marker = L.marker([library.lat, library.lng], {
                    icon: L.divIcon({
                        className: 'custom-marker',
                        html: '<div style="background-color: #0d6efd; width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3);"><i class="bi bi-building text-white"></i></div>',
                        iconSize: [30, 30],
                        iconAnchor: [15, 15]
                    })
                }).addTo(map);

                marker.bindPopup(`
                    <div style="min-width: 200px;">
                        <h6 class="mb-2">${library.name}</h6>
                        <p class="mb-2 small text-muted">
                            <i class="bi bi-geo-alt me-1"></i>${library.address}
                        </p>
                        <a href="/book/${library.bookId}/loan?library=${library.id}" class="btn btn-sm btn-primary w-100">
                            <i class="bi bi-book me-1"></i>Request Loan
                        </a>
                    </div>
                `);

                marker.on('click', function() {
                    selectLibrary(library.id, library.lat, library.lng);
                });

                markers.push({ id: library.id, marker: marker, data: library });
            });

            // Ajuster la vue pour montrer toutes les bibliothèques
            if (libraries.length > 0) {
                const bounds = L.latLngBounds(libraries.map(lib => [lib.lat, lib.lng]));
                map.fitBounds(bounds, { padding: [50, 50] });
            }
        }

        // Obtenir la localisation de l'utilisateur
        function getUserLocation() {
            const statusEl = document.getElementById('location-status');
            
            if (!navigator.geolocation) {
                statusEl.textContent = 'Geolocation is not supported by your browser';
                statusEl.className = 'ms-2 text-danger';
                return;
            }

            statusEl.textContent = 'Getting your location...';
            statusEl.className = 'ms-2 text-info';

            navigator.geolocation.getCurrentPosition(
                function(position) {
                    userLocation = {
                        lat: position.coords.latitude,
                        lng: position.coords.longitude
                    };

                    // Ajouter un marqueur pour l'utilisateur
                    if (userMarker) {
                        map.removeLayer(userMarker);
                    }

                    userMarker = L.marker([userLocation.lat, userLocation.lng], {
                        icon: L.divIcon({
                            className: 'user-marker',
                            html: '<div style="background-color: #dc3545; width: 35px; height: 35px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 3px solid white; box-shadow: 0 2px 5px rgba(0,0,0,0.3);"><i class="bi bi-person-fill text-white"></i></div>',
                            iconSize: [35, 35],
                            iconAnchor: [17.5, 17.5]
                        })
                    }).addTo(map);

                    userMarker.bindPopup('<strong>Your Location</strong>').openPopup();

                    // Centrer la carte sur l'utilisateur
                    map.setView([userLocation.lat, userLocation.lng], 13);

                    // Calculer et afficher les distances
                    calculateDistances();

                    statusEl.textContent = 'Location found!';
                    statusEl.className = 'ms-2 text-success';
                },
                function(error) {
                    statusEl.textContent = 'Unable to get your location: ' + error.message;
                    statusEl.className = 'ms-2 text-danger';
                }
            );
        }

        // Calculer les distances entre l'utilisateur et les bibliothèques
        function calculateDistances() {
            if (!userLocation) return;

            const librariesWithDistance = libraries.map(library => {
                const distance = calculateDistance(
                    userLocation.lat,
                    userLocation.lng,
                    library.lat,
                    library.lng
                );
                return { ...library, distance: distance };
            });

            // Trier par distance
            librariesWithDistance.sort((a, b) => a.distance - b.distance);

            // Afficher les distances
            librariesWithDistance.forEach(library => {
                const distanceEl = document.querySelector(`.distance-info-${library.id}`);
                if (distanceEl) {
                    distanceEl.style.display = 'block';
                    distanceEl.querySelector('.distance-text').textContent = 
                        library.distance < 1 
                            ? `${(library.distance * 1000).toFixed(0)} m away`
                            : `${library.distance.toFixed(1)} km away`;
                }
            });

            // Réorganiser les cartes par distance
            const container = document.getElementById('libraries-list');
            librariesWithDistance.forEach(library => {
                const card = document.querySelector(`[data-library-id="${library.id}"]`).parentElement;
                container.appendChild(card);
            });
        }

        // Calculer la distance entre deux points (formule de Haversine)
        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Rayon de la Terre en km
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = 
                Math.sin(dLat/2) * Math.sin(dLat/2) +
                Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }

        // Sélectionner une bibliothèque
        function selectLibrary(libraryId, lat, lng) {
            // Retirer la sélection précédente
            document.querySelectorAll('.library-card').forEach(card => {
                card.classList.remove('selected');
            });

            // Ajouter la sélection
            const card = document.querySelector(`[data-library-id="${libraryId}"]`);
            if (card) {
                card.classList.add('selected');
                
                // Scroll vers la carte sélectionnée
                card.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            }

            // Centrer la carte sur la bibliothèque
            if (lat && lng) {
                map.setView([lat, lng], 15);

                // Ouvrir le popup du marqueur
                const markerData = markers.find(m => m.id === libraryId);
                if (markerData) {
                    markerData.marker.openPopup();
                }
            }
        }

        // Fonction pour centrer la carte sur une bibliothèque
        function focusOnMap(libraryId, lat, lng) {
            selectLibrary(libraryId, lat, lng);
            
            // Scroll vers la carte
            document.getElementById('map').scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        // Initialiser la carte au chargement de la page
        document.addEventListener('DOMContentLoaded', function() {
            if (libraries.length > 0) {
                initMap();
            }
        });
    </script>
{% endblock %}
{% endblock %}