{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- =======================
        Page Banner START -->
        <section class="bg-primary bg-opacity-10 py-5 mt-4">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h3 mb-0">{{ book.title }}</h1>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb breadcrumb-dots mb-0">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                                    <li class="breadcrumb-item"><a href="{{ path('book_list') }}">Books</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">{{ book.title }}</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- =======================
        Page Banner END -->

        <!-- =======================
        Page content START -->
        <section class="pt-5">
            <div class="row g-4 g-sm-5" data-sticky-container>
                <!-- Left sidebar START -->
                <div class="col-xl-4">
                    <div data-sticky data-margin-top="80" data-sticky-for="992">
                        <div class="row justify-content-center">
                            <div class="col-md-8 col-xl-12">
                                <!-- Card START -->
                                <div class="card shadow">
                                    <!-- Image -->
                                    <div class="rounded-3">
                                        {% if book.coverImage %}
                                            <img src="{{ asset(book.coverImage) }}" class="card-img-top" alt="{{ book.title }}">
                                        {% else %}
                                            <img src="{{ asset('assets/images/book/01.jpg') }}" class="card-img-top" alt="{{ book.title }}">
                                        {% endif %}
                                    </div>
                
                                    <!-- Card body -->
                                    <div class="card-body pb-3">
                                        <!-- Buttons and price -->
                                        <div class="text-center">
                                            <!-- Buttons -->
                                            {% if book.isDigital %}
                                                <a href="{{ path('book_purchase', {'id': book.id}) }}" class="btn btn-success-soft mb-2 mb-sm-0 me-0 me-sm-3">
                                                    <i class="bi bi-cart3 me-2"></i>Buy Digital
                                                </a>
                                            {% endif %}
                                            <a href="{{ path('book_libraries', {'id': book.id}) }}" class="btn btn-primary mb-2 mb-sm-0">
                                                <i class="bi bi-book me-2"></i>Borrow
                                            </a>
                                        </div>
                                    </div>
                                </div>
                                <!-- Card END -->
                            </div>
                        </div> <!-- Row End -->
                    </div>
                </div>
                <!-- Left sidebar END -->
                    
                <!-- Main content START -->
                <div class="col-xl-8">
                    <!-- Price Item START -->
                    {% if book.price %}
                    <ul class="list-inline mb-4">
                        <!-- Price -->
                        <li class="list-inline-item">
                            <div class="btn btn-success-soft-check">
                                <span class="mb-2 h6 fw-light">
                                    {% if book.isDigital %}Digital{% else %}Physical{% endif %}
                                </span>
                                <!-- Price -->
                                <span class="d-flex align-items-center">
                                    <span class="mb-0 h5 me-2 text-success">${{ book.price }}</span>
                                </span>
                            </div>
                        </li>
                    </ul>
                    {% endif %}
                    <!-- Price Item END -->

                    <!-- Content -->
                    <h4>Description</h4>
                    {% if book.description %}
                        <p>{{ book.description }}</p>
                    {% else %}
                        <p>No description available for this book.</p>
                    {% endif %}
                    
                    <!-- Additional info -->
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <!-- List START -->
                            <ul class="list-group list-group-borderless">
                                {% if book.publishedAt %}
                                <li class="list-group-item px-0">
                                    <span class="h6 fw-light"><i class="bi fa-fw bi-calendar-fill text-primary me-2"></i>Published date:</span>
                                    <span class="h6">{{ book.publishedAt|date('d M Y') }}</span>
                                </li>
                                {% endif %}
                                <li class="list-group-item px-0">
                                    <span class="h6 fw-light"><i class="fas fa-fw fa-book text-primary me-2"></i>Format:</span>
                                    <span class="h6">{% if book.isDigital %}Digital (PDF){% else %}Physical Book{% endif %}</span>
                                </li>
                            </ul>
                            <!-- List END -->
                        </div>

                        <div class="col-md-6">
                            <!-- List START -->
                            <ul class="list-group list-group-borderless">
                                {% if book.author %}
                                <li class="list-group-item px-0">
                                    <span class="h6 fw-light"><i class="bi fa-fw bi-person-circle text-primary me-2"></i>Author:</span>
                                    <span class="h6">{{ book.author }}</span>
                                </li>
                                {% endif %}
                                {% if book.price %}
                                <li class="list-group-item px-0">
                                    <span class="h6 fw-light"><i class="bi fa-fw bi-tag-fill text-primary me-2"></i>Price:</span>
                                    <span class="h6">${{ book.price }}</span>
                                </li>
                                {% endif %}
                                <li class="list-group-item px-0">
                                    <span class="h6 fw-light"><i class="bi fa-fw bi-calendar-plus text-primary me-2"></i>Added:</span>
                                    <span class="h6">{{ book.createdAt|date('d M Y') }}</span>
                                </li>
                            </ul>
                            <!-- List END -->
                        </div>
                    </div>

                    <!-- Action buttons -->
                    <div class="mt-4">
                        <h4>Get this book</h4>
                        <div class="d-flex gap-2 flex-wrap">
                            {% if book.isDigital %}
                                <a href="{{ path('book_purchase', {'id': book.id}) }}" class="btn btn-success">
                                    <i class="bi bi-cart-check me-2"></i>Purchase Digital Copy
                                </a>
                            {% endif %}
                            <a href="{{ path('book_libraries', {'id': book.id}) }}" class="btn btn-primary">
                                <i class="bi bi-building me-2"></i>Borrow from Library
                            </a>
                            <a href="{{ path('book_list') }}" class="btn btn-light">
                                <i class="bi bi-arrow-left me-2"></i>Back to Books
                            </a>
                        </div>
                    </div>
                </div>
                <!-- Main content END -->
            </div><!-- Row END -->
        </section>
        <!-- =======================
        Page content END -->
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->


<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>
{% endblock %}