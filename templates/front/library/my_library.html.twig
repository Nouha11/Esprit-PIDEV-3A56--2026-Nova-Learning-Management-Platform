{% extends 'base.html.twig' %}

{% block title %}My Library - NOVA{% endblock %}

{% block body %}

<!-- Main Content START -->
<main>
    <div class="container">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} alert-dismissible fade show mt-4" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            {% endfor %}
        {% endfor %}
        
        {% block front_content %}
        <!-- =======================
        Page Banner START -->
        <section class="bg-primary bg-opacity-10 py-5 mt-4">
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="h3 mb-0">My Library</h1>
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb breadcrumb-dots mb-0">
                                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Home</a></li>
                                    <li class="breadcrumb-item active" aria-current="page">My Library</li>
                                </ol>
                            </nav>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- =======================
        Page Banner END -->

        <!-- =======================
        Page content START -->
        <section class="pt-5">
        
        <!-- Digital Books Section -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">
                        <i class="bi bi-cloud-download text-primary me-2"></i>
                        My Digital Books
                    </h3>
                    <span class="badge bg-primary">{{ digitalPurchases|length }} book{{ digitalPurchases|length != 1 ? 's' : '' }}</span>
                </div>
                
                {% if digitalPurchases is empty %}
                    <div class="card border">
                        <div class="card-body text-center py-5">
                            <img src="{{ asset('assets/images/element/online.svg') }}" class="h-100px mb-3" alt="">
                            <h5>No Digital Books Yet</h5>
                            <p class="mb-3">You haven't purchased any digital books yet.</p>
                            <a href="{{ path('book_list') }}" class="btn btn-primary">
                                <i class="bi bi-search me-2"></i>Browse Books
                            </a>
                        </div>
                    </div>
                {% else %}
                    <div class="row g-4">
                        {% for purchase in digitalPurchases %}
                            <div class="col-sm-6 col-lg-4 col-xl-3">
                                <div class="card shadow h-100">
                                    <img src="{{ asset(purchase.book.coverImage ?: 'assets/images/book/01.jpg') }}" 
                                         class="card-img-top" 
                                         alt="{{ purchase.book.title }}"
                                         style="height: 250px; object-fit: cover;">
                                    <div class="card-body pb-0">
                                        <h6 class="card-title">
                                            <a href="{{ path('book_show', {'id': purchase.book.id}) }}">{{ purchase.book.title }}</a>
                                        </h6>
                                        <p class="mb-2 text-truncate-2">
                                            <small class="text-muted">by {{ purchase.book.author ?: 'Unknown' }}</small>
                                        </p>
                                    </div>
                                    <div class="card-footer pt-0 pb-3">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <small class="text-muted">
                                                <i class="bi bi-calendar3 me-1"></i>
                                                {{ purchase.purchasedAt|date('M d, Y') }}
                                            </small>
                                            <div>
                                                {% if purchase.book.pdfUrl %}
                                                    <a href="{{ path('book_read_pdf', {'id': purchase.book.id}) }}" class="btn btn-sm btn-success">
                                                        <i class="bi bi-book-fill me-1"></i>Read PDF
                                                    </a>
                                                {% else %}
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="bi bi-exclamation-triangle me-1"></i>PDF Not Available
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Active Loans Section -->
        <div class="row mb-5">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">
                        <i class="bi bi-book text-success me-2"></i>
                        Currently Borrowed
                    </h3>
                    <span class="badge bg-success">{{ activeLoans|length }} book{{ activeLoans|length != 1 ? 's' : '' }}</span>
                </div>
                
                {% if activeLoans is empty %}
                    <div class="card border">
                        <div class="card-body text-center py-5">
                            <img src="{{ asset('assets/images/element/book-bg.svg') }}" class="h-100px mb-3" alt="">
                            <h5>No Active Loans</h5>
                            <p class="mb-3">You don't have any borrowed books at the moment.</p>
                            <a href="{{ path('book_list') }}" class="btn btn-success">
                                <i class="bi bi-search me-2"></i>Browse Books to Borrow
                            </a>
                        </div>
                    </div>
                {% else %}
                    <div class="row g-4">
                        {% for loan in activeLoans %}
                            <div class="col-12">
                                <div class="card border">
                                    <div class="card-body">
                                        <div class="row align-items-center">
                                            <div class="col-md-2">
                                                <img src="{{ asset(loan.book.coverImage ?: 'assets/images/book/01.jpg') }}" 
                                                     class="rounded" 
                                                     alt="{{ loan.book.title }}"
                                                     style="width: 100%; max-width: 120px;">
                                            </div>
                                            <div class="col-md-7">
                                                <h5 class="mb-2">
                                                    <a href="{{ path('book_show', {'id': loan.book.id}) }}">{{ loan.book.title }}</a>
                                                </h5>
                                                <p class="mb-2 text-muted">by {{ loan.book.author ?: 'Unknown' }}</p>
                                                <div class="d-flex gap-3 mb-2">
                                                    <small>
                                                        <i class="bi bi-calendar-check text-success me-1"></i>
                                                        Pickup: {{ loan.startAt|date('M d, Y H:i') }}
                                                    </small>
                                                    {% if loan.endAt %}
                                                    <small>
                                                        <i class="bi bi-calendar-x text-danger me-1"></i>
                                                        Return: {{ loan.endAt|date('M d, Y H:i') }}
                                                    </small>
                                                    {% endif %}
                                                </div>
                                                {% if loan.library %}
                                                <small class="text-muted">
                                                    <i class="bi bi-building me-1"></i>{{ loan.library.name }}
                                                </small>
                                                {% endif %}
                                            </div>
                                            <div class="col-md-3 text-end">
                                                <span class="badge {{ loan.statusBadgeClass }} mb-2">{{ loan.statusLabel }}</span>
                                                {% if loan.status == 'PENDING' %}
                                                    <p class="small text-muted mb-0">Waiting for approval</p>
                                                {% elseif loan.status == 'APPROVED' %}
                                                    <p class="small text-muted mb-0">Ready for pickup</p>
                                                {% elseif loan.status == 'ACTIVE' %}
                                                    <p class="small text-muted mb-0">Book in your possession</p>
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Loan History Section -->
        {% if loanHistory is not empty %}
            <div class="row">
                <div class="col-12">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h3 class="mb-0">
                            <i class="bi bi-clock-history text-info me-2"></i>
                            Loan History
                        </h3>
                        <span class="badge bg-info">Last 10 returns</span>
                    </div>
                    
                    <div class="card border">
                        <div class="card-body">
                            <div class="table-responsive">
                                <table class="table table-hover align-middle">
                                    <thead>
                                        <tr>
                                            <th>Book</th>
                                            <th>Author</th>
                                            <th>Borrowed</th>
                                            <th>Returned</th>
                                            <th>Duration</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for loan in loanHistory %}
                                            <tr>
                                                <td>
                                                    <a href="{{ path('book_show', {'id': loan.book.id}) }}">
                                                        {{ loan.book.title }}
                                                    </a>
                                                </td>
                                                <td>{{ loan.book.author ?: 'Unknown' }}</td>
                                                <td>
                                                    <small class="text-muted">
                                                        {{ loan.startAt|date('M d, Y') }}
                                                    </small>
                                                </td>
                                                <td>
                                                    <small class="text-muted">
                                                        {{ loan.endAt|date('M d, Y') }}
                                                    </small>
                                                </td>
                                                <td>
                                                    <span class="badge bg-light text-dark">
                                                        {{ loan.startAt.diff(loan.endAt).days }} days
                                                    </span>
                                                </td>
                                            </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
        
        </section>
        <!-- =======================
        Page content END -->
        {% endblock %}
    </div>
</main>
<!-- Main Content END -->


<!-- Back to top -->
<div class="back-top"><i class="bi bi-arrow-up-short position-absolute top-50 start-50 translate-middle"></i></div>
{% endblock %}
