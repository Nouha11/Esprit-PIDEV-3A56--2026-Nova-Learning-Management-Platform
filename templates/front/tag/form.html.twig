{% extends 'base.html.twig' %}

{% block title %}{{ tag.id ? 'Edit Tag' : 'Create Tag' }}{% endblock %}

{% block body %}
<div class="row mt-4">
    <div class="col-md-6 offset-md-3">
        <div class="card">
            <div class="card-header">
                <h3 class="mb-0">{{ tag.id ? 'Edit Tag' : 'Create New Tag' }}</h3>
            </div>
            <div class="card-body">
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                {% endfor %}

                {{ form_start(form) }}
                    <div class="mb-3">
                        {{ form_label(form.name, 'Tag Name', {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.name, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.name) }}
                        <div class="form-text">
                            Maximum 50 characters. Tag names must be unique.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a href="{{ path('tag_index') }}" class="btn btn-secondary">
                            <i class="bi bi-x-circle"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle"></i> {{ tag.id ? 'Update' : 'Create' }} Tag
                        </button>
                    </div>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
