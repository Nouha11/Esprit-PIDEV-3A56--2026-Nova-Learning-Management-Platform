###> OAuth Configuration for Development ###
# Copy this file to .env.local and fill in the credentials
# Get credentials from team lead or project documentation

# Google OAuth (Shared Development Credentials)
GOOGLE_CLIENT_ID=your-shared-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-shared-google-client-secret

# LinkedIn OAuth (Shared Development Credentials)
LINKEDIN_CLIENT_ID=your-shared-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-shared-linkedin-secret

###> Instructions ###
# 1. Copy this file: cp .env.local.example .env.local
# 2. Replace the placeholder values with actual credentials (get from team lead)
# 3. Never commit .env.local to Git!
